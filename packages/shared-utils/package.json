{
  "name": "@melody-mind/shared-utils",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "exports": {
    "./*": "./src/*"
  },
  "scripts": {
    "lint": "pnpm exec eslint --config ../../eslint.config.mjs \"src/**/*.{js,ts}\"",
    "lint:check": "pnpm exec eslint --config ../../eslint.config.mjs \"src/**/*.{js,ts}\"",
    "format": "pnpm exec prettier --write \"src/**/*.{js,ts}\"",
    "format:check": "pnpm exec prettier --check \"src/**/*.{js,ts}\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
