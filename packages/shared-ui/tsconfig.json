{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": true,
    "types": ["astro/client"],
    "baseUrl": ".",
    "paths": {
      "@shared-icons/*": ["../shared-icons/src/*"],
      "@shared-utils/*": ["../shared-utils/src/*"]
    }
  },
  "include": ["src/**/*", "env.d.ts"],
  "exclude": ["node_modules", "dist"]
}
