{
  "name": "@melody-mind/shared-ui",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "lint": "pnpm format && pnpm exec eslint --config ../../eslint.config.mjs --fix \"src/**/*.{js,ts,jsx,tsx,astro}\" && pnpm stylelint",
    "lint:check": "pnpm exec eslint --config ../../eslint.config.mjs \"src/**/*.{js,ts,jsx,tsx,astro}\" && pnpm stylelint:check",
    "format": "pnpm exec prettier --write \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx}\"",
    "format:check": "pnpm exec prettier --check \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx}\"",
    "stylelint": "pnpm exec stylelint --config ../../stylelint.config.cjs --fix \"src/**/*.{astro,css}\"",
    "stylelint:check": "pnpm exec stylelint --config ../../stylelint.config.cjs \"src/**/*.{astro,css}\" --quiet"
  },
  "peerDependencies": {
    "astro": "^6.0.5",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.7",
    "astro": "^6.0.8",
    "astro-icon": "^1.1.5",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.0.2",
    "typescript": "^5.9.3"
  }
}
