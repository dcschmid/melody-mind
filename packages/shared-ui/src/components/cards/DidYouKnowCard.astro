---
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { IconName } from "@shared-ui/components/visual/Icon.astro";

interface Props {
  title?: string;
  icon?: IconName;
  className?: string;
}

const {
  title = "Did You Know?",
  icon = "tabler:antenna-bars-5",
  className = "",
} = Astro.props as Props;

const titleId = `did-you-know-${Math.random().toString(36).slice(2, 10)}`;
const classes = ["did-you-know-card", className].filter(Boolean).join(" ");
const hasTitleSlot = Astro.slots.has("title");
---

<aside class={classes} aria-labelledby={titleId}>
  <span class="did-you-know-card__icon-shell" aria-hidden="true">
    <span class="did-you-know-card__icon-ring">
      <Icon name={icon} class="did-you-know-card__icon" aria-hidden="true" />
    </span>
  </span>
  <div class="did-you-know-card__content">
    <p id={titleId} class="did-you-know-card__title">
      {hasTitleSlot ? <slot name="title" /> : title}
    </p>
    <div class="did-you-know-card__body">
      <slot />
    </div>
  </div>
</aside>

<style>
  .did-you-know-card {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--stack-gap-sm) var(--stack-gap-md);
    align-items: start;
    padding: var(--panel-padding-md);
    margin-block: var(--content-margin-block);
    overflow: hidden;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 48%, transparent),
      inset 0 -1px 0 color-mix(in srgb, var(--surface-border-soft) 18%, transparent),
      var(--shadow-sm);
  }

  .did-you-know-card__icon-shell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--icon-shell-size-md);
    block-size: var(--icon-shell-size-md);
    padding: var(--spacing-2xs);
    background: color-mix(in srgb, var(--accent-primary) 8%, var(--surface-panel-raised));
    border: 1px solid
      color-mix(in srgb, var(--accent-primary) 28%, var(--surface-border-soft));
    border-radius: var(--radius-lg);
  }

  .did-you-know-card__icon-ring {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 100%;
    block-size: 100%;
    background: color-mix(
      in srgb,
      var(--surface-panel-raised) 88%,
      var(--accent-primary)
    );
    border-radius: calc(var(--radius-lg) - var(--spacing-xs));
  }

  .did-you-know-card__icon {
    inline-size: var(--icon-size-xs);
    block-size: var(--icon-size-xs);
    color: var(--accent-primary);
  }

  .did-you-know-card__content {
    display: grid;
    gap: var(--spacing-sm);
    min-inline-size: 0;
    padding-block-start: var(--spacing-2xs);
  }

  .did-you-know-card__title {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: 1.14;
    color: var(--heading-color);
    letter-spacing: var(--letter-spacing-normal);
    text-wrap: balance;
  }

  .did-you-know-card__body {
    font-size: var(--font-size-xs);
    line-height: 1.58;
    color: color-mix(in srgb, var(--text-secondary) 85%, var(--accent-primary) 15%);
  }

  .did-you-know-card__body :global(p) {
    margin: 0;
  }

  .did-you-know-card__body :global(p:first-child)::first-letter {
    float: none;
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    color: inherit;
  }

  .did-you-know-card__body :global(p + p) {
    margin-block-start: 0.75em;
  }

  @media (width < 640px) {
    .did-you-know-card {
      gap: var(--stack-gap-sm) var(--stack-gap-md);
      padding: var(--panel-padding-sm);
      margin-block: var(--spacing-base);
    }

    .did-you-know-card__icon-shell {
      inline-size: var(--icon-shell-size-sm);
      block-size: var(--icon-shell-size-sm);
    }

    .did-you-know-card__body {
      font-size: var(--font-size-xs);
    }
  }
</style>
