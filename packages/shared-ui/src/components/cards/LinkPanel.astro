---
import type { LinkPanelItem } from "@shared-ui/components/cards/linkPanel";
import ButtonLink from "@shared-ui/components/buttons/ButtonLink.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props {
  title?: string;
  titleIcon?: string;
  items?: readonly LinkPanelItem[];
  class?: string;
}

const { title, titleIcon, items = [], class: className } = Astro.props as Props;
---

{
  items.length ? (
    <section class:list={["link-panel", className]}>
      {title ? (
        <header class="link-panel__header">
          {titleIcon ? (
            <Icon name={titleIcon} class="link-panel__title-icon" aria-hidden="true" />
          ) : null}
          <h2 class="link-panel__title">{title}</h2>
        </header>
      ) : null}

      <div class="link-panel__actions">
        {items.map((item) => (
          <ButtonLink
            href={item.href}
            variant={item.variant ?? "secondary"}
            size="compact"
            icon={item.icon}
            analyticsPodcastTarget={item.analyticsPodcastTarget}
            aria-label={item.ariaLabel}
          >
            {item.label}
          </ButtonLink>
        ))}
      </div>
    </section>
  ) : null
}

<style>
  .link-panel {
    display: grid;
    gap: var(--spacing-base);
    padding: var(--spacing-lg) 0;
    border-block: 1px solid var(--surface-border-soft);
  }

  .link-panel__header {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .link-panel__title {
    margin: 0;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .link-panel__title-icon {
    inline-size: 1rem;
    block-size: 1rem;
    color: var(--accent-primary);
  }

  .link-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }
</style>
