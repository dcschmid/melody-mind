---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

const { title = "Key takeaways", items = [] } = Astro.props as {
  title?: string;
  items?: string[];
};
const visibleItems = items.slice(0, 4);
---

{
  visibleItems.length ? (
    <aside class="knowledge-takeaways" aria-labelledby="knowledge-takeaways-title">
      <div class="knowledge-takeaways__header">
        <div class="knowledge-takeaways__badge">What you'll take away</div>
        <Headline level="h2" textSize="lg" className="knowledge-takeaways__title">
          <span id="knowledge-takeaways-title">{title}</span>
        </Headline>
        <Paragraph textSize="base" className="knowledge-takeaways__subtitle">
          Short points to remember after reading.
        </Paragraph>
      </div>
      <ol class="knowledge-takeaways__list">
        {visibleItems.map((item) => (
          <li class="knowledge-takeaways__item">
            <span class="knowledge-takeaways__icon" aria-hidden="true">
              <Icon name="star" role="img" aria-hidden="true" />
            </span>
            <span class="knowledge-takeaways__text">{item}</span>
          </li>
        ))}
      </ol>
    </aside>
  ) : null
}

<style>
  /* -----------------------------------------------------------------------------
     KnowledgeTakeaways Component Styles
     Highlighted summary section with key points
     WCAG AAA compliant with responsive grid layout
     ----------------------------------------------------------------------------- */

  .knowledge-takeaways {
    display: grid;
    gap: var(--spacing-lg);
    padding: clamp(var(--spacing-lg), 2.2vw, var(--spacing-xl)) 0 0;
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .knowledge-takeaways__header {
    position: relative;
    display: grid;
    gap: var(--spacing-xs);
  }

  .knowledge-takeaways__badge {
    inline-size: fit-content;
    padding-inline-start: var(--spacing-base);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    background: none;
    border: 0;
    border-radius: 0;
  }

  .knowledge-takeaways__badge::before {
    position: absolute;
    inset-inline-start: 0;
    inline-size: 0.65rem;
    block-size: 1px;
    margin-block-start: 0.55rem;
    content: "";
    background: currentcolor;
  }

  /* Section title */
  .knowledge-takeaways__title {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--heading-color);
  }

  .knowledge-takeaways__subtitle {
    max-inline-size: 60ch;
    margin: 0;
    line-height: var(--line-height-relaxed);
    color: var(--prose-color);
  }

  .knowledge-takeaways__list {
    display: grid;
    gap: var(--spacing-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .knowledge-takeaways__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-md);
    align-items: start;
    padding: var(--spacing-base);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .knowledge-takeaways__icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: 2rem;
    block-size: 2rem;
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 12%, var(--surface-1));
    border-radius: var(--radius-base);
  }

  .knowledge-takeaways__text {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
  }

  @media (width >= 768px) {
    .knowledge-takeaways__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
