---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

const { title = "Key takeaways", items = [] } = Astro.props as {
  title?: string;
  items?: string[];
};
const visibleItems = items.slice(0, 4);
const takeawayIcons = ["globe", "share-2", "book-open", "music"];
const takeawayEntries = visibleItems.map((item, index) => {
  const parts = item
    .split(/(?<=[.!?])\s+/)
    .map((part) => part.trim())
    .filter(Boolean);
  const heading = parts.length > 1 ? parts[0].replace(/[.!?]+$/, "") : "";
  const description = parts.length > 1 ? parts.slice(1).join(" ") : item;

  return {
    description,
    heading,
    icon: takeawayIcons[index % takeawayIcons.length],
    iconClass: `knowledge-takeaways__icon--${(index % takeawayIcons.length) + 1}`,
  };
});
---

{
  visibleItems.length ? (
    <aside class="knowledge-takeaways" aria-labelledby="knowledge-takeaways-title">
      <div class="knowledge-takeaways__header">
        <div class="knowledge-takeaways__badge">What you'll take away</div>
        <Headline level="h2" textSize="lg" className="knowledge-takeaways__title">
          <span id="knowledge-takeaways-title">{title}</span>
        </Headline>
        <Paragraph textSize="base" className="knowledge-takeaways__subtitle">
          Short points to remember after reading.
        </Paragraph>
        <span class="knowledge-takeaways__accent" aria-hidden="true" />
      </div>
      <ol class="knowledge-takeaways__list">
        {takeawayEntries.map((item) => (
          <li class="knowledge-takeaways__item">
            <span
              class:list={["knowledge-takeaways__icon", item.iconClass]}
              aria-hidden="true"
            >
              <Icon name={item.icon} role="img" aria-hidden="true" />
            </span>
            <div class="knowledge-takeaways__copy">
              {item.heading ? (
                <span class="knowledge-takeaways__item-title">{item.heading}</span>
              ) : null}
              <span class="knowledge-takeaways__text">{item.description}</span>
            </div>
          </li>
        ))}
      </ol>
    </aside>
  ) : null
}

<style>
  /* -----------------------------------------------------------------------------
     KnowledgeTakeaways Component Styles
     Highlighted summary section with key points
     WCAG AAA compliant with responsive grid layout
     ----------------------------------------------------------------------------- */

  .knowledge-takeaways {
    display: grid;
    gap: clamp(var(--spacing-base), 1.6vw, var(--spacing-lg));
    padding: 0;
  }

  .knowledge-takeaways__header {
    display: grid;
    gap: 0.35rem;
    justify-items: center;
    text-align: center;
  }

  .knowledge-takeaways__badge {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .knowledge-takeaways__badge::before {
    inline-size: 0.7rem;
    block-size: 0.7rem;
    content: "";
    border: 1px solid currentcolor;
    border-radius: 0.18rem;
  }

  .knowledge-takeaways__title {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--heading-color);
  }

  .knowledge-takeaways__subtitle {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--prose-color);
  }

  .knowledge-takeaways__accent {
    inline-size: 3.25rem;
    block-size: 2px;
    margin-block-start: 0.45rem;
    background: var(--accent-primary);
    border-radius: var(--radius-full);
  }

  .knowledge-takeaways__list {
    display: grid;
    gap: clamp(var(--spacing-sm), 1.5vw, var(--spacing-base));
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .knowledge-takeaways__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem 0.9rem;
    align-items: start;
    padding: clamp(0.95rem, 1.6vw, 1.2rem);
    background: color-mix(in srgb, var(--surface-panel-raised) 94%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: calc(var(--radius-xl) - 0.1rem);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 58%, transparent),
      var(--shadow-md);
  }

  .knowledge-takeaways__copy {
    display: grid;
    grid-column: 2;
    gap: 0.4rem;
    min-inline-size: 0;
  }

  .knowledge-takeaways__icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: 1.95rem;
    block-size: 1.95rem;
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-1) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--surface-border-soft) 95%, transparent);
    border-radius: 0.65rem;
  }

  .knowledge-takeaways__icon--1 {
    color: #35f2d4;
  }

  .knowledge-takeaways__icon--2 {
    color: #dc7dff;
  }

  .knowledge-takeaways__icon--3 {
    color: #3ef2ea;
  }

  .knowledge-takeaways__icon--4 {
    color: #d8e3ed;
  }

  .knowledge-takeaways__item-title {
    display: block;
    min-inline-size: 0;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    line-height: 1.32;
    color: var(--heading-color);
  }

  .knowledge-takeaways__text {
    display: block;
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: color-mix(in srgb, var(--text-secondary) 92%, #d8e3ed);
  }

  @media (width >= 720px) {
    .knowledge-takeaways__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
