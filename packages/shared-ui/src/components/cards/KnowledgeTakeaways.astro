---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

const { title = "Key takeaways", items = [] } = Astro.props as {
  title?: string;
  items?: string[];
};
---

{
  items.length ? (
    <aside class="knowledge-takeaways" aria-labelledby="knowledge-takeaways-title">
      <div class="knowledge-takeaways__header">
        <div class="knowledge-takeaways__badge">What you'll take away</div>
        <Headline level="h2" textSize="lg" className="knowledge-takeaways__title">
          <span id="knowledge-takeaways-title">{title}</span>
        </Headline>
        <Paragraph textSize="base" className="knowledge-takeaways__subtitle">
          Short points to remember after reading.
        </Paragraph>
      </div>
      <ol class="knowledge-takeaways__list">
        {items.map((item) => (
          <li class="knowledge-takeaways__item">
            <span class="knowledge-takeaways__icon" aria-hidden="true">
              <Icon name="star" role="img" aria-hidden="true" />
            </span>
            <span class="knowledge-takeaways__text">{item}</span>
          </li>
        ))}
      </ol>
    </aside>
  ) : null
}

<style>
  /* -----------------------------------------------------------------------------
     KnowledgeTakeaways Component Styles
     Highlighted summary section with key points
     WCAG AAA compliant with responsive grid layout
     ----------------------------------------------------------------------------- */

  .knowledge-takeaways {
    /* Layout */
    display: grid;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);

    /* Visual styling */
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-2) 92%, transparent),
      color-mix(in srgb, var(--surface-1) 76%, transparent)
    );
    border: 2px solid var(--border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  /* Header section */
  .knowledge-takeaways__header {
    display: grid;
    gap: var(--spacing-xs);
  }

  /* Badge label */
  .knowledge-takeaways__badge {
    inline-size: fit-content;
    padding: var(--spacing-xs) var(--spacing-sm);

    /* Typography */
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);

    /* Visual styling */
    background: var(--surface-1);
    border: 1px solid var(--accent-primary);
    border-radius: var(--radius-full);
  }

  /* Section title */
  .knowledge-takeaways__title {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--heading-color);
  }

  /* Subtitle description */
  .knowledge-takeaways__subtitle {
    max-inline-size: 60ch;
    margin: 0;
    line-height: var(--line-height-relaxed);
    color: var(--prose-color);
  }

  /* List container */
  .knowledge-takeaways__list {
    display: grid;
    gap: var(--spacing-md);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  /* Individual takeaway item */
  .knowledge-takeaways__item {
    /* Layout */
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-md);
    align-items: start;
    padding: var(--spacing-base);

    /* Visual styling */
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);

    /* Smooth transition on hover */
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .knowledge-takeaways__item:hover,
  .knowledge-takeaways__item:focus {
    border-color: var(--accent-muted);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  /* Icon container */
  .knowledge-takeaways__icon {
    /* Layout */
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: 2rem;
    block-size: 2rem;

    /* Visual styling */
    color: var(--accent-primary);
    background: var(--surface-2);
    border-radius: var(--radius-base);
  }

  .knowledge-takeaways__icon :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
  }

  /* Takeaway text */
  .knowledge-takeaways__text {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
  }

  /* Responsive: Two columns on tablet and larger */
  @media (width >= 768px) {
    .knowledge-takeaways__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .knowledge-takeaways__item {
      transition: none;
    }

    .knowledge-takeaways__item:hover,
    .knowledge-takeaways__item:focus {
      transform: none;
    }
  }
</style>
