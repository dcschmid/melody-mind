---
import Headline from "@shared-ui/components/typography/Headline.astro";

type TakeawayItem =
  | string
  | {
      description: string;
      heading?: string;
    };

const {
  title = "Key takeaways",
  items = [],
  idBase = "knowledge-takeaways",
} = Astro.props as {
  title?: string;
  items?: TakeawayItem[];
  idBase?: string;
};
const titleId = `${idBase}-title`;
const takeawayEntries = items
  .map((item, index) => ({
    description: typeof item === "string" ? item : item.description,
    heading: typeof item === "string" ? "" : item.heading,
    marker: index + 1,
  }))
  .filter((item) => item.description.trim().length > 0);
---

{
  takeawayEntries.length ? (
    <aside class="knowledge-takeaways" aria-labelledby={titleId}>
      <div class="knowledge-takeaways__header">
        <Headline level="h2" textSize="2xl" className="knowledge-takeaways__title">
          <span id={titleId}>{title}</span>
        </Headline>
        <span class="knowledge-takeaways__accent" aria-hidden="true" />
      </div>
      <ol class="knowledge-takeaways__list">
        {takeawayEntries.map((item) => (
          <li class="knowledge-takeaways__item">
            <span class="knowledge-takeaways__marker" aria-hidden="true">
              {item.marker}
            </span>
            <div class="knowledge-takeaways__copy">
              {item.heading ? (
                <span class="knowledge-takeaways__item-title">{item.heading}</span>
              ) : null}
              <span class="knowledge-takeaways__text">{item.description}</span>
            </div>
          </li>
        ))}
      </ol>
    </aside>
  ) : null
}

<style>
  /* -----------------------------------------------------------------------------
     KnowledgeTakeaways Component Styles
     Highlighted summary section with key points
     WCAG AAA compliant with responsive grid layout
     ----------------------------------------------------------------------------- */

  .knowledge-takeaways {
    display: grid;
    gap: clamp(var(--spacing-base), 1.8vw, var(--spacing-lg));
    padding: 0;
    container-type: inline-size;
  }

  .knowledge-takeaways__header {
    display: grid;
    gap: var(--spacing-xs);
    justify-items: center;
    text-align: center;
  }

  .knowledge-takeaways__title {
    margin: 0;
    font-size: clamp(var(--font-size-xl), 2.1vw + 0.8rem, var(--font-size-2xl));
    font-weight: var(--font-weight-bold);
    color: var(--heading-color);
    letter-spacing: 0;
    text-wrap: balance;
  }

  .knowledge-takeaways__accent {
    inline-size: var(--spacing-2xl);
    block-size: 2px;
    margin-block-start: var(--spacing-md);
    background: var(--accent-primary);
    border-radius: var(--radius-full);
  }

  .knowledge-takeaways__list {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
    border-top: 1px solid color-mix(in srgb, var(--surface-border-soft) 82%, transparent);
  }

  .knowledge-takeaways__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--spacing-sm);
    align-items: start;
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--surface-border-soft) 76%, transparent);
  }

  .knowledge-takeaways__copy {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
  }

  .knowledge-takeaways__marker {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: clamp(var(--icon-shell-size-sm), 6cqi, var(--icon-shell-size-md));
    block-size: clamp(var(--icon-shell-size-sm), 6cqi, var(--icon-shell-size-md));
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-primary) 30%, transparent);
    border-radius: var(--radius-full);
  }

  .knowledge-takeaways__item-title {
    display: block;
    min-inline-size: 0;
    font-size: clamp(var(--font-size-base), 0.45vw + 1rem, var(--font-size-lg));
    font-weight: var(--font-weight-semibold);
    line-height: 1.28;
    color: var(--heading-color);
    text-wrap: balance;
  }

  .knowledge-takeaways__text {
    display: block;
    max-inline-size: min(40rem, 90vw);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--text-secondary);
  }

  @container (width >= 42rem) {
    .knowledge-takeaways__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .knowledge-takeaways__item:nth-child(odd) {
      padding-inline-end: var(--spacing-lg);
      border-inline-end: 1px solid
        color-mix(in srgb, var(--surface-border-soft) 48%, transparent);
    }

    .knowledge-takeaways__item:nth-child(even) {
      padding-inline-start: var(--spacing-lg);
    }
  }

  @container (width < 34rem) {
    .knowledge-takeaways {
      gap: var(--spacing-base);
    }

    .knowledge-takeaways__header {
      justify-items: start;
      text-align: start;
    }

    .knowledge-takeaways__title {
      font-size: var(--font-size-xl);
    }

    .knowledge-takeaways__accent {
      inline-size: var(--spacing-xl);
      margin-block-start: var(--spacing-xs);
    }

    .knowledge-takeaways__item {
      gap: var(--spacing-sm);
      padding: var(--spacing-base) 0;
    }

    .knowledge-takeaways__marker {
      inline-size: var(--icon-shell-size-sm);
      block-size: var(--icon-shell-size-sm);
      font-size: var(--font-size-xs);
    }

    .knowledge-takeaways__item-title {
      font-size: var(--font-size-base);
    }

    .knowledge-takeaways__text {
      max-inline-size: none;
      font-size: var(--font-size-sm);
      line-height: 1.55;
    }
  }
</style>
