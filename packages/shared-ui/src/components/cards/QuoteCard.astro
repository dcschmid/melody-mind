---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  quote: string;
  authorName?: string;
  authorRole?: string;
  sourceLabel?: string;
  sourceUrl?: string;
  avatarSrc?: ImageMetadata;
  avatarAlt?: string;
  avatarInitials?: string;
  className?: string;
}

const {
  quote,
  authorName,
  authorRole,
  sourceLabel,
  sourceUrl,
  avatarSrc,
  avatarAlt = authorName ? `${authorName} portrait` : "",
  avatarInitials,
  className = "",
} = Astro.props as Props;

const initials =
  avatarInitials ||
  authorName
    ?.split(/\s+/u)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("") ||
  "";

const hasAuthorMeta = Boolean(authorName || authorRole);
const classes = ["quote-card", className].filter(Boolean).join(" ");
---

<figure class={classes}>
  <blockquote class="quote-card__quote">
    <p class="quote-card__text">"{quote}"</p>
  </blockquote>

  {
    hasAuthorMeta ? (
      <figcaption class="quote-card__author">
        {avatarSrc ? (
          <Image
            class="quote-card__avatar-image"
            src={avatarSrc}
            alt={avatarAlt}
            width={avatarSrc.width}
            height={avatarSrc.height}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="quote-card__avatar-fallback" aria-hidden="true">
            {initials || "Q"}
          </span>
        )}

        <span class="quote-card__author-copy">
          {authorName ? <span class="quote-card__author-name">{authorName}</span> : null}
          {authorRole ? <span class="quote-card__author-role">{authorRole}</span> : null}
          {sourceLabel ? (
            sourceUrl ? (
              <AccessibleExternalLink
                className="quote-card__source"
                href={sourceUrl}
                target="_blank"
                rel="noreferrer"
              >
                {sourceLabel}
              </AccessibleExternalLink>
            ) : (
              <span class="quote-card__source">{sourceLabel}</span>
            )
          ) : null}
        </span>
      </figcaption>
    ) : null
  }
</figure>

<style>
  .quote-card {
    position: relative;
    display: grid;
    gap: var(--stack-gap-sm);
    padding: var(--panel-padding-sm);
    overflow: hidden;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--surface-panel-raised) 98%, transparent),
      color-mix(in srgb, var(--surface-panel-bg) 92%, transparent) 58%,
      color-mix(in srgb, var(--surface-panel-raised) 94%, transparent)
    );
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 58%, transparent),
      inset 0 -1px 0 color-mix(in srgb, var(--surface-border-soft) 28%, transparent),
      var(--shadow-md);
  }

  .quote-card::before {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    inline-size: calc(var(--accent-bar-width) + 0.06rem);
    content: "";
    background: var(--accent-primary);
    border-radius: var(--radius-full);
    box-shadow: 0 0 1rem color-mix(in srgb, var(--accent-primary) 16%, transparent);
  }

  .quote-card__quote {
    position: relative;
    padding-inline-end: clamp(var(--spacing-base), 2vw, 2.8rem);
    margin: 0;
  }

  .quote-card__text {
    margin: 0;
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    line-height: 1.24;
    color: var(--heading-color);
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .quote-card__author {
    display: flex;
    gap: calc(var(--spacing-sm) + 0.2rem);
    align-items: center;
    width: fit-content;
    max-width: 100%;
    padding: 0;
    margin: 0;
    margin-block-start: var(--spacing-2xs);
  }

  .quote-card__avatar-image,
  .quote-card__avatar-fallback {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: var(--icon-shell-size-md);
    block-size: var(--icon-shell-size-md);
    overflow: hidden;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent-primary) 20%, var(--surface-1)),
      color-mix(in srgb, var(--surface-panel-bg) 92%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--surface-border-soft) 92%, transparent);
    border-radius: var(--radius-lg);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-1) 54%, transparent);
  }

  .quote-card__avatar-image {
    object-fit: cover;
  }

  .quote-card__avatar-fallback {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--heading-color);
  }

  .quote-card__author-copy {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
  }

  .quote-card__author-name {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--heading-color);
  }

  .quote-card__author-role {
    font-size: var(--font-size-xs);
    line-height: 1.35;
    color: var(--accent-primary);
  }

  .quote-card__source {
    font-size: var(--font-size-xs);
    line-height: 1.35;
    color: var(--text-tertiary);
    text-decoration: none;
  }

  a.quote-card__source:hover,
  a.quote-card__source:focus-visible {
    color: var(--heading-color);
    text-decoration: underline;
    text-underline-offset: var(--text-underline-offset-base);
  }

  @media (width < 640px) {
    .quote-card {
      gap: var(--stack-gap-sm);
      padding: var(--panel-padding-sm);
    }

    .quote-card__quote {
      padding-inline-end: var(--spacing-lg);
    }

    .quote-card__text {
      font-size: var(--font-size-sm);
      line-height: 1.22;
    }

    .quote-card__author {
      gap: calc(var(--spacing-sm) + 0.15rem);
      width: 100%;
    }

    .quote-card__avatar-image,
    .quote-card__avatar-fallback {
      inline-size: var(--icon-shell-size-md);
      block-size: var(--icon-shell-size-md);
    }
  }
</style>
