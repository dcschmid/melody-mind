---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  quote: string;
  authorName?: string;
  authorRole?: string;
  sourceLabel?: string;
  sourceUrl?: string;
  avatarSrc?: ImageMetadata;
  avatarAlt?: string;
  avatarInitials?: string;
  className?: string;
}

const {
  quote,
  authorName,
  authorRole,
  sourceLabel,
  sourceUrl,
  avatarSrc,
  avatarAlt = authorName ? `${authorName} portrait` : "",
  avatarInitials,
  className = "",
} = Astro.props as Props;

const initials =
  avatarInitials ||
  authorName
    ?.split(/\s+/u)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("") ||
  "";

const hasAuthorMeta = Boolean(authorName || authorRole);
const classes = ["quote-card", className].filter(Boolean).join(" ");
---

<figure class={classes}>
  <blockquote class="quote-card__quote">
    <p class="quote-card__text">"{quote}"</p>
  </blockquote>

  <span class="quote-card__decoration" aria-hidden="true">"</span>

  {
    hasAuthorMeta ? (
      <figcaption class="quote-card__author">
        {avatarSrc ? (
          <Image
            class="quote-card__avatar-image"
            src={avatarSrc}
            alt={avatarAlt}
            width={avatarSrc.width}
            height={avatarSrc.height}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <span class="quote-card__avatar-fallback" aria-hidden="true">
            {initials || "Q"}
          </span>
        )}

        <span class="quote-card__author-copy">
          <span class="quote-card__attribution-prefix">by </span>
          {authorName ? <span class="quote-card__author-name">{authorName}</span> : null}
          {authorRole ? <span class="quote-card__author-role">{authorRole}</span> : null}
          {sourceLabel ? (
            sourceUrl ? (
              <AccessibleExternalLink
                className="quote-card__source"
                href={sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {sourceLabel}
              </AccessibleExternalLink>
            ) : (
              <span class="quote-card__source">{sourceLabel}</span>
            )
          ) : null}
        </span>
      </figcaption>
    ) : null
  }
</figure>

<style>
  @media screen and (prefers-reduced-motion: reduce) {
    .quote-card {
      position: relative;
      display: grid;
      padding: var(--panel-padding-sm);
      overflow: hidden;
      background: color-mix(
        in srgb,
        var(--surface-panel-bg) 85%,
        var(--accent-primary) 8%
      );
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-md);
      transition: none;
    }
  }

  .quote-card {
    position: relative;
    display: grid;
    padding: var(--panel-padding-sm);
    overflow: hidden;
    background: color-mix(in srgb, var(--surface-panel-bg) 85%, var(--accent-primary) 8%);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    transition:
      transform var(--motion-duration-base) var(--motion-ease-standard),
      box-shadow var(--motion-duration-base) var(--motion-ease-standard);
  }

  @media (hover: hover) {
    .quote-card:hover,
    .quote-card:focus {
      box-shadow: var(--shadow-lg);
      transform: translateY(-1px);
    }

    .quote-card:hover::before,
    .quote-card:focus::before {
      box-shadow: 0 0 1.4rem color-mix(in srgb, var(--accent-primary) 24%, transparent);
    }
  }

  .quote-card__decoration {
    position: absolute;
    inset-block: auto -0.75rem;
    inset-inline: auto 0.5rem;
    z-index: 0;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(6rem, 18vw, 10rem);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: color-mix(in srgb, var(--accent-primary) 10%, transparent);
    pointer-events: none;
    user-select: none;
  }

  .quote-card::before {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    inline-size: calc(var(--accent-bar-width) + 0.06rem);
    content: "";
    background: var(--accent-primary);
    border-radius: var(--radius-full);
    box-shadow: 0 0 1rem color-mix(in srgb, var(--accent-primary) 16%, transparent);
  }

  .quote-card__quote {
    position: relative;
    z-index: 1;
    padding-inline-end: clamp(var(--spacing-base), 2vw, 2.8rem);
    margin: 0;
  }

  .quote-card__author {
    display: flex;
    gap: calc(var(--spacing-sm) + 0.2rem);
    align-items: center;
    width: fit-content;
    max-width: 100%;
    margin: 0;
    margin-block-start: var(--spacing-lg);
  }

  .quote-card__text {
    margin: 0;
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    font-feature-settings:
      "kern" 1,
      "liga" 1;
    line-height: 1.2;
    color: var(--heading-color);
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .quote-card__avatar-image,
    .quote-card__avatar-fallback {
      display: inline-flex;
      flex-shrink: 0;
      align-items: center;
      justify-content: center;
      inline-size: var(--icon-shell-size-md);
      block-size: var(--icon-shell-size-md);
      overflow: hidden;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--accent-primary) 20%, var(--surface-1)),
        color-mix(in srgb, var(--surface-panel-bg) 92%, transparent)
      );
      border: 1px solid color-mix(in srgb, var(--surface-border-soft) 92%, transparent);
      border-radius: var(--radius-lg);
      transition: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .quote-card__avatar-image,
    .quote-card__avatar-fallback {
      transition: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .quote-card__avatar-image,
    .quote-card__avatar-fallback {
      transition: transform var(--motion-duration-fast) var(--motion-ease-standard);
    }
  }

  .quote-card__avatar-image,
  .quote-card__avatar-fallback {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: var(--icon-shell-size-md);
    block-size: var(--icon-shell-size-md);
    overflow: hidden;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent-primary) 20%, var(--surface-1)),
      color-mix(in srgb, var(--surface-panel-bg) 92%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--surface-border-soft) 92%, transparent);
    border-radius: var(--radius-lg);
  }

  @media (hover: hover) {
    .quote-card__avatar-image:hover,
    .quote-card__avatar-fallback:hover,
    .quote-card__avatar-image:focus,
    .quote-card__avatar-fallback:focus {
      transform: scale(1.03);
    }
  }

  .quote-card__avatar-image {
    object-fit: cover;
  }

  .quote-card__avatar-fallback {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--heading-color);
  }

  .quote-card__author-copy {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .quote-card__attribution-prefix {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-regular);
    color: var(--accent-primary);
    letter-spacing: 0.02em;
  }

  .quote-card__author-name {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    font-feature-settings:
      "kern" 1,
      "liga" 1;
    line-height: var(--line-height-tight);
    color: var(--heading-color);
  }

  .quote-card__author-role {
    font-size: var(--font-size-xs);
    line-height: 1.4;
    color: var(--accent-primary);
  }

  .quote-card__source {
    font-size: var(--font-size-xs);
    line-height: 1.4;
    color: var(--text-tertiary);
    text-decoration: none;
  }

  a.quote-card__source:hover,
  a.quote-card__source:focus-visible {
    color: var(--heading-color);
    text-decoration: underline;
    text-underline-offset: var(--text-underline-offset-base);
  }

  @media (width < 640px) {
    .quote-card__author {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-sm);
      align-items: flex-start;
      margin-block-start: var(--spacing-md);
    }

    .quote-card__author-copy {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);
      width: 100%;
    }

    .quote-card__quote {
      padding-inline-end: var(--spacing-lg);
    }

    .quote-card__text {
      font-size: var(--font-size-sm);
      line-height: 1.22;
    }

    .quote-card__avatar-image,
    .quote-card__avatar-fallback {
      inline-size: var(--icon-shell-size-sm);
      block-size: var(--icon-shell-size-sm);
    }

    .quote-card__decoration {
      font-size: clamp(4rem, 20vw, 6rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .quote-card,
    .quote-card__avatar-image,
    .quote-card__avatar-fallback,
    .quote-card__decoration {
      transition: none;
    }

    .quote-card:hover,
    .quote-card__avatar-image:hover,
    .quote-card__avatar-fallback:hover,
    .quote-card:focus,
    .quote-card__avatar-image:focus,
    .quote-card__avatar-fallback:focus {
      transform: none;
    }
  }
</style>
