---
import type { ImageMetadata } from "astro";
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";

type CssLengthUnit =
  | "px"
  | "rem"
  | "em"
  | "ch"
  | "ex"
  | "ic"
  | "lh"
  | "rlh"
  | "vw"
  | "vh"
  | "vmin"
  | "vmax"
  | "svw"
  | "svh"
  | "lvw"
  | "lvh"
  | "dvw"
  | "dvh"
  | "%";

type CssLength = "0" | `${number}${CssLengthUnit}`;

interface BaseProps extends astroHTML.JSX.HTMLAttributes {
  id: string;
  title: string;
  description: string;
  eyebrow?: string;
  imageWidth?: number | `${number}`;
  imageHeight?: number | `${number}`;
  imageLoading?: "eager" | "lazy";
  imageDecoding?: "sync" | "async" | "auto";
  imageSizes?: string;
  mediaAspectRatio?: `${number} / ${number}`;
  mediaObjectFit?: "cover" | "contain";
  titleLevel?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  titleMaxWidth?: CssLength;
  descriptionMaxWidth?: CssLength;
  dataTestId?: string;
  class?: string;
}

type Props =
  | (BaseProps & {
      imageSrc: string | ImageMetadata;
      imageAlt: string;
      imageDecorative?: false;
    })
  | (BaseProps & {
      imageSrc: string | ImageMetadata;
      imageAlt?: string;
      imageDecorative: true;
    })
  | (BaseProps & {
      imageSrc?: undefined;
      imageAlt?: string;
      imageDecorative?: boolean;
    });

const {
  id,
  title,
  description,
  eyebrow,
  imageSrc,
  imageAlt,
  imageDecorative = false,
  imageWidth,
  imageHeight,
  imageLoading = "lazy",
  imageDecoding = "async",
  imageSizes,
  mediaAspectRatio,
  mediaObjectFit = "cover",
  titleLevel = "h2",
  titleMaxWidth,
  descriptionMaxWidth,
  dataTestId,
  class: className,
  ...rest
} = Astro.props as Props;

const sanitizeId = (str: string) =>
  str
    .replace(/[^a-zA-Z0-9_-]/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");

const sanitizeCssLength = (value: CssLength | undefined, propName: string) => {
  if (!value) {
    return undefined;
  }

  const normalizedValue = String(value).trim();
  const isValidLength =
    normalizedValue === "0" ||
    /^(?:\d+(?:\.\d+)?|\.\d+)(?:px|rem|em|ch|ex|ic|lh|rlh|vw|vh|vmin|vmax|svw|svh|lvw|lvh|dvw|dvh|%)$/.test(
      normalizedValue
    );

  if (!isValidLength) {
    if (import.meta.env.DEV) {
      console.warn(
        `[HeroTeaser] Ignoring invalid ${propName} value: "${normalizedValue}".`
      );
    }

    return undefined;
  }

  return normalizedValue;
};

const sanitizeAspectRatio = (value: string | undefined) => {
  if (!value) {
    return undefined;
  }

  const normalizedValue = value.trim().replace(/\s*\/\s*/, " / ");
  const match = normalizedValue.match(/^(\d+(?:\.\d+)?|\.\d+) \/ (\d+(?:\.\d+)?|\.\d+)$/);

  if (!match) {
    if (import.meta.env.DEV) {
      console.warn(`[HeroTeaser] Ignoring invalid mediaAspectRatio: "${value}".`);
    }

    return undefined;
  }

  const [, widthRatio, heightRatio] = match;

  if (Number(widthRatio) <= 0 || Number(heightRatio) <= 0) {
    if (import.meta.env.DEV) {
      console.warn(`[HeroTeaser] Ignoring invalid mediaAspectRatio: "${value}".`);
    }

    return undefined;
  }

  return `${widthRatio} / ${heightRatio}`;
};

const rootId = id ? sanitizeId(id) : `hero-teaser-${crypto.randomUUID()}`;
const headingId = `${rootId}-title`;
const descriptionId = `${rootId}-description`;
const hasMediaSlot = Astro.slots.has("media");
const hasMetaSlot = Astro.slots.has("meta");
const hasActionsSlot = Astro.slots.has("actions");
const hasMedia = Boolean(imageSrc) || hasMediaSlot;

const resolvedImageAlt = imageDecorative ? "" : (imageAlt?.trim() ?? "");

if (imageSrc && !imageDecorative && !resolvedImageAlt) {
  throw new Error(
    `[HeroTeaser] imageAlt is required when imageSrc is provided. Set imageDecorative={true} only when the image adds no information.`
  );
}

const resolvedImageWidth = imageWidth ?? 1200;
const resolvedImageHeight = imageHeight ?? 900;
const resolvedMediaAspectRatio =
  sanitizeAspectRatio(mediaAspectRatio) ??
  `${resolvedImageWidth} / ${resolvedImageHeight}`;
const resolvedImageSizes =
  imageSizes ?? "(max-width: 640px) 100vw, (max-width: 960px) 80vw, 45vw";
const resolvedFetchPriority = imageLoading === "eager" ? "high" : undefined;
const titleMaxInlineSize = sanitizeCssLength(titleMaxWidth, "titleMaxWidth");
const descriptionMaxInlineSize = sanitizeCssLength(
  descriptionMaxWidth,
  "descriptionMaxWidth"
);
---

<section
  {...rest}
  class:list={["hero-teaser", className]}
  data-testid={dataTestId}
  aria-labelledby={headingId}
  aria-describedby={descriptionId}
>
  <div class="hero-teaser__grid">
    <div class="hero-teaser__copy">
      {eyebrow ? <span class="eyebrow hero-teaser__eyebrow">{eyebrow}</span> : null}

      <Headline
        id={headingId}
        level={titleLevel}
        textSize="3xl"
        className="hero-teaser__title"
        style={titleMaxInlineSize ? `max-inline-size: ${titleMaxInlineSize};` : undefined}
      >
        {title}
      </Headline>

      <Paragraph
        id={descriptionId}
        textSize="xl"
        className="hero-teaser__description"
        style={descriptionMaxInlineSize
          ? `max-inline-size: ${descriptionMaxInlineSize};`
          : undefined}
      >
        {description}
      </Paragraph>
    </div>

    <div
      class:list={[
        "hero-teaser__media",
        `hero-teaser__media--${mediaObjectFit}`,
        !hasMedia && "hero-teaser__media--placeholder",
      ]}
      style={`--hero-teaser-media-aspect-ratio: ${resolvedMediaAspectRatio};`}
    >
      {
        imageSrc ? (
          <OptimizedImage
            src={imageSrc}
            alt={resolvedImageAlt}
            class="hero-teaser__image"
            width={resolvedImageWidth}
            height={resolvedImageHeight}
            loading={imageLoading}
            decoding={imageDecoding}
            sizes={resolvedImageSizes}
            fetchpriority={resolvedFetchPriority}
          />
        ) : hasMediaSlot ? (
          <slot name="media" />
        ) : (
          <div
            class="hero-teaser__placeholder"
            role="img"
            aria-label="No image available"
          >
            <Icon name="image" class="hero-teaser__placeholder-icon" aria-hidden="true" />
            <span class="hero-teaser__placeholder-label">No image available</span>
          </div>
        )
      }
    </div>
  </div>
  {
    hasMetaSlot || hasActionsSlot ? (
      <div class="hero-teaser__footer">
        {hasMetaSlot ? (
          <div class="hero-teaser__meta">
            <slot name="meta" />
          </div>
        ) : null}
        {hasActionsSlot ? (
          <div class="hero-teaser__actions">
            <slot name="actions" />
          </div>
        ) : null}
      </div>
    ) : null
  }
</section>

<style>
  .hero-teaser {
    inline-size: 100%;
    padding: 0;
    margin-inline: auto;
    color: var(--text-primary);
    background: none;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .hero-teaser__grid {
    display: grid;
    gap: clamp(var(--spacing-lg), 3vw, var(--spacing-3xl));
    align-items: center;
  }

  .hero-teaser__footer {
    display: grid;
    gap: clamp(var(--spacing-md), 2.4vw, var(--spacing-lg));
    inline-size: 100%;
    padding-block-start: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl));
    margin-block-start: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl));
    border-block-start: 1px solid
      color-mix(in srgb, var(--accent-primary) 18%, var(--border-muted));
  }

  .hero-teaser__copy {
    position: relative;
    display: grid;
    gap: clamp(var(--spacing-base), 2.5vw, var(--spacing-lg));
    align-content: center;
    min-inline-size: 0;
    padding: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl))
      clamp(var(--spacing-md), 2vw, var(--spacing-xl));
    border-radius: var(--radius-lg);
  }

  .hero-teaser__eyebrow {
    padding-block-end: clamp(var(--spacing-xs), 0.5vw, var(--spacing-sm));
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-teaser__title {
    padding-block-start: clamp(var(--spacing-2xs), 0.3vw, var(--spacing-xs));
    font-size: var(--font-size-4xl);
    line-height: 0.95;
    text-wrap: balance;
  }

  .hero-teaser__description {
    padding-block-start: clamp(var(--spacing-sm), 1vw, var(--spacing-md));
    font-size: var(--font-size-lg);
    color: var(--text-secondary);
  }

  .hero-teaser__meta,
  .hero-teaser__actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: clamp(var(--spacing-sm), 2vw, var(--spacing-md));
    align-items: stretch;
    inline-size: 100%;
  }

  .hero-teaser__meta > :global(*),
  .hero-teaser__actions > :global(*) {
    inline-size: 100%;
    min-block-size: 100%;
  }

  .hero-teaser__actions :global(a),
  .hero-teaser__actions :global(button) {
    min-block-size: var(--control-min-block-size);
  }

  .hero-teaser__media {
    min-inline-size: 0;
    aspect-ratio: var(--hero-teaser-media-aspect-ratio, 4 / 3);
    overflow: hidden;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
  }

  .hero-teaser__media:has(img) {
    cursor: default;
  }

  .hero-teaser__media--contain {
    display: grid;
    place-items: center;
  }

  .hero-teaser__media--placeholder {
    min-block-size: 18rem;
  }

  .hero-teaser__placeholder {
    display: grid;
    gap: var(--spacing-sm);
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
    padding: var(--spacing-lg);
    color: var(--text-secondary);
    text-align: center;
  }

  .hero-teaser__placeholder-icon {
    inline-size: var(--icon-size-xl);
    block-size: var(--icon-size-xl);
    color: var(--accent-primary);
  }

  .hero-teaser__placeholder-label {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
  }

  @media (width >= 640px) {
    .hero-teaser__footer {
      grid-template-columns: minmax(0, 1.4fr) minmax(14rem, auto);
      align-items: start;
    }
  }

  @media (width >= 960px) {
    .hero-teaser__grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 1fr);
    }

    .hero-teaser__copy {
      order: 2;
      padding-inline-start: clamp(0rem, 1.5vw, var(--spacing-base));
    }

    .hero-teaser__media {
      order: 1;
    }
  }
</style>

<style is:global>
  :where(
    .hero-teaser__media > img,
    .hero-teaser__media > picture,
    .hero-teaser__media > picture > img
  ) {
    display: block;
  }

  :where(
    .hero-teaser__media--cover > img,
    .hero-teaser__media--cover > picture,
    .hero-teaser__media--cover > picture > img
  ) {
    inline-size: 100%;
    block-size: 100%;
  }

  :where(.hero-teaser__media--cover > img, .hero-teaser__media--cover > picture > img) {
    object-fit: cover;
  }

  :where(.hero-teaser__media--contain > picture) {
    display: grid;
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
  }

  :where(
    .hero-teaser__media--contain > img,
    .hero-teaser__media--contain > picture > img
  ) {
    inline-size: auto;
    block-size: auto;
    max-block-size: 100%;
    object-fit: contain;
  }
</style>
