---
import type { ImageMetadata } from "astro";
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props extends astroHTML.JSX.HTMLAttributes {
  id: string;
  title: string;
  description: string;
  eyebrow?: string;
  imageSrc?: string | ImageMetadata;
  imageAlt?: string;
  imageWidth?: number | `${number}`;
  imageHeight?: number | `${number}`;
  imageLoading?: "eager" | "lazy";
  imageDecoding?: "sync" | "async" | "auto";
  mediaAspectRatio?: string;
  mediaObjectFit?: "cover" | "contain";
  mediaPosition?: "start" | "end";
  titleLevel?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  dataTestId?: string;
  class?: string;
}

const {
  id,
  title,
  description,
  eyebrow,
  imageSrc,
  imageAlt = "",
  imageWidth,
  imageHeight,
  imageLoading = "lazy",
  imageDecoding = "async",
  mediaAspectRatio,
  mediaObjectFit = "cover",
  mediaPosition = "start",
  titleLevel = "h2",
  dataTestId,
  class: className,
  ...rest
} = Astro.props as Props;

const headingId = `${id}-title`;
const descriptionId = `${id}-description`;
const hasMediaSlot = Astro.slots.has("media");
const hasMetaSlot = Astro.slots.has("meta");
const hasActionsSlot = Astro.slots.has("actions");
const hasMedia = Boolean(imageSrc) || hasMediaSlot;
const resolvedImageWidth = imageWidth ?? 1200;
const resolvedImageHeight = imageHeight ?? 900;
const resolvedMediaAspectRatio =
  mediaAspectRatio ?? `${resolvedImageWidth} / ${resolvedImageHeight}`;
---

<section
  {...rest}
  class:list={["hero-teaser", `hero-teaser--media-${mediaPosition}`, className]}
  data-testid={dataTestId}
  aria-labelledby={headingId}
  aria-describedby={descriptionId}
>
  <div class="hero-teaser__grid">
    <div class="hero-teaser__copy">
      {eyebrow ? <p class="hero-teaser__eyebrow">{eyebrow}</p> : null}

      <Headline
        id={headingId}
        level={titleLevel}
        textSize="3xl"
        className="hero-teaser__title"
      >
        {title}
      </Headline>

      <Paragraph id={descriptionId} textSize="xl" className="hero-teaser__description">
        {description}
      </Paragraph>
    </div>

    <div
      class:list={[
        "hero-teaser__media",
        `hero-teaser__media--${mediaObjectFit}`,
        !hasMedia && "hero-teaser__media--placeholder",
      ]}
      style={`--hero-teaser-media-aspect-ratio: ${resolvedMediaAspectRatio};`}
    >
      {
        imageSrc ? (
          <OptimizedImage
            src={imageSrc}
            alt={imageAlt}
            class="hero-teaser__image"
            width={resolvedImageWidth}
            height={resolvedImageHeight}
            loading={imageLoading}
            decoding={imageDecoding}
          />
        ) : hasMediaSlot ? (
          <slot name="media" />
        ) : (
          <div
            class="hero-teaser__placeholder"
            role="img"
            aria-label="No image available"
          >
            <Icon name="image" class="hero-teaser__placeholder-icon" aria-hidden="true" />
            <span class="hero-teaser__placeholder-label">No image available</span>
          </div>
        )
      }
    </div>
  </div>
  {
    hasMetaSlot || hasActionsSlot ? (
      <div class="hero-teaser__footer">
        {hasMetaSlot ? (
          <div class="hero-teaser__meta">
            <slot name="meta" />
          </div>
        ) : null}
        {hasActionsSlot ? (
          <div class="hero-teaser__actions">
            <slot name="actions" />
          </div>
        ) : null}
      </div>
    ) : null
  }
</section>

<style>
  .hero-teaser {
    position: relative;
    box-sizing: border-box;
    inline-size: 100%;
    padding: clamp(var(--spacing-base), 4vw, var(--spacing-2xl));
    margin-inline: auto;
    overflow: hidden;
    color: var(--text-primary);
    background:
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--accent-primary) 14%, transparent),
        transparent 38%
      ),
      var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
    isolation: isolate;
  }

  .hero-teaser::after {
    position: absolute;
    inset: auto 0 0;
    block-size: 1px;
    content: "";
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--accent-primary) 38%, transparent),
      transparent
    );
    opacity: 0.9;
  }

  .hero-teaser__grid {
    display: grid;
    gap: clamp(var(--spacing-base), 3vw, var(--spacing-2xl));
    align-items: center;
  }

  .hero-teaser__footer {
    display: grid;
    gap: clamp(var(--spacing-md), 2.4vw, var(--spacing-lg));
    inline-size: 100%;
    padding-block-start: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl));
    margin-block-start: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl));
    border-block-start: 1px solid
      color-mix(in srgb, var(--border-default) 42%, transparent);
  }

  .hero-teaser__copy {
    display: grid;
    gap: clamp(var(--spacing-base), 2.5vw, var(--spacing-lg));
    min-inline-size: 0;
  }

  .hero-teaser__eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-widest);
  }

  .hero-teaser__title {
    max-inline-size: 16ch;
    font-size: var(--font-size-2xl);
    line-height: 1.1;
    text-wrap: pretty;
  }

  .hero-teaser__description {
    max-inline-size: 40ch;
    font-size: var(--font-size-lg);
    color: var(--text-secondary);
  }

  .hero-teaser__meta,
  .hero-teaser__actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: clamp(var(--spacing-sm), 2vw, var(--spacing-md));
    align-items: stretch;
    inline-size: 100%;
  }

  .hero-teaser__meta {
    justify-content: flex-start;
  }

  .hero-teaser__actions {
    justify-content: flex-start;
  }

  .hero-teaser__meta > :global(*),
  .hero-teaser__actions > :global(*) {
    inline-size: 100%;
    min-block-size: 100%;
  }

  .hero-teaser__actions :global(a),
  .hero-teaser__actions :global(button) {
    min-block-size: 48px;
  }

  .hero-teaser__media {
    position: relative;
    min-inline-size: 0;
    aspect-ratio: var(--hero-teaser-media-aspect-ratio, 4 / 3);
    overflow: hidden;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 45%, transparent),
        transparent
      ),
      var(--surface-chip-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: calc(var(--radius-2xl) - var(--spacing-xs));
    box-shadow: var(--shadow-md);
  }

  .hero-teaser__media--contain {
    display: grid;
    place-items: center;
  }

  .hero-teaser__media--placeholder {
    min-block-size: 18rem;
  }

  .hero-teaser__placeholder {
    display: grid;
    gap: var(--spacing-sm);
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
    padding: var(--spacing-xl);
    color: var(--text-secondary);
    text-align: center;
  }

  .hero-teaser__placeholder-icon {
    inline-size: 2rem;
    block-size: 2rem;
    color: var(--accent-primary);
  }

  .hero-teaser__placeholder-label {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
  }

  @media (width >= 640px) {
    .hero-teaser {
      padding: clamp(var(--spacing-lg), 2.8vw, var(--spacing-2xl));
    }

    .hero-teaser__title {
      font-size: var(--font-size-2xl);
      line-height: var(--heading-line-height);
    }

    .hero-teaser__description {
      font-size: var(--font-size-lg);
    }
  }

  @media (width >= 960px) {
    .hero-teaser__grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.95fr);
    }

    .hero-teaser--media-start .hero-teaser__copy {
      order: 2;
    }

    .hero-teaser--media-start .hero-teaser__media {
      order: 1;
    }

    .hero-teaser--media-end .hero-teaser__copy {
      order: 1;
    }

    .hero-teaser--media-end .hero-teaser__media {
      order: 2;
    }

    .hero-teaser__footer {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (width >= 1200px) {
    .hero-teaser__title {
      max-inline-size: 18ch;
    }

    .hero-teaser__description {
      max-inline-size: 44ch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-teaser {
      scroll-behavior: auto;
    }
  }
</style>

<style is:global>
  :where(
    .hero-teaser__media img,
    .hero-teaser__media picture,
    .hero-teaser__media picture > img,
    .hero-teaser__media svg
  ) {
    display: block;
  }

  :where(
    .hero-teaser__media--cover img,
    .hero-teaser__media--cover picture,
    .hero-teaser__media--cover picture > img,
    .hero-teaser__media--cover svg
  ) {
    inline-size: 100%;
    block-size: 100%;
  }

  :where(
    .hero-teaser__media--cover img,
    .hero-teaser__media--cover picture > img,
    .hero-teaser__media--cover svg
  ) {
    object-fit: cover;
  }

  :where(.hero-teaser__media--contain picture) {
    display: grid;
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
  }

  :where(
    .hero-teaser__media--contain img,
    .hero-teaser__media--contain picture > img,
    .hero-teaser__media--contain svg
  ) {
    inline-size: auto;
    max-inline-size: 100%;
    block-size: auto;
    max-block-size: 100%;
    object-fit: contain;
  }
</style>
