---
import type { ImageMetadata } from "astro";
import type { ContentCardMetaItem } from "./relatedContent";
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props extends astroHTML.JSX.HTMLAttributes {
  id: string;
  title: string;
  href?: string;
  description?: string;
  /** Controls top/bottom card chrome (default) vs minimal sides */
  chrome?: "default" | "minimal";
  /** Visual style variant: default, feature (primary CTA), action (secondary CTA) */
  variant?: "default" | "feature" | "action";
  /** Controls padding and font sizes: compact, default, spacious */
  size?: "compact" | "default" | "spacious";
  dataTestId?: string;
  mediaAspectRatio?: string;
  mediaObjectFit?: "cover" | "contain";
  imageSrc?: string | ImageMetadata;
  imageAlt?: string;
  imageWidth?: number | `${number}`;
  imageHeight?: number | `${number}`;
  imageLoading?: "eager" | "lazy";
  imageDecoding?: "sync" | "async" | "auto";
  imageSizes?: string;
  titleLevel?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  /** Array of {label, iconName?, datetime?} for metadata row */
  metaItems?: ContentCardMetaItem[];
  descriptionLineClamp?: number;
  /** Button label text */
  ctaLabel?: string;
  /** Icon name for button */
  ctaIconName?: string;
  /** Screen reader text for button */
  ctaSrText?: string;
  target?: string;
  rel?: string;
  class?: string;
}

const {
  id,
  title,
  href,
  description,
  chrome = "default",
  variant = "default",
  size = "default",
  dataTestId,
  mediaAspectRatio,
  mediaObjectFit = "cover",
  imageSrc,
  imageAlt,
  imageWidth,
  imageHeight,
  imageLoading = "lazy",
  imageDecoding = "async",
  imageSizes,
  titleLevel = "h3",
  metaItems = [],
  descriptionLineClamp = 0,
  ctaLabel,
  ctaIconName,
  ctaSrText,
  target,
  rel,
  class: className,
  ...rest
} = Astro.props as Props;

const titleId = `${id}-title`;
const descriptionId = `${id}-description`;
const metaId = `${id}-meta`;
const hasSlottedMedia = Astro.slots.has("media");
const hasMedia = Boolean(imageSrc) || hasSlottedMedia;
const hasHeader = Astro.slots.has("header");
const hasBadge = Astro.slots.has("badge");
const hasFooterMetaSlot = Astro.slots.has("footer-meta");
const hasFooter = Astro.slots.has("footer");
const hasScreenReaderSlot = Astro.slots.has("sr");
const hasMeta = metaItems.length > 0 || hasFooterMetaSlot;
const hasCta = Boolean(ctaLabel);
const describedBy = [description ? descriptionId : null, hasMeta ? metaId : null]
  .filter(Boolean)
  .join(" ");
const descriptionStyle =
  descriptionLineClamp > 0
    ? `--content-card-description-line-clamp: ${descriptionLineClamp};`
    : undefined;
const resolvedImageWidth = imageWidth ?? 1024;
const resolvedImageHeight = imageHeight ?? 683;
const resolvedMediaAspectRatio =
  mediaAspectRatio ?? `${resolvedImageWidth} / ${resolvedImageHeight}`;
const TitleTag = titleLevel;
const ContentTag = href ? "a" : "div";
const contentProps = href
  ? {
      href,
      ...(target ? { target } : {}),
      // Security: Add rel="noopener noreferrer" when target="_blank" to prevent reverse tabnabbing
      ...(target === "_blank"
        ? {
            rel:
              [rel, "noopener", "noreferrer"].filter(Boolean).join(" ") ||
              "noopener noreferrer",
          }
        : rel
          ? { rel }
          : {}),
      "aria-labelledby": titleId,
      "aria-describedby": describedBy || undefined,
    }
  : {};
---

<article
  {...rest}
  class:list={[
    "content-card",
    `content-card--chrome-${chrome}`,
    `content-card--${variant}`,
    `content-card--size-${size}`,
    /* Applied when card is navigable link - enables hover/focus states */
    href && "content-card--interactive",
    className,
  ]}
  data-testid={dataTestId}
  aria-labelledby={titleId}
  aria-describedby={describedBy || undefined}
>
  <ContentTag class="content-card__content" {...contentProps}>
    {
      hasMedia ? (
        <div
          class:list={["content-card__media", `content-card__media--${mediaObjectFit}`]}
          style={`--content-card-media-aspect-ratio: ${resolvedMediaAspectRatio};`}
        >
          {imageSrc ? (
            <OptimizedImage
              src={imageSrc}
              alt={imageAlt ?? ""}
              aria-hidden={imageAlt === undefined ? "true" : undefined}
              class="content-card__media-image"
              width={resolvedImageWidth}
              height={resolvedImageHeight}
              loading={imageLoading}
              decoding={imageDecoding}
              sizes={imageSizes}
            />
          ) : (
            <slot name="media" />
          )}
          {hasBadge ? (
            <div class="content-card__badge">
              <slot name="badge" />
            </div>
          ) : null}
        </div>
      ) : null
    }

    <div class="content-card__body">
      {hasHeader ? <slot name="header" /> : null}

      <TitleTag class="content-card__title" id={titleId}>
        {title}
      </TitleTag>

      {
        description ? (
          <p
            id={descriptionId}
            class:list={[
              "content-card__description",
              descriptionLineClamp > 0 && "content-card__description--clamped",
            ]}
            style={descriptionStyle}
          >
            {description}
          </p>
        ) : null
      }

      {
        hasMeta ? (
          <div class="content-card__meta" id={metaId}>
            {metaItems.map((item) => {
              const MetaTag = item.datetime ? "time" : "span";
              const metaProps = item.datetime
                ? { datetime: item.datetime, "aria-label": item.label }
                : {};
              return (
                <MetaTag class="content-card__meta-item" {...metaProps}>
                  {item.iconName ? (
                    <Icon
                      name={item.iconName}
                      class="content-card__meta-icon"
                      aria-hidden="true"
                    />
                  ) : null}
                  <span>{item.label}</span>
                </MetaTag>
              );
            })}
            {hasFooterMetaSlot ? <slot name="footer-meta" /> : null}
          </div>
        ) : null
      }
    </div>

    {
      hasFooter ? (
        <div class="content-card__footer">
          <slot name="footer" />
        </div>
      ) : hasCta && !href ? (
        <div class="content-card__footer">
          <button type="button" class="content-card__cta">
            {ctaIconName ? (
              <Icon
                name={ctaIconName}
                class="content-card__cta-icon"
                aria-hidden="true"
              />
            ) : null}
            <span>{ctaLabel}</span>
          </button>
        </div>
      ) : null
    }

    {
      hasScreenReaderSlot ? (
        <span class="content-card__sr">
          <slot name="sr" />
        </span>
      ) : hasCta && ctaSrText ? (
        <span class="content-card__sr">{ctaSrText}</span>
      ) : null
    }
  </ContentTag>
</article>

<style>
  .content-card {
    position: relative;
    display: flex;
    inline-size: 100%;
    min-inline-size: 0;
    block-size: 100%;
    container-type: inline-size;
    overflow: hidden;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);

    /* Extra radius creates softer, more editorial feel beyond standard xl */
    border-radius: calc(var(--radius-xl) + var(--spacing-xs));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 74%, transparent),
      var(--shadow-base);
  }

  .content-card--interactive.content-card--action:hover,
  .content-card--interactive.content-card--action:focus-within {
    border-color: var(--accent-primary);
  }

  .content-card--interactive.content-card--action:focus-within {
    box-shadow: var(--interactive-shadow-focus), var(--shadow-xl);
  }

  .content-card__media {
    position: relative;
    inline-size: 100%;
    aspect-ratio: var(--content-card-media-aspect-ratio, 3 / 2);
    overflow: hidden;
    background: var(--surface-chip-bg);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .content-card__media-image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .content-card--feature .content-card__media {
    background: var(--surface-pill-bg);
    border-block-end-color: var(--surface-border-accent);
  }

  /* Minimal chrome removes media bottom border */
  .content-card--chrome-minimal .content-card__media {
    border-block-end: 0;
  }

  /* Subtle corner vignettes: top-light and bottom-dark gradients add depth */
  .content-card__media::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-scrim) 6%, transparent),
        transparent 36%
      ),
      linear-gradient(
        180deg,
        transparent 55%,
        color-mix(in srgb, var(--surface-scrim) 22%, transparent)
      );
  }

  .content-card__media--contain {
    display: grid;
    place-items: center;
  }

  /* Base media styles: layout, sizing, object-fit for default/cover variants */
  .content-card__media :global(img),
  .content-card__media :global(picture),
  .content-card__media :global(picture > img),
  .content-card__media :global(svg) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .content-card__media--contain :global(img),
  .content-card__media--contain :global(picture > img),
  .content-card__media--contain :global(svg) {
    object-fit: contain;
  }

  .content-card__badge {
    position: absolute;
    inset-block-end: var(--spacing-base);
    inset-inline-end: var(--spacing-base);
    z-index: 1;
  }

  .content-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--spacing-md);
    padding: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
  }

  .content-card__content {
    display: flex;
    flex-direction: column;
    inline-size: 100%;
    color: inherit;
    text-decoration: none;
  }

  .content-card__content:hover,
  .content-card__content:focus-visible {
    text-decoration: none;
  }

  .content-card--size-compact .content-card__body {
    gap: var(--spacing-sm);
    padding: var(--spacing-base);
  }

  .content-card--size-spacious .content-card__body {
    gap: var(--spacing-base);
    padding: var(--spacing-xl);
  }

  .content-card__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--heading-font-weight);
    line-height: var(--heading-line-height);
    color: var(--heading-color);
    letter-spacing: var(--heading-letter-spacing);
    text-wrap: balance;
    overflow-wrap: break-word;
  }

  .content-card--size-compact .content-card__title {
    font-size: var(--font-size-base);
  }

  .content-card--size-spacious .content-card__title {
    font-size: var(--font-size-lg);
  }

  /* Warm amber undertone on interactive titles */
  .content-card--interactive:hover .content-card__title,
  .content-card--interactive:focus-within .content-card__title {
    color: color-mix(in srgb, var(--heading-color) 85%, var(--accent-primary) 15%);
  }

  .content-card__description {
    margin: 0;
    font-size: var(--font-size-base);
    line-height: var(--prose-line-height);
    color: color-mix(in srgb, var(--text-secondary) 85%, var(--accent-primary) 15%);
    text-wrap: pretty;
    overflow-wrap: break-word;
  }

  .content-card--size-compact .content-card__description {
    font-size: var(--font-size-sm);
  }

  .content-card__description--clamped {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: var(--content-card-description-line-clamp);
    /* stylelint-disable-next-line property-no-deprecated */
    -webkit-box-orient: vertical;
  }

  .content-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm) var(--spacing-lg);
    padding-block-start: var(--spacing-md);
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .content-card--size-compact .content-card__meta {
    gap: var(--spacing-sm) var(--spacing-md);
  }

  .content-card--size-spacious .content-card__meta {
    padding-block-start: var(--spacing-lg);
  }

  .content-card__meta-item {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    min-inline-size: 0;
    font-weight: var(--font-weight-medium);
    color: color-mix(in srgb, var(--text-secondary) 85%, var(--accent-primary) 15%);
  }

  .content-card__meta-icon {
    display: block;
    flex-shrink: 0;
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
    color: var(--accent-primary);
  }

  /* Icon color shift indicates metadata presence on hover */
  .content-card--interactive:hover .content-card__meta-icon,
  .content-card--interactive:focus-within .content-card__meta-icon {
    color: var(--accent-primary);
  }

  .content-card__footer {
    padding: 0 clamp(var(--spacing-lg), 2vw, var(--spacing-xl))
      clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
  }

  .content-card--size-compact .content-card__footer {
    padding: 0 var(--spacing-base) var(--spacing-base);
  }

  .content-card--size-spacious .content-card__footer {
    padding: 0 var(--spacing-xl) var(--spacing-xl);
  }

  .content-card__cta {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
    min-inline-size: calc(var(--spacing-4xl) + var(--spacing-3xl) - var(--spacing-xs));
    min-block-size: var(--control-min-block-size);
    padding: var(--button-padding-y) var(--button-padding-x);
    font-size: var(--font-size-sm);
    font-weight: var(--button-font-weight);
    color: var(--text-primary);
    text-align: center;
    background: color-mix(in srgb, var(--surface-1) 78%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-xs);
  }

  .content-card__cta-icon {
    display: block;
    inline-size: var(--icon-size-xs);
    block-size: var(--icon-size-xs);
  }

  .content-card--feature .content-card__cta {
    color: var(--button-text-accent);
    background: var(--button-primary-bg);
    border-color: var(--surface-border-accent);
    box-shadow: var(--shadow-lg);
  }

  .content-card--action .content-card__cta {
    background: var(--surface-chip-bg);
    border-color: var(--surface-border-accent);
  }

  /* CTA keyboard focus: clear visible indicator */
  .content-card__cta:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  /* CTA hover: only triggers on CTA hover, not entire card */
  .content-card__cta:hover,
  .content-card__cta:focus-within {
    cursor: pointer;
    background: var(--surface-card-hover);
    box-shadow: var(--shadow-sm);
  }

  .content-card--interactive.content-card--feature .content-card__cta:hover,
  .content-card--interactive.content-card--feature .content-card__cta:focus-within {
    background: var(--accent-primary-hover);
    box-shadow: var(--shadow-xl);
  }

  .content-card--interactive.content-card--action .content-card__cta:hover,
  .content-card--interactive.content-card--action .content-card__cta:focus-within {
    background: var(--surface-pill-bg);
  }

  .content-card__sr {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  @container (max-width: 24rem) {
    .content-card--size-spacious .content-card__body {
      gap: var(--spacing-sm);
      padding: var(--spacing-base);
    }

    .content-card--size-spacious .content-card__title {
      font-size: var(--font-size-lg);
    }

    .content-card--size-spacious .content-card__footer {
      padding: 0 var(--spacing-base) var(--spacing-base);
    }

    .content-card__badge {
      inset-block-end: var(--spacing-sm);
      inset-inline-end: var(--spacing-sm);
    }
  }
</style>

{
  /* Global styles: targets slotted/child elements that escape scoped CSS
   - Variant-specific sizing (--cover, --contain) needs global selectors
   - Interactive hover states for feature/action variants need cross-scope access */
}
<style is:global>
  :where(
    .content-card__media img,
    .content-card__media picture,
    .content-card__media picture > img,
    .content-card__media svg
  ) {
    display: block;
  }

  :where(
    .content-card__media--cover img,
    .content-card__media--cover picture,
    .content-card__media--cover picture > img,
    .content-card__media--cover svg
  ) {
    inline-size: 100%;
    block-size: 100%;
  }

  :where(
    .content-card__media--cover img,
    .content-card__media--cover picture > img,
    .content-card__media--cover svg
  ) {
    object-fit: cover;
  }

  :where(.content-card__media--contain picture) {
    display: grid;
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
  }

  :where(
    .content-card__media--contain img,
    .content-card__media--contain picture > img,
    .content-card__media--contain svg
  ) {
    display: block;
    inline-size: auto;
    max-inline-size: 100%;
    block-size: auto;
    max-block-size: 100%;
    object-fit: contain;
  }

  :is(
      .content-card--interactive.content-card--action:hover,
      .content-card--interactive.content-card--action:focus-within,
      .content-card--interactive.content-card--feature:hover,
      .content-card--interactive.content-card--feature:focus-within
    )
    :where(.content-card__media img, .content-card__media picture > img) {
    transform: scale(1.05);
  }
</style>
