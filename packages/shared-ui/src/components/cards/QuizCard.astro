---
import Card from "./Card.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

export const prerender = true;

interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  imageAlt?: string;
  ctaLabel?: string;
  id?: string;
}

const {
  title,
  description,
  href,
  image,
  imageAlt = `${title} cover image`,
  ctaLabel = "Play Quiz",
  id,
} = Astro.props as Props;

const cardId = id ?? `quiz-card-${href.replaceAll("/", "-").replace(/^-+/, "")}`;
---

<Card
  variant="elevated"
  href={href}
  labelledBy={cardId}
  dataTestId="quiz-card"
  imageSrc={image}
  imageAlt={imageAlt}
  imageClassName="quiz-card__image"
>
  <h3 id={cardId} class="quiz-card__title">{title}</h3>
  <Paragraph textSize="sm" className="quiz-card__description">
    {description}
  </Paragraph>

  <Fragment slot="footer">
    <span class="quiz-card__cta">
      <Icon name="play" class="quiz-card__cta-icon" aria-hidden="true" />
      <span>{ctaLabel}</span>
    </span>
  </Fragment>
</Card>

<style>
  /* -----------------------------------------------------------------------------
     QuizCard Component Styles
     Specialized card for quiz content with CTA button
     WCAG AAA compliant with clear visual hierarchy
     ----------------------------------------------------------------------------- */

  .quiz-card__title {
    /* Layout */
    padding: var(--spacing-lg) var(--spacing-lg) 0;
    margin: 0;

    /* Typography */
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--heading-color);
    letter-spacing: var(--letter-spacing-tight);
  }

  .quiz-card__description {
    /* Line clamping for consistent card heights */
    display: -webkit-box;
    padding: var(--spacing-sm) var(--spacing-lg) var(--spacing-base);
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 3;

    /* Typography */
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--prose-color);

    /* Required for line clamping */
    -webkit-box-orient: vertical;
  }

  /* Call-to-action button */
  .quiz-card__cta {
    /* Layout */
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
    inline-size: fit-content;
    min-inline-size: 9.5rem;
    padding: var(--spacing-sm) var(--spacing-lg);

    /* Typography */
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);

    /* Visual styling */
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-lg);

    /* Smooth transitions */
    transition:
      transform var(--transition-base),
      background-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .quiz-card__image {
    background: color-mix(in srgb, var(--surface-2) 82%, transparent);
  }

  /* Hover state when parent card is interactive */
  :global(.card--interactive.card--elevated:hover) .quiz-card__cta,
  :global(.card--interactive.card--elevated:focus-visible) .quiz-card__cta {
    background: var(--accent-strong);
    box-shadow: var(--shadow-xl);
    transform: translateY(-1px);
  }

  /* Icon sizing */
  .quiz-card__cta-icon {
    inline-size: 0.95rem;
    block-size: 0.95rem;
  }

  /* Reduced motion support */
  @media screen and (prefers-reduced-motion: reduce) {
    .quiz-card__cta {
      transition: none;
    }

    :global(.card--interactive.card--elevated:hover) .quiz-card__cta,
    :global(.card--interactive.card--elevated:focus-visible) .quiz-card__cta {
      transform: none;
    }
  }
</style>
