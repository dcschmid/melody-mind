---
interface Props extends astroHTML.JSX.HTMLAttributes {
  href?: string;
  labelledBy: string;
  describedBy?: string;
  variant?: "default" | "elevated";
  dataTestId?: string;
  linkClassName?: string;
  mediaAspectRatio?: string;
  mediaObjectFit?: "cover" | "contain";
  class?: string;
  imageSrc?: string;
  imageAlt?: string;
  imageClassName?: string;
  imageWidth?: number | string;
  imageHeight?: number | string;
  imageLoading?: "eager" | "lazy";
  imageDecoding?: "sync" | "async" | "auto";
}

const {
  href,
  labelledBy,
  describedBy,
  variant = "default",
  dataTestId,
  linkClassName,
  mediaAspectRatio,
  mediaObjectFit = "cover",
  imageSrc,
  imageAlt = "",
  imageClassName,
  imageWidth,
  imageHeight,
  imageLoading = "lazy",
  imageDecoding = "async",
  class: className,
  ...rest
} = Astro.props as Props;

const hasSlottedMedia = Astro.slots.has("media");
const hasMedia = Boolean(imageSrc) || hasSlottedMedia;
const hasBadge = Astro.slots.has("badge");
const hasFooter = Astro.slots.has("footer");
const hasScreenReaderText = Astro.slots.has("sr");
const resolvedMediaAspectRatio =
  mediaAspectRatio ??
  (imageWidth && imageHeight ? `${imageWidth} / ${imageHeight}` : "3 / 2");
---

<article
  {...rest}
  class:list={["card", `card--${variant}`, href && "card--interactive", className]}
  data-testid={dataTestId}
  aria-labelledby={labelledBy}
  aria-describedby={describedBy}
>
  {
    href ? (
      <a
        href={href}
        class:list={["card__link", linkClassName]}
        aria-labelledby={labelledBy}
        aria-describedby={describedBy}
      >
        {hasMedia && (
          <div
            class:list={["card__media", `card__media--${mediaObjectFit}`]}
            style={`--card-media-aspect-ratio: ${resolvedMediaAspectRatio}; --card-media-object-fit: ${mediaObjectFit};`}
          >
            {imageSrc ? (
              <img
                src={imageSrc}
                alt={imageAlt}
                class:list={["card__media-image", imageClassName]}
                width={imageWidth}
                height={imageHeight}
                loading={imageLoading}
                decoding={imageDecoding}
              />
            ) : (
              <slot name="media" />
            )}
            {hasBadge && (
              <div class="card__badge">
                <slot name="badge" />
              </div>
            )}
          </div>
        )}

        <div class="card__body">
          <slot />
        </div>

        {hasFooter && (
          <div class="card__footer">
            <slot name="footer" />
          </div>
        )}
        {hasScreenReaderText && (
          <span class="card__sr">
            <slot name="sr" />
          </span>
        )}
      </a>
    ) : (
      <>
        {hasMedia && (
          <div
            class:list={["card__media", `card__media--${mediaObjectFit}`]}
            style={`--card-media-aspect-ratio: ${resolvedMediaAspectRatio}; --card-media-object-fit: ${mediaObjectFit};`}
          >
            {imageSrc ? (
              <img
                src={imageSrc}
                alt={imageAlt}
                class:list={["card__media-image", imageClassName]}
                width={imageWidth}
                height={imageHeight}
                loading={imageLoading}
                decoding={imageDecoding}
              />
            ) : (
              <slot name="media" />
            )}
            {hasBadge && (
              <div class="card__badge">
                <slot name="badge" />
              </div>
            )}
          </div>
        )}

        <div class="card__body">
          <slot />
        </div>

        {hasFooter && (
          <div class="card__footer">
            <slot name="footer" />
          </div>
        )}
      </>
    )
  }
</article>

<style>
  /* -----------------------------------------------------------------------------
     Card Component Styles
     Flexible card layout with media support, WCAG AAA compliance
     Supports default and elevated variants with hover interactions
     ----------------------------------------------------------------------------- */

  .card {
    /* Layout */
    position: relative;
    display: flex;
    flex-direction: column;
    block-size: 100%;

    /* Performance optimizations */
    contain-intrinsic-size: 360px;
    container-type: inline-size;
    content-visibility: auto;

    /* Visual styling */
    overflow: hidden;
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-base);
  }

  /* Default variant - standard card with border */
  @media screen and (prefers-reduced-motion: reduce) {
    .card--default {
      color: var(--text-primary);
      background: var(--card-bg);
      border: var(--card-border-width) solid var(--card-border-color);
      transition: none;
    }
  }

  .card--default {
    color: var(--text-primary);
    background: var(--card-bg);
    border: var(--card-border-width) solid var(--card-border-color);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  /* Elevated variant - gradient background with shadow */
  .card--elevated {
    background: linear-gradient(180deg, var(--surface-1) 0%, var(--surface-2) 100%);
    border: 1px solid var(--border-default);
    box-shadow:
      var(--shadow-lg),
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 18%, transparent);
    transition:
      transform var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  /* Card link wrapper - inherits color and fills card */
  .card__link {
    display: flex;
    flex: 1;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
  }

  /* Remove default outline, use parent card border */
  .card__link:focus-visible {
    outline: 2px solid transparent;
  }

  /* Focus state for default cards - accent border and inset shadow */
  .card--default:has(.card__link:focus-visible) {
    border-color: var(--accent-primary);
    box-shadow:
      inset 0 0 0 3px var(--accent-primary),
      var(--shadow-md);
  }

  .card--interactive.card--default:hover,
  .card--interactive.card--default:focus {
    border-color: color-mix(in srgb, var(--accent-primary) 28%, var(--border-default));
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  /* Focus state for elevated cards - enhanced shadow */
  .card--elevated:has(.card__link:focus-visible) {
    border-color: var(--accent-primary);
    box-shadow:
      inset 0 0 0 3px color-mix(in srgb, var(--accent-primary) 44%, transparent),
      var(--shadow-xl);
  }

  /* Interactive elevated card hover state */
  .card--interactive.card--elevated:hover,
  .card--interactive.card--elevated:focus-visible {
    border-color: color-mix(in srgb, var(--accent-primary) 36%, var(--border-default));
    box-shadow:
      var(--shadow-2xl),
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 24%, transparent);
    transform: translateY(-4px);
  }

  /* Media container - responsive aspect ratio */
  .card__media {
    position: relative;
    aspect-ratio: var(--card-media-aspect-ratio, 3 / 2);
    overflow: hidden;
    background: var(--surface-2);
  }

  /* Elevated card media - darker background with border */
  .card--elevated .card__media {
    background: var(--surface-3);
    border-block-end: 1px solid var(--border-muted);
  }

  /* Cover mode - image fills container */
  .card__media--cover :global(img),
  .card__media--cover .card__media-image,
  .card__media--cover :global(picture),
  .card__media--cover :global(svg) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
  }

  .card__media--cover :global(img),
  .card__media--cover .card__media-image,
  .card__media--cover :global(svg) {
    object-fit: cover;
  }

  /* Contain mode - image centered, maintains aspect ratio */
  .card__media--contain {
    display: grid;
    place-items: center;
  }

  .card__media--contain :global(picture) {
    display: block;
    inline-size: 100%;
  }

  .card__media--contain :global(img),
  .card__media--contain .card__media-image,
  .card__media--contain :global(svg) {
    display: block;
    inline-size: 100%;
    max-inline-size: 100%;
    block-size: auto;
    max-block-size: 100%;
    object-fit: contain;
  }

  /* Interactive card image zoom on hover */
  .card--interactive.card--elevated .card__media :global(img) {
    transition: transform var(--transition-slow);
  }

  .card--interactive.card--elevated:hover .card__media :global(img),
  .card--interactive.card--elevated:focus-visible .card__media :global(img) {
    transform: scale(1.03);
  }

  /* Badge positioning - bottom right corner */
  .card__badge {
    position: absolute;
    inset-block-end: var(--spacing-base);
    inset-inline-end: var(--spacing-base);
  }

  /* Card body - flexible content area */
  .card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  /* Card footer - consistent padding */
  .card__footer {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
  }

  /* Screen reader only text for accessibility */
  .card__sr {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: inset(50%);
  }

  /* Reduced motion support - disable animations */
  @media screen and (prefers-reduced-motion: reduce) {
    .card--elevated {
      transition: none;
    }

    .card--interactive.card--default:hover,
    .card--interactive.card--default:focus {
      transform: none;
    }

    .card--interactive.card--elevated .card__media :global(img) {
      transition: none;
    }

    .card--interactive.card--elevated:hover,
    .card--interactive.card--elevated:focus-visible {
      transform: none;
    }

    .card--interactive.card--elevated:hover .card__media :global(img),
    .card--interactive.card--elevated:focus-visible .card__media :global(img) {
      transform: none;
    }
  }

  /* Container query - responsive badge positioning */
  @container (max-width: 480px) {
    .card__badge {
      inset-block-end: var(--spacing-md);
      inset-inline-end: var(--spacing-md);
    }
  }
</style>
