---
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import type { RelatedContentCardItem } from "./relatedContent";

interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  copy?: string;
  listAriaLabel?: string;
  items: RelatedContentCardItem[];
  mediaObjectFit?: "cover" | "contain";
}

const {
  id = "related-content-section",
  eyebrow = "Related",
  title,
  copy,
  listAriaLabel = title,
  items = [],
  mediaObjectFit = "contain",
} = Astro.props as Props;

const titleId = `${id}-title`;
const defaultCoverImage = "/default-cover.jpg";
---

{
  items.length ? (
    <section class="related-content-section" aria-labelledby={titleId}>
      <Stack className="related-content-section__header" gap="base">
        <Stack className="related-content-section__copy-block" gap="xs">
          <p class="related-content-section__eyebrow">{eyebrow}</p>
          <Headline level="h2" textSize="2xl" className="related-content-section__title">
            <span id={titleId}>{title}</span>
          </Headline>
          {copy ? (
            <Paragraph textSize="base" className="related-content-section__copy">
              {copy}
            </Paragraph>
          ) : null}
        </Stack>
      </Stack>

      <AutoGrid
        as="ul"
        className="related-content-section__grid"
        preset="cards"
        gap="lg"
        ariaLabel={listAriaLabel}
      >
        {items.map((item) => (
          <li class="related-content-section__item">
            <ContentCard
              id={item.id}
              dataTestId="related-content-card"
              href={item.href}
              variant="default"
              size="compact"
              mediaObjectFit={mediaObjectFit}
              imageSrc={item.imageSrc || defaultCoverImage}
              imageAlt={
                item.imageAlt ?? (item.imageSrc ? `Cover image for ${item.title}` : "")
              }
              imageWidth={1024}
              imageHeight={683}
              title={item.title}
              description={item.description}
              metaItems={item.metaItems || []}
              descriptionLineClamp={3}
              ctaSrText={item.ctaSrText || "Opens content"}
            />
          </li>
        ))}
      </AutoGrid>
    </section>
  ) : null
}

<style>
  .related-content-section {
    display: grid;
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    padding-block: clamp(var(--spacing-lg), 2.5vw, var(--spacing-2xl));
    padding-inline: 0;
    margin-block-start: var(--spacing-xl);
    border-block-start: 1px solid var(--surface-border-accent);
  }

  .related-content-section__copy-block {
    max-inline-size: var(--measure-copy-compact);
  }

  .related-content-section__eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .related-content-section__title {
    margin: 0;
    font-size: var(--font-size-xl);
    line-height: 1.08;
    color: var(--text-primary);
  }

  .related-content-section__copy {
    max-inline-size: var(--measure-copy-narrow);
    margin: 0;
    font-size: var(--font-size-xs);
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .related-content-section__grid {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .related-content-section__item {
    min-inline-size: 0;
  }

  @media (width >= 50rem) {
    .related-content-section__header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }
  }

  @media (width < 40rem) {
    .related-content-section {
      gap: var(--spacing-lg);
    }

    .related-content-section__header {
      gap: var(--spacing-md);
    }
  }
</style>
