---
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import type { RelatedContentCardItem } from "./relatedContent";

interface Props {
  id?: string;
  title: string;
  copy?: string;
  listAriaLabel?: string;
  items: RelatedContentCardItem[];
  eyebrow?: string;
  linkHref?: string;
  linkLabel?: string;
}

const {
  id = "related-content-section",
  title,
  copy,
  listAriaLabel = title,
  items = [],
  eyebrow = "Continue reading",
  linkHref = "/",
  linkLabel = "View all articles",
} = Astro.props as Props;

const titleId = `${id}-title`;

// Security: Validate URL scheme, default to "/" for javascript: or data: URIs
const isExternalHref =
  typeof linkHref === "string" &&
  (linkHref.startsWith("http://") || linkHref.startsWith("https://"));
const safeHref =
  linkHref && typeof linkHref === "string" && !linkHref.match(/^\s*(javascript:|data:)/i)
    ? linkHref
    : "/";
const defaultCoverImage = "/default-cover.jpg";
---

{
  items.length ? (
    <section class="related-content-section" aria-labelledby={titleId}>
      <Stack className="related-content-section__header" gap="base">
        <Stack className="related-content-section__copy-block" gap="xs">
          <p class="related-content-section__eyebrow">{eyebrow}</p>
          <Headline level="h2" textSize="2xl" className="related-content-section__title">
            <span id={titleId}>{title}</span>
          </Headline>
          {copy ? (
            <Paragraph textSize="base" className="related-content-section__copy">
              {copy}
            </Paragraph>
          ) : null}
        </Stack>
        <a
          class="related-content-section__link"
          href={safeHref}
          {...(isExternalHref ? { rel: "noopener noreferrer", target: "_blank" } : {})}
        >
          {linkLabel} <span aria-hidden="true">→</span>
          {isExternalHref ? (
            <span class="related-content-section__sr">Opens in new tab</span>
          ) : null}
        </a>
      </Stack>

      <AutoGrid
        as="ul"
        className="related-content-section__grid"
        preset="cards"
        gap="lg"
        ariaLabel={listAriaLabel}
      >
        {items.map((item) => (
          <li class="related-content-section__item">
            <ContentCard
              id={item.id}
              dataTestId="related-content-card"
              href={item.href}
              variant="default"
              size="compact"
              mediaObjectFit="contain"
              imageSrc={item.imageSrc || defaultCoverImage}
              imageAlt={
                item.imageAlt ?? (item.imageSrc ? `Cover image for ${item.title}` : "")
              }
              imageWidth={1024}
              imageHeight={683}
              title={item.title}
              description={item.description}
              metaItems={item.metaItems || []}
              descriptionLineClamp={3}
              ctaSrText={item.ctaSrText || "Opens content"}
            />
          </li>
        ))}
      </AutoGrid>
    </section>
  ) : null
}

<style>
  .related-content-section {
    display: grid;
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    padding-block: clamp(var(--spacing-lg), 2.5vw, var(--spacing-2xl));
    padding-inline: 0;
    margin-block-start: var(--spacing-xl);
    border-block-start: 1px solid var(--surface-border-accent);
  }

  .related-content-section__copy-block {
    max-inline-size: var(--measure-copy-compact);
  }

  .related-content-section__eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .related-content-section__title {
    margin: 0;
    font-size: var(--font-size-xl);
    line-height: 1.08;
    color: var(--text-primary);
  }

  .related-content-section__copy {
    max-inline-size: var(--measure-copy-narrow);
    margin: 0;
    font-size: var(--font-size-xs);
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .related-content-section__link {
    display: inline-flex;
    gap: var(--spacing-xs);
    place-self: start;
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
    text-decoration: none;
    border-radius: var(--radius-base);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .related-content-section__link {
      transition: none;
    }
  }

  .related-content-section__link:hover,
  .related-content-section__link:focus-visible {
    color: var(--accent-strong);
    background-color: color-mix(in srgb, var(--accent-primary) 10%, transparent);
  }

  .related-content-section__link:active {
    color: var(--accent-strong);
    background-color: color-mix(in srgb, var(--accent-primary) 16%, transparent);
  }

  .related-content-section__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .related-content-section__grid {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .related-content-section__sr {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  .related-content-section__item {
    min-inline-size: 0;
    opacity: 0;
    animation: fade-in-up var(--motion-duration-base) var(--motion-ease-standard) both;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(var(--motion-distance-sm));
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .related-content-section__item {
      opacity: 1;
      animation: none;
    }
  }

  @media (width >= 50rem) {
    .related-content-section__header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .related-content-section__link {
      justify-self: end;
    }
  }

  @media (width < 40rem) {
    .related-content-section {
      gap: var(--spacing-lg);
    }

    .related-content-section__header {
      gap: var(--spacing-md);
    }
  }
</style>
