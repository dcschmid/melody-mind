---
import TaxonomyArticleGrid from "@shared-ui/components/taxonomy/TaxonomyArticleGrid.astro";
import TaxonomyBlockHeader from "@shared-ui/components/taxonomy/TaxonomyBlockHeader.astro";

interface Props {
  subsectionId: string;
  group: {
    id: string;
    title: string;
    description?: string;
    articleCount: number;
    articles: any[];
  };
}

const { subsectionId, group } = Astro.props as Props;
---

<div id={`${subsectionId}--${group.id}`} class="taxonomy-group-block">
  <div class="taxonomy-group-block__header">
    <TaxonomyBlockHeader
      wrapperClassName="taxonomy-group-block__info"
      titleClassName="taxonomy-group-block__title"
      level="h3"
      title={group.title}
      description={group.description}
      countLabel={`${group.articleCount} ${group.articleCount === 1 ? "article" : "articles"}`}
    />
  </div>

  <TaxonomyArticleGrid articles={group.articles} emptyDescription="No articles yet." />
</div>

<style>
  .taxonomy-group-block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    padding-block-start: var(--spacing-lg);
    scroll-margin-block-start: var(--spacing-3xl);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .taxonomy-group-block + .taxonomy-group-block {
    margin-block-start: var(--spacing-sm);
  }

  .taxonomy-group-block__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  @media (width >= 640px) {
    .taxonomy-group-block__header {
      flex-direction: row;
      gap: var(--spacing-base);
      align-items: flex-start;
    }
  }

  .taxonomy-group-block__info {
    flex: 1;
  }

  .taxonomy-group-block__title {
    color: var(--text-primary);
  }
</style>
