---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";

interface Props {
  id: string;
  title: string;
  description?: string;
  imageSrc?: ImageMetadata;
  imageAlt?: string;
}

const { id, title, description, imageSrc, imageAlt = title } = Astro.props as Props;
---

<div class="taxonomy-section-hero">
  <HeroTeaser
    id={`taxonomy-hero-${id}`}
    class="taxonomy-section-hero__teaser"
    {title}
    titleLevel="h1"
    description={description ||
      "Explore the connected topics and articles in this section."}
    mediaAspectRatio="4 / 3"
  >
    {
      imageSrc ? (
        <Fragment slot="media">
          <Image
            src={imageSrc}
            alt={imageAlt}
            loading="eager"
            class="taxonomy-section-hero__image"
            width={imageSrc.width}
            height={imageSrc.height}
          />
        </Fragment>
      ) : null
    }
  </HeroTeaser>
</div>

<style>
  .taxonomy-section-hero {
    padding-block-end: var(--spacing-xl);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .taxonomy-section-hero :global(.taxonomy-section-hero__teaser.hero-teaser) {
    border-color: var(--surface-border-soft);
    box-shadow: var(--shadow-lg);
  }

  .taxonomy-section-hero :global(.taxonomy-section-hero__teaser .hero-teaser__media) {
    border-color: var(--surface-border-soft);
    box-shadow: var(--shadow-md);
  }

  .taxonomy-section-hero
    :global(.taxonomy-section-hero__teaser .hero-teaser__description) {
    color: var(--text-secondary);
  }

  .taxonomy-section-hero__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }
</style>
