---
import type { ImageMetadata } from "astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";

interface TaxonomyArticleCardItem {
  id: string;
  title: string;
  description: string;
  href: string;
  imageSrc: ImageMetadata | string;
  imageAlt: string;
  readingTime?: number;
  createdAt?: Date | null;
}

interface Props {
  articles: TaxonomyArticleCardItem[];
  emptyDescription: string;
}

const { articles, emptyDescription } = Astro.props as Props;

const articleDateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

{
  articles.length > 0 ? (
    <ul class="taxonomy-article-grid">
      {articles.map((article, index) => {
        const createdAt = article.createdAt || new Date();

        return (
          <li class="taxonomy-article-grid__item">
            <ContentCard
              id={`card-title-${article.id}-${index}`}
              dataTestId="knowledge-card"
              data-title={article.title}
              data-description={article.description}
              href={article.href}
              variant="default"
              size="default"
              mediaObjectFit="contain"
              imageSrc={article.imageSrc}
              imageAlt={article.imageAlt}
              imageWidth={1024}
              imageHeight={683}
              title={article.title}
              description={article.description}
              metaItems={[
                {
                  iconName: "clock",
                  label: `${article.readingTime || 0} min read`,
                },
                {
                  iconName: "calendar",
                  label: articleDateFormatter.format(createdAt),
                  datetime: createdAt.toISOString(),
                },
              ]}
              ctaSrText="Opens article"
            />
          </li>
        );
      })}
    </ul>
  ) : (
    <EmptyState class="taxonomy-article-grid__empty" description={emptyDescription} />
  )
}

<style>
  .taxonomy-article-grid {
    display: grid;
    gap: var(--spacing-lg);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .taxonomy-article-grid__item {
    min-inline-size: 0;
  }

  @media (width >= 640px) {
    .taxonomy-article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1024px) {
    .taxonomy-article-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .taxonomy-article-grid__empty {
    padding: var(--spacing-lg) var(--spacing-base);
    text-align: left;
    background: color-mix(in srgb, var(--surface-panel-bg) 72%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    box-shadow: none;
  }
</style>
