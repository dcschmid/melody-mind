---
import Headline from "@shared-ui/components/typography/Headline.astro";

interface JumpTarget {
  anchorId: string;
  title: string;
  articleCount: number;
}

interface Props {
  targets: JumpTarget[];
  title?: string;
  navLabel?: string;
}

const { targets, title = "Jump to a topic", navLabel = "Jump to a topic" } = Astro.props;
---

{
  targets.length >= 1 && (
    <nav class="taxonomy-jump-nav" aria-label={navLabel}>
      <div class="taxonomy-jump-nav__panel">
        <div class="taxonomy-jump-nav__header">
          <Headline level="h2" textSize="xl" className="taxonomy-jump-nav__headline">
            {title}
          </Headline>
        </div>
        <div class="taxonomy-jump-nav__content">
          <ul class="taxonomy-jump-nav__list">
            {targets.map((target) => (
              <li class="taxonomy-jump-nav__item">
                <a href={`#${target.anchorId}`} class="taxonomy-jump-nav__link">
                  <span class="taxonomy-jump-nav__title">{target.title}</span>
                  <span
                    class="taxonomy-jump-nav__count"
                    aria-label={`${target.articleCount} articles`}
                  >
                    {target.articleCount}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </nav>
  )
}

<style>
  .taxonomy-jump-nav {
    position: relative;
    display: block;
  }

  .taxonomy-jump-nav__panel {
    display: grid;
    gap: var(--spacing-base);
    padding-block: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
  }

  .taxonomy-jump-nav__header {
    display: grid;
    gap: var(--spacing-sm);
  }

  .taxonomy-jump-nav__headline {
    margin: 0;
    color: var(--text-primary);
  }

  @media (width >= 40rem) {
    .taxonomy-jump-nav__header {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--spacing-lg);
      align-items: center;
      justify-content: space-between;
    }
  }

  .taxonomy-jump-nav__content {
    width: 100%;
    min-width: 0;
  }

  .taxonomy-jump-nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .taxonomy-jump-nav__item {
    margin: 0;
  }

  .taxonomy-jump-nav__link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) var(--spacing-sm);
    color: var(--text-primary);
    text-decoration: none;
    background: none;
    border: 1px solid var(--surface-border-subtle);
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  @media (prefers-reduced-motion: reduce) {
    .taxonomy-jump-nav__link {
      transition: none;
    }
  }

  .taxonomy-jump-nav__link:hover,
  .taxonomy-jump-nav__link:focus-visible {
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 5%, transparent);
    border-color: var(--surface-border-accent);
  }

  .taxonomy-jump-nav__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .taxonomy-jump-nav__count {
    flex-shrink: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-none);
    color: var(--text-tertiary);
  }

  @media (width < 40rem) {
    .taxonomy-jump-nav__list {
      display: grid;
      gap: var(--spacing-sm);
    }

    .taxonomy-jump-nav__link {
      display: flex;
      justify-content: space-between;
      padding: var(--spacing-md) var(--spacing-base);
      border-radius: var(--radius-lg);
    }

    .taxonomy-jump-nav__link:hover,
    .taxonomy-jump-nav__link:focus-visible {
      transform: none;
    }
  }
</style>
