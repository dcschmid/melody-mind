---
interface Props extends astroHTML.JSX.HTMLAttributes {
  title?: string;
  level?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  className?: string;
  class?: string;
  textSize?: "sm" | "base" | "lg" | "xl" | "2xl" | "3xl" | "4xl";
  textAlign?: "left" | "center" | "right";
}

const {
  title,
  level = "h1",
  className = "",
  class: classProp = "",
  textSize = "lg",
  textAlign = "left",
  ...rest
} = Astro.props as Props;

const Tag = level;

const textSizeClasses: Record<NonNullable<Props["textSize"]>, string> = {
  sm: "headline--size-sm",
  base: "headline--size-base",
  lg: "headline--size-lg",
  xl: "headline--size-xl",
  "2xl": "headline--size-2xl",
  "3xl": "headline--size-3xl",
  "4xl": "headline--size-4xl",
};

const textAlignClasses: Record<NonNullable<Props["textAlign"]>, string> = {
  left: "headline--align-left",
  center: "headline--align-center",
  right: "headline--align-right",
};

const classes = [
  "headline",
  textSizeClasses[textSize],
  textAlignClasses[textAlign],
  className,
  classProp,
]
  .filter(Boolean)
  .join(" ");
---

<Tag {...rest} class={classes}>{title || <slot />}</Tag>

<style>
  /* -----------------------------------------------------------------------------
     Headline Component Styles
     Semantic, responsive heading system with WCAG AAA compliance
     Supports multiple sizes and text alignment options
     ----------------------------------------------------------------------------- */

  .headline {
    /* Reset default margins */
    margin: 0;

    /* Typography - semantic tokens from design system */
    font-family: var(--font-sans);
    font-weight: var(--heading-font-weight);
    line-height: var(--heading-line-height);
    color: var(--heading-color);
    letter-spacing: var(--heading-letter-spacing);

    /* Improved text rendering */
    text-wrap: balance;
    overflow-wrap: break-word;
    text-rendering: optimizelegibility;
  }

  /* Small size - uses responsive typography scale */
  .headline--size-sm {
    font-size: var(--font-size-lg);
  }

  /* Base size - default size for h2/h3 */
  .headline--size-base {
    font-size: var(--font-size-xl);
  }

  /* Large size - section headings */
  .headline--size-lg {
    font-size: var(--font-size-2xl);
  }

  /* Extra large - page titles */
  .headline--size-xl {
    font-size: clamp(2.1rem, 1.7rem + 1.6vw, 3.25rem);
  }

  /* 2xl size - hero sections */
  .headline--size-2xl {
    font-size: clamp(2.4rem, 2rem + 1.8vw, 3.65rem);
  }

  /* 3xl size - major landing pages */
  .headline--size-3xl {
    font-size: clamp(2.75rem, 2.2rem + 2.4vw, 4.4rem);
  }

  /* 4xl size - hero headings, fully responsive */
  .headline--size-4xl {
    font-size: clamp(3rem, 2.3rem + 3.4vw, 5rem);
  }

  /* Text alignment options */
  .headline--align-left {
    text-align: start;
  }

  .headline--align-center {
    text-align: center;
  }

  .headline--align-right {
    text-align: end;
  }
</style>
