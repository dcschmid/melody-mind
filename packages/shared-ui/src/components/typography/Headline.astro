---
interface Props extends astroHTML.JSX.HTMLAttributes {
  title?: string;
  level: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  className?: string;
  class?: string;
  textSize?: "sm" | "base" | "lg" | "xl" | "2xl" | "3xl" | "4xl";
  textAlign?: "left" | "center" | "right";
}

const {
  title,
  level,
  className = "",
  class: classProp = "",
  textSize = "2xl",
  textAlign = "left",
  id,
  ...rest
} = Astro.props as Props;

const Tag = level;

const textSizeClasses: Record<NonNullable<Props["textSize"]>, string> = {
  sm: "headline--size-sm",
  base: "headline--size-base",
  lg: "headline--size-lg",
  xl: "headline--size-xl",
  "2xl": "headline--size-2xl",
  "3xl": "headline--size-3xl",
  "4xl": "headline--size-4xl",
};

const textAlignClasses: Record<NonNullable<Props["textAlign"]>, string> = {
  left: "headline--align-left",
  center: "headline--align-center",
  right: "headline--align-right",
};

const classes = [
  "headline",
  textSizeClasses[textSize],
  textAlignClasses[textAlign],
  className,
  classProp,
]
  .filter(Boolean)
  .join(" ");
---

<Tag id={id} {...rest} class={classes}>{title || <slot />}</Tag>

<style>
  /* -----------------------------------------------------------------------------
     Headline Component Styles
     Semantic, tokenized heading styles with explicit level and alignment options
     ----------------------------------------------------------------------------- */

  .headline {
    /* Reset default margins */
    margin: 0;

    /* Typography - semantic tokens from design system */
    font-family: var(--font-sans);
    font-weight: var(--heading-font-weight);
    line-height: var(--heading-line-height);
    color: var(--heading-color);
    letter-spacing: var(--heading-letter-spacing);

    /* Improved text rendering */
    text-wrap: balance;
    overflow-wrap: break-word;
    text-rendering: optimizelegibility;
  }

  /* Small size - compact headings */
  .headline--size-sm {
    font-size: var(--font-size-sm);
  }

  /* Base size - low-emphasis headings */
  .headline--size-base {
    font-size: var(--font-size-base);
  }

  /* Large size - compact section headings */
  .headline--size-lg {
    font-size: var(--font-size-lg);
  }

  /* Extra large - page titles */
  .headline--size-xl {
    font-size: var(--font-size-xl);
  }

  /* 2xl size - hero sections */
  .headline--size-2xl {
    font-size: var(--font-size-2xl);
  }

  /* 3xl size - major landing pages */
  .headline--size-3xl {
    font-size: var(--font-size-3xl);
  }

  /* 4xl size - hero headings, fully responsive */
  .headline--size-4xl {
    font-size: var(--font-size-4xl);
  }

  /* Text alignment options */
  .headline--align-left {
    text-align: start;
  }

  .headline--align-center {
    text-align: center;
  }

  .headline--align-right {
    text-align: end;
  }
</style>
