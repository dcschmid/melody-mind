---
/**
 * Shared reading progress bar with self-contained styles and client behavior.
 *
 * Progress persistence is optional. When `storageKey` is provided, the component
 * restores and saves progress using the slug stored on a companion DOM node.
 */
interface Props {
  className?: string;
  barClassName?: string;
  labelClassName?: string;
  barId?: string;
  labelId?: string;
  labelText?: string;
  progressDataId?: string;
  storageKey?: string;
}

const {
  className = "reading-progress",
  barClassName = "reading-progress__bar",
  labelClassName = "sr-only",
  barId,
  labelId,
  labelText = "Reading progress: 0 percent",
  progressDataId = "recent-read-data",
  storageKey = "",
} = Astro.props;

const instanceId = Math.random().toString(36).slice(2, 10);
const resolvedBarId = barId ?? `reading-progress-bar-${instanceId}`;
const resolvedLabelId = labelId ?? `reading-progress-label-${instanceId}`;
---

<div
  class={className}
  data-reading-progress="true"
  data-animate="soft-fade"
  data-progress-data-id={progressDataId}
  data-storage-key={storageKey}
>
  <div
    id={resolvedBarId}
    class={barClassName}
    role="progressbar"
    aria-label="Reading progress"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
    aria-valuetext={labelText}
    data-reading-progress-bar
  >
  </div>
  <span id={resolvedLabelId} class={labelClassName} data-reading-progress-label>
    {labelText}
  </span>
</div>

<script>
  import { safeLocalStorage } from "@shared-utils/utils/storage/safeStorage";

  const SAVE_THROTTLE_MS = 1000;
  const RESTORE_DELAY_MS = 200;
  const MIN_RESTORE_PROGRESS = 0.02;
  const MAX_RESTORE_PROGRESS = 0.95;
  const SCROLL_TOP_THRESHOLD = 4;

  document.querySelectorAll("[data-reading-progress='true']").forEach((root) => {
    if (!(root instanceof HTMLElement)) {
      return;
    }

    const bar = root.querySelector<HTMLElement>("[data-reading-progress-bar]");
    const label = root.querySelector<HTMLSpanElement>("[data-reading-progress-label]");

    if (!(bar instanceof HTMLElement) || !(label instanceof HTMLElement)) {
      return;
    }

    const progressDataId = root.dataset.progressDataId ?? "recent-read-data";
    const storageKey = root.dataset.storageKey ?? "";
    const progressData = document.getElementById(progressDataId);
    const progressSlug = (progressData?.dataset.slug ?? "").replace(/^\/+/, "");

    const prefersReduced =
      window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches ?? false;

    if (!prefersReduced) {
      bar.style.transition =
        "transform var(--motion-duration-fast) var(--motion-ease-standard)";
    }

    const getProgressStore = (): Record<
      string,
      { progress: number; updatedAt: string }
    > | null => {
      if (!progressSlug || !storageKey) {
        return null;
      }
      const parsed = safeLocalStorage.get<
        Record<string, { progress: number; updatedAt: string }>
      >(storageKey, {});
      return typeof parsed === "object" && parsed !== null ? parsed : null;
    };

    const setProgressStore = (
      store: Record<string, { progress: number; updatedAt: string }>
    ): void => {
      if (!progressSlug || !storageKey) {
        return;
      }
      safeLocalStorage.set(storageKey, store);
    };

    const restoreProgress = (): void => {
      if (!progressSlug || !storageKey) {
        return;
      }

      const store = getProgressStore();
      if (!store) {
        return;
      }

      const entry = store[progressSlug];
      const progress = entry?.progress;

      if (
        typeof progress !== "number" ||
        progress < MIN_RESTORE_PROGRESS ||
        progress > MAX_RESTORE_PROGRESS
      ) {
        return;
      }

      const doc = document.documentElement;
      const scrollable = doc.scrollHeight - doc.clientHeight;
      if (scrollable <= 0 || doc.scrollTop > SCROLL_TOP_THRESHOLD) {
        return;
      }

      window.scrollTo({
        top: Math.round(scrollable * progress),
        behavior: prefersReduced ? "auto" : "smooth",
      });
    };

    let ticking = false;
    let hasInteracted = false;
    let lastSavedAt = 0;

    const COMPLETE_DELAY_MS = 600;
    let hasCompleted = false;

    const celebrateCompletion = (): void => {
      if (hasCompleted) {
        return;
      }
      hasCompleted = true;
      root.classList.add("reading-progress--complete");
      setTimeout(() => {
        root.classList.remove("reading-progress--complete");
      }, COMPLETE_DELAY_MS);
    };

    const compute = (): void => {
      ticking = false;
      const doc = document.documentElement;
      const scrollable = doc.scrollHeight - doc.clientHeight;
      if (!scrollable) {
        bar.style.transform = "scaleX(0)";
        bar.setAttribute("aria-valuenow", "0");
        bar.setAttribute("aria-valuetext", "Reading progress: 0%");
        label.textContent = "Reading progress: 0%";
        return;
      }
      const raw = (doc.scrollTop / scrollable) * 100;
      const clamped = Math.min(Math.max(raw, 0), 100);
      const progressText = `Reading progress: ${clamped.toFixed(0)}%`;

      bar.style.transform = `scaleX(${clamped / 100})`;
      bar.setAttribute("aria-valuenow", clamped.toFixed(0));
      bar.setAttribute("aria-valuetext", progressText);
      label.textContent = progressText;

      if (clamped >= 99) {
        celebrateCompletion();
      } else if (clamped < 90) {
        hasCompleted = false;
      }

      if (progressSlug && storageKey && hasInteracted) {
        const now = Date.now();
        if (now - lastSavedAt > SAVE_THROTTLE_MS) {
          lastSavedAt = now;
          const store = getProgressStore() ?? {};

          if (clamped >= 98) {
            delete store[progressSlug];
          } else {
            store[progressSlug] = {
              progress: clamped / 100,
              updatedAt: new Date().toISOString(),
            };
          }
          setProgressStore(store);
        }
      }
    };

    const onScroll = (): void => {
      hasInteracted = true;
      if (ticking) {
        return;
      }
      ticking = true;
      requestAnimationFrame(compute);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    compute();

    const scheduleRestore = (): void => {
      window.setTimeout(() => {
        if (!hasInteracted) {
          restoreProgress();
        }
      }, RESTORE_DELAY_MS);
    };

    scheduleRestore();
    window.addEventListener("load", scheduleRestore, { once: true });
    window.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden" && hasInteracted) {
        compute();
      }
    });
  });
</script>

<style>
  .reading-progress {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 60;
    height: 0.25rem;
    background: color-mix(in srgb, var(--accent-muted) 24%, var(--surface-2));
  }

  .reading-progress::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background: var(--accent-primary);
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left center;
  }

  .reading-progress__bar {
    inline-size: 100%;
    height: 100%;
    background: var(--accent-primary);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    transform: scaleX(0);
    transform-origin: left center;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .reading-progress--complete::after {
      animation: none;
    }
  }

  .reading-progress--complete::after {
    animation: progress-complete var(--motion-duration-slow) var(--motion-ease-standard);
  }

  @keyframes progress-complete {
    0% {
      opacity: 0;
      transform: scaleX(0.92);
    }

    35% {
      opacity: 0.42;
      transform: scaleX(1);
    }

    100% {
      opacity: 0;
      transform: scaleX(1);
    }
  }

  @media (width >= 40rem) {
    .reading-progress {
      height: 0.375rem;
    }

    .reading-progress__bar {
      border-radius: 0 var(--radius-base) var(--radius-base) 0;
    }
  }

  @media (width >= 64rem) {
    .reading-progress {
      height: 0.5rem;
    }

    .reading-progress__bar {
      border-radius: 0 var(--radius-md) var(--radius-md) 0;
    }
  }

  @media print {
    .reading-progress {
      display: none;
    }
  }
</style>
