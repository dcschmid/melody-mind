---
import Icon from "@shared-ui/components/visual/Icon.astro";

/**
 * @component SkipLink
 * @description Accessibility component that allows keyboard users to bypass repetitive navigation
 * and quickly access the main content. Initially hidden visually but appears when focused.
 *
 * @example
 * ```astro
 * <SkipLink targetId="article-content" />
 * <SkipLink targetId="main-content" />
 * ```
 */
interface Props {
  /**
   * The ID of the element to target when the skip link is activated
   * @default "main-content"
   */
  targetId?: string;
  /**
   * Accessible label for the skip link
   * @default "Skip to main content"
   */
  label?: string;
}

const {
  targetId = "main-content",
  label = "Skip to main content",
} = Astro.props;

const sanitizedTargetId = targetId.replace(/[^a-zA-Z0-9_-]/g, "");
const href = `#${sanitizedTargetId || "main-content"}`;
const ariaLabel = label.trim() || "Skip to main content";
---
<a
  href={href}
  class="skip-link"
  data-skip-link
  aria-label={ariaLabel}
>
  <Icon name="chevron-down" class="skip-link__icon" aria-hidden="true" />
  {ariaLabel}
</a>
<style>
  /* SkipLink: WCAG AAA skip navigation, hidden until focused */
  .skip-link {
    position: absolute;
    inset-block-start: -9999px;
    inset-inline-start: 50%;
    z-index: 100;
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    min-inline-size: max-content;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) var(--spacing-base);
    font-weight: var(--font-weight-bold);
    color: var(--button-text-accent);
    text-decoration: none;
    background: var(--accent-primary);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transform: translateX(-50%);
    transition:
      inset-block-start 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      background-color var(--transition-fast);
  }

  .skip-link:focus-visible {
    inset-block-start: 0;
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .skip-link__icon {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
    margin-block-start: 0.5px;
    color: var(--accent-muted);
  }

  .skip-link:focus-visible .skip-link__icon {
    animation: skip-link-bounce 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .skip-link:hover,
  .skip-link:focus-visible {
    background: var(--accent-primary-hover);
  }

  .skip-link:active {
    transform: translateX(-50%) scale(0.97);
    transition: transform 0.1s;
  }

  @keyframes skip-link-bounce {
    0% {
      opacity: 0.6;
      transform: translateY(-4px);
    }

    60% {
      transform: translateY(2px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .skip-link {
      transition: none;
    }

    .skip-link:active {
      transform: translateX(-50%);
      transition: none;
    }

    .skip-link:focus-visible .skip-link__icon {
      animation: none;
    }
  }
</style>