---
import Icon from "@shared-ui/components/visual/Icon.astro";

/**
 * @component SkipLink
 * @description Accessibility component that allows keyboard users to bypass repetitive navigation
 * and quickly access the main content. Initially hidden visually but appears when focused.
 *
 * @example
 * ```astro
 * <SkipLink targetId="article-content" />
 * <SkipLink targetId="main-content" />
 * ```
 */
interface Props {
  /**
   * The ID of the element to target when the skip link is activated
   * @default "main-content"
   */
  targetId?: string;
  label?: string;
}

const { targetId = "main-content", label = "Skip to main content" } = Astro.props;

const skipLinkClasses = "skip-link";
const iconClasses = "skip-link__icon";
---

<a href={`#${targetId}`} class={skipLinkClasses} data-skip-link aria-label={label}>
  <Icon name="external-link" class={iconClasses} aria-hidden="true" />
  {label}
</a>
<style>
  .skip-link {
    position: absolute;
    inset-block-start: -9999px;
    inset-inline-start: 50%;
    z-index: 50;
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    padding: 0.5rem 1rem;
    font-weight: 700;
    color: var(--skip-link-text);
    text-decoration: none;
    background: var(--skip-link-bg);
    border-radius: 0 0 0.5rem 0.5rem;
    box-shadow: var(--skip-link-shadow);
    transform: translateX(-50%);
  }

  .skip-link:focus-visible {
    inset-block-start: 0;
    outline: 2px solid var(--skip-link-outline);
    outline-offset: 4px;
  }

  .skip-link__icon {
    inline-size: 1rem;
    block-size: 1rem;
  }
</style>
