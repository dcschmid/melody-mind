---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import type { ImageMetadata } from "astro";
import ThemeToggle from "@shared-ui/components/actions/ThemeToggle.astro";
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { AppShellNavItem } from "@shared-utils/utils/appShell";
import type { AppShellHeaderConfig } from "@shared-utils/utils/appShell";

type SiteHeaderConfig = AppShellHeaderConfig & {
  brandLogoSrc?: string | ImageMetadata;
};

interface Props {
  headerConfig?: SiteHeaderConfig;
  navItems?: AppShellNavItem[];
  showIcons?: boolean;
  showBrand?: boolean;
  brandHref?: string;
  brandText?: string;
  brandMark?: string;
  brandLogoSrc?: string | ImageMetadata;
  brandLogoAlt?: string;
  brandLogoWidth?: number;
  brandLogoHeight?: number;
  brandAriaLabel?: string;
  menuOpenLabel?: string;
  menuCloseLabel?: string;
  menuText?: string;
  navAriaLabel?: string;
}

const {
  headerConfig,
  navItems = [],
  showIcons = true,
  showBrand = true,
  brandHref = "/",
  brandText = "Melody Mind",
  brandMark = "MM",
  brandLogoSrc,
  brandLogoAlt = "",
  brandLogoWidth = 1024,
  brandLogoHeight = 683,
  brandAriaLabel = "Go to the homepage",
  menuOpenLabel = "Open main menu",
  menuCloseLabel = "Close main menu",
  menuText = "Menu",
  navAriaLabel = "Primary navigation",
} = Astro.props as Props;

const resolvedHeaderConfig = {
  navItems,
  showIcons,
  showBrand,
  brandHref,
  brandText,
  brandMark,
  brandLogoSrc,
  brandLogoAlt,
  brandLogoWidth,
  brandLogoHeight,
  brandAriaLabel,
  menuOpenLabel,
  menuCloseLabel,
  menuText,
  navAriaLabel,
  ...headerConfig,
};

const currentPath = Astro.url.pathname;
const hasBrandLogo = Boolean(resolvedHeaderConfig.brandLogoSrc);
const hasBrandText = resolvedHeaderConfig.brandText.trim().length > 0;
const navIdBase =
  `${resolvedHeaderConfig.navAriaLabel}-${currentPath}`
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-") || "site-header";
const navId = `${navIdBase}-nav`;
---

<header
  class:list={[
    "site-header",
    !resolvedHeaderConfig.showBrand && "site-header--brandless",
  ]}
  role="banner"
  data-site-header
  data-open="false"
>
  <button
    class="site-header__backdrop"
    aria-label="Close menu"
    data-site-header-backdrop
    tabindex="-1"></button>
  <div class="site-header__inner">
    {
      resolvedHeaderConfig.showBrand && (
        <a
          class:list={[
            "site-header__brand",
            !hasBrandText && "site-header__brand--logo-only",
          ]}
          href={resolvedHeaderConfig.brandHref}
          aria-label={resolvedHeaderConfig.brandAriaLabel}
        >
          {hasBrandLogo ? (
            <>
              <span class="site-header__brand-logo-wrap">
                <OptimizedImage
                  src={resolvedHeaderConfig.brandLogoSrc!}
                  class="site-header__brand-logo"
                  alt={resolvedHeaderConfig.brandLogoAlt}
                  width={resolvedHeaderConfig.brandLogoWidth}
                  height={resolvedHeaderConfig.brandLogoHeight}
                  loading="lazy"
                  decoding="async"
                />
              </span>
              {hasBrandText && (
                <span class="site-header__brand-text">
                  {resolvedHeaderConfig.brandText}
                </span>
              )}
            </>
          ) : (
            <>
              <span class="site-header__brand-mark" aria-hidden="true">
                {resolvedHeaderConfig.brandMark}
              </span>
              {hasBrandText && (
                <span class="site-header__brand-text">
                  {resolvedHeaderConfig.brandText}
                </span>
              )}
            </>
          )}
        </a>
      )
    }

    <button
      type="button"
      class="site-header__menu-toggle"
      aria-expanded="false"
      aria-controls={navId}
      aria-label={resolvedHeaderConfig.menuOpenLabel}
      data-site-header-toggle
      data-menu-open-label={resolvedHeaderConfig.menuOpenLabel}
      data-menu-close-label={resolvedHeaderConfig.menuCloseLabel}
    >
      <span class="site-header__menu-toggle-inner">
        <Icon name="menu" class="site-header__menu-icon" aria-hidden="true" />
        <span>{resolvedHeaderConfig.menuText}</span>
      </span>
    </button>

    {
      resolvedHeaderConfig.navItems.length > 0 && (
        <nav
          id={navId}
          class="site-header__nav"
          aria-label={resolvedHeaderConfig.navAriaLabel}
          data-site-header-nav
        >
          <ul class="site-header__nav-list">
            {resolvedHeaderConfig.navItems.map((item) => {
              const isExternal = /^https?:\/\//.test(item.href);
              const isActive = isExternal
                ? false
                : item.href === "/"
                  ? currentPath === "/"
                  : currentPath.startsWith(item.href);

              return (
                <li class="site-header__nav-item">
                  <AccessibleExternalLink
                    className="site-header__nav-link"
                    href={item.href}
                    target={item.target}
                    rel={item.rel}
                    aria-current={isActive ? "page" : undefined}
                  >
                    {resolvedHeaderConfig.showIcons && item.icon ? (
                      <Icon
                        name={item.icon}
                        class="site-header__nav-icon"
                        aria-hidden="true"
                      />
                    ) : null}
                    <span>{item.label}</span>
                  </AccessibleExternalLink>
                </li>
              );
            })}
          </ul>
          <div class="site-header__actions">
            <ThemeToggle />
          </div>
        </nav>
      )
    }
  </div>
</header>

<script>
  import { bindOverlayDisclosure } from "@shared-ui/scripts/interactive/overlayDisclosure";

  const headerRoots = Array.from(
    document.querySelectorAll<HTMLElement>("[data-site-header]")
  ).filter((root) => root.dataset.siteHeaderBound !== "true");

  headerRoots.forEach((header) => {
    header.dataset.siteHeaderBound = "true";
    const toggle = header.querySelector<HTMLButtonElement>("[data-site-header-toggle]");
    const nav = header.querySelector<HTMLElement>("[data-site-header-nav]");
    const backdrop = header.querySelector<HTMLButtonElement>(
      "[data-site-header-backdrop]"
    );
    if (!toggle || !nav) {
      return;
    }

    if (backdrop) {
      backdrop.addEventListener("click", () => {
        toggle.click();
      });
    }

    const mobileMedia = window.matchMedia("(max-width: 879.98px)");
    const openLabel = toggle.dataset.menuOpenLabel || "Open main menu";
    const closeLabel = toggle.dataset.menuCloseLabel || "Close main menu";

    bindOverlayDisclosure({
      root: header,
      toggle,
      panel: nav,
      mobileMedia,
      bodyClass: "site-header-menu-open",
      manageHidden: false,
      excludeFromOutsideLock: (element, root) =>
        element === root || element.contains(root),
      onOpenChange: (open) => {
        toggle.setAttribute("aria-label", open ? closeLabel : openLabel);
        nav.setAttribute("aria-hidden", open ? "false" : "true");
      },
      applyDesktopState: () => {
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", openLabel);
        header.dataset.open = "false";
        nav.removeAttribute("aria-hidden");
      },
      applyMobileClosedState: () => {
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", openLabel);
        header.dataset.open = "false";
        nav.setAttribute("aria-hidden", "true");
      },
      closeOnLinkSelector: "a[href]",
    });
  });
</script>

<style>
  :global(body.site-header-menu-open) {
    overflow: hidden;
  }

  .site-header {
    position: relative;
    z-index: 80;
    padding: max(env(safe-area-inset-top), 0px) var(--spacing-xs) 0;
    isolation: isolate;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-header__backdrop {
      position: fixed;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      padding: 0;
      appearance: none;
      pointer-events: none;
      cursor: default;
      background: color-mix(in srgb, var(--bg-primary) 56%, var(--text-primary));
      border: 0;
      opacity: 0;
      transition: none;
    }
  }

  .site-header__backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    appearance: none;
    pointer-events: none;
    cursor: default;
    background: color-mix(in srgb, var(--bg-primary) 56%, var(--text-primary));
    border: 0;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .site-header[data-open="true"] > .site-header__backdrop {
    pointer-events: auto;
    opacity: 0.72;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header::after {
      transition-duration: 0ms;
    }

    .site-header[data-open="true"] .site-header__menu-icon {
      transform: none;
    }
  }

  .site-header__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--spacing-2xs);
    align-items: center;
    max-inline-size: var(--page-shell-max-inline-wide);
    min-block-size: var(--site-header-height);
    padding: var(--spacing-xs);
    margin: var(--spacing-2xs) auto 0;
    background: var(--site-header-shell-bg);
    border-radius: var(--radius-xl);
  }

  .site-header--brandless .site-header__inner {
    grid-template-columns: auto;
    justify-content: end;
  }

  .site-header__brand {
    display: inline-flex;
    gap: var(--spacing-sm);
    place-self: center start;
    align-items: center;
    justify-content: center;
    min-inline-size: 0;
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    color: var(--text-primary);
    text-decoration: none;
    border-radius: var(--radius-lg);
  }

  .site-header__brand:hover,
  .site-header__brand:focus {
    transform: scale(1.04) translateY(-1px);
  }

  .site-header__brand:active {
    transform: scale(0.98);
  }

  .site-header__brand:focus-visible {
    transform: scale(1.04) translateY(-1px);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .site-header__brand:hover,
    .site-header__brand:focus-visible {
      transform: scale(1.04) translateY(-1px);
    }
  }

  .site-header__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: calc(var(--control-min-block-size) - var(--spacing-xs));
    block-size: calc(var(--control-min-block-size) - var(--spacing-xs));
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    letter-spacing: -0.02em;
    background: color-mix(
      in srgb,
      var(--accent-primary) 12%,
      var(--surface-panel-raised)
    );
    border: 1px solid color-mix(in srgb, var(--accent-primary) 28%, var(--border-default));
    border-radius: var(--radius-lg);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .site-header__brand-mark {
      transition:
        transform var(--transition-fast) cubic-bezier(0.34, 1.56, 0.64, 1),
        box-shadow var(--transition-fast) cubic-bezier(0.34, 1.56, 0.64, 1),
        background-color var(--transition-fast);
    }

    .site-header__brand:hover .site-header__brand-mark,
    .site-header__brand:focus .site-header__brand-mark {
      box-shadow:
        0 4px 12px color-mix(in srgb, var(--accent-primary) 22%, transparent),
        0 2px 4px color-mix(in srgb, var(--accent-primary) 14%, transparent);
      transform: translateY(-2px) scale(1.06);
    }

    .site-header__brand:active .site-header__brand-mark {
      box-shadow: none;
      transform: translateY(0) scale(1);
    }
  }

  .site-header__brand-logo-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: calc(var(--control-min-block-size) * 2.18);
    block-size: calc(var(--control-min-block-size) - (var(--control-padding-block) * 2));
  }

  .site-header__brand--logo-only .site-header__brand-logo-wrap {
    inline-size: clamp(
      calc(var(--control-min-block-size) * 2.18),
      28vw,
      calc(var(--control-min-block-size) * 2.64)
    );
    block-size: calc(var(--control-min-block-size) - (var(--control-padding-block) * 2));
  }

  .site-header__brand-logo {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: contain;
    object-position: center;
  }

  .site-header__brand-text {
    min-inline-size: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
  }

  .site-header__menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    font: inherit;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .site-header__menu-toggle:hover,
  .site-header__menu-toggle:focus {
    background: color-mix(in srgb, var(--accent-primary) 8%, var(--surface-panel-raised));
    border-color: var(--accent-primary);
    transform: scale(1.03);
  }

  .site-header__menu-toggle:active {
    transform: scale(0.97);
  }

  .site-header__menu-toggle-inner {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-header__menu-icon,
    .site-header__nav-icon {
      inline-size: var(--icon-size-sm);
      block-size: var(--icon-size-sm);
      transition: none;
    }
  }

  .site-header__menu-icon,
  .site-header__nav-icon {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .site-header__menu-icon,
    .site-header__nav-icon {
      transition: transform var(--transition-base) ease-out;
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-header__nav {
      position: absolute;
      inset-block-start: calc(100% + var(--spacing-2xs));
      inset-inline: 0;
      z-index: 5;
      visibility: hidden;
      gap: var(--spacing-sm);
      padding: var(--spacing-xs);
      background: var(--surface-1);
      border: 1px solid var(--surface-border-default);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xl);
      opacity: 0;
      transform: translateY(-6px) scale(0.97);
      transition: none;
    }
  }

  .site-header__nav {
    position: absolute;
    inset-block-start: calc(100% + var(--spacing-2xs));
    inset-inline: 0;
    z-index: 5;
    visibility: hidden;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs);
    background: var(--surface-1);
    border: 1px solid var(--surface-border-default);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    transition:
      visibility 0ms linear 300ms,
      opacity var(--transition-base) ease-out,
      transform var(--transition-base) ease-out;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-header[data-open="true"] .site-header__nav {
      visibility: visible;
      opacity: 1;
      transform: translateY(0) scale(1);
      transition: none;
    }
  }

  .site-header[data-open="true"] .site-header__nav {
    visibility: visible;
    opacity: 1;
    transform: translateY(0) scale(1);
    transition:
      visibility 0ms,
      opacity var(--transition-base) ease-out,
      transform var(--transition-base) ease-out;
  }

  .site-header[data-open="true"] .site-header__menu-icon {
    transform: rotate(0.5turn);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__nav {
      transform: none;
      transition-delay: 0ms;
      transition-duration: 0ms;
    }

    .site-header[data-open="true"] .site-header__nav {
      transition-duration: 0ms;
    }
  }

  .site-header__actions {
    display: flex;
    justify-content: flex-start;
  }

  .site-header__actions :global(.theme-toggle) {
    --theme-toggle-pill-bg: transparent;
    --theme-toggle-pill-border-color: transparent;
    --theme-toggle-pill-icon-size: calc(
      var(--control-min-block-size-compact) - var(--spacing-sm)
    );
    --theme-toggle-pill-hover-bg: color-mix(
      in srgb,
      var(--surface-panel-raised) 62%,
      transparent
    );
    --theme-toggle-pill-hover-border-color: color-mix(
      in srgb,
      var(--surface-border-soft) 70%,
      transparent
    );
    --theme-toggle-pill-focus-bg: color-mix(
      in srgb,
      var(--surface-panel-raised) 62%,
      transparent
    );
    --theme-toggle-pill-focus-border-color: color-mix(
      in srgb,
      var(--surface-border-soft) 70%,
      transparent
    );
  }

  @media (width >= 880px) {
    .site-header__actions :global(.theme-toggle) {
      --theme-toggle-pill-padding: calc(var(--spacing-xs) - 0.15rem);
    }
  }

  .site-header__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-header__nav-item {
    border-radius: var(--radius-md);
  }

  .site-header__nav-item:hover,
  .site-header__nav-item:focus {
    background: color-mix(in srgb, var(--accent-primary) 6%, transparent);
    border-radius: var(--radius-md);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-header__nav-link {
      display: inline-flex;
      gap: var(--spacing-sm);
      align-items: center;
      min-block-size: var(--control-min-block-size);
      padding: var(--spacing-sm) var(--spacing-sm);
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-medium);
      color: var(--text-primary);
      text-decoration: none;
      border-radius: var(--radius-md);
      transition: none;
    }
  }

  .site-header__nav-link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-header__nav-link:hover,
  .site-header__nav-link:focus {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-primary) 10%, transparent);
  }

  .site-header__nav-link:active {
    transform: translateX(2px);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .site-header__nav-link:hover,
    .site-header__nav-link:focus {
      transform: translateX(4px);
      transition:
        color var(--transition-fast),
        background-color var(--transition-fast),
        transform 280ms cubic-bezier(0.34, 1.2, 0.64, 1);
    }
  }

  @media (width >= 880px) {
    .site-header__nav-link:hover,
    .site-header__nav-link:focus {
      transform: none;
    }
  }

  .site-header__nav-link:focus-visible {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
    box-shadow: inset 0 -2px 0 color-mix(in srgb, var(--accent-strong) 70%, transparent);
  }

  .site-header__nav-link[aria-current="page"] {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
  }

  @media (width >= 880px) {
    .site-header__backdrop {
      display: none;
    }

    .site-header {
      padding-inline: var(--spacing-sm);
    }

    .site-header__inner {
      grid-template-columns: auto minmax(0, 1fr);
      gap: var(--spacing-xs);
      padding: var(--spacing-xs) var(--spacing-md);
      margin-top: var(--spacing-xs);
    }

    .site-header--brandless .site-header__inner {
      grid-template-columns: minmax(0, 1fr);
    }

    .site-header__menu-toggle {
      display: none;
    }

    .site-header__brand-logo-wrap {
      inline-size: calc(var(--control-min-block-size) * 2.36);
      block-size: calc(
        var(--control-min-block-size) - var(--spacing-sm) - var(--spacing-2xs)
      );
    }

    .site-header__brand--logo-only .site-header__brand-logo-wrap {
      inline-size: calc(var(--control-min-block-size) * 2.73);
      block-size: calc(var(--control-min-block-size) - var(--spacing-xs));
    }

    .site-header__nav {
      position: static;
      inset: auto;
      z-index: auto;
      display: flex;
      visibility: visible;
      grid-column: auto;
      gap: var(--spacing-md);
      align-items: center;
      justify-content: flex-end;
      padding-block: 0;
      padding-inline: 0;
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
      opacity: 1;
      transform: none;
    }

    .site-header__actions {
      flex-shrink: 0;
      margin-inline-start: var(--spacing-sm);
    }

    .site-header__nav-list {
      display: flex;
      flex-flow: row wrap;
      gap: var(--spacing-2xs);
      justify-content: flex-end;
    }

    .site-header__nav-link {
      min-block-size: var(--control-min-block-size);
      padding: var(--spacing-sm) var(--spacing-md);
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-medium);
      color: var(--text-primary);
      background: transparent;
      border-radius: var(--radius-md);
    }

    .site-header__nav-link:hover {
      color: var(--accent-strong);
      background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
    }

    .site-header__nav-link:focus {
      color: var(--accent-strong);
      background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
    }

    .site-header__nav-link:focus-visible {
      color: var(--accent-strong);
      background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
      box-shadow: inset 0 -2px 0 color-mix(in srgb, var(--accent-strong) 70%, transparent);
    }

    .site-header__nav-link[aria-current="page"] {
      background: transparent;
      box-shadow: inset 0 -2px 0 var(--accent-strong);
    }

