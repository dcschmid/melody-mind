---
import { Image, Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import ThemeToggle from "@shared-ui/components/actions/ThemeToggle.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { NavItem } from "@shared-ui/components/navigation/types";

interface Props {
  navItems?: NavItem[];
  showIcons?: boolean;
  brandHref?: string;
  brandText?: string;
  brandMark?: string;
  brandLogoSrc?: string | ImageMetadata;
  brandLogoAlt?: string;
  brandLogoWidth?: number;
  brandLogoHeight?: number;
  brandAriaLabel?: string;
  menuOpenLabel?: string;
  menuCloseLabel?: string;
  menuText?: string;
  navAriaLabel?: string;
}

const {
  navItems = [],
  showIcons = true,
  brandHref = "/",
  brandText = "Melody Mind",
  brandMark = "MM",
  brandLogoSrc,
  brandLogoAlt = "",
  brandLogoWidth = 1024,
  brandLogoHeight = 683,
  brandAriaLabel = "Go to the homepage",
  menuOpenLabel = "Open main menu",
  menuCloseLabel = "Close main menu",
  menuText = "Menu",
  navAriaLabel = "Primary navigation",
} = Astro.props as Props;

const currentPath = Astro.url.pathname;
const hasBrandLogo = Boolean(brandLogoSrc);
const importedBrandLogoSrc =
  brandLogoSrc && typeof brandLogoSrc !== "string" ? brandLogoSrc : undefined;
const stringBrandLogoSrc = typeof brandLogoSrc === "string" ? brandLogoSrc : undefined;
---

<header class="site-header" role="banner">
  <div class="site-header__inner">
    <a class="site-header__brand" href={brandHref} aria-label={brandAriaLabel}>
      {
        hasBrandLogo ? (
          <span class="site-header__brand-logo-wrap">
            {importedBrandLogoSrc ? (
              <Picture
                src={importedBrandLogoSrc}
                formats={["avif", "webp"]}
                class="site-header__brand-logo"
                alt={brandLogoAlt}
                width={brandLogoWidth}
                height={brandLogoHeight}
                loading="eager"
                decoding="async"
              />
            ) : stringBrandLogoSrc ? (
              <Image
                class="site-header__brand-logo"
                src={stringBrandLogoSrc}
                alt={brandLogoAlt}
                width={brandLogoWidth}
                height={brandLogoHeight}
                loading="eager"
                decoding="async"
              />
            ) : null}
          </span>
        ) : (
          <>
            <span class="site-header__brand-mark" aria-hidden="true">
              {brandMark}
            </span>
            <span class="site-header__brand-text">{brandText}</span>
          </>
        )
      }
    </a>

    <button
      type="button"
      class="site-header__menu-toggle"
      aria-expanded="false"
      aria-controls="site-primary-nav"
      aria-label={menuOpenLabel}
      data-menu-open-label={menuOpenLabel}
      data-menu-close-label={menuCloseLabel}
      data-site-header-toggle
    >
      <span class="site-header__menu-icon-wrap" aria-hidden="true">
        <Icon name="menu" class="site-header__menu-icon site-header__menu-icon--open" />
        <Icon name="x" class="site-header__menu-icon site-header__menu-icon--close" />
      </span>
      <span>{menuText}</span>
    </button>

    <nav id="site-primary-nav" class="site-header__nav" aria-label={navAriaLabel}>
      <div class="site-header__actions">
        <div class="site-header__theme-toggle">
          <ThemeToggle />
        </div>
      </div>
      <ul class="site-header__nav-list">
        {
          navItems.map((item) => {
            const isExternal = /^https?:\/\//.test(item.href);
            const isActive = isExternal
              ? false
              : item.href === "/"
                ? currentPath === "/"
                : currentPath.startsWith(item.href);

            return (
              <li>
                <a
                  class="site-header__nav-link"
                  href={item.href}
                  target={item.target}
                  rel={item.rel}
                  aria-current={isActive ? "page" : undefined}
                >
                  {showIcons && item.icon ? (
                    <Icon
                      name={item.icon}
                      class="site-header__nav-icon"
                      aria-hidden="true"
                    />
                  ) : null}
                  <span>{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
  <button
    type="button"
    class="site-header__scrim"
    aria-label="Close main menu"
    tabindex="-1"
    data-site-header-scrim></button>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-site-header-toggle]");
  const nav = document.getElementById("site-primary-nav");
  const scrim = document.querySelector<HTMLButtonElement>("[data-site-header-scrim]");
  const header = document.querySelector<HTMLElement>(".site-header");

  if (toggle && nav && header) {
    const desktopQuery = window.matchMedia("(min-width: 880px)");
    const getFocusableNavItems = (): HTMLElement[] =>
      Array.from(
        nav.querySelectorAll<HTMLElement>(
          "a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled])"
        )
      );
    let previousFocus: HTMLElement | null = null;

    const updateNavInteractivity = (open: boolean): void => {
      const isDesktop = desktopQuery.matches;
      nav.dataset.open = open ? "true" : "false";

      if (isDesktop) {
        nav.removeAttribute("aria-hidden");
        nav.inert = false;
        if (scrim) {
          scrim.hidden = true;
          scrim.setAttribute("aria-hidden", "true");
        }
        return;
      }

      const shouldHideNav = !open;
      nav.setAttribute("aria-hidden", shouldHideNav ? "true" : "false");
      nav.inert = shouldHideNav;
      if (scrim) {
        scrim.hidden = shouldHideNav;
        scrim.setAttribute("aria-hidden", shouldHideNav ? "true" : "false");
      }
    };

    const setOpen = (open: boolean, restoreFocus = true): void => {
      if (open) {
        previousFocus =
          document.activeElement instanceof HTMLElement ? document.activeElement : null;
      }

      header.dataset.open = open ? "true" : "false";
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      const openLabel = toggle.dataset.menuOpenLabel || "Open main menu";
      const closeLabel = toggle.dataset.menuCloseLabel || "Close main menu";
      toggle.setAttribute("aria-label", open ? closeLabel : openLabel);
      updateNavInteractivity(open);

      if (open) {
        window.requestAnimationFrame(() => {
          getFocusableNavItems()[0]?.focus();
        });
        return;
      }

      if (!restoreFocus) {
        return;
      }

      const activeElement = document.activeElement;
      const shouldRestoreFocus =
        activeElement instanceof HTMLElement &&
        (nav.contains(activeElement) || activeElement === scrim);

      if (!shouldRestoreFocus) {
        return;
      }

      if (previousFocus) {
        previousFocus.focus();
        return;
      }

      toggle.focus();
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    const handleDesktopChange = (event: MediaQueryListEvent): void => {
      if (event.matches) {
        setOpen(false);
        return;
      }
      updateNavInteractivity(toggle.getAttribute("aria-expanded") === "true");
    };

    const navLinks = Array.from(nav.querySelectorAll<HTMLAnchorElement>("a[href]"));
    navLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (!desktopQuery.matches) {
          setOpen(false);
        }
      });
    });

    scrim?.addEventListener("click", () => setOpen(false));

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setOpen(false);
        return;
      }

      if (event.key !== "Tab" || toggle.getAttribute("aria-expanded") !== "true") {
        return;
      }

      const focusable = [toggle, ...getFocusableNavItems()];
      if (!focusable.length) {
        return;
      }

      const activeElement = document.activeElement;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && activeElement === first) {
        event.preventDefault();
        last.focus();
        return;
      }

      if (!event.shiftKey && activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    setOpen(false, false);
    desktopQuery.addEventListener("change", handleDesktopChange);
  }

  document.addEventListener("keydown", (event) => {
    if (
      event.key !== "/" ||
      event.defaultPrevented ||
      event.metaKey ||
      event.ctrlKey ||
      event.altKey
    ) {
      return;
    }

    const activeElement = document.activeElement;
    if (
      activeElement instanceof HTMLInputElement ||
      activeElement instanceof HTMLTextAreaElement ||
      activeElement instanceof HTMLSelectElement ||
      activeElement?.getAttribute("contenteditable") === "true"
    ) {
      return;
    }

    event.preventDefault();
  });
</script>

<style>
  /* -----------------------------------------------------------------------------
     SiteHeader Component Styles
     Responsive navigation header with mobile menu
     WCAG AAA compliant with keyboard and screen reader support
     ----------------------------------------------------------------------------- */

  .site-header {
    position: relative;
    z-index: 50;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg-primary) 94%, transparent),
      color-mix(in srgb, var(--bg-primary) 98%, transparent)
    );
    border-block-end: 1px solid var(--border-default);
  }

  .site-header__inner {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: space-between;
    max-inline-size: 72rem;
    padding: var(--spacing-sm) var(--spacing-md);
    margin: 0 auto;
  }

  .site-header__inner > * {
    min-inline-size: 0;
  }

  @media (width >= 640px) {
    .site-header__inner {
      padding-inline: var(--spacing-lg);
    }
  }

  @media (width >= 1024px) {
    .site-header__inner {
      padding-inline: var(--spacing-xl);
    }
  }

  .site-header__brand {
    display: inline-flex;
    flex-shrink: 0;
    gap: var(--spacing-xs);
    align-items: center;
    max-inline-size: min(52vw, 14rem);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    text-decoration: none;
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-header__brand:hover,
  .site-header__brand:focus-visible {
    color: var(--accent-primary);
    box-shadow: var(--interactive-shadow-focus);
  }

  .site-header__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.2rem;
    block-size: 2.2rem;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    letter-spacing: 0.04em;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--surface-2) 92%, var(--bg-primary)),
      color-mix(in srgb, var(--surface-1) 96%, transparent)
    );
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-xs);
  }

  .site-header__brand-text {
    line-height: var(--line-height-tight);
  }

  .site-header__brand-logo-wrap {
    display: inline-flex;
    align-items: center;
    inline-size: 150px;
    max-inline-size: 100%;
    block-size: 4.5rem;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .site-header__brand-logo {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
  }

  .site-header__menu-toggle {
    position: relative;
    z-index: 70;
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    min-block-size: 48px;
    padding: var(--spacing-xs) var(--spacing-md);
    font: inherit;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--surface-2) 92%, var(--bg-primary)),
      color-mix(in srgb, var(--surface-1) 96%, transparent)
    );
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-header__menu-toggle:hover,
  .site-header__menu-toggle:focus-visible {
    background: color-mix(in srgb, var(--accent-primary) 10%, var(--surface-1));
    border-color: var(--accent-strong);
    box-shadow: var(--interactive-shadow-focus);
  }

  .site-header__menu-icon-wrap {
    position: relative;
    display: inline-grid;
    place-items: center;
    inline-size: 1rem;
    block-size: 1rem;
  }

  .site-header__menu-icon {
    position: absolute;
    inline-size: 1rem;
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-header__menu-icon--close {
    opacity: 0;
    transform: scale(0.8);
  }

  .site-header[data-open="true"] .site-header__menu-icon--open {
    opacity: 0;
    transform: scale(0.8);
  }

  .site-header[data-open="true"] .site-header__menu-icon--close {
    opacity: 1;
    transform: scale(1);
  }

  .site-header__nav {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    visibility: hidden;
    flex-direction: column;
    gap: var(--spacing-xl);
    align-items: center;
    inline-size: 100vw;
    block-size: 100dvh;
    min-block-size: 100dvh;
    padding: 5.5rem var(--spacing-lg) var(--spacing-xl);
    overflow-block: auto;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-2) 96%, var(--bg-primary) 4%),
      var(--bg-primary)
    );
    box-shadow: var(--shadow-xl);
    backdrop-filter: blur(16px);
    transform: translateX(100%);
    transition: transform var(--transition-fast);
  }

  .site-header__nav[data-open="true"],
  .site-header[data-open="true"] .site-header__nav {
    visibility: visible;
    pointer-events: auto;
    transform: translateX(0);
  }

  .site-header__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: flex-start;
    inline-size: min(100%, 24rem);
  }

  .site-header__theme-toggle :global(.theme-toggle) {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-block-size: 2.5rem;
    padding: var(--spacing-xs) var(--spacing-md);
    font: inherit;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--surface-2) 92%, var(--surface-1));
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-header__theme-toggle :global(.theme-toggle:hover),
  .site-header__theme-toggle :global(.theme-toggle:focus-visible) {
    background: color-mix(in srgb, var(--accent-primary) 10%, var(--surface-1));
    border-color: var(--accent-strong);
    box-shadow: var(--interactive-shadow-focus);
    transform: translateY(-1px);
  }

  .site-header__theme-toggle {
    display: flex;
    justify-content: flex-start;
  }

  .site-header__theme-toggle :global(.theme-toggle__pill) {
    border: 0;
    box-shadow: none;
  }

  .site-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    inline-size: min(100%, 24rem);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-header__nav-list > li {
    flex: 0 0 auto;
    min-inline-size: 0;
  }

  .site-header__nav-link {
    display: inline-flex;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: space-between;
    min-block-size: 48px;
    padding: var(--spacing-xs) var(--spacing-md);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--surface-2) 92%, var(--surface-1));
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-full);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-header__nav-link:hover,
  .site-header__nav-link:focus-visible {
    background: color-mix(in srgb, var(--accent-primary) 10%, var(--surface-1));
    border-color: var(--accent-strong);
    box-shadow: var(--interactive-shadow-focus);
  }

  .site-header__nav-icon {
    flex-shrink: 0;
    inline-size: 1rem;
    block-size: 1rem;
  }

  .site-header__nav-link[aria-current="page"] {
    border-color: var(--accent-strong);
    box-shadow:
      inset 0 0 0 1px var(--accent-strong),
      var(--interactive-shadow-focus);
  }

  .site-header__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 1.5rem;
    min-block-size: 1.5rem;
    padding: 0 var(--spacing-xs);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--button-text-accent);
  }

  .site-header__scrim {
    position: fixed;
    inset: 0;
    z-index: 55;
    pointer-events: none;
    background: var(--surface-scrim);
    border: 0;
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .site-header[data-open="true"] .site-header__scrim {
    pointer-events: auto;
    opacity: 1;
  }

  .site-header__brand:focus-visible,
  .site-header__menu-toggle:focus-visible,
  .site-header__nav-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .site-header[data-open="true"] .site-header__menu-toggle {
    position: fixed;
    inset-block-start: var(--spacing-sm);
    inset-inline-end: var(--spacing-lg);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__brand {
      transition: none !important;
      animation: none !important;
    }

    .site-header__menu-toggle {
      transition: none !important;
      animation: none !important;
    }

    .site-header__menu-icon {
      transition: none !important;
      animation: none !important;
    }

    .site-header__nav {
      transition: none !important;
      animation: none !important;
    }

    .site-header__theme-toggle :global(.theme-toggle) {
      transition: none !important;
      animation: none !important;
    }

    .site-header__nav-link {
      transition: none !important;
      animation: none !important;
    }

    .site-header__scrim {
      transition: none !important;
      animation: none !important;
    }
  }

  @media (width >= 880px) {
    .site-header__inner {
      gap: var(--spacing-lg);
      padding: var(--spacing-md) var(--spacing-xl);
    }

    .site-header {
      backdrop-filter: blur(14px);
    }

    .site-header__brand {
      max-inline-size: min(30vw, 17rem);
    }

    .site-header__menu-toggle {
      position: static;
      display: none;
    }

    .site-header__nav {
      position: static;
      inset: auto;
      visibility: visible;
      flex: 1;
      flex-direction: row;
      gap: var(--spacing-md);
      align-items: center;
      justify-content: flex-end;
      inline-size: auto;
      min-inline-size: 0;
      block-size: auto;
      min-block-size: 0;
      padding: 0;
      overflow: visible;
      pointer-events: auto;
      background: transparent;
      border: 0;
      transform: none;
    }

    .site-header__actions {
      display: inline-flex;
      flex-shrink: 0;
      gap: var(--spacing-md);
      align-items: center;
      justify-content: flex-end;
      order: 2;
    }

    .site-header__theme-toggle :global(.theme-toggle) {
      min-block-size: 2.35rem;
      padding: var(--spacing-xs) var(--spacing-md);
      font-size: var(--font-size-base);
    }

    .site-header__nav-list {
      display: inline-flex;
      flex-wrap: nowrap;
      gap: var(--spacing-md);
      align-items: center;
      justify-content: flex-end;
      order: 1;
    }

    .site-header__nav-link {
      min-block-size: 2.35rem;
      padding: var(--spacing-xs) var(--spacing-md);
      font-size: var(--font-size-base);
      background: color-mix(in srgb, var(--surface-2) 92%, var(--surface-1));
    }

    .site-header__scrim {
      display: none;
    }
  }
</style>
