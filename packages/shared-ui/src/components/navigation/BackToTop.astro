---
/**
 * @component BackToTop
 * @description Simple back-to-top button with accessibility support.
 */
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props {
  className?: string;
  ariaLabel?: string;
  scrollThreshold?: number;
}

const { className = "", ariaLabel, scrollThreshold } = Astro.props;
const safeThreshold =
  typeof scrollThreshold === "number" && scrollThreshold > 0 ? scrollThreshold : 300;
const buttonAriaLabel = ariaLabel?.trim() || "Back to top";
const screenReaderText = "Back to top";
---

<button
  id="back-to-top"
  class={`back-to-top ${className}`.trim()}
  aria-label={buttonAriaLabel}
  type="button"
  data-scroll-threshold={safeThreshold}
>
  <Icon name="arrow-up" class="back-to-top__icon" aria-hidden="true" />
  <span class="back-to-top__sr">{screenReaderText}</span>
</button>

<script>
  (function () {
    const button = document.getElementById("back-to-top");
    if (!button) {
      return;
    }

    const threshold = parseInt(button.dataset.scrollThreshold || "300", 10);
    let ticking = false;

    function showButton() {
      if (!button.classList.contains("is-visible")) {
        button.classList.add("is-visible");
        button.removeAttribute("aria-hidden");
      }
    }

    function hideButton() {
      if (button.classList.contains("is-visible")) {
        button.classList.remove("is-visible");
        button.setAttribute("aria-hidden", "true");
      }
    }

    function scrollToTop() {
      window.scrollTo({ top: 0, behavior: "smooth" });
      hideButton();
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          if (window.scrollY > threshold) {
            showButton();
          } else {
            hideButton();
          }
          ticking = false;
        });
        ticking = true;
      }
    }

    button.addEventListener("click", scrollToTop);
    window.addEventListener("scroll", onScroll, { passive: true });

    if (window.scrollY > threshold) {
      showButton();
    }
  })();
</script>
<style>
  /* -----------------------------------------------------------------------------
     BackToTop Button Component
     Fixed position scroll-to-top with accessibility support
     WCAG AAA compliant with 52px minimum touch target
     ----------------------------------------------------------------------------- */

  .back-to-top {
    position: fixed;
    inset-block-end: calc(var(--spacing-lg) + env(safe-area-inset-bottom, 0px));
    inset-inline-end: var(--spacing-lg);
    z-index: 30;
    visibility: hidden;

    /* WCAG AAA minimum touch target size */
    min-inline-size: var(--control-min-inline-size);
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm);
    color: var(--accent-primary);
    pointer-events: none;
    cursor: pointer;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
    opacity: 0;

    /* Smooth transitions */
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast),
      color var(--transition-fast),
      opacity var(--transition-fast),
      visibility var(--transition-fast);
  }

  /* Visible state - controlled by JS */
  .back-to-top.is-visible {
    visibility: visible;
    pointer-events: auto;
    opacity: 1;
  }

  /* Hover and focus states - enhanced visual feedback */
  .back-to-top:hover,
  .back-to-top:focus-visible {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-primary) 8%, var(--surface-1));
    border-color: var(--accent-primary);
    box-shadow: var(--interactive-shadow-focus);
    transform: scale(1.05);
  }

  /* Active/press state - satisfying tactile feedback */
  @media screen and (prefers-reduced-motion: reduce) {
    .back-to-top:active {
      box-shadow: var(--shadow-xs);
      transform: scale(0.96);
      transition: none;
    }
  }

  .back-to-top:active {
    box-shadow: var(--shadow-xs);
    transform: scale(0.96);
    transition:
      transform 80ms cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 80ms ease-out;
  }

  /* Focus visible state - WCAG AAA compliant */
  .back-to-top:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* Icon sizing - scales responsively */
  .back-to-top__icon {
    display: block;
    inline-size: var(--icon-size-lg);
    block-size: var(--icon-size-lg);
  }

  /* Larger icon on desktop for better visibility */
  @media (width >= 768px) {
    .back-to-top {
      inset-inline-end: calc(var(--spacing-xl) + env(safe-area-inset-right, 0px));
    }

    .back-to-top__icon {
      inline-size: calc(var(--icon-size-lg) + 0.25rem);
      block-size: calc(var(--icon-size-lg) + 0.25rem);
    }
  }

  /* Screen reader only text for accessibility */
  .back-to-top__sr {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      visibility: visible;
      opacity: 1;
      transition: none;
    }

    .back-to-top.is-visible {
      animation: none;
    }
  }
</style>
