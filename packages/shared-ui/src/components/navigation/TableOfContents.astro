---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
  className?: string;
  idBase?: string;
  defaultExpanded?: boolean;
  staticOnDesktop?: boolean;
}

const {
  headings = [],
  title,
  className = "",
  idBase = "toc",
  defaultExpanded = false,
  staticOnDesktop = false,
} = Astro.props as Props;
const filteredHeadings = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 4
);
const topLevelDepth = filteredHeadings.length
  ? Math.min(...filteredHeadings.map((heading) => heading.depth))
  : 2;
const tocTitle = title || "Table of contents";
const safeIdBase = idBase.replace(/[^a-zA-Z0-9_-]+/g, "-");
const toggleId = `${safeIdBase}-toggle`;
const contentId = `${safeIdBase}-content`;
---

<div
  class={`toc ${className}`.trim()}
  data-toc-root
  data-toc-id={safeIdBase}
  data-toc-default-expanded={defaultExpanded ? "true" : "false"}
  data-toc-static-desktop={staticOnDesktop ? "true" : "false"}
>
  <button
    id={toggleId}
    type="button"
    aria-expanded={defaultExpanded ? "true" : "false"}
    aria-controls={contentId}
    aria-label={tocTitle}
    class="toc__toggle"
    data-toc-toggle
  >
    <span class="toc__toggle-label">
      <Icon name="menu" class="toc__toggle-icon" aria-hidden="true" />
      <span>{tocTitle}</span>
    </span>
    <Icon name="chevron-down" class="toc__toggle-chevron" aria-hidden="true" />
  </button>

  <div
    id={contentId}
    aria-labelledby={toggleId}
    class="toc__content"
    data-toc-content
    hidden={!defaultExpanded}
  >
    <nav aria-label="Table of contents" class="toc__nav">
      <a href="#article-content" class="toc__skip">Skip to article content</a>
      <ul class="toc__list">
        {
          filteredHeadings.map((heading) => (
            <li
              class:list={[
                "toc__item",
                `toc__item--depth-${heading.depth}`,
                heading.depth > topLevelDepth && "toc__item--child",
              ]}
            >
              <a
                href={`#${heading.slug}`}
                class:list={[
                  "toc__link",
                  `toc__link--depth-${heading.depth}`,
                  heading.depth > topLevelDepth && "toc__link--child",
                ]}
              >
                <span class="toc__link-marker" aria-hidden="true" />
                <span class="toc__link-text">{heading.text}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  const tocRoots = Array.from(
    document.querySelectorAll<HTMLElement>("[data-toc-root]")
  ).filter((root) => root.dataset.tocBound !== "true");

  tocRoots.forEach((root) => {
    root.dataset.tocBound = "true";
    const controller = new AbortController();
    const { signal } = controller;
    const toggle = root.querySelector<HTMLButtonElement>("[data-toc-toggle]");
    const content = root.querySelector<HTMLElement>("[data-toc-content]");
    const list = root.querySelector<HTMLUListElement>(".toc__list");
    const defaultExpanded = root.dataset.tocDefaultExpanded === "true";
    const staticOnDesktop = root.dataset.tocStaticDesktop === "true";
    if (!toggle || !content) {
      return;
    }

    const buildListFromDom = () => {
      if (!list) {
        return;
      }

      const articleRoot =
        root.closest("main")?.querySelector<HTMLElement>("#article-content") ||
        document.querySelector<HTMLElement>("#article-content");
      if (!articleRoot) {
        return;
      }

      const articleHeadings = Array.from(
        articleRoot.querySelectorAll<HTMLElement>(":is(h2, h3, h4)")
      )
        .filter((heading) => Boolean(heading.id && heading.textContent?.trim()))
        .map((heading) => ({
          depth: Number.parseInt(heading.tagName.slice(1), 10),
          slug: heading.id,
          text: heading.textContent?.trim() || "",
        }));

      if (!articleHeadings.length) {
        return;
      }

      const topLevelDepth = Math.min(...articleHeadings.map((heading) => heading.depth));

      list.replaceChildren();

      articleHeadings.forEach((heading) => {
        const item = document.createElement("li");
        item.className = "toc__item";
        item.classList.add(`toc__item--depth-${heading.depth}`);
        if (heading.depth > topLevelDepth) {
          item.classList.add("toc__item--child");
        }

        const link = document.createElement("a");
        link.href = `#${heading.slug}`;
        link.className = "toc__link";
        link.classList.add(`toc__link--depth-${heading.depth}`);
        if (heading.depth > topLevelDepth) {
          link.classList.add("toc__link--child");
        }

        const marker = document.createElement("span");
        marker.className = "toc__link-marker";
        marker.setAttribute("aria-hidden", "true");

        const text = document.createElement("span");
        text.className = "toc__link-text";
        text.textContent = heading.text;

        link.append(marker, text);
        item.append(link);
        list.append(item);
      });
    };

    const setExpanded = (expanded: boolean) => {
      toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      content.hidden = !expanded;
      root.classList.toggle("toc--open", expanded);
    };

    const applyResponsiveMode = () => {
      const useDesktopStatic =
        staticOnDesktop && window.matchMedia("(min-width: 1024px)").matches;

      if (useDesktopStatic) {
        toggle.hidden = true;
        content.hidden = false;
        root.classList.add("toc--desktop-static", "toc--open");
        return;
      }

      toggle.hidden = false;
      root.classList.remove("toc--desktop-static");
      setExpanded(defaultExpanded);
    };

    applyResponsiveMode();
    window.addEventListener("resize", applyResponsiveMode, { signal });

    toggle.addEventListener(
      "click",
      () => {
        if (root.classList.contains("toc--desktop-static")) {
          return;
        }
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        if (!expanded) {
          buildListFromDom();
        }
        setExpanded(!expanded);
      },
      { signal }
    );

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", buildListFromDom, {
        once: true,
        signal,
      });
    } else {
      requestAnimationFrame(buildListFromDom);
    }

    window.addEventListener("pagehide", () => controller.abort(), {
      once: true,
      signal,
    });
  });
</script>

<style is:global>
  .toc[data-toc-root] {
    display: grid;
    gap: var(--spacing-xs);
  }

  .toc[data-toc-root] .toc__toggle {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: space-between;
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block-compact) var(--control-padding-inline-compact);
    font: inherit;
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-section-bg) 88%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .toc[data-toc-root] .toc__toggle-label {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .toc[data-toc-root] .toc__toggle-icon,
  .toc[data-toc-root] .toc__toggle-chevron {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .toc[data-toc-root] .toc__toggle-chevron {
    color: var(--text-secondary);
    transition: transform 160ms ease;
  }

  .toc[data-toc-root] .toc__content {
    display: grid;
    gap: var(--spacing-base);
    padding: var(--panel-padding-md);
    background: color-mix(in srgb, var(--surface-section-bg) 96%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-1) 16%, transparent);
  }

  .toc[data-toc-root] .toc__content[hidden] {
    display: none;
  }

  .toc[data-toc-root].toc--desktop-static .toc__content {
    display: grid;
  }

  .toc[data-toc-root] .toc__nav {
    display: grid;
    gap: var(--spacing-xs);
    max-block-size: min(28rem, calc(100vh - 11rem));
    overflow-y: auto;
    scrollbar-gutter: stable;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  .toc[data-toc-root] .toc__list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .toc[data-toc-root] .toc__skip {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  .toc[data-toc-root] .toc__item {
    min-inline-size: 0;
  }

  .toc[data-toc-root] .toc__link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: calc(var(--spacing-xs) + 0.1rem);
    align-items: center;
    min-block-size: calc(var(--control-min-block-size) - 0.25rem);
    padding: var(--spacing-xs) 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1.35;
    color: var(--text-primary);
    text-decoration: none;
    border-radius: var(--radius-md);
  }

  .toc[data-toc-root] .toc__link-marker {
    inline-size: 0.42rem;
    block-size: 0.42rem;
    background: color-mix(in srgb, var(--accent-primary) 78%, transparent);
    border-radius: var(--radius-full);
    opacity: 0.88;
  }

  .toc[data-toc-root] .toc__link-text {
    min-inline-size: 0;
    text-wrap: pretty;
    overflow-wrap: break-word;
  }

  .toc[data-toc-root] .toc__link--child {
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--spacing-sm);
    min-block-size: calc(var(--control-min-block-size-compact) - 0.15rem);
    padding-inline-start: calc(var(--spacing-lg) + 0.55rem);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--text-secondary);
  }

  .toc[data-toc-root] .toc__link--depth-2 {
    font-size: clamp(var(--font-size-sm), 0.35vw + 1rem, var(--font-size-base));
    font-weight: var(--font-weight-semibold);
  }

  .toc[data-toc-root] .toc__link--depth-3 {
    font-size: var(--font-size-sm);
  }

  .toc[data-toc-root] .toc__link--depth-4 {
    font-size: var(--font-size-xs);
    opacity: 0.92;
  }

  .toc[data-toc-root] .toc__item--child {
    position: relative;
  }

  .toc[data-toc-root] .toc__item--child::before {
    position: absolute;
    inset-block: 0.45rem;
    inset-inline-start: calc(var(--spacing-sm) + 0.18rem);
    inline-size: 1px;
    content: "";
    background: color-mix(in srgb, var(--surface-border-soft) 62%, transparent);
  }

  .toc[data-toc-root] .toc__link:hover,
  .toc[data-toc-root] .toc__link:focus-visible {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-1) 5%, transparent);
  }

  .toc[data-toc-root] .toc__link:hover .toc__link-marker,
  .toc[data-toc-root] .toc__link:focus-visible .toc__link-marker {
    transform: scale(1.15);
  }

  .toc[data-toc-root] .toc__toggle:focus-visible,
  .toc[data-toc-root] .toc__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .toc[data-toc-root] .toc__toggle:hover,
  .toc[data-toc-root] .toc__toggle:focus {
    background: color-mix(in srgb, var(--surface-section-bg) 90%, var(--accent-primary));
    border-color: color-mix(
      in srgb,
      var(--accent-primary) 22%,
      var(--surface-border-soft)
    );
  }

  .toc[data-toc-root].toc--open .toc__toggle-chevron {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .toc[data-toc-root] .toc__toggle {
      transition: none;
    }

    .toc[data-toc-root] .toc__toggle-chevron {
      transition: none;
    }

    .toc[data-toc-root] .toc__link-marker {
      transition: none;
    }
  }

  @media (width >= 48rem) {
    .toc[data-toc-root] .toc__content {
      padding: var(--panel-padding-sm);
    }

    .toc[data-toc-root] .toc__nav {
      max-block-size: min(30rem, calc(100vh - 12rem));
    }
  }

  @media (width < 40rem) {
    .toc[data-toc-root] .toc__toggle-label::after {
      inline-size: 100%;
      margin-inline-start: 0;
    }
  }
</style>
