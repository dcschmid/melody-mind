---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
  className?: string;
  idBase?: string;
}

const { headings = [], title, className = "", idBase = "toc" } = Astro.props as Props;
const filteredHeadings = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 4
);
const tocTitle = title || "Table of contents";
const safeIdBase = idBase.replace(/[^a-zA-Z0-9_-]+/g, "-");
const toggleId = `${safeIdBase}-toggle`;
const contentId = `${safeIdBase}-content`;
---

<div class={`toc ${className}`.trim()} data-toc-root data-toc-id={safeIdBase}>
  <button
    id={toggleId}
    type="button"
    aria-expanded="false"
    aria-controls={contentId}
    aria-label={tocTitle}
    class="toc__toggle"
    data-toc-toggle
  >
    <span class="toc__toggle-label">
      <Icon name="menu" class="toc__toggle-icon" aria-hidden="true" />
      <span>{tocTitle}</span>
    </span>
    <Icon name="chevron-down" class="toc__toggle-chevron" aria-hidden="true" />
  </button>

  <div
    id={contentId}
    aria-labelledby={toggleId}
    class="toc__content"
    data-toc-content
    hidden
  >
    <nav aria-label="Table of contents" class="toc__nav">
      <a href="#article-content" class="toc__skip">Skip to article content</a>
      <ul class="toc__list">
        {
          filteredHeadings.map((heading) => (
            <li class:list={["toc__item", heading.depth > 2 && "toc__item--child"]}>
              <a
                href={`#${heading.slug}`}
                class:list={["toc__link", heading.depth > 2 && "toc__link--child"]}
              >
                {heading.text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  const tocRoots = Array.from(
    document.querySelectorAll<HTMLElement>("[data-toc-root]")
  ).filter((root) => root.dataset.tocBound !== "true");

  tocRoots.forEach((root) => {
    root.dataset.tocBound = "true";
    const toggle = root.querySelector<HTMLButtonElement>("[data-toc-toggle]");
    const content = root.querySelector<HTMLElement>("[data-toc-content]");
    const list = root.querySelector<HTMLUListElement>(".toc__list");
    if (!toggle || !content) {
      return;
    }

    const buildListFromDom = () => {
      if (!list) {
        return;
      }

      const articleRoot =
        root.closest("main")?.querySelector<HTMLElement>("#article-content") ||
        document.querySelector<HTMLElement>("#article-content");
      if (!articleRoot) {
        return;
      }

      const articleHeadings = Array.from(
        articleRoot.querySelectorAll<HTMLElement>(":is(h2, h3, h4)")
      )
        .filter((heading) => Boolean(heading.id && heading.textContent?.trim()))
        .map((heading) => ({
          depth: Number.parseInt(heading.tagName.slice(1), 10),
          slug: heading.id,
          text: heading.textContent?.trim() || "",
        }));

      if (!articleHeadings.length) {
        return;
      }

      list.replaceChildren();

      articleHeadings.forEach((heading) => {
        const item = document.createElement("li");
        item.className = "toc__item";
        if (heading.depth > 2) {
          item.classList.add("toc__item--child");
        }

        const link = document.createElement("a");
        link.href = `#${heading.slug}`;
        link.className = "toc__link";
        if (heading.depth > 2) {
          link.classList.add("toc__link--child");
        }
        link.textContent = heading.text;

        item.append(link);
        list.append(item);
      });
    };

    const setExpanded = (expanded: boolean) => {
      toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      content.hidden = !expanded;
      root.classList.toggle("toc--open", expanded);
    };

    setExpanded(false);

    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      if (!expanded) {
        buildListFromDom();
      }
      setExpanded(!expanded);
    });

    content.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) {
        return;
      }

      const link = target.closest<HTMLAnchorElement>("a[href^='#']");
      if (link) {
        setExpanded(false);
      }
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", buildListFromDom, { once: true });
    } else {
      requestAnimationFrame(buildListFromDom);
    }
  });
</script>

<style is:global>
  .toc[data-toc-root] {
    display: grid;
    gap: var(--spacing-xs);
  }

  .toc[data-toc-root] .toc__toggle {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: space-between;
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    font: inherit;
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: none;
    border: 1px solid var(--surface-border-soft);
    background: var(--surface-section-bg);
    border-radius: var(--radius-lg);
    transition:
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .toc[data-toc-root] .toc__toggle-label {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .toc[data-toc-root] .toc__toggle-icon,
  .toc[data-toc-root] .toc__toggle-chevron {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .toc[data-toc-root] .toc__toggle-chevron {
    color: var(--text-secondary);
    transition: transform 160ms ease;
  }

  .toc[data-toc-root] .toc__content {
    padding: var(--spacing-sm);
    background: var(--surface-section-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .toc[data-toc-root] .toc__nav {
    display: grid;
    gap: var(--spacing-xs);
    max-block-size: min(24rem, calc(100vh - 11rem));
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    scrollbar-gutter: stable;
  }

  .toc[data-toc-root] .toc__list {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .toc[data-toc-root] .toc__skip,
  .toc[data-toc-root] .toc__link {
    display: flex;
    align-items: center;
    min-block-size: 2.75rem;
    padding: 0.625rem var(--spacing-sm);
    color: var(--text-primary);
    font-weight: var(--font-weight-medium);
    line-height: 1.35;
    text-decoration: none;
    border-radius: var(--radius-md);
  }

  .toc[data-toc-root] .toc__skip {
    margin-block-end: var(--spacing-2xs);
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
  }

  .toc[data-toc-root] .toc__link--child {
    min-block-size: 2.375rem;
    padding-inline-start: calc(var(--spacing-sm) + 1rem);
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
  }

  .toc[data-toc-root] .toc__item--child {
    position: relative;
  }

  .toc[data-toc-root] .toc__item--child::before {
    position: absolute;
    inset-block: 0.625rem 0.625rem;
    inset-inline-start: var(--spacing-sm);
    inline-size: 1px;
    content: "";
    background: var(--surface-border-soft);
  }

  .toc[data-toc-root] .toc__skip:hover,
  .toc[data-toc-root] .toc__skip:focus-visible,
  .toc[data-toc-root] .toc__link:hover,
  .toc[data-toc-root] .toc__link:focus-visible {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--accent-primary) 9%, transparent);
  }

  .toc[data-toc-root] .toc__toggle:focus-visible,
  .toc[data-toc-root] .toc__skip:focus-visible,
  .toc[data-toc-root] .toc__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .toc[data-toc-root] .toc__toggle:hover {
    background: color-mix(in srgb, var(--surface-section-bg) 82%, var(--accent-primary));
    border-color: var(--surface-border-medium);
  }

  .toc[data-toc-root].toc--open .toc__toggle-chevron {
    transform: rotate(180deg);
  }

  @media (min-width: 48rem) {
    .toc[data-toc-root] .toc__content {
      padding: var(--spacing-base);
    }

    .toc[data-toc-root] .toc__nav {
      max-block-size: min(26rem, calc(100vh - 12rem));
    }

    .toc[data-toc-root] .toc__link {
      min-block-size: 2.5rem;
      padding-inline: 0.875rem;
    }

    .toc[data-toc-root] .toc__link--child {
      padding-inline-start: calc(0.875rem + 1rem);
    }
  }
</style>
