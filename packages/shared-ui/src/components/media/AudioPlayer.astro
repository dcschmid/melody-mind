---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props {
  title: string;
  audioUrl: string;
  subtitleUrl?: string | undefined;
}

const { title, audioUrl, subtitleUrl } = Astro.props as Props;
const playerId = subtitleUrl ?? audioUrl;
const playerSlug =
  playerId.replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") || "audio";
const statusId = `episode-player-status-${playerSlug}`;
const progressId = `episode-player-progress-${playerSlug}`;
const timeId = `episode-player-time-${playerSlug}`;
---

<div
  class="episode-player"
  data-episode-player
  data-player-id={playerId}
  aria-label={`Audio player for ${title}`}
>
  <div class="episode-player__controls">
    <button
      class="episode-player__transport-button"
      type="button"
      data-action="rewind"
      aria-label="Go back 10 seconds"
      title="Go back 10 seconds"
    >
      <Icon
        name="tabler:arrow-back-up"
        class="episode-player__transport-icon"
        aria-hidden="true"
      />
    </button>
    <button
      class="episode-player__control"
      type="button"
      data-action="toggle"
      aria-label={`Play ${title}`}
      aria-pressed="false"
      aria-describedby={statusId}
    >
      <Icon
        name="tabler:player-play-filled"
        class="episode-player__control-icon episode-player__control-icon--play"
        aria-hidden="true"
      />
      <Icon
        name="tabler:player-pause-filled"
        class="episode-player__control-icon episode-player__control-icon--pause"
        aria-hidden="true"
      />
    </button>
    <button
      class="episode-player__retry"
      type="button"
      data-action="retry"
      aria-label="Retry loading audio"
      hidden
    >
      Retry
    </button>
    <button
      class="episode-player__transport-button"
      type="button"
      data-action="forward"
      aria-label="Skip forward 10 seconds"
      title="Skip forward 10 seconds"
    >
      <Icon
        name="tabler:arrow-forward-up"
        class="episode-player__transport-icon"
        aria-hidden="true"
      />
    </button>
  </div>

  <div class="episode-player__status" id={statusId} aria-live="polite" aria-atomic="true">
    {title}
  </div>

  <div class="episode-player__progress-wrap">
    <label class="episode-player__progress-label" for={progressId}
      >Playback progress</label
    >
    <input
      id={progressId}
      class="episode-player__progress"
      type="range"
      min="0"
      max="0"
      step="1"
      value="0"
      data-episode-progress
      aria-describedby={timeId}
    />
  </div>

  <div class="episode-player__meta">
    <span class="episode-player__time" id={timeId} aria-live="polite" aria-atomic="true"
      >0:00 / 0:00</span
    >
  </div>

  <audio
    class="episode-player__audio"
    preload="metadata"
    aria-label={`Audio playback for ${title}`}
    data-title={title}
    crossorigin=""
  >
    <source src={audioUrl} type="audio/mpeg" />
    <track
      kind="captions"
      src={subtitleUrl ?? undefined}
      srclang="en"
      label="English"
      default={Boolean(subtitleUrl)}
    />
    Your browser does not support audio playback.
  </audio>
  <script>
    import "@shared-ui/scripts/audio-player.ts";
  </script>
</div>

<style>
  .episode-player {
    display: grid;
    gap: var(--spacing-base);
    padding: var(--spacing-lg);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
  }

  .episode-player__controls {
    display: grid;
    grid-template-columns: auto auto auto auto;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
  }

  .episode-player__control,
  .episode-player__transport-button,
  .episode-player__retry {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: var(--control-min-inline-size);
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font: inherit;
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  .episode-player__control {
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .episode-player__control-icon--pause {
    display: none;
  }

  .episode-player__status,
  .episode-player__time {
    color: var(--text-secondary);
    text-align: center;
  }

  .episode-player__progress-wrap {
    display: grid;
    gap: var(--spacing-xs);
  }

  .episode-player__progress-label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .episode-player__progress {
    inline-size: 100%;
    accent-color: var(--accent-primary);
  }

  .episode-player__control:focus-visible,
  .episode-player__transport-button:focus-visible,
  .episode-player__retry:focus-visible,
  .episode-player__progress:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .episode-player__retry[hidden] {
    display: none;
  }

  @media (width < 480px) {
    .episode-player__controls {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
