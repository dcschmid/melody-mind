---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props {
  title: string;
  audioUrl: string;
  subtitleUrl?: string | undefined;
}

const { title, audioUrl, subtitleUrl } = Astro.props as Props;
const playerId = subtitleUrl ?? audioUrl;
const playerSlug =
  playerId.replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") || "audio";
const statusId = `episode-player-status-${playerSlug}`;
const progressId = `episode-player-progress-${playerSlug}`;
const timeId = `episode-player-time-${playerSlug}`;
---

<div
  class="episode-player"
  data-episode-player
  data-player-id={playerId}
  aria-label={`Audio player for ${title}`}
>
  <div class="episode-player__shell">
    <div class="episode-player__controls">
      <button
        class="episode-player__transport-button"
        type="button"
        data-action="rewind"
        aria-label="Go back 10 seconds"
        title="Go back 10 seconds"
      >
        <Icon
          name="tabler:arrow-back-up"
          class="episode-player__transport-icon"
          aria-hidden="true"
        />
      </button>
      <button
        class="episode-player__control"
        type="button"
        data-action="toggle"
        aria-label={`Play ${title}`}
        aria-pressed="false"
        aria-describedby={statusId}
      >
        <Icon
          name="tabler:player-play-filled"
          class="episode-player__control-icon episode-player__control-icon--play"
          aria-hidden="true"
        />
        <Icon
          name="tabler:player-pause-filled"
          class="episode-player__control-icon episode-player__control-icon--pause"
          aria-hidden="true"
        />
      </button>
      <button
        class="episode-player__retry"
        type="button"
        data-action="retry"
        aria-label="Retry loading audio"
        hidden
      >
        Retry
      </button>
      <button
        class="episode-player__transport-button"
        type="button"
        data-action="forward"
        aria-label="Skip forward 10 seconds"
        title="Skip forward 10 seconds"
      >
        <Icon
          name="tabler:arrow-forward-up"
          class="episode-player__transport-icon"
          aria-hidden="true"
        />
      </button>
    </div>

    <div class="episode-player__content">
      <div class="episode-player__header">
        <div class="episode-player__identity">
          <p class="episode-player__title">{title}</p>
          <div
            class="episode-player__status episode-player__status--sr-only"
            id={statusId}
            aria-live="polite"
            aria-atomic="true"
          >
            Ready to play
          </div>
        </div>
        <div class="episode-player__visualizer" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span
          ></span><span></span>
        </div>
      </div>

      <div class="episode-player__progress-wrap">
        <label class="episode-player__progress-label" for={progressId}
          >Playback progress</label
        >
        <input
          id={progressId}
          class="episode-player__progress"
          type="range"
          min="0"
          max="0"
          step="1"
          value="0"
          data-episode-progress
          aria-describedby={timeId}
        />
      </div>

      <div class="episode-player__meta" id={timeId} aria-live="polite" aria-atomic="true">
        <span class="episode-player__time episode-player__time--current">0:00</span>
        <span class="episode-player__time episode-player__time--remaining">-0:00</span>
      </div>
    </div>
  </div>

  <audio
    class="episode-player__audio"
    preload="metadata"
    aria-label={`Audio playback for ${title}`}
    data-title={title}
    crossorigin=""
  >
    <source src={audioUrl} type="audio/mpeg" />
    <track
      kind="captions"
      src={subtitleUrl ?? undefined}
      srclang="en"
      label="English"
      default={Boolean(subtitleUrl)}
    />
    Your browser does not support audio playback.
  </audio>
  <script>
    import "@shared-ui/scripts/audio-player.ts";
  </script>
</div>

<style>
  .episode-player {
    position: relative;
    padding: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    overflow: hidden;
    background:
      radial-gradient(
        circle at 100% 100%,
        color-mix(in srgb, var(--accent-primary) 10%, transparent),
        transparent 35%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 28%, transparent),
        color-mix(in srgb, var(--surface-1) 12%, transparent)
      ),
      var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 72%, transparent),
      var(--shadow-xl);
  }

  .episode-player__shell {
    display: grid;
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    align-items: center;
  }

  .episode-player__controls {
    display: flex;
    gap: var(--spacing-base);
    align-items: center;
    justify-content: center;
  }

  .episode-player__control,
  .episode-player__transport-button,
  .episode-player__retry {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: var(--control-min-inline-size);
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font: inherit;
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 60%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  .episode-player__control {
    min-inline-size: 6.25rem;
    min-block-size: 6.25rem;
    color: var(--button-text-accent);
    background: linear-gradient(
      135deg,
      var(--accent-primary),
      color-mix(in srgb, var(--accent-primary) 82%, var(--accent-strong))
    );
    border-color: color-mix(
      in srgb,
      var(--accent-primary) 72%,
      var(--surface-border-accent)
    );
    box-shadow:
      0 0 0 0.5rem color-mix(in srgb, var(--accent-primary) 10%, transparent),
      var(--shadow-lg);
  }

  .episode-player__control-icon {
    inline-size: 2rem;
    block-size: 2rem;
  }

  .episode-player__control-icon--pause {
    display: none;
  }

  .episode-player__content {
    display: grid;
    gap: var(--spacing-base);
    min-inline-size: 0;
  }

  .episode-player__header {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
    justify-content: space-between;
  }

  .episode-player__identity {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .episode-player__title {
    margin: 0;
    font-size: clamp(var(--font-size-lg), 1.2vw, var(--font-size-xl));
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    text-wrap: pretty;
  }

  .episode-player__status {
    font-size: var(--font-size-base);
    color: var(--accent-primary);
  }

  .episode-player__status--sr-only {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  .episode-player__visualizer {
    display: flex;
    flex-shrink: 0;
    gap: var(--spacing-sm);
    align-items: end;
    min-block-size: 2.5rem;
    padding-inline-end: var(--spacing-sm);
    opacity: 0.85;
  }

  .episode-player__visualizer > span {
    inline-size: 0.3rem;
    background: color-mix(in srgb, var(--accent-primary) 80%, var(--accent-strong));
    border-radius: var(--radius-full);
  }

  .episode-player__visualizer > span:nth-child(1) {
    block-size: 1.7rem;
  }

  .episode-player__visualizer > span:nth-child(2) {
    block-size: 1.95rem;
  }

  .episode-player__visualizer > span:nth-child(3) {
    block-size: 0.95rem;
  }

  .episode-player__visualizer > span:nth-child(4) {
    block-size: 1.35rem;
  }

  .episode-player__visualizer > span:nth-child(5) {
    block-size: 0.85rem;
  }

  .episode-player__visualizer > span:nth-child(6) {
    block-size: 2.3rem;
  }

  .episode-player__visualizer > span:nth-child(7) {
    block-size: 1.5rem;
  }

  .episode-player__progress-wrap {
    display: grid;
    gap: var(--spacing-xs);
  }

  .episode-player__progress-label {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  .episode-player__progress {
    inline-size: 100%;
    accent-color: var(--accent-primary);
  }

  .episode-player__meta {
    display: flex;
    gap: var(--spacing-base);
    align-items: center;
    justify-content: space-between;
  }

  .episode-player__time {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
  }

  .episode-player__control:focus-visible,
  .episode-player__transport-button:focus-visible,
  .episode-player__retry:focus-visible,
  .episode-player__progress:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .episode-player__control:hover,
  .episode-player__transport-button:hover,
  .episode-player__retry:hover,
  .episode-player__control:focus-visible,
  .episode-player__transport-button:focus-visible,
  .episode-player__retry:focus-visible {
    border-color: var(--surface-border-accent);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .episode-player__retry[hidden] {
    display: none;
  }

  @media (width >= 768px) {
    .episode-player__shell {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }

  @media (width < 480px) {
    .episode-player__controls {
      flex-wrap: wrap;
      justify-content: flex-start;
    }

    .episode-player__control {
      min-inline-size: 4.75rem;
      min-block-size: 4.75rem;
    }

    .episode-player__header {
      flex-wrap: wrap;
      align-items: start;
    }
  }
</style>
