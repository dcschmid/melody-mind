---
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  subtitleUrl?: string | undefined;
  podcastTitle: string;
  flushTop?: boolean;
}

const { subtitleUrl, podcastTitle, flushTop = false } = Astro.props as Props;
const transcriptSlug =
  (subtitleUrl || podcastTitle).replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") ||
  "transcript";
const transcriptTitleId = `transcript-title-${transcriptSlug}`;
const transcriptContentId = `transcript-content-${transcriptSlug}`;
---

{
  subtitleUrl ? (
    <section
      class:list={["transcript", flushTop && "transcript--flush-top"]}
      aria-labelledby={transcriptTitleId}
      data-subtitle-url={subtitleUrl}
      data-podcast-title={podcastTitle}
      data-player-id={subtitleUrl}
    >
      <details class="transcript__details">
        <summary class="transcript__summary" aria-controls={transcriptContentId}>
          <span class="transcript__summary-title" id={transcriptTitleId}>
            <Icon name="file-text" class="transcript__summary-icon" aria-hidden="true" />
            Transcript
          </span>
          <span class="transcript__summary-hint">
            <span class="transcript__summary-hint-text">Show transcript</span>
            <Icon
              name="tabler:chevron-down"
              class="transcript__summary-chevron"
              aria-hidden="true"
            />
          </span>
        </summary>
        <div class="transcript__body" id={transcriptContentId}>
          <Paragraph
            textSize="sm"
            className="transcript__status transcript__status--loading"
            role="status"
            aria-atomic="true"
            hidden
          >
            Loading transcript...
          </Paragraph>
          <Paragraph
            textSize="sm"
            className="transcript__status transcript__status--error"
            role="status"
            aria-atomic="true"
            hidden
          >
            Could not load the transcript.
          </Paragraph>
          <div class="transcript__content" hidden />
        </div>
      </details>
    </section>
  ) : null
}

<script>
  import "@shared-ui/scripts/transcript.ts";
</script>

<style>
  .transcript {
    margin-block-start: var(--spacing-xl);
    overflow: hidden;
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--surface-1) 20%, transparent),
        color-mix(in srgb, var(--accent-primary) 6%, transparent)
      ),
      var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .transcript--flush-top {
    margin-block-start: 0;
  }

  .transcript__summary {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: space-between;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-lg);
    cursor: pointer;
    list-style: none;
  }

  .transcript__summary::-webkit-details-marker {
    display: none;
  }

  .transcript__summary:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .transcript__summary-title {
    display: inline-flex;
    gap: var(--spacing-base);
    align-items: center;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .transcript__summary-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 3rem;
    block-size: 3rem;
    padding: var(--spacing-sm);
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface-1) 55%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-md);
  }

  .transcript__summary-hint,
  .transcript__status {
    color: var(--text-secondary);
  }

  .transcript__summary-hint {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .transcript__summary-hint-text {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  .transcript__summary-chevron {
    inline-size: 1.5rem;
    block-size: 1.5rem;
    transition: transform var(--transition-base);
  }

  .transcript__details[open] .transcript__summary-chevron {
    transform: rotate(180deg);
  }

  .transcript__body {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .transcript__summary-chevron {
      transition: none;
    }
  }

  .transcript__content {
    display: grid;
    gap: var(--spacing-sm);
    max-block-size: 24rem;
    overflow-block: auto;
  }

  .transcript__content :global(.transcript__cue) {
    display: grid;
    grid-template-columns: minmax(3.5rem, auto) 1fr;
    gap: var(--spacing-md);
    align-items: start;
    inline-size: 100%;
    padding: var(--spacing-base);
    margin: 0;
    font: inherit;
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
    text-align: start;
    appearance: none;
    cursor: pointer;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .transcript__content :global(.transcript__cue:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .transcript__content :global(.transcript__cue--active) {
    background: color-mix(in srgb, var(--accent-primary) 8%, var(--surface-1));
    border-color: var(--surface-border-accent);
  }

  .transcript__content :global(.transcript__time) {
    font-weight: var(--font-weight-semibold);
    font-variant-numeric: tabular-nums;
    color: var(--accent-primary);
    text-align: end;
  }

  @media (width < 640px) {
    .transcript__summary {
      flex-wrap: wrap;
      align-items: start;
      padding: var(--spacing-base);
    }

    .transcript__summary-hint {
      inline-size: auto;
    }

    .transcript__body {
      padding: 0 var(--spacing-base) var(--spacing-base);
    }

    .transcript__content :global(.transcript__cue) {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--spacing-sm);
    }
  }
</style>
