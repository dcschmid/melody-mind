---
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  subtitleUrl?: string | undefined;
  podcastTitle: string;
}

const { subtitleUrl, podcastTitle } = Astro.props as Props;
const transcriptSlug =
  (subtitleUrl || podcastTitle).replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") ||
  "transcript";
const transcriptTitleId = `transcript-title-${transcriptSlug}`;
const transcriptContentId = `transcript-content-${transcriptSlug}`;
---

{
  subtitleUrl && (
    <section
      class="transcript"
      aria-labelledby={transcriptTitleId}
      data-subtitle-url={subtitleUrl}
      data-podcast-title={podcastTitle}
      data-player-id={subtitleUrl}
    >
      <details class="transcript__details">
        <summary class="transcript__summary" aria-controls={transcriptContentId}>
          <span class="transcript__summary-title" id={transcriptTitleId}>
            <Icon name="file-text" class="transcript__summary-icon" aria-hidden="true" />
            Transcript
          </span>
          <span class="transcript__summary-hint">Show transcript</span>
        </summary>
        <div class="transcript__body" id={transcriptContentId}>
          <Paragraph
            textSize="sm"
            className="transcript__status transcript__status--loading"
            role="status"
            aria-atomic="true"
            hidden
          >
            Loading transcript...
          </Paragraph>
          <Paragraph
            textSize="sm"
            className="transcript__status transcript__status--error"
            role="status"
            aria-atomic="true"
            hidden
          >
            Could not load the transcript.
          </Paragraph>
          <div class="transcript__content" hidden />
        </div>
      </details>
    </section>
  )
}

<script>
  import "@shared-ui/scripts/transcript.ts";
</script>

<style>
  .transcript {
    margin-block-start: var(--spacing-xl);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 96%, transparent),
      color-mix(in srgb, var(--surface-2) 78%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--accent-primary) 28%, transparent);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .transcript__summary {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-base) var(--spacing-lg);
    cursor: pointer;
    list-style: none;
    background: color-mix(in srgb, var(--surface-1) 88%, var(--surface-2));
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .transcript__summary::-webkit-details-marker {
    display: none;
  }

  .transcript__summary:focus-visible {
    outline: none;
    border-radius: var(--radius-base);
    box-shadow: var(--interactive-shadow-focus);
  }

  .transcript__summary-title {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .transcript__summary-icon {
    flex: 0 0 auto;
    inline-size: 1rem;
    block-size: 1rem;
    color: var(--accent-primary);
  }

  .transcript__summary-hint {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  .transcript__body {
    padding: var(--spacing-base) var(--spacing-lg) var(--spacing-lg);
    border-block-start: 1px solid
      color-mix(in srgb, var(--border-default) 58%, transparent);
  }

  .transcript__status {
    margin: 0 0 var(--spacing-md);
    color: var(--text-secondary);
  }

  .transcript__status--error {
    color: var(--color-error);
  }

  .transcript__content {
    display: grid;
    gap: var(--spacing-md);
    max-block-size: 24rem;
    padding-inline-end: var(--spacing-xs);
    overflow-block: auto;
  }

  :global(.transcript .transcript__cue) {
    display: grid;
    grid-template-columns: minmax(3.5rem, auto) 1fr;
    gap: var(--spacing-md);
    align-items: start;
    inline-size: 100%;
    padding: var(--spacing-md) var(--spacing-base);
    margin: 0;
    font: inherit;
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
    text-align: start;
    appearance: none;
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 88%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--border-default) 58%, transparent);
    border-radius: var(--radius-md);
  }

  :global(.transcript .transcript__cue:focus-visible) {
    outline: none;
    box-shadow: var(--interactive-shadow-focus);
  }

  :global(.transcript .transcript__cue--active) {
    background: color-mix(in srgb, var(--accent-primary) 10%, var(--surface-1));
    border-color: color-mix(in srgb, var(--accent-primary) 42%, transparent);
  }

  :global(.transcript .transcript__time) {
    display: inline-block;
    min-inline-size: 3.5rem;
    font-weight: var(--font-weight-semibold);
    font-variant-numeric: tabular-nums;
    color: var(--accent-primary);
    text-align: end;
  }

  :global(.transcript .transcript__text) {
    color: var(--text-primary);
  }
</style>
