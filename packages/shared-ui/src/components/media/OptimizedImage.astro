---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props extends astroHTML.JSX.ImgHTMLAttributes {
  src: string | ImageMetadata;
  /**
   * Alt text for the image. Use an empty string only when the image is decorative.
   * Additional image attributes such as `aria-*`, `role`, `style`, and `data-*`
   * are forwarded to the rendered image.
   */
  alt: string;
  class?: string;
  width: number | `${number}`;
  height: number | `${number}`;
  sizes?: string;
  loading?: "eager" | "lazy";
  decoding?: "sync" | "async" | "auto";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  sizes,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
  ...imageAttributes
} = Astro.props as Props;

const importedImageSrc = typeof src !== "string" ? src : undefined;
const stringImageSrc = typeof src === "string" ? src : undefined;
const requestedWidth = Number(width);
const requestedHeight = Number(height);
const hasValidRequestedWidth = Number.isFinite(requestedWidth) && requestedWidth > 0;
const hasValidRequestedHeight = Number.isFinite(requestedHeight) && requestedHeight > 0;

const resolvedImportedDimensions = importedImageSrc
  ? (() => {
      const intrinsicWidth = importedImageSrc.width;
      const intrinsicHeight = importedImageSrc.height;

      if (hasValidRequestedWidth && hasValidRequestedHeight) {
        return {
          width: requestedWidth,
          height: requestedHeight,
        };
      }

      if (hasValidRequestedWidth) {
        return {
          width: requestedWidth,
          height: Math.round((requestedWidth * intrinsicHeight) / intrinsicWidth),
        };
      }

      if (hasValidRequestedHeight) {
        return {
          width: Math.round((requestedHeight * intrinsicWidth) / intrinsicHeight),
          height: requestedHeight,
        };
      }

      return {
        width: intrinsicWidth,
        height: intrinsicHeight,
      };
    })()
  : undefined;
---

{
  importedImageSrc ? (
    <Image
      src={importedImageSrc}
      alt={alt}
      class={className}
      width={resolvedImportedDimensions?.width ?? width}
      height={resolvedImportedDimensions?.height ?? height}
      sizes={sizes}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...imageAttributes}
    />
  ) : stringImageSrc ? (
    <Image
      src={stringImageSrc}
      alt={alt}
      class={className}
      width={width}
      height={height}
      sizes={sizes}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...imageAttributes}
    />
  ) : null
}
