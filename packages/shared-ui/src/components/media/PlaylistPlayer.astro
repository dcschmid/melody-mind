---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Song {
  title: string;
  audioUrl: string;
  lyricsUrl?: string;
  durationSeconds?: number;
  trackNumber: number;
}

interface Props {
  albumTitle: string;
  songs: Song[];
  lyricsUrlBase?: string;
}

const { albumTitle, songs, lyricsUrlBase } = Astro.props as Props;
const playerSlug =
  albumTitle.replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") || "playlist";
const playerId = `playlist-${playerSlug}`;
const statusId = `${playerId}-status`;
const progressId = `${playerId}-progress`;
const timeId = `${playerId}-time`;
---

<div
  class="playlist-player"
  data-playlist-player
  data-player-id={playerId}
  data-album-title={albumTitle}
  aria-label={`Playlist player for ${albumTitle}`}
>
  <div class="playlist-player__now-playing">
    <div class="playlist-player__now-playing-row">
      <div class="playlist-player__info">
        <p class="playlist-player__current-title" data-current-track-title>
          Ready to Play
        </p>
        <p class="playlist-player__album">{albumTitle}</p>
      </div>
      <div class="playlist-player__visualizer" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
    </div>

    <div class="playlist-player__controls">
      <button
        class="playlist-player__transport-button"
        type="button"
        data-action="prev"
        aria-label="Previous track"
        title="Previous track"
      >
        <Icon
          name="tabler:player-skip-back-filled"
          class="playlist-player__transport-icon"
          aria-hidden="true"
        />
      </button>
      <button
        class="playlist-player__control"
        type="button"
        data-action="toggle"
        aria-label="Play"
        aria-pressed="false"
      >
        <Icon
          name="tabler:player-play-filled"
          class="playlist-player__control-icon playlist-player__control-icon--play"
          aria-hidden="true"
        />
        <Icon
          name="tabler:player-pause-filled"
          class="playlist-player__control-icon playlist-player__control-icon--pause"
          aria-hidden="true"
        />
      </button>
      <button
        class="playlist-player__transport-button"
        type="button"
        data-action="next"
        aria-label="Next track"
        title="Next track"
      >
        <Icon
          name="tabler:player-skip-forward-filled"
          class="playlist-player__transport-icon"
          aria-hidden="true"
        />
      </button>
    </div>

    <div class="playlist-player__progress-wrap">
      <label class="sr-only" for={progressId}>Playback progress</label>
      <input
        id={progressId}
        class="playlist-player__progress"
        type="range"
        min="0"
        max="0"
        step="1"
        value="0"
        data-playlist-progress
        aria-label="Playback progress"
      />
      <div class="playlist-player__meta" id={timeId}>
        <span class="playlist-player__time" data-current-time>0:00</span>
        <span class="playlist-player__time" data-remaining-time>-0:00</span>
      </div>
    </div>
  </div>

  <div
    class="playlist-player__status playlist-player__status--sr-only"
    id={statusId}
    aria-live="polite"
    aria-atomic="true"
  >
    Ready to play
  </div>

  <div class="playlist-player__tracklist-section">
    <div class="playlist-player__tracklist-header">
      <span class="playlist-player__col playlist-player__col--num">#</span>
      <span class="playlist-player__col playlist-player__col--title">Title</span>
      <span class="playlist-player__col playlist-player__col--duration">
        <Icon name="tabler:clock" class="playlist-player__col-icon" aria-hidden="true" />
      </span>
    </div>

    <ol class="playlist-player__tracklist" role="list">
      {
        songs.map((song, index) => (
          <li
            class="playlist-player__track"
            data-track-index={index}
            data-track-title={song.title}
            data-track-url={song.audioUrl}
            data-track-lyrics={
              song.lyricsUrl ||
              (lyricsUrlBase
                ? `${lyricsUrlBase}/${String(index + 1).padStart(2, "0")}-${song.title.toLowerCase().replace(/\s+/g, "-")}.txt`
                : undefined)
            }
            data-track-duration={song.durationSeconds}
            data-track-number={song.trackNumber}
            role="button"
            tabindex="0"
          >
            <span class="playlist-player__track-num">
              <span class="playlist-player__track-num-text">{song.trackNumber}</span>
              <Icon
                name="tabler:player-play-filled"
                class="playlist-player__track-play-icon"
                aria-hidden="true"
              />
            </span>
            <span class="playlist-player__track-title">{song.title}</span>
            <span class="playlist-player__track-duration">
              {song.durationSeconds
                ? `${Math.floor(song.durationSeconds / 60)}:${String(song.durationSeconds % 60).padStart(2, "0")}`
                : ""}
            </span>
            <a
              class="playlist-player__track-download"
              href={song.audioUrl}
              download={song.title}
              aria-label={`Download ${song.title}`}
              title="Download track"
            >
              <Icon
                name="download"
                class="playlist-player__track-download-icon"
                aria-hidden="true"
              />
            </a>
          </li>
        ))
      }
    </ol>
  </div>

  <audio
    class="playlist-player__audio"
    preload="metadata"
    crossorigin=""
    data-playlist-audio
  >
    <source src={songs[0]?.audioUrl || ""} type="audio/mpeg" />
    Your browser does not support audio playback.
  </audio>

  <script>
    import "@shared-ui/scripts/playlist-player.ts";
  </script>
</div>

<style>
  .playlist-player {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        ellipse at 70% 0%,
        color-mix(in srgb, var(--accent-primary) 6%, transparent),
        transparent 60%
      ),
      var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 40%, transparent),
      var(--shadow-lg);
  }

  /* ── Now-playing area ── */
  .playlist-player__now-playing {
    display: grid;
    gap: var(--spacing-lg);
    padding: var(--spacing-xl) var(--spacing-lg);
    text-align: center;
  }

  .playlist-player__now-playing-row {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: space-between;
  }

  .playlist-player__info {
    display: grid;
    gap: 0.125rem;
    min-inline-size: 0;
    text-align: start;
  }

  .playlist-player__current-title {
    margin: 0;
    overflow: hidden;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: 1.3;
    color: var(--text-primary);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .playlist-player__album {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Visualizer ── */
  .playlist-player__visualizer {
    display: flex;
    flex-shrink: 0;
    gap: 0.2rem;
    align-items: end;
    block-size: 1.5rem;
    opacity: 0.65;
  }

  .playlist-player__visualizer > span {
    inline-size: 0.2rem;
    background: var(--accent-primary);
    border-radius: var(--radius-full);
  }

  .playlist-player__visualizer > span:nth-child(1) {
    block-size: 1rem;
  }
  .playlist-player__visualizer > span:nth-child(2) {
    block-size: 0.65rem;
  }
  .playlist-player__visualizer > span:nth-child(3) {
    block-size: 1.4rem;
  }
  .playlist-player__visualizer > span:nth-child(4) {
    block-size: 0.85rem;
  }
  .playlist-player__visualizer > span:nth-child(5) {
    block-size: 0.5rem;
  }

  /* ── Transport controls ── */
  .playlist-player__controls {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
    justify-content: center;
  }

  .playlist-player__control,
  .playlist-player__transport-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    font: inherit;
    color: var(--text-primary);
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 45%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }

  .playlist-player__transport-button {
    inline-size: 2.5rem;
    block-size: 2.5rem;
  }

  .playlist-player__control {
    inline-size: 3.25rem;
    block-size: 3.25rem;
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: transparent;
    box-shadow: 0 0 0 0.35rem color-mix(in srgb, var(--accent-primary) 12%, transparent);
  }

  .playlist-player__control:hover,
  .playlist-player__transport-button:hover {
    transform: scale(1.08);
  }

  .playlist-player__control:active,
  .playlist-player__transport-button:active {
    transform: scale(0.95);
  }

  .playlist-player__control-icon {
    inline-size: 1.25rem;
    block-size: 1.25rem;
  }

  .playlist-player__control-icon--pause {
    display: none;
  }

  :global([data-player-state="playing"]) .playlist-player__control-icon--play {
    display: none;
  }

  :global([data-player-state="playing"]) .playlist-player__control-icon--pause {
    display: block;
  }

  .playlist-player__transport-icon {
    inline-size: 1rem;
    block-size: 1rem;
  }

  /* ── Progress ── */
  .playlist-player__progress-wrap {
    display: grid;
    gap: var(--spacing-xs);
  }

  .playlist-player__progress {
    inline-size: 100%;
    block-size: 0.25rem;
    accent-color: var(--accent-primary);
    cursor: pointer;
    appearance: auto;
  }

  .playlist-player__meta {
    display: flex;
    justify-content: space-between;
  }

  .playlist-player__time {
    font-size: 0.6875rem;
    font-weight: var(--font-weight-medium);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
  }

  /* ── SR-only status ── */
  .playlist-player__status--sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  /* ── Tracklist ── */
  .playlist-player__tracklist-section {
    padding: var(--spacing-base) var(--spacing-base) var(--spacing-lg);
    background: color-mix(in srgb, var(--surface-1) 20%, transparent);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .playlist-player__tracklist-header {
    display: grid;
    grid-template-columns: 2rem 1fr 3rem 2.5rem;
    gap: var(--spacing-sm);
    align-items: center;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-block-end: 1px solid
      color-mix(in srgb, var(--surface-border-soft) 60%, transparent);
    margin-block-end: 0.125rem;
    font-size: 0.625rem;
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .playlist-player__col--num {
    text-align: center;
  }

  .playlist-player__col--duration {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .playlist-player__col-icon {
    inline-size: 0.75rem;
    block-size: 0.75rem;
  }

  .playlist-player__tracklist {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
    max-block-size: min(55vh, 26rem);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* ── Track row ── */
  .playlist-player__track {
    display: grid;
    grid-template-columns: 2rem 1fr 3rem 2.5rem;
    gap: var(--spacing-sm);
    align-items: center;
    min-block-size: 2.75rem;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color 0.12s ease;
  }

  .playlist-player__track:hover {
    background-color: color-mix(in srgb, var(--surface-1) 55%, transparent);
  }

  .playlist-player__track[data-is-playing="true"] {
    background-color: color-mix(in srgb, var(--accent-primary) 14%, transparent);
  }

  .playlist-player__track[data-is-playing="true"] .playlist-player__track-title {
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
  }

  .playlist-player__track-num {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-xs);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
  }

  .playlist-player__track-play-icon {
    position: absolute;
    inset: 0;
    display: none;
    margin: auto;
    inline-size: 0.875rem;
    block-size: 0.875rem;
    color: var(--accent-primary);
  }

  .playlist-player__track[data-is-playing="true"] .playlist-player__track-num-text {
    display: none;
  }

  .playlist-player__track[data-is-playing="true"] .playlist-player__track-play-icon {
    display: flex;
  }

  .playlist-player__track-title {
    overflow: hidden;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .playlist-player__track-duration {
    font-size: var(--font-size-xs);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
    text-align: end;
  }

  .playlist-player__track-download {
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: 1.75rem;
    block-size: 1.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition:
      color 0.12s ease,
      background-color 0.12s ease;
  }

  .playlist-player__track-download:hover {
    color: var(--accent-primary);
    background-color: color-mix(in srgb, var(--surface-1) 55%, transparent);
  }

  .playlist-player__track-download-icon {
    inline-size: 0.875rem;
    block-size: 0.875rem;
  }

  .playlist-player__track-download:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* ── Focus states ── */
  .playlist-player__control:focus-visible,
  .playlist-player__transport-button:focus-visible,
  .playlist-player__progress:focus-visible,
  .playlist-player__track:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .playlist-player__track:focus-visible {
    background-color: color-mix(in srgb, var(--surface-1) 55%, transparent);
  }

  /* ── Visualizer animation ── */
  :global([data-player-state="playing"]) .playlist-player__visualizer > span {
    animation: visualizer-pulse 0.55s ease-in-out infinite alternate;
  }

  :global([data-player-state="playing"])
    .playlist-player__visualizer
    > span:nth-child(1) {
    animation-delay: 0ms;
  }
  :global([data-player-state="playing"])
    .playlist-player__visualizer
    > span:nth-child(2) {
    animation-delay: 120ms;
  }
  :global([data-player-state="playing"])
    .playlist-player__visualizer
    > span:nth-child(3) {
    animation-delay: 60ms;
  }
  :global([data-player-state="playing"])
    .playlist-player__visualizer
    > span:nth-child(4) {
    animation-delay: 180ms;
  }
  :global([data-player-state="playing"])
    .playlist-player__visualizer
    > span:nth-child(5) {
    animation-delay: 240ms;
  }

  @keyframes visualizer-pulse {
    from {
      transform: scaleY(0.3);
    }
    to {
      transform: scaleY(1);
    }
  }

  /* ── Responsive ── */
  @media (width >= 480px) {
    .playlist-player__now-playing {
      padding: var(--spacing-xl);
    }

    .playlist-player__current-title {
      font-size: var(--font-size-xl);
    }

    .playlist-player__control {
      inline-size: 3.5rem;
      block-size: 3.5rem;
    }

    .playlist-player__control-icon {
      inline-size: 1.5rem;
      block-size: 1.5rem;
    }

    .playlist-player__transport-button {
      inline-size: 2.75rem;
      block-size: 2.75rem;
    }

    .playlist-player__transport-icon {
      inline-size: 1.25rem;
      block-size: 1.25rem;
    }

    .playlist-player__tracklist-section {
      padding: var(--spacing-base) var(--spacing-lg) var(--spacing-lg);
    }

    .playlist-player__tracklist-header {
      grid-template-columns: 2.5rem 1fr 3.5rem 2.5rem;
    }

    .playlist-player__track {
      grid-template-columns: 2.5rem 1fr 3.5rem 2.5rem;
      min-block-size: 3rem;
    }

    .playlist-player__track-title {
      font-size: var(--font-size-base);
    }
  }

  @media (width >= 768px) {
    .playlist-player__tracklist-header {
      grid-template-columns: 3rem 1fr 4rem 2.5rem;
    }

    .playlist-player__track {
      grid-template-columns: 3rem 1fr 4rem 2.5rem;
    }
  }

  @media (width < 480px) {
    .playlist-player__tracklist-header {
      display: none;
    }

    .playlist-player__track-download {
      display: none;
    }
  }
</style>
