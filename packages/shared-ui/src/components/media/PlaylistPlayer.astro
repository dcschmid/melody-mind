---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Song {
  title: string;
  audioUrl: string;
  lyricsUrl?: string;
  durationSeconds?: number;
  trackNumber: number;
}

interface Props {
  albumTitle: string;
  songs: Song[];
  lyricsUrlBase?: string;
  albumArtworkUrl?: string;
}

const { albumTitle, songs, lyricsUrlBase, albumArtworkUrl } = Astro.props as Props;
const playerSlug =
  albumTitle.replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") || "playlist";
const playerId = `playlist-${playerSlug}`;
const statusId = `${playerId}-status`;
const progressId = `${playerId}-progress`;
const timeId = `${playerId}-time`;
---

<div
  class="playlist-player"
  data-playlist-player
  data-player-id={playerId}
  data-album-title={albumTitle}
  data-album-artwork-url={albumArtworkUrl}
  aria-label={`Playlist player for ${albumTitle}`}
>
  <div class="playlist-player__now-playing">
    <div class="playlist-player__now-playing-row">
      <div
        class="playlist-player__info"
        role="region"
        aria-live="polite"
        aria-atomic="true"
      >
        <p class="playlist-player__current-title" data-current-track-title>
          Ready to Play
        </p>
        <p class="playlist-player__album">{albumTitle}</p>
      </div>
      <div class="playlist-player__visualizer" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
    </div>

    <div class="playlist-player__controls">
      <button
        class="playlist-player__volume-button"
        type="button"
        data-action="volume"
        aria-label="Toggle mute"
        aria-pressed="false"
        title="Toggle mute"
      >
        <Icon
          name="tabler:volume"
          class="playlist-player__volume-icon playlist-player__volume-icon--on"
          aria-hidden="true"
        />
        <Icon
          name="tabler:volume-off"
          class="playlist-player__volume-icon playlist-player__volume-icon--off"
          aria-hidden="true"
        />
      </button>
      <button
        class="playlist-player__transport-button"
        type="button"
        data-action="shuffle"
        aria-label="Shuffle"
        title="Shuffle"
      >
        <Icon
          name="tabler:arrows-shuffle"
          class="playlist-player__transport-icon"
          aria-hidden="true"
        />
      </button>
      <div class="playlist-player__transport-cluster">
        <button
          class="playlist-player__transport-button"
          type="button"
          data-action="prev"
          aria-label="Previous track"
          title="Previous track"
        >
          <Icon
            name="tabler:player-skip-back-filled"
            class="playlist-player__transport-icon"
            aria-hidden="true"
          />
        </button>
        <button
          class="playlist-player__control"
          type="button"
          data-action="toggle"
          aria-label="Play"
          aria-pressed="false"
        >
          <Icon
            name="tabler:player-play"
            class="playlist-player__control-icon playlist-player__control-icon--play"
            aria-hidden="true"
          />
          <Icon
            name="tabler:player-pause"
            class="playlist-player__control-icon playlist-player__control-icon--pause"
            aria-hidden="true"
          />
        </button>
        <button
          class="playlist-player__transport-button"
          type="button"
          data-action="next"
          aria-label="Next track"
          title="Next track"
        >
          <Icon
            name="tabler:player-skip-forward-filled"
            class="playlist-player__transport-icon"
            aria-hidden="true"
          />
        </button>
      </div>
      <button
        class="playlist-player__transport-button"
        type="button"
        data-action="repeat"
        aria-label="Repeat"
        title="Repeat"
      >
        <Icon
          name="tabler:repeat-off"
          class="playlist-player__repeat-icon playlist-player__repeat-icon--off"
          aria-hidden="true"
        />
        <Icon
          name="tabler:repeat"
          class="playlist-player__repeat-icon playlist-player__repeat-icon--all"
          aria-hidden="true"
        />
        <Icon
          name="tabler:repeat-once"
          class="playlist-player__repeat-icon playlist-player__repeat-icon--one"
          aria-hidden="true"
        />
      </button>
    </div>

    <div class="playlist-player__progress-wrap">
      <label class="sr-only" for={progressId}>Playback progress</label>
      <input
        id={progressId}
        class="playlist-player__progress"
        type="range"
        min="0"
        max="0"
        step="1"
        value="0"
        data-playlist-progress
        aria-label="Playback progress"
      />
      <div class="playlist-player__meta" id={timeId}>
        <span class="playlist-player__time" data-current-time>0:00</span>
        <span class="playlist-player__time" data-remaining-time>-0:00</span>
      </div>
    </div>
  </div>

  <div
    class="playlist-player__status playlist-player__status--sr-only"
    id={statusId}
    data-playlist-status
    aria-live="polite"
    aria-atomic="true"
  >
    Ready to play
  </div>

  <div class="playlist-player__tracklist-section">
    <div class="playlist-player__tracklist-header">
      <span class="playlist-player__col playlist-player__col--num">#</span>
      <span class="playlist-player__col playlist-player__col--title">Title</span>
      <span class="playlist-player__col playlist-player__col--duration">
        <Icon name="tabler:clock" class="playlist-player__col-icon" aria-hidden="true" />
      </span>
    </div>

    <ol class="playlist-player__tracklist">
      {
        songs.map((song, index) => (
          <li
            class="playlist-player__track"
            data-track-index={index}
            data-track-title={song.title}
            data-track-url={song.audioUrl}
            data-track-lyrics={
              song.lyricsUrl ||
              (lyricsUrlBase
                ? `${lyricsUrlBase}/${String(index + 1).padStart(2, "0")}-${song.title.toLowerCase().replace(/\s+/g, "-")}.txt`
                : undefined)
            }
            data-track-duration={song.durationSeconds}
            data-track-number={song.trackNumber}
          >
            <span class="playlist-player__track-num">
              <span class="playlist-player__track-num-text">{song.trackNumber}</span>
              <Icon
                name="tabler:player-play-filled"
                class="playlist-player__track-play-icon"
                aria-hidden="true"
              />
            </span>
            <span class="playlist-player__track-title">{song.title}</span>
            <span class="playlist-player__track-duration">
              {song.durationSeconds
                ? `${Math.floor(song.durationSeconds / 60)}:${String(song.durationSeconds % 60).padStart(2, "0")}`
                : ""}
            </span>
            <a
              class="playlist-player__track-download"
              href={song.audioUrl}
              download={encodeURIComponent(song.title)}
              aria-label={`Download ${song.title}`}
              title="Download track"
            >
              <Icon
                name="download"
                class="playlist-player__track-download-icon"
                aria-hidden="true"
              />
            </a>
          </li>
        ))
      }
    </ol>
    <p class="playlist-player__shortcuts-hint" aria-hidden="true">
      <kbd>Space</kbd> play · <kbd>S</kbd> shuffle · <kbd>R</kbd> repeat · <kbd>M</kbd> mute
    </p>
  </div>

  <audio
    class="playlist-player__audio"
    preload="metadata"
    crossorigin=""
    data-playlist-audio
  >
    <source src={songs[0]?.audioUrl || ""} type="audio/mpeg" />
    <!-- eslint-disable-next-line astro/jsx-a11y/media-has-caption -->
    <track kind="captions" label="Lyrics" srclang="en" />
    Your browser does not support audio playback.
  </audio>

  <script>
    import "@shared-ui/scripts/playlist-player.ts";
  </script>
</div>

<style>
  .playlist-player {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        ellipse at 70% 0%,
        color-mix(in srgb, var(--accent-primary) 6%, transparent),
        transparent 60%
      ),
      var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-2xl);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 40%, transparent),
      var(--shadow-lg);
  }

  /* ── Now-playing area ── */
  .playlist-player__now-playing {
    display: grid;
    gap: var(--spacing-xl);
    padding: var(--spacing-lg) var(--spacing-base);
    text-align: center;
  }

  .playlist-player__now-playing-row {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: space-between;
  }

  .playlist-player__info {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
    text-align: start;
  }

  .playlist-player__current-title {
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: 1.3;
    color: var(--text-primary);
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .playlist-player__current-title[data-transitioning="true"] {
    opacity: 0;
  }

  .playlist-player__album {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  /* ── Visualizer ── */
  .playlist-player__visualizer {
    display: flex;
    flex-shrink: 0;
    gap: var(--spacing-2xs);
    align-items: end;
    block-size: 1.5rem;
    opacity: 0.65;
  }

  .playlist-player__visualizer > span {
    inline-size: var(--spacing-2xs);
    background: var(--accent-primary);
    border-radius: var(--radius-full);
    transform: scaleY(var(--playlist-bar-scale, 1));
    transform-origin: bottom;
  }

  .playlist-player__visualizer > span:nth-child(1) {
    block-size: 1rem;
  }

  .playlist-player__visualizer > span:nth-child(2) {
    block-size: 0.65rem;
  }

  .playlist-player__visualizer > span:nth-child(3) {
    block-size: 1.4rem;
  }

  .playlist-player__visualizer > span:nth-child(4) {
    block-size: 0.85rem;
  }

  .playlist-player__visualizer > span:nth-child(5) {
    block-size: 0.5rem;
  }

  /* ── Transport controls ── */
  .playlist-player__controls {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
  }

  .playlist-player__transport-cluster {
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__control,
    .playlist-player__transport-button,
    .playlist-player__volume-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      font: inherit;
      color: var(--text-primary);
      cursor: pointer;
      background: color-mix(in srgb, var(--surface-1) 45%, transparent);
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-full);
      transition: none;
    }
  }

  .playlist-player__control,
  .playlist-player__transport-button,
  .playlist-player__volume-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    font: inherit;
    color: var(--text-primary);
    touch-action: manipulation;
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 45%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .playlist-player__control,
    .playlist-player__transport-button,
    .playlist-player__volume-button {
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
  }

  .playlist-player__volume-button,
  .playlist-player__transport-button {
    inline-size: 2.75rem;
    block-size: 2.75rem;
  }

  .playlist-player__control {
    position: relative;
    inline-size: 3.5rem;
    block-size: 3.5rem;
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: transparent;
    box-shadow: 0 0 0 0.35rem color-mix(in srgb, var(--accent-primary) 12%, transparent);
  }

  .playlist-player__volume-button {
    position: relative;
  }

  .playlist-player__volume-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    transition: opacity 0.15s ease;
  }

  .playlist-player__volume-icon--off {
    display: none;
    opacity: 0;
  }

  :global([data-player-muted="true"]) .playlist-player__volume-icon--on {
    opacity: 0;
  }

  :global([data-player-muted="true"]) .playlist-player__volume-icon--off {
    display: block;
    opacity: 1;
    animation: volume-fade 0.2s ease-out;
  }

  @keyframes volume-fade {
    0% {
      opacity: 0;
    }

    100% {
      opacity: 1;
    }
  }

  /* Shuffle */
  @media screen and (prefers-reduced-motion: reduce) {
    :global([data-player-shuffle="true"])
      .playlist-player__transport-button[data-action="shuffle"] {
      color: var(--accent-primary);
      background: color-mix(in srgb, var(--accent-primary) 14%, transparent);
      border-color: color-mix(in srgb, var(--accent-primary) 30%, transparent);
      animation: none;
    }
  }

  :global([data-player-shuffle="true"])
    .playlist-player__transport-button[data-action="shuffle"] {
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 14%, transparent);
    border-color: color-mix(in srgb, var(--accent-primary) 30%, transparent);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    :global([data-player-shuffle="true"])
      .playlist-player__transport-button[data-action="shuffle"] {
      animation: shuffle-bounce 0.35s ease-out;
    }
  }

  @keyframes shuffle-bounce {
    0% {
      transform: scale(1);
    }

    30% {
      transform: scale(1.15);
    }

    60% {
      transform: scale(0.95);
    }

    100% {
      transform: scale(1);
    }
  }

  /* Repeat */
  .playlist-player__repeat-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .playlist-player__repeat-icon--all,
  .playlist-player__repeat-icon--one {
    display: none;
  }

  .playlist-player__transport-button[data-action="repeat"] {
    position: relative;
  }

  :global([data-player-repeat="all"]) .playlist-player__repeat-icon--off,
  :global([data-player-repeat="one"]) .playlist-player__repeat-icon--off {
    opacity: 0;
    transform: scale(0.7);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global([data-player-repeat="all"]) .playlist-player__repeat-icon--all {
      display: block;
      color: var(--accent-primary);
      opacity: 1;
      transform: scale(1);
      animation: none;
    }
  }

  :global([data-player-repeat="all"]) .playlist-player__repeat-icon--all {
    display: block;
    color: var(--accent-primary);
    opacity: 1;
    transform: scale(1);
    animation: repeat-pulse 0.35s ease-out;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global([data-player-repeat="one"]) .playlist-player__repeat-icon--one {
      display: block;
      color: var(--accent-primary);
      opacity: 1;
      transform: scale(1);
      animation: none;
    }
  }

  :global([data-player-repeat="one"]) .playlist-player__repeat-icon--one {
    display: block;
    color: var(--accent-primary);
    opacity: 1;
    transform: scale(1);
    animation: repeat-pulse 0.35s ease-out;
  }

  @keyframes repeat-pulse {
    0% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.2);
    }

    100% {
      transform: scale(1);
    }
  }

  :global([data-player-repeat="all"])
    .playlist-player__transport-button[data-action="repeat"],
  :global([data-player-repeat="one"])
    .playlist-player__transport-button[data-action="repeat"] {
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 14%, transparent);
    border-color: color-mix(in srgb, var(--accent-primary) 30%, transparent);
  }

  .playlist-player__control:hover,
  .playlist-player__transport-button:hover,
  .playlist-player__volume-button:hover,
  .playlist-player__control:focus,
  .playlist-player__transport-button:focus,
  .playlist-player__volume-button:focus {
    transform: scale(1.08);
  }

  .playlist-player__control:active,
  .playlist-player__transport-button:active,
  .playlist-player__volume-button:active {
    transform: scale(0.95);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__control:hover,
    .playlist-player__transport-button:hover,
    .playlist-player__volume-button:hover,
    .playlist-player__control:focus,
    .playlist-player__transport-button:focus,
    .playlist-player__volume-button:focus {
      transform: none;
    }

    .playlist-player__control:active,
    .playlist-player__transport-button:active,
    .playlist-player__volume-button:active {
      transform: none;
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__control-icon {
      position: absolute;
      inset: 0;
      inline-size: 1.25rem;
      block-size: 1.25rem;
      margin: auto;
      transition: none;
    }
  }

  .playlist-player__control-icon {
    position: absolute;
    inset: 0;
    inline-size: 1.375rem;
    block-size: 1.375rem;
    margin: auto;
    color: var(--button-text-accent);
    fill: none;
    stroke: currentcolor;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .playlist-player__control-icon--play {
    visibility: visible;
    opacity: 1;
    transform: scale(1);
  }

  .playlist-player__control-icon--pause {
    visibility: hidden;
    opacity: 0;
    transform: scale(0.8);
  }

  .playlist-player__control[data-pop="true"] .playlist-player__control-icon {
    animation: control-icon-pop 0.25s ease-out forwards;
  }

  @keyframes control-icon-pop {
    0% {
      transform: scale(1);
    }

    40% {
      transform: scale(1.25);
    }

    100% {
      transform: scale(1);
    }
  }

  :global([data-player-state="playing"]) .playlist-player__control-icon--play {
    visibility: hidden;
    opacity: 0;
    transform: scale(0.8);
  }

  :global([data-player-state="playing"]) .playlist-player__control-icon--pause {
    visibility: visible;
    opacity: 1;
    transform: scale(1);
  }

  .playlist-player__transport-icon {
    inline-size: 1.125rem;
    block-size: 1.125rem;
  }

  /* ── Progress ── */
  .playlist-player__progress-wrap {
    display: grid;
    gap: var(--spacing-xs);
  }

  .playlist-player__progress {
    inline-size: 100%;
    block-size: 0.5rem;
    appearance: auto;
    accent-color: var(--accent-primary);
    touch-action: pan-x;
    cursor: pointer;
  }

  .playlist-player__meta {
    display: flex;
    justify-content: space-between;
  }

  .playlist-player__time {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
  }

  /* ── SR-only status ── */
  .playlist-player__status--sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: inset(50%);
  }

  /* ── Tracklist ── */
  .playlist-player__tracklist-section {
    padding: var(--spacing-base) var(--spacing-base) var(--spacing-lg);
    background: color-mix(in srgb, var(--surface-1) 20%, transparent);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .playlist-player__tracklist-header {
    display: grid;
    grid-template-columns: 2rem 1fr 3rem 2.5rem;
    gap: var(--spacing-sm);
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-xs);
    margin-block-end: var(--spacing-2xs);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    border-block-end: 1px solid
      color-mix(in srgb, var(--surface-border-soft) 60%, transparent);
  }

  .playlist-player__col--num {
    text-align: center;
  }

  .playlist-player__col--duration {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .playlist-player__col-icon {
    inline-size: 0.75rem;
    block-size: 0.75rem;
  }

  .playlist-player__tracklist {
    display: flex;
    flex-direction: column;
    max-block-size: min(55vh, 26rem);
    padding: 0;
    margin: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    list-style: none;
  }

  .playlist-player__shortcuts-hint {
    display: flex;
    gap: var(--spacing-2xs);
    align-items: center;
    justify-content: center;
    margin: var(--spacing-sm) 0 0;
    font-size: var(--font-size-xs);
    color: var(--text-tertiary);
  }

  .playlist-player__shortcuts-hint kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2xs) var(--spacing-xs);
    font-family: inherit;
    font-size: inherit;
    font-weight: var(--font-weight-medium);
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface-1) 60%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
  }

  /* ── Track row ── */
  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__track {
      display: grid;
      grid-template-columns: 2rem 1fr 3rem 2.5rem;
      gap: var(--spacing-sm);
      align-items: center;
      min-block-size: 2.75rem;
      padding: var(--spacing-xs) var(--spacing-sm);
      cursor: pointer;
      border-radius: var(--radius-md);
      transition: none;
    }
  }

  .playlist-player__track {
    position: relative;
    display: grid;
    grid-template-columns: 2rem 1fr 3rem 2.5rem;
    gap: var(--spacing-sm);
    align-items: center;
    min-block-size: 2.75rem;
    padding: var(--spacing-xs) var(--spacing-sm);
