---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Song {
  title: string;
  audioUrl: string;
  lyricsUrl?: string;
  isInstrumental?: boolean;
  transcriptUnavailableReason?: string;
  durationSeconds?: number;
  trackNumber: number;
}

interface Props {
  albumTitle: string;
  songs: Song[];
  albumArtworkUrl?: string;
}

const { albumTitle, songs, albumArtworkUrl } = Astro.props as Props;
const playerSlug =
  albumTitle.replace(/[^a-z0-9]+/gi, "-").replace(/(^-|-$)/g, "") || "playlist";
const playerId = `playlist-${playerSlug}`;
const statusId = `${playerId}-status`;
const progressId = `${playerId}-progress`;
const timeId = `${playerId}-time`;
const hasSongs = songs.length > 0;

const getTrackFallbackLabel = (song: Song): string =>
  song.lyricsUrl
    ? ""
    : song.isInstrumental
      ? "Instrumental"
      : song.transcriptUnavailableReason || "Transcript unavailable";
---

<section
  class="playlist-player"
  data-playlist-player
  data-player-id={playerId}
  data-album-title={albumTitle}
  data-album-artwork-url={albumArtworkUrl}
  aria-label={`Playlist player for ${albumTitle}`}
>
  <div class="playlist-player__now-playing">
    <div class="playlist-player__now-playing-row">
      <div class="playlist-player__info">
        <p class="playlist-player__current-title" data-current-track-title>
          Ready to Play
        </p>
        <p class="playlist-player__album">{albumTitle}</p>
      </div>
    </div>

    <div class="playlist-player__controls">
      <button
        class="playlist-player__volume-button"
        type="button"
        data-action="volume"
        aria-label="Toggle mute"
        aria-pressed="false"
        title="Toggle mute"
        disabled={!hasSongs}
      >
        <Icon
          name="tabler:volume"
          class="playlist-player__volume-icon playlist-player__volume-icon--on"
          aria-hidden="true"
        />
        <Icon
          name="tabler:volume-off"
          class="playlist-player__volume-icon playlist-player__volume-icon--off"
          aria-hidden="true"
        />
      </button>
      <div class="playlist-player__transport-cluster">
        <button
          class="playlist-player__transport-button"
          type="button"
          data-action="prev"
          aria-label="Previous track"
          title="Previous track"
          disabled={!hasSongs}
        >
          <Icon
            name="tabler:player-skip-back-filled"
            class="playlist-player__transport-icon"
            aria-hidden="true"
          />
        </button>
        <button
          class="playlist-player__control"
          type="button"
          data-action="toggle"
          aria-label="Play"
          aria-pressed="false"
          disabled={!hasSongs}
        >
          <Icon
            name="tabler:player-play"
            class="playlist-player__control-icon playlist-player__control-icon--play"
            aria-hidden="true"
          />
          <Icon
            name="tabler:player-pause"
            class="playlist-player__control-icon playlist-player__control-icon--pause"
            aria-hidden="true"
          />
        </button>
        <button
          class="playlist-player__transport-button"
          type="button"
          data-action="next"
          aria-label="Next track"
          title="Next track"
          disabled={!hasSongs}
        >
          <Icon
            name="tabler:player-skip-forward-filled"
            class="playlist-player__transport-icon"
            aria-hidden="true"
          />
        </button>
      </div>
    </div>

    <div class="playlist-player__progress-wrap">
      <label class="sr-only" for={progressId}>Playback progress</label>
      <input
        id={progressId}
        class="playlist-player__progress"
        type="range"
        min="0"
        max="0"
        step="1"
        value="0"
        data-playlist-progress
        aria-label="Playback progress"
        aria-describedby={timeId}
        disabled={!hasSongs}
      />
      <div class="playlist-player__meta" id={timeId}>
        <span class="playlist-player__time" data-current-time>0:00</span>
        <span class="playlist-player__time" data-remaining-time>-0:00</span>
      </div>
    </div>
  </div>

  <div
    class="playlist-player__status playlist-player__status--sr-only"
    id={statusId}
    data-playlist-status
    aria-live="polite"
    aria-atomic="true"
  >
    Ready to play
  </div>

  <div class="playlist-player__tracklist-section">
    <div class="playlist-player__tracklist-header">
      <span class="playlist-player__col playlist-player__col--num">#</span>
      <span class="playlist-player__col playlist-player__col--title">Title</span>
      <span class="playlist-player__col playlist-player__col--duration">
        <Icon name="tabler:clock" class="playlist-player__col-icon" aria-hidden="true" />
      </span>
      <span class="playlist-player__col playlist-player__col--action">
        <span class="sr-only">Lyrics</span>
      </span>
    </div>

    <ol class="playlist-player__tracklist">
      {
        songs.map((song, index) => {
          const fallbackLabel = getTrackFallbackLabel(song);
          const playLabel = fallbackLabel
            ? `Play ${song.title}. ${fallbackLabel}.`
            : `Play ${song.title}`;

          return (
            <li
              class="playlist-player__track"
              data-track-index={index}
              data-track-title={song.title}
              data-track-url={song.audioUrl}
              data-track-duration={song.durationSeconds}
              data-track-number={song.trackNumber}
            >
              <button
                class="playlist-player__track-button"
                type="button"
                data-track-button
                aria-label={playLabel}
              >
                <span class="playlist-player__track-num">
                  <span class="playlist-player__track-num-text">{song.trackNumber}</span>
                  <Icon
                    name="tabler:player-play-filled"
                    class="playlist-player__track-play-icon"
                    aria-hidden="true"
                  />
                </span>
                <span class="playlist-player__track-title-wrap">
                  <span class="playlist-player__track-title">{song.title}</span>
                  {fallbackLabel ? (
                    <span class="playlist-player__track-lyrics-status">
                      {fallbackLabel}
                    </span>
                  ) : null}
                </span>
                <span class="playlist-player__track-duration">
                  {song.durationSeconds
                    ? `${Math.floor(song.durationSeconds / 60)}:${String(song.durationSeconds % 60).padStart(2, "0")}`
                    : ""}
                </span>
              </button>
              {song.lyricsUrl ? (
                <a
                  class="playlist-player__track-lyrics"
                  href={song.lyricsUrl}
                  target="_blank"
                  rel="noreferrer noopener"
                  aria-label={`Open lyrics for ${song.title} in a new tab`}
                  title="Open lyrics in a new tab"
                >
                  <Icon
                    name="tabler:file-text"
                    class="playlist-player__track-action-icon"
                    aria-hidden="true"
                  />
                </a>
              ) : (
                <span
                  class="playlist-player__track-action-placeholder"
                  aria-hidden="true"
                />
              )}
            </li>
          );
        })
      }
    </ol>
  </div>

  {
    /* eslint-disable astro/jsx-a11y/media-has-caption -- Captions are not exposed through the hidden native audio element; lyrics are separate transcript links. */
  }
  <audio class="playlist-player__audio" preload="metadata" data-playlist-audio>
    <source src={songs[0]?.audioUrl || ""} type="audio/mpeg" />
    Your browser does not support audio playback.
  </audio>
  {/* eslint-enable astro/jsx-a11y/media-has-caption */}

  <script>
    import "@shared-ui/scripts/playlist-player.ts";
  </script>
</section>

<style>
  .playlist-player {
    position: relative;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface-panel-bg) 96%, var(--surface-2));
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-base);
  }

  .playlist-player::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    border: 1px solid color-mix(in srgb, var(--accent-primary) 32%, transparent);
    border-radius: inherit;
    opacity: 0;
    transform: scale(0.995);
  }

  /* ── Now-playing area ── */
  .playlist-player__now-playing {
    display: grid;
    gap: var(--spacing-xl);
    padding: var(--spacing-lg) var(--spacing-base);
    text-align: center;
  }

  .playlist-player__now-playing-row {
    display: flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: space-between;
  }

  .playlist-player__info {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
    text-align: start;
  }

  .playlist-player__current-title {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: 1.3;
    color: var(--text-primary);
    overflow-wrap: anywhere;
    white-space: normal;
    transition: opacity 0.2s ease;
  }

  .playlist-player__current-title[data-transitioning="true"] {
    opacity: 0;
  }

  .playlist-player__album {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  /* ── Transport controls ── */
  .playlist-player__controls {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
  }

  .playlist-player__transport-cluster {
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__control,
    .playlist-player__transport-button,
    .playlist-player__volume-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      font: inherit;
      color: var(--text-primary);
      cursor: pointer;
      background: color-mix(in srgb, var(--surface-1) 45%, transparent);
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-full);
      transition: none;
    }
  }

  .playlist-player__control,
  .playlist-player__transport-button,
  .playlist-player__volume-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    font: inherit;
    color: var(--text-primary);
    touch-action: manipulation;
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 45%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .playlist-player__control,
    .playlist-player__transport-button,
    .playlist-player__volume-button {
      transition:
        transform 0.15s ease,
        box-shadow 0.15s ease;
    }
  }

  .playlist-player__volume-button,
  .playlist-player__transport-button {
    inline-size: 2.75rem;
    block-size: 2.75rem;
  }

  .playlist-player__control {
    position: relative;
    inline-size: 3.5rem;
    block-size: 3.5rem;
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: transparent;
    box-shadow: 0 0 0 0.35rem color-mix(in srgb, var(--accent-primary) 12%, transparent);
  }

  .playlist-player__volume-button {
    position: relative;
  }

  .playlist-player__control:disabled,
  .playlist-player__transport-button:disabled,
  .playlist-player__volume-button:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .playlist-player__volume-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    transition: opacity 0.15s ease;
  }

  .playlist-player__volume-icon--off {
    display: none;
    opacity: 0;
  }

  :global([data-player-muted="true"]) .playlist-player__volume-icon--on {
    opacity: 0;
  }

  :global([data-player-muted="true"]) .playlist-player__volume-icon--off {
    display: block;
    opacity: 1;
    animation: volume-fade 0.2s ease-out;
  }

  @keyframes volume-fade {
    0% {
      opacity: 0;
    }

    100% {
      opacity: 1;
    }
  }

  .playlist-player__control:where(:not(:disabled)):hover,
  .playlist-player__transport-button:where(:not(:disabled)):hover,
  .playlist-player__volume-button:where(:not(:disabled)):hover,
  .playlist-player__control:where(:not(:disabled)):focus,
  .playlist-player__transport-button:where(:not(:disabled)):focus,
  .playlist-player__volume-button:where(:not(:disabled)):focus {
    transform: scale(1.08);
  }

  .playlist-player__control:where(:not(:disabled)):active,
  .playlist-player__transport-button:where(:not(:disabled)):active,
  .playlist-player__volume-button:where(:not(:disabled)):active {
    transform: scale(0.95);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__control:where(:not(:disabled)):hover,
    .playlist-player__transport-button:where(:not(:disabled)):hover,
    .playlist-player__volume-button:where(:not(:disabled)):hover,
    .playlist-player__control:where(:not(:disabled)):focus,
    .playlist-player__transport-button:where(:not(:disabled)):focus,
    .playlist-player__volume-button:where(:not(:disabled)):focus {
      transform: none;
    }

    .playlist-player__control:where(:not(:disabled)):active,
    .playlist-player__transport-button:where(:not(:disabled)):active,
    .playlist-player__volume-button:where(:not(:disabled)):active {
      transform: none;
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__control-icon {
      position: absolute;
      inset: 0;
      inline-size: 1.25rem;
      block-size: 1.25rem;
      margin: auto;
      transition: none;
    }
  }

  .playlist-player__control-icon {
    position: absolute;
    inset: 0;
    inline-size: 1.375rem;
    block-size: 1.375rem;
    margin: auto;
    color: var(--button-text-accent);
    fill: none;
    stroke: currentcolor;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .playlist-player__control-icon--play {
    visibility: visible;
    opacity: 1;
    transform: scale(1);
  }

  .playlist-player__control-icon--pause {
    visibility: hidden;
    opacity: 0;
    transform: scale(0.8);
  }

  .playlist-player__control[data-pop="true"] .playlist-player__control-icon {
    animation: control-icon-acknowledge 0.18s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes control-icon-acknowledge {
    0% {
      opacity: 0.72;
    }

    100% {
      opacity: 1;
    }
  }

  :global([data-player-state="playing"]) .playlist-player__control-icon--play {
    visibility: hidden;
    opacity: 0;
    transform: scale(0.8);
  }

  :global([data-player-state="playing"]) .playlist-player__control-icon--pause {
    visibility: visible;
    opacity: 1;
    transform: scale(1);
  }

  .playlist-player__transport-icon {
    inline-size: 1.125rem;
    block-size: 1.125rem;
  }

  /* ── Progress ── */
  .playlist-player__progress-wrap {
    display: grid;
    gap: var(--spacing-xs);
  }

  .playlist-player__progress {
    inline-size: 100%;
    block-size: 0.5rem;
    appearance: auto;
    accent-color: var(--accent-primary);
    touch-action: pan-x;
    cursor: pointer;
  }

  .playlist-player__meta {
    display: flex;
    justify-content: space-between;
  }

  .playlist-player__time {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
  }

  /* ── SR-only status ── */
  .playlist-player__status--sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: inset(50%);
  }

  /* ── Tracklist ── */
  .playlist-player__tracklist-section {
    padding: var(--spacing-base) var(--spacing-base) var(--spacing-lg);
    background: color-mix(in srgb, var(--surface-1) 20%, transparent);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .playlist-player__tracklist-header {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr) 3rem 2.75rem;
    gap: var(--spacing-sm);
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-xs);
    margin-block-end: var(--spacing-2xs);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    border-block-end: 1px solid
      color-mix(in srgb, var(--surface-border-soft) 60%, transparent);
  }

  .playlist-player__col--num {
    text-align: center;
  }

  .playlist-player__col--duration {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .playlist-player__col--action {
    text-align: center;
  }

  .playlist-player__col-icon {
    inline-size: 0.75rem;
    block-size: 0.75rem;
  }

  .playlist-player__tracklist {
    display: flex;
    flex-direction: column;
    max-block-size: min(55vh, 26rem);
    padding: 0;
    margin: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    list-style: none;
  }

  /* ── Track row ── */
  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__track {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 2.75rem;
      gap: var(--spacing-sm);
      align-items: center;
      padding: var(--spacing-xs) var(--spacing-sm);
      border-radius: var(--radius-md);
      transition: none;
    }
  }

  .playlist-player__track {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 2.75rem;
    gap: var(--spacing-sm);
    align-items: center;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-md);
    transition: background-color 0.12s ease;
  }

  .playlist-player__track:hover,
  .playlist-player__track:focus-within {
    background-color: color-mix(in srgb, var(--surface-1) 55%, transparent);
  }

  .playlist-player__track-button {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr) 3rem;
    gap: var(--spacing-sm);
    align-items: center;
    min-inline-size: 0;
    min-block-size: 2.75rem;
    padding: 0;
    font: inherit;
    color: inherit;
    text-align: start;
    touch-action: manipulation;
    cursor: pointer;
    background: transparent;
    border: 0;
    border-radius: var(--radius-sm);
  }

  .playlist-player__track[data-is-current="true"]:not([data-is-playing="true"]) {
    background-color: color-mix(in srgb, var(--accent-primary) 7%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent-primary) 13%, transparent);
  }

  .playlist-player__track[data-is-playing="true"] {
    background-color: color-mix(in srgb, var(--accent-primary) 14%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent-primary) 25%, transparent);
  }

  .playlist-player__track-title {
    display: -webkit-box;
    min-inline-size: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1.25;
    color: var(--text-primary);
    overflow-wrap: anywhere;
    white-space: normal;
  }

  .playlist-player__track-title-wrap {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
  }

  .playlist-player__track[data-is-playing="true"] .playlist-player__track-title {
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
  }

  .playlist-player__track[data-is-current="true"]:not([data-is-playing="true"])
    .playlist-player__track-title {
    color: var(--text-primary);
  }

  .playlist-player__track-num {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-xs);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
  }

  .playlist-player__track-play-icon {
    position: absolute;
    inset: 0;
    display: none;
    inline-size: 0.875rem;
    block-size: 0.875rem;
    margin: auto;
    color: var(--accent-primary);
    opacity: 0;
    transform: scale(0.8);
  }

  .playlist-player__track[data-is-playing="true"] .playlist-player__track-num-text {
    display: none;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .playlist-player__track[data-is-playing="true"] .playlist-player__track-play-icon {
      display: flex;
      animation: none;
    }
  }

  .playlist-player__track[data-is-playing="true"] .playlist-player__track-play-icon {
    display: flex;
    animation: track-play-icon-reveal 0.3s ease-out forwards;
  }

  @keyframes track-play-icon-reveal {
    from {
      opacity: 0;
      transform: scale(0.8);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .playlist-player__track-play-icon {
      opacity: 1;
      transform: none;
      animation: none;
    }

    .playlist-player__control[data-pop="true"] .playlist-player__control-icon {
      animation: none;
    }

    .playlist-player__volume-icon {
      transition: none;
    }

    :global([data-player-muted="true"]) .playlist-player__volume-icon--off {
      animation: none;
    }

    .playlist-player__current-title {
      transition: none;
    }

    .playlist-player__current-title[data-transitioning="true"] {
      opacity: 1;
    }

    :global([data-player-celebrating="true"]) .playlist-player,
    :global([data-player-celebrating="true"]) .playlist-player::before {
      animation: none;
    }
  }

  .playlist-player__track-duration {
    min-inline-size: 0;
    font-size: var(--font-size-xs);
    font-variant-numeric: tabular-nums;
    color: var(--text-secondary);
    text-align: end;
  }

  .playlist-player__track-lyrics {
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.75rem;
    block-size: 2.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    touch-action: manipulation;
    border-radius: var(--radius-md);
  }

  .playlist-player__track-lyrics-status {
    min-inline-size: 0;
    overflow: hidden;
