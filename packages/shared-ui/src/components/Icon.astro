---
import AppleMusicIcon from "@shared-icons/apple-music.svg";
import ArrowLeftIcon from "@shared-icons/arrow-left.svg";
import ArrowRightIcon from "@shared-icons/arrow-right.svg";
import ArrowUpIcon from "@shared-icons/arrow-up.svg";
import BookOpenIcon from "@shared-icons/book-open.svg";
import BookIcon from "@shared-icons/book.svg";
import BookmarkIcon from "@shared-icons/bookmark.svg";
import CalendarIcon from "@shared-icons/calendar.svg";
import ChevronDownIcon from "@shared-icons/chevron-down.svg";
import ChevronRightDuoIcon from "@shared-icons/chevron-right-duo-svgrepo-com.svg";
import ChevronRightIcon from "@shared-icons/chevron-right.svg";
import ClockIcon from "@shared-icons/clock.svg";
import CloudIcon from "@shared-icons/cloud.svg";
import CompassIcon from "@shared-icons/compass.svg";
import CopyIcon from "@shared-icons/copy.svg";
import CpuIcon from "@shared-icons/cpu.svg";
import DeezerIcon from "@shared-icons/deezer.svg";
import DiscIcon from "@shared-icons/disc.svg";
import ExternalLinkIcon from "@shared-icons/external-link.svg";
import EyeIcon from "@shared-icons/eye.svg";
import FileTextIcon from "@shared-icons/file-text.svg";
import FilterIcon from "@shared-icons/filter.svg";
import FlagIcon from "@shared-icons/flag.svg";
import FlameIcon from "@shared-icons/flame.svg";
import GlobeIcon from "@shared-icons/globe.svg";
import GridIcon from "@shared-icons/grid.svg";
import GuitarIcon from "@shared-icons/guitar.svg";
import HeadphonesIcon from "@shared-icons/headphones.svg";
import HeartIcon from "@shared-icons/heart.svg";
import HelpCircleIcon from "@shared-icons/help-circle.svg";
import HomeIcon from "@shared-icons/home.svg";
import ImageIcon from "@shared-icons/image.svg";
import InfoIcon from "@shared-icons/info.svg";
import LeafIcon from "@shared-icons/leaf.svg";
import MailIcon from "@shared-icons/mail.svg";
import MenuIcon from "@shared-icons/menu.svg";
import MessageCircleIcon from "@shared-icons/message-circle.svg";
import MicIcon from "@shared-icons/mic.svg";
import MusicIcon from "@shared-icons/music.svg";
import PlayIcon from "@shared-icons/play.svg";
import PrinterIcon from "@shared-icons/printer.svg";
import RefreshCcwIcon from "@shared-icons/refresh-ccw.svg";
import SearchIcon from "@shared-icons/search.svg";
import SendIcon from "@shared-icons/send.svg";
import SettingsIcon from "@shared-icons/settings.svg";
import Share2Icon from "@shared-icons/share-2.svg";
import ShieldIcon from "@shared-icons/shield.svg";
import SparklesIcon from "@shared-icons/sparkles.svg";
import SpotifyIcon from "@shared-icons/spotify.svg";
import StarIcon from "@shared-icons/star.svg";
import TagIcon from "@shared-icons/tag.svg";
import TvIcon from "@shared-icons/tv.svg";
import UserIcon from "@shared-icons/user.svg";
import WaveIcon from "@shared-icons/wave.svg";
import XIcon from "@shared-icons/x.svg";
import ZapIcon from "@shared-icons/zap.svg";

const iconRegistry = {
  "apple-music": AppleMusicIcon,
  "arrow-left": ArrowLeftIcon,
  "arrow-right": ArrowRightIcon,
  "arrow-up": ArrowUpIcon,
  "book-open": BookOpenIcon,
  book: BookIcon,
  bookmark: BookmarkIcon,
  calendar: CalendarIcon,
  "chevron-down": ChevronDownIcon,
  "chevron-right-duo-svgrepo-com": ChevronRightDuoIcon,
  "chevron-right": ChevronRightIcon,
  clock: ClockIcon,
  cloud: CloudIcon,
  compass: CompassIcon,
  copy: CopyIcon,
  cpu: CpuIcon,
  deezer: DeezerIcon,
  disc: DiscIcon,
  "external-link": ExternalLinkIcon,
  eye: EyeIcon,
  "file-text": FileTextIcon,
  filter: FilterIcon,
  flag: FlagIcon,
  flame: FlameIcon,
  globe: GlobeIcon,
  grid: GridIcon,
  guitar: GuitarIcon,
  headphones: HeadphonesIcon,
  heart: HeartIcon,
  "help-circle": HelpCircleIcon,
  home: HomeIcon,
  image: ImageIcon,
  info: InfoIcon,
  leaf: LeafIcon,
  mail: MailIcon,
  menu: MenuIcon,
  "message-circle": MessageCircleIcon,
  mic: MicIcon,
  music: MusicIcon,
  play: PlayIcon,
  printer: PrinterIcon,
  "refresh-ccw": RefreshCcwIcon,
  search: SearchIcon,
  send: SendIcon,
  settings: SettingsIcon,
  "share-2": Share2Icon,
  shield: ShieldIcon,
  sparkles: SparklesIcon,
  spotify: SpotifyIcon,
  star: StarIcon,
  tag: TagIcon,
  tv: TvIcon,
  user: UserIcon,
  wave: WaveIcon,
  x: XIcon,
  zap: ZapIcon,
} as const;

export type IconName = keyof typeof iconRegistry;

interface Props extends astroHTML.JSX.SVGAttributes {
  name: IconName | string;
}

const {
  name,
  width = "1em",
  height = "1em",
  "aria-hidden": ariaHidden,
  focusable = "false",
  ...restProps
} = Astro.props as Props & Record<string, unknown>;
const SvgIcon = iconRegistry[name as IconName];
---

{
  SvgIcon ? (
    <SvgIcon
      width={width}
      height={height}
      aria-hidden={ariaHidden}
      focusable={focusable}
      {...restProps}
    />
  ) : null
}
