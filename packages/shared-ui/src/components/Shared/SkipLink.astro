---
/**
 * @component SkipLink
 * @description Accessibility component that allows keyboard users to bypass repetitive navigation
 * and quickly access the main content. Initially hidden visually but appears when focused.
 *
 * @example
 * ```astro
 * <SkipLink targetId="article-content" />
 * <SkipLink targetId="main-content" />
 * ```
 */
interface Props {
  /**
   * The ID of the element to target when the skip link is activated
   * @default "main-content"
   */
  targetId?: string;
  label?: string;
}

const { targetId = "main-content", label = "Skip to main content" } = Astro.props;

const skipLinkClasses = "skip-link";
const iconClasses = "skip-link__icon";
---

<a
  href={`#${targetId}`}
  class={skipLinkClasses}
  data-skip-link
  aria-label={label}
>
  <svg
    class={iconClasses}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path d="M14 5h5v5"></path>
    <path d="M10 14 19 5"></path>
    <path d="M19 14v5h-14v-14h5"></path>
  </svg>
  {label}
</a>
<style>
  .skip-link {
    position: absolute;
    inset-block-start: -9999px;
    inset-inline-start: 50%;
    z-index: 50;
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    padding: 0.5rem 1rem;
    font-weight: 700;
    color: var(--color-gn-soot-950);
    text-decoration: none;
    background: var(--color-gn-amber-500);
    border-radius: 0 0 0.5rem 0.5rem;
    box-shadow: 4px 4px 0 rgb(0 0 0 / 70%);
    transform: translateX(-50%);
  }

  .skip-link:focus-visible {
    inset-block-start: 0;
    outline: 2px solid var(--color-gn-amber-300);
    outline-offset: 4px;
  }

  .skip-link__icon {
    inline-size: 1rem;
    block-size: 1rem;
  }
</style>
