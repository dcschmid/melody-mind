---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props as Props;
---

<span class:list={["visually-hidden", className]}>
  <slot />
</span>

<style>
  .visually-hidden {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: inset(50%);
  }
</style>
