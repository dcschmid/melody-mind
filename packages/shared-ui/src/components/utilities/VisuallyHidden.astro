---
interface Props extends astroHTML.JSX.HTMLAttributes {
  class?: string;
  className?: string;
}

const { class: classProp = "", className = "", ...rest } = Astro.props as Props;
---

<span {...rest} class:list={["visually-hidden", className, classProp]}>
  <slot />
</span>

<style>
  .visually-hidden {
    position: var(--sr-only, absolute);
    inline-size: var(--sr-only-width, 1px);
    block-size: var(--sr-only-height, 1px);
    padding: var(--sr-only-padding, 0);
    margin: var(--sr-only-margin, -1px);
    overflow: var(--sr-only-overflow, hidden);
    white-space: var(--sr-only-white-space, nowrap);
    border: var(--sr-only-border, 0);
    /* stylelint-disable-next-line property-no-deprecated -- Legacy fallback for older assistive/browser combinations. */
    clip: var(--sr-only-clip, rect(0 0 0 0));
    clip-path: var(--sr-only-clip-path, inset(50%));
  }
</style>
