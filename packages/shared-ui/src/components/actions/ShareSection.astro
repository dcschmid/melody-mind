---
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props {
  id?: string;
  shareUrl: string;
  contentTitle: string;
  contentDescription?: string;
  title?: string;
  note?: string;
  successMessage?: string;
  errorMessage?: string;
}

const {
  id,
  shareUrl,
  contentTitle,
  contentDescription = "",
  title = "Share this article",
  note = "Choose one way to share this page.",
  successMessage = "Link copied.",
  errorMessage = "Copy failed. Please copy the link manually.",
} = Astro.props as Props;

const shareTitle = `${contentTitle} | Melody Mind`;
const sanitizedDesc = (contentDescription || "").replace(/\r\n|\r|\n/g, " ").trim();
const shareText = sanitizedDesc ? `${contentTitle} - ${sanitizedDesc}` : contentTitle;
const shareMailSubject = encodeURIComponent(shareTitle);
const shareMailBody = encodeURIComponent(
  sanitizedDesc ? `${sanitizedDesc}\n\n${shareUrl}` : shareUrl
);
const MASTODON_SHARE_URL = "https://mastodon.social/share";
const mastodonShareUrl = `${MASTODON_SHARE_URL}?text=${encodeURIComponent(
  `${shareText} ${shareUrl}`
)}`;

const hasValidUrl = (() => {
  try {
    const url = new URL(shareUrl);
    return url.protocol === "http:" || url.protocol === "https:";
  } catch {
    return false;
  }
})();

const sanitizeId = (str: string) =>
  str
    .replace(/[^a-zA-Z0-9_-]/g, "-")
    .replace(/-+/g, "-")
    .replace(/^-|-$/g, "");

const sanitizedProvidedId = id ? sanitizeId(id) : "";
const sanitizedTitleId = contentTitle ? sanitizeId(contentTitle.toLowerCase()) : "";
const rootId =
  sanitizedProvidedId ||
  (sanitizedTitleId
    ? `share-section-${sanitizedTitleId}`
    : `share-section-${Math.random().toString(36).slice(2, 9)}`);

const noteToUse = note;
---

<section
  class="share-section"
  id={rootId}
  aria-labelledby={`${rootId}-title`}
  data-share-root
  data-share-url={hasValidUrl ? shareUrl : ""}
  data-share-title={shareTitle}
  data-share-text={shareText}
  data-share-success={successMessage}
  data-share-error={errorMessage}
  hidden={!hasValidUrl ? "true" : undefined}
>
  <div class="share-section__copy">
    <h2 class="share-section__title" id={`${rootId}-title`}>{title}</h2>
    <p
      class="share-section__note"
      data-share-status
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
      {noteToUse}
    </p>
  </div>

  <div class="share-section__actions" role="group" aria-label="Share options">
    <button
      type="button"
      data-share="native"
      class="share-section__button share-section__button--primary"
      aria-label="Share with your device"
    >
      <Icon name="send" class="share-section__button-icon" aria-hidden="true" />
      <span>Share</span>
    </button>
    <button
      type="button"
      data-share="copy"
      class="share-section__button"
      data-copy-button
      aria-label="Copy link to this article"
    >
      <Icon
        name="copy"
        class="share-section__button-icon"
        data-copy-icon
        aria-hidden="true"
      />
      <span data-copy-label>Copy link</span>
    </button>
    <a
      href={`mailto:?subject=${shareMailSubject}&body=${shareMailBody}`}
      class="share-section__button share-section__button--tertiary"
      aria-label="Share via email"
    >
      <Icon name="mail" class="share-section__button-icon" aria-hidden="true" />
      <span>Email</span>
    </a>
    <a
      href={mastodonShareUrl}
      target="_blank"
      rel="noreferrer noopener"
      class="share-section__button share-section__button--tertiary"
      aria-label="Share on Mastodon (opens in a new tab)"
    >
      <Icon name="message-circle" class="share-section__button-icon" aria-hidden="true" />
      <span>Mastodon</span>
    </a>
  </div>
</section>

<script>
  const shareRoots = Array.from(
    document.querySelectorAll<HTMLElement>("[data-share-root]")
  ).filter((root) => root.dataset.shareBound !== "true");

  const copySuccessVariants = [
    "Link copied.",
    "Ready to share.",
    "Sent to clipboard.",
    "Your turn to spread the word.",
  ];

  shareRoots.forEach((shareSection) => {
    shareSection.dataset.shareBound = "true";
    const shareUrl = shareSection.dataset.shareUrl || "";
    const shareTitle = shareSection.dataset.shareTitle || "";
    const shareText = shareSection.dataset.shareText || "";
    const copyErrorMessage = shareSection.dataset.shareError || "";
    const statusEl = shareSection.querySelector<HTMLElement>("[data-share-status]");
    const defaultStatus = statusEl?.textContent || "";
    const copyBtn = shareSection.querySelector<HTMLElement>("[data-copy-button]");
    const copyLabel = shareSection.querySelector("[data-copy-label]");
    const nativeShareBtn = shareSection.querySelector('[data-share="native"]');
    let resetTimer: number | undefined;
    let animationTimer: number | undefined;

    const copySuccessMsg =
      shareSection.dataset.shareSuccess === "Link copied."
        ? copySuccessVariants[Math.floor(Math.random() * copySuccessVariants.length)]
        : shareSection.dataset.shareSuccess || "";

    const setStatus = (message: string) => {
      if (!statusEl) {
        return;
      }
      statusEl.textContent = message;
      if (resetTimer) {
        window.clearTimeout(resetTimer);
      }
      resetTimer = window.setTimeout(() => {
        statusEl.textContent = defaultStatus;
      }, 4000);
    };

    const copyLink = async () => {
      if (!shareUrl) {
        setStatus(copyErrorMessage);
        return;
      }
      try {
        if (!navigator.clipboard) {
          throw new Error("clipboard unavailable");
        }
        await navigator.clipboard.writeText(shareUrl);
        setStatus(copySuccessMsg);

        if (copyBtn && copyLabel) {
          if (animationTimer) {
            window.clearTimeout(animationTimer);
          }
          copyBtn.classList.add("share-section__button--success");
          copyLabel.textContent = "Copied";
          copyBtn.setAttribute("aria-label", "Link copied to clipboard");

          animationTimer = window.setTimeout(() => {
            copyBtn.classList.remove("share-section__button--success");
            copyLabel.textContent = "Copy link";
            copyBtn.setAttribute("aria-label", "Copy link to this article");
          }, 2000);
        }
      } catch {
        setStatus(copyErrorMessage);
      }
    };

    copyBtn?.addEventListener("click", () => {
      copyLink();
    });

    nativeShareBtn?.addEventListener("click", async () => {
      if (navigator.share) {
        try {
          await navigator.share({ title: shareTitle, text: shareText, url: shareUrl });
          setStatus(copySuccessMsg);
          return;
        } catch (error) {
          if (error instanceof Error && error.name === "AbortError") {
            return;
          }
        }
      }
      copyLink();
    });
  });
</script>

<style>
  .share-section {
    display: grid;
    gap: var(--spacing-lg);
    align-items: center;
    padding-block: var(--spacing-xl);
    padding-inline: 0;
    margin-block-start: 0;
    border-block-start: 0;
  }

  .share-section__copy {
    display: grid;
    gap: var(--spacing-xs);
  }

  .share-section__copy::before {
    display: block;
    width: 2rem;
    height: 2px;
    margin-block-end: var(--spacing-sm);
    content: "";
    background: var(--accent-primary);
  }

  .share-section__title {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  .share-section__note {
    margin: 0;
    font-size: var(--font-size-xs);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .share-section__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .share-section__button {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-block-size: var(--control-min-block-size, 2.75rem);
    padding: var(--control-padding-block-compact) var(--control-padding-inline-compact);
    font: inherit;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    text-decoration: none;
    cursor: pointer;
    background: transparent;
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--control-radius-compact);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  @media (width < 640px) {
    .share-section__button {
      min-block-size: 3rem;
      padding: var(--spacing-md) var(--spacing-base);
      font-size: var(--font-size-sm);
    }

    .share-section__button--primary {
      justify-content: center;
      width: 100%;
    }

    .share-section__button--tertiary {
      flex: 0 0 auto;
      width: auto;
    }

    .share-section__button--success {
      justify-content: center;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .share-section__button {
      transition: none;
    }

    .share-section__button--success {
      transform: none;
    }
  }

  .share-section__button--primary {
    font-size: var(--font-size-sm);
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .share-section__button--success {
    color: var(--color-success);
    background: color-mix(in srgb, var(--color-success) 8%, transparent);
    border-color: var(--color-success);
    transform: scale(1.05);
  }

  .share-section__button--tertiary {
    color: var(--text-tertiary);
    background: transparent;
    border-color: var(--surface-border-soft);
  }

  .share-section__button--tertiary:hover,
  .share-section__button--tertiary:focus {
    color: var(--accent-primary);
    background: transparent;
    border-color: var(--accent-primary);
    transform: translateY(-1px);
  }

  .share-section__button:hover,
  .share-section__button:focus {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
    border-color: var(--surface-border-medium);
    transform: translateY(-1px);
  }

  .share-section__button--primary:hover,
  .share-section__button--primary:focus {
    background: var(--accent-primary-hover);
    border-color: var(--accent-primary-hover);
  }

  .share-section__button:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .share-section__button-icon {
    inline-size: var(--icon-size-xs);
    block-size: var(--icon-size-xs);
  }

  @media (width >= 640px) {
    .share-section {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--spacing-2xl);
    }

    .share-section__actions {
      gap: var(--spacing-md);
    }
  }

  :global(:root[data-theme="dark"]) .share-section__button--success {
    color: var(--color-success);
    background: color-mix(in srgb, var(--color-success) 12%, transparent);
    border-color: var(--color-success);
  }

  :global(:root[data-theme="dark"]) .share-section__button--tertiary {
    color: var(--color-dark-text-tertiary);
    border-color: var(--color-dark-border-default);
  }

  :global(:root[data-theme="dark"]) .share-section__button--tertiary:hover,
  :global(:root[data-theme="dark"]) .share-section__button--tertiary:focus {
    color: var(--color-dark-accent-primary);
    border-color: var(--color-dark-accent-primary);
  }
</style>
