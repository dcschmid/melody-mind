---
import Icon from "../visual/Icon.astro";
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-pressed="false"
  aria-label="Switch to dark theme"
>
  <span class="theme-toggle__pill" aria-hidden="true">
    <span class="theme-toggle__pill-icon" data-option="light">
      <Icon
        name="sun"
        class="theme-toggle__icon theme-toggle__icon--sun"
        aria-hidden="true"
        role="presentation"
      />
    </span>
    <span class="theme-toggle__pill-icon" data-option="dark">
      <Icon
        name="moon"
        class="theme-toggle__icon theme-toggle__icon--moon"
        aria-hidden="true"
        role="presentation"
      />
    </span>
  </span>
  <span class="theme-toggle__sr" aria-live="polite" aria-atomic="true">
    Theme mode: <span data-theme-toggle-label>system</span>
  </span>
</button>

<script>
  /**
   * ThemeToggle keeps the toggle button in sync with the stored, system, or resolved theme.
   * It writes ARIA attributes for the active mode and updates the system preference listener.
   */
  import {
    getStoredTheme,
    getSystemTheme,
    getResolvedTheme,
    setStoredTheme,
    applyTheme,
  } from "@shared-utils/utils/theme/themeStorage";

  const toggles = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]")
  );

  const updateToggle = (): void => {
    if (!toggles.length) {
      return;
    }

    const stored = getStoredTheme();
    const resolved = stored ?? getSystemTheme();
    toggles.forEach((toggle) => {
      const label = toggle.querySelector<HTMLSpanElement>("[data-theme-toggle-label]");
      toggle.dataset.theme = resolved;
      toggle.dataset.mode = stored ? "manual" : "system";
      if (label) {
        label.textContent = resolved;
      }
      toggle.setAttribute("aria-pressed", String(resolved === "dark"));
      toggle.setAttribute(
        "aria-label",
        resolved === "dark" ? "Switch to light theme" : "Switch to dark theme"
      );
    });
  };

  // Toggle manually switches between light/dark and persists the selection.
  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const nextTheme = getResolvedTheme() === "dark" ? "light" : "dark";
      setStoredTheme(nextTheme);
      applyTheme(nextTheme, "manual");
      updateToggle();
    });
  });

  // Re-apply the system theme only when the user has not locked in a preference.
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
    if (getStoredTheme()) {
      return;
    }

    applyTheme(getSystemTheme(), "system");
    updateToggle();
  });

  // External theme changes (e.g., storage updates) trigger a quick refresh of the toggle state.
  window.addEventListener("theme:change", () => {
    updateToggle();
  });

  updateToggle();
</script>

<style>
  .theme-toggle {
    position: relative;
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: flex-start;
    min-inline-size: 0;
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    cursor: pointer;
    background: none;
    border: none;
  }

  .theme-toggle:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .theme-toggle__pill {
      display: flex;
      gap: 0.4rem;
      padding: 0.35rem;
      background: var(--surface-3);
      border: 1px solid var(--border-default);
      border-radius: 999px;
      transition: none;
    }
  }

  .theme-toggle__pill {
    display: flex;
    gap: 0.4rem;
    padding: 0.35rem;
    background: color-mix(in srgb, var(--surface-3) 80%, var(--bg-primary) 20%);
    border: 1px solid color-mix(in srgb, var(--border-default) 70%, transparent);
    border-radius: 999px;
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .theme-toggle__pill-icon {
      display: grid;
      place-items: center;
      width: 2.25rem;
      height: 2.25rem;
      color: var(--text-secondary);
      border-radius: 999px;
      opacity: 0.3;
      transition: none;
    }
  }

  .theme-toggle__pill-icon {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--text-primary);
    border-radius: 999px;
    opacity: 0.55;
    transition:
      opacity var(--transition-fast),
      background var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .theme-toggle:hover .theme-toggle__pill,
  .theme-toggle:focus-visible .theme-toggle__pill {
    border-color: var(--accent-primary);
    box-shadow: var(--interactive-shadow-focus);
  }

  .theme-toggle__icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .theme-toggle[data-theme="light"] .theme-toggle__pill-icon[data-option="light"],
  .theme-toggle[data-theme="dark"] .theme-toggle__pill-icon[data-option="dark"] {
    color: var(--text-primary);
    background: var(--surface-1);
    box-shadow:
      var(--shadow-lg),
      inset 0 0 0 1px color-mix(in srgb, var(--surface-1) 10%, transparent);
    opacity: 1;
  }

  .theme-toggle[data-theme="light"]
    .theme-toggle__pill-icon[data-option="light"]
    .theme-toggle__icon {
    color: var(--accent-strong);
    filter: drop-shadow(
      0 0 4px color-mix(in srgb, var(--accent-primary) 40%, transparent)
    );
  }

  .theme-toggle[data-theme="dark"]
    .theme-toggle__pill-icon[data-option="dark"]
    .theme-toggle__icon {
    color: var(--accent-primary);
    filter: drop-shadow(
      0 0 4px color-mix(in srgb, var(--accent-primary) 50%, transparent)
    );
  }

  .theme-toggle__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: inset(50%);
  }
</style>
