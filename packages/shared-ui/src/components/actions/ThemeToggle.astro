---
import Icon from "../visual/Icon.astro";
---

<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  data-theme="system"
  aria-label="Theme mode selector"
>
  <span class="theme-toggle__pill" aria-hidden="true">
    <span class="theme-toggle__pill-icon" data-option="light">
      <Icon
        name="sun"
        class="theme-toggle__icon"
        aria-hidden="true"
        role="presentation"
      />
    </span>
    <span class="theme-toggle__pill-icon" data-option="dark">
      <Icon
        name="moon"
        class="theme-toggle__icon"
        aria-hidden="true"
        role="presentation"
      />
    </span>
    <span class="theme-toggle__pill-icon" data-option="system">
      <Icon
        name="monitor"
        class="theme-toggle__icon"
        aria-hidden="true"
        role="presentation"
      />
    </span>
  </span>
  <span class="theme-toggle__sr" aria-live="polite" aria-atomic="true">
    Theme mode: <span data-theme-toggle-label>system</span>
  </span>
</button>

<script>
  import { THEME_EVENTS } from "@shared-utils/constants/events";
  import {
    getStoredTheme,
    getSystemTheme,
    setStoredTheme,
    applyTheme,
    THEME_STORAGE_KEY,
    type Theme,
  } from "@shared-utils/utils/theme/themeStorage";

  const boundWindows = new WeakSet<Window & typeof globalThis>();

  const allToggles = (): HTMLButtonElement[] =>
    Array.from(document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]"));

  const getModeLabel = (stored: Theme | null): string => stored ?? "system";

  const getNextModeLabel = (stored: Theme | null): string =>
    stored === null ? "light" : stored === "light" ? "dark" : "system";

  const updateToggle = (toggle: HTMLButtonElement): void => {
    const stored = getStoredTheme();
    const label = toggle.querySelector<HTMLSpanElement>("[data-theme-toggle-label]");
    const modeLabel = getModeLabel(stored);
    const nextModeLabel = getNextModeLabel(stored);
    toggle.dataset.theme = modeLabel;
    toggle.dataset.mode = stored ? "manual" : "system";
    if (label) {
      label.textContent = modeLabel;
    }
    toggle.setAttribute(
      "aria-label",
      `Theme mode: ${modeLabel}. Switch to ${nextModeLabel} theme.`
    );
  };

  const updateAllToggles = (): void => {
    allToggles().forEach((toggle) => {
      bindToggle(toggle);
      updateToggle(toggle);
    });
  };

  const cycleTheme = (() => {
    const SEQUENCE: Array<Theme | null> = [null, "light", "dark"];
    return (stored: Theme | null): { next: Theme | null; stored: Theme | null } => {
      const index = stored === null ? 0 : SEQUENCE.indexOf(stored);
      const nextIndex = (index + 1) % SEQUENCE.length;
      return { next: SEQUENCE[nextIndex], stored: SEQUENCE[nextIndex] };
    };
  })();

  const bindToggle = (toggle: HTMLButtonElement): void => {
    if (toggle.dataset.themeToggleBound === "true") {
      return;
    }

    toggle.dataset.themeToggleBound = "true";
    toggle.addEventListener("click", () => {
      const stored = getStoredTheme();
      const { next, stored: nextStored } = cycleTheme(stored);
      try {
        setStoredTheme(nextStored);
      } catch {
        // localStorage unavailable; skip persistence and still apply theme.
      }
      applyTheme(next ?? getSystemTheme(), nextStored === null ? "system" : "manual");
    });
    updateToggle(toggle);
  };

  updateAllToggles();

  const win = window as Window & typeof globalThis;
  if (!boundWindows.has(win)) {
    boundWindows.add(win);

    const darkModeQuery = win.matchMedia?.("(prefers-color-scheme: dark)");
    darkModeQuery?.addEventListener("change", () => {
      if (getStoredTheme()) {
        return;
      }
      applyTheme(getSystemTheme(), "system");
    });

    win.addEventListener(THEME_EVENTS.CHANGED, () => {
      updateAllToggles();
    });

    win.addEventListener("storage", (event) => {
      if (event.key !== THEME_STORAGE_KEY) {
        return;
      }
      updateAllToggles();
    });
  }
</script>

<style>
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-inline-size: 0;
    min-block-size: var(--control-min-block-size);
    padding: 0;
    color: var(--text-primary);
    cursor: pointer;
    background: none;
    border: 0;
    border-radius: var(--radius-lg);
  }

  .theme-toggle:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .theme-toggle__pill {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--theme-toggle-pill-padding, calc(var(--spacing-xs) - 0.05rem));
    background: var(--theme-toggle-pill-bg, var(--surface-panel-raised));
    border: 1px solid var(--theme-toggle-pill-border-color, var(--surface-border-soft));
    border-radius: var(--radius-full);
    transition:
      background 250ms var(--motion-ease-standard),
      border-color 250ms var(--motion-ease-standard),
      box-shadow 250ms var(--motion-ease-standard);
  }

  .theme-toggle__pill-icon {
    display: grid;
    place-items: center;
    inline-size: var(
      --theme-toggle-pill-icon-size,
      var(--control-min-inline-size-compact)
    );
    block-size: var(--theme-toggle-pill-icon-size, var(--control-min-block-size-compact));
    margin-inline: var(--spacing-2xs, 0.125rem);
    color: var(--text-secondary);
    border-radius: var(--radius-full);
    opacity: 0.4;
    transform: scale(0.85);
    transition:
      color 200ms var(--motion-ease-standard),
      background 200ms var(--motion-ease-standard),
      opacity 200ms var(--motion-ease-standard),
      transform 200ms var(--motion-ease-standard);
    will-change: transform, opacity;
  }

  .theme-toggle:hover .theme-toggle__pill {
    background: var(--theme-toggle-pill-hover-bg, var(--surface-panel-raised));
    border-color: var(--theme-toggle-pill-hover-border-color, var(--surface-border-soft));
  }

  .theme-toggle:focus .theme-toggle__pill {
    background: var(--theme-toggle-pill-focus-bg, var(--surface-panel-raised));
    border-color: var(
      --theme-toggle-pill-focus-border-color,
      var(--surface-border-medium)
    );
  }

  .theme-toggle:active .theme-toggle__pill {
    transform: scale(0.96);
    transition-duration: 150ms;
  }

  .theme-toggle[data-theme="light"] .theme-toggle__pill-icon[data-option="light"],
  .theme-toggle[data-theme="dark"] .theme-toggle__pill-icon[data-option="dark"],
  .theme-toggle[data-mode="system"] .theme-toggle__pill-icon[data-option="system"] {
    color: var(--accent-strong);
    background: color-mix(in srgb, var(--accent-primary) 15%, var(--surface-1));
    opacity: 1;
    transform: scale(1);
  }

  .theme-toggle[data-theme="light"] .theme-toggle__pill-icon[data-option="dark"],
  .theme-toggle[data-theme="light"] .theme-toggle__pill-icon[data-option="system"],
  .theme-toggle[data-theme="dark"] .theme-toggle__pill-icon[data-option="light"],
  .theme-toggle[data-theme="dark"] .theme-toggle__pill-icon[data-option="system"],
  .theme-toggle[data-mode="system"] .theme-toggle__pill-icon[data-option="light"],
  .theme-toggle[data-mode="system"] .theme-toggle__pill-icon[data-option="dark"] {
    opacity: 0.4;
    transform: scale(0.85);
  }

  .theme-toggle__sr {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .theme-toggle__pill {
      transition: none;
    }

    .theme-toggle__pill-icon {
      opacity: 1 !important;
      transform: none !important;
      transition: none;
    }

    .theme-toggle:active .theme-toggle__pill {
      transform: none;
    }
  }
</style>
