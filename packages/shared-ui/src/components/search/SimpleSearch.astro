---
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

export interface SearchItem {
  title: string;
  description?: string;
  url: string;
}

interface Props {
  idBase: string;
  items: SearchItem[];
  label?: string;
  placeholder?: string;
  emptyText?: string;
  noResultsText?: string;
  limit?: number;
  initialQuery?: string;
}

const {
  idBase,
  items,
  label = "Search",
  placeholder = "Search...",
  emptyText = "Start typing to search.",
  noResultsText = "No results found.",
  limit = 20,
  initialQuery = "",
} = Astro.props as Props;

const inputId = `${idBase}-input`;
---

<div class="simple-search" data-simple-search-root data-simple-search-id={idBase}>
  <div class="simple-search__field">
    <label class="simple-search__label" for={inputId}>{label}</label>
    <input
      id={inputId}
      class="simple-search__input"
      type="search"
      placeholder={placeholder}
      autocomplete="off"
      spellcheck="false"
      aria-label={label}
      value={initialQuery}
      data-simple-search-input
    />
  </div>

  <Paragraph
    textSize="sm"
    className="simple-search__status"
    data-simple-search-status
    role="status"
    aria-live="polite"
  >
    {emptyText}
  </Paragraph>

  <ul
    class="simple-search__results"
    data-simple-search-results
    aria-label="Search results"
  >
  </ul>
</div>

<script is:inline define:vars={{ items, emptyText, noResultsText, limit, initialQuery }}>
  const roots = document.querySelectorAll("[data-simple-search-root]");

  const escapeText = (value) => (value || "").toString();
  const normalize = (value) =>
    (value || "")
      .toString()
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim();

  const scoreItem = (item, query) => {
    const q = normalize(query);
    const title = normalize(item.title);
    const description = normalize(item.description);
    let score = 0;
    if (title === q) {
      score += 100;
    }
    if (title.startsWith(q)) {
      score += 50;
    }
    if (title.includes(q)) {
      score += 20;
    }
    if (description.includes(q)) {
      score += 10;
    }
    return score;
  };

  roots.forEach((root) => {
    const input = root.querySelector("[data-simple-search-input]");
    const results = root.querySelector("[data-simple-search-results]");
    const status = root.querySelector("[data-simple-search-status]");
    if (
      !(input instanceof HTMLInputElement) ||
      !(results instanceof HTMLElement) ||
      !(status instanceof HTMLElement)
    ) {
      return;
    }

    const updateUrl = (query) => {
      const url = new URL(window.location.href);
      const trimmedQuery = query.trim();
      if (trimmedQuery) {
        url.searchParams.set("q", trimmedQuery);
      } else {
        url.searchParams.delete("q");
      }
      window.history.replaceState({}, "", url);
    };

    const renderResults = (matches) => {
      results.replaceChildren();
      if (!matches.length) {
        status.textContent = noResultsText;
        return;
      }

      status.textContent = `${matches.length} result${matches.length === 1 ? "" : "s"} found`;

      matches.forEach((item, index) => {
        const listItem = document.createElement("li");
        listItem.className = "simple-search__result-item";

        const link = document.createElement("a");
        link.href = escapeText(item.url);
        link.className = "simple-search__result-link";

        const rank = document.createElement("span");
        rank.className = "simple-search__result-rank";
        rank.setAttribute("aria-hidden", "true");
        rank.textContent = String(index + 1);

        const copy = document.createElement("span");
        copy.className = "simple-search__result-copy";

        const title = document.createElement("strong");
        title.className = "simple-search__result-title";
        title.textContent = escapeText(item.title);
        copy.appendChild(title);

        if (item.description) {
          const description = document.createElement("span");
          description.className = "simple-search__result-description";
          description.textContent = escapeText(item.description);
          copy.appendChild(description);
        }

        const arrow = document.createElement("span");
        arrow.className = "simple-search__result-arrow";
        arrow.setAttribute("aria-hidden", "true");
        arrow.textContent = "→";

        link.append(rank, copy, arrow);
        listItem.appendChild(link);
        results.appendChild(listItem);
      });
    };

    const runSearch = (query) => {
      const q = normalize(query);
      if (!q) {
        results.replaceChildren();
        status.textContent = emptyText;
        return;
      }

      const matches = items
        .map((item) => ({ ...item, _score: scoreItem(item, q) }))
        .filter((item) => item._score > 0)
        .sort((a, b) => b._score - a._score || a.title.localeCompare(b.title))
        .slice(0, limit);

      renderResults(matches);
    };

    const startupQuery =
      input.value ||
      initialQuery ||
      new URL(window.location.href).searchParams.get("q") ||
      "";

    if (startupQuery) {
      input.value = startupQuery;
      runSearch(startupQuery);
    }

    input.addEventListener("input", (event) => {
      const value =
        event.currentTarget instanceof HTMLInputElement ? event.currentTarget.value : "";
      updateUrl(value);
      runSearch(value);
    });
  });
</script>

<style>
  .simple-search {
    display: grid;
    gap: var(--spacing-base);
    min-inline-size: 0;
  }

  .simple-search__field {
    display: grid;
    gap: var(--spacing-xs);
  }

  .simple-search__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .simple-search__input {
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font: inherit;
    font-size: var(--font-size-base);
    color: var(--text-primary);
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .simple-search__input:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--surface-border-accent-strong);
  }

  .simple-search__status {
    margin: 0;
    color: var(--text-secondary);
  }

  .simple-search__results {
    display: grid;
    gap: var(--spacing-sm);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .simple-search__result-item {
    display: grid;
  }

  .simple-search__result-link {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--spacing-sm);
    align-items: start;
    padding: var(--spacing-base);
    color: var(--text-primary);
    text-decoration: none;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .simple-search__result-link:hover,
  .simple-search__result-link:focus {
    background: var(--surface-card-hover);
    border-color: var(--surface-border-accent);
  }

  .simple-search__result-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--surface-border-accent-strong);
  }

  .simple-search__result-rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--icon-size-xl);
    block-size: var(--icon-size-xl);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 8%, transparent);
    border-radius: var(--radius-full);
  }

  .simple-search__result-copy {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .simple-search__result-title {
    font-size: var(--font-size-base);
    line-height: var(--line-height-snug);
    color: var(--text-primary);
  }

  .simple-search__result-description {
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .simple-search__result-arrow {
    color: var(--text-tertiary);
  }

  @media (width < 640px) {
    .simple-search__result-link {
      grid-template-columns: minmax(0, 1fr);
    }

    .simple-search__result-arrow {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .simple-search__result-link {
      transition: none;
    }
  }
</style>
