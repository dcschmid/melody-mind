---
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
export interface SearchItem {
  title: string;
  description?: string;
  url: string;
}

interface Props {
  items: SearchItem[];
  placeholder?: string;
  emptyText?: string;
  noResultsText?: string;
  limit?: number;
  initialQuery?: string;
}

const {
  items,
  placeholder = "Search...",
  emptyText = "Start typing to search.",
  noResultsText = "No results found.",
  limit = 20,
  initialQuery = "",
} = Astro.props as Props;
---

<div class="simple-search" data-simple-search-root>
  <div class="simple-search__field">
    <label class="simple-search__label" for="simple-search-input">Search</label>
    <input
      id="simple-search-input"
      class="simple-search__input"
      type="search"
      placeholder={placeholder}
      autocomplete="off"
      value={initialQuery}
      data-simple-search-input
    />
  </div>

  <Paragraph
    textSize="sm"
    className="simple-search__status"
    data-simple-search-status
    role="status"
    aria-live="polite"
    aria-atomic="true"
  >
    {emptyText}
  </Paragraph>

  <ul
    class="simple-search__results"
    data-simple-search-results
    aria-label="Search results"
  >
  </ul>
</div>

<script is:inline define:vars={{ items, emptyText, noResultsText, limit, initialQuery }}>
  const root = document.querySelector("[data-simple-search-root]");
  const input = root?.querySelector("[data-simple-search-input]");
  const results = root?.querySelector("[data-simple-search-results]");
  const status = root?.querySelector("[data-simple-search-status]");

  const escapeHtml = (value) =>
    (value || "")
      .toString()
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");

  const normalize = (value) =>
    (value || "")
      .toString()
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim();

  const scoreItem = (item, query) => {
    const q = normalize(query);
    const title = normalize(item.title);
    const description = normalize(item.description);

    let score = 0;

    if (title === q) {
      score += 100;
    }
    if (title.startsWith(q)) {
      score += 50;
    }
    if (title.includes(q)) {
      score += 20;
    }
    if (description.includes(q)) {
      score += 10;
    }

    return score;
  };

  const updateUrl = (query) => {
    const url = new URL(window.location.href);
    const trimmedQuery = query.trim();

    if (trimmedQuery) {
      url.searchParams.set("q", trimmedQuery);
    } else {
      url.searchParams.delete("q");
    }

    window.history.replaceState({}, "", url);
  };

  const renderResults = (matches) => {
    if (!results || !status) {
      return;
    }

    if (!matches.length) {
      results.innerHTML = "";
      status.textContent = noResultsText;
      return;
    }

    status.textContent = `${matches.length} result${matches.length === 1 ? "" : "s"} found`;

    results.innerHTML = matches
      .map(
        (item, index) => `
          <li class="simple-search__result-item">
            <a href="${escapeHtml(item.url)}" class="simple-search__result-link">
              <span class="simple-search__result-rank" aria-hidden="true">${index + 1}</span>
              <span class="simple-search__result-copy">
                <strong class="simple-search__result-title">${escapeHtml(item.title)}</strong>
                ${
                  item.description
                    ? `<span class="simple-search__result-description">${escapeHtml(item.description)}</span>`
                    : ""
                }
              </span>
              <span class="simple-search__result-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        `
      )
      .join("");
  };

  const runSearch = (query) => {
    if (!results || !status) {
      return;
    }

    const q = normalize(query);

    if (!q) {
      results.innerHTML = "";
      status.textContent = emptyText;
      return;
    }

    const matches = items
      .map((item) => ({
        ...item,
        _score: scoreItem(item, q),
      }))
      .filter((item) => item._score > 0)
      .sort((a, b) => b._score - a._score || a.title.localeCompare(b.title))
      .slice(0, limit);

    renderResults(matches);
  };

  const getUrlQuery = () =>
    new URL(window.location.href).searchParams.get("q")?.trim() || "";

  input?.addEventListener("input", (event) => {
    const value =
      event.currentTarget instanceof HTMLInputElement ? event.currentTarget.value : "";
    updateUrl(value);
    runSearch(value);
  });

  const startupQuery = initialQuery || getUrlQuery();

  if (input instanceof HTMLInputElement && input.value !== startupQuery) {
    input.value = startupQuery;
  }

  if (startupQuery) {
    runSearch(startupQuery);
  }
</script>

<style>
  /* -----------------------------------------------------------------------------
     SimpleSearch Component Styles
     Basic search with input field and inline results
     WCAG AAA compliant with proper focus states and touch targets
     ----------------------------------------------------------------------------- */

  .simple-search {
    display: grid;
    gap: var(--spacing-lg);
    min-inline-size: 0;
  }

  /* Search field container */
  .simple-search__field {
    display: grid;
    gap: var(--spacing-sm);
  }

  /* Search label */
  .simple-search__label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  /* Search input field */
  .simple-search__input {
    box-sizing: border-box;

    /* Sizing */
    inline-size: 100%;
    min-block-size: 3.5rem;
    padding: var(--spacing-md) var(--spacing-lg);

    /* Typography */
    font: inherit;
    font-size: var(--font-size-lg);
    color: var(--text-primary);

    /* Visual styling */
    background: var(--bg-primary);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-xl);
  }

  .simple-search__input::placeholder {
    color: var(--text-tertiary);
  }

  .simple-search__input:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--accent-primary);
  }

  /* Status message - shows result count */
  .simple-search__status {
    margin: 0;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  /* Results list */
  .simple-search__results {
    display: grid;
    gap: var(--spacing-md);
    min-inline-size: 0;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  :global(.simple-search__result-item) {
    display: grid;
  }

  /* Result link - card style */
  :global(.simple-search__result-link) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--spacing-md);
    align-items: start;
    min-inline-size: 0;
    padding: var(--spacing-lg) var(--spacing-lg);
    color: var(--text-primary);
    text-decoration: none;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 94%, transparent),
      color-mix(in srgb, var(--surface-2) 72%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--border-default) 78%, transparent);
    border-radius: var(--radius-xl);
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  :global(.simple-search__result-link:hover),
  :global(.simple-search__result-link:focus-visible) {
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  :global(.simple-search__result-link:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  :global(.simple-search__result-rank) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 2rem;
    min-block-size: 2rem;
    padding: 0 var(--spacing-xs);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-primary) 28%, transparent);
    border-radius: var(--radius-full);
  }

  :global(.simple-search__result-copy) {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  /* Result title */
  :global(.simple-search__result-title) {
    display: block;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-snug);
    color: var(--heading-color);
    text-wrap: balance;
  }

  /* Result description */
  :global(.simple-search__result-description) {
    display: block;
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 3;
    line-height: var(--prose-line-height);
    color: var(--text-secondary);
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global(.simple-search__result-arrow) {
      align-self: center;
      font-size: 1.1rem;
      color: color-mix(in srgb, var(--text-secondary) 70%, transparent);
      transition: none;
    }
  }

  :global(.simple-search__result-arrow) {
    align-self: center;
    font-size: 1.1rem;
    color: color-mix(in srgb, var(--text-secondary) 70%, transparent);
    transition:
      transform var(--transition-fast),
      color var(--transition-fast);
  }

  :global(.simple-search__result-link:hover .simple-search__result-arrow),
  :global(.simple-search__result-link:focus-visible .simple-search__result-arrow) {
    color: var(--accent-primary);
    transform: translateX(2px);
  }

  @media (width < 640px) {
    .simple-search {
      gap: var(--spacing-md);
    }

    .simple-search__input {
      min-block-size: 3.25rem;
      padding: 0.875rem 1rem;
      font-size: var(--font-size-base);
    }

    .simple-search__status {
      font-size: var(--font-size-sm);
    }

    :global(.simple-search__result-link) {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--spacing-sm);
      padding: var(--spacing-md);
    }

    :global(.simple-search__result-rank) {
      min-inline-size: 2.25rem;
      min-block-size: 2.25rem;
      font-size: var(--font-size-xs);
    }

    :global(.simple-search__result-title) {
      font-size: var(--font-size-lg);
      text-wrap: pretty;
    }

    :global(.simple-search__result-description) {
      -webkit-line-clamp: 2;
    }

    :global(.simple-search__result-arrow) {
      display: none;
    }
  }

  /* Reduced motion support - disable all animations */
  @media screen and (prefers-reduced-motion: reduce) {
    :global(.simple-search__result-link) {
      transition: none;
    }

    :global(.simple-search__result-link:hover),
    :global(.simple-search__result-link:focus-visible) {
      transform: none;
    }
  }
</style>
