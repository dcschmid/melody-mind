---
interface Props {
  initialQuery?: string;
  searchIndexUrl?: string;
  title: string;
  lead: string;
  placeholder: string;
  emptyText: string;
  noResultsText: string;
  resultLimit?: number;
  eyebrow?: string;
  helpText?: string;
  metaFields?: string[];
  headerVariant?: "card" | "underlined";
  resultsVariant?: "card" | "list";
}

const {
  initialQuery = "",
  searchIndexUrl = "/search-index.json",
  title,
  lead,
  placeholder,
  emptyText,
  noResultsText,
  resultLimit = 24,
  eyebrow = "Search the archive",
  helpText,
  metaFields = [],
  headerVariant = "card",
  resultsVariant = "card",
} = Astro.props as Props;
---

<section
  class:list={[
    "orama-search",
    `orama-search--header-${headerVariant}`,
    `orama-search--results-${resultsVariant}`,
  ]}
  data-orama-search
  data-index-url={searchIndexUrl}
  data-initial-query={initialQuery}
  data-empty-text={emptyText}
  data-no-results-text={noResultsText}
  data-result-limit={resultLimit}
  data-meta-fields={metaFields.join(",")}
>
  <header class="orama-search__header">
    <h1 class="orama-search__title">{title}</h1>
    <p class="orama-search__lead">{lead}</p>
  </header>

  <section class="orama-search__panel" aria-labelledby="orama-search-results-title">
    <div class="orama-search__panel-head">
      <p class="orama-search__eyebrow">{eyebrow}</p>
      <h2 id="orama-search-results-title" class="orama-search__results-title">Results</h2>
      {helpText ? <p class="orama-search__help">{helpText}</p> : null}
    </div>

    <label class="orama-search__field">
      <span class="orama-search__field-label">Search query</span>
      <input
        class="orama-search__input"
        type="search"
        value={initialQuery}
        {placeholder}
        autocomplete="off"
        spellcheck="false"
        data-orama-search-input
      />
    </label>

    <p class="orama-search__status" aria-live="polite" data-orama-search-status>
      {initialQuery ? "Loading results..." : emptyText}
    </p>
    <ol class="orama-search__results" data-orama-search-results></ol>
  </section>
</section>

<script>
  import { loadIndex, searchIndex } from "@freshjuice/astro-search-plugin/core";

  const roots = document.querySelectorAll("[data-orama-search]");

  roots.forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.oramaSearchBound === "true") {
      return;
    }

    root.dataset.oramaSearchBound = "true";

    const input = root.querySelector("[data-orama-search-input]");
    const status = root.querySelector("[data-orama-search-status]");
    const results = root.querySelector("[data-orama-search-results]");

    if (
      !(input instanceof HTMLInputElement) ||
      !(status instanceof HTMLElement) ||
      !(results instanceof HTMLOListElement)
    ) {
      return;
    }

    const indexUrl = root.dataset.indexUrl || "/search-index.json";
    const emptyText = root.dataset.emptyText || "Type a title or keyword.";
    const noResultsText = root.dataset.noResultsText || "No matching results found.";
    const resultLimit = Number.parseInt(root.dataset.resultLimit || "24", 10);
    const metaFields = (root.dataset.metaFields || "")
      .split(",")
      .map((field) => field.trim())
      .filter(Boolean);
    const indexPromise = loadIndex(indexUrl);

    const updateUrl = (query: string) => {
      const url = new URL(window.location.href);

      if (query) {
        url.searchParams.set("q", query);
      } else {
        url.searchParams.delete("q");
      }

      window.history.replaceState(null, "", `${url.pathname}${url.search}${url.hash}`);
    };

    const getMetaValue = (document: Record<string, unknown>, field: string) => {
      const value = document[field];
      return Array.isArray(value) ? value : [value];
    };

    const renderResults = (hits: Array<{ document: Record<string, unknown> }>) => {
      results.replaceChildren();

      for (const hit of hits) {
        const resultDocument = hit.document;
        const item = document.createElement("li");
        const link = document.createElement("a");
        const title = document.createElement("span");
        const description = document.createElement("span");
        const meta = document.createElement("span");

        item.className = "orama-search__result-item";
        link.className = "orama-search__result-link";
        title.className = "orama-search__result-title";
        description.className = "orama-search__result-description";
        meta.className = "orama-search__result-meta";

        link.href = String(resultDocument.url || "#");
        title.textContent = String(
          resultDocument.title || resultDocument.url || "Untitled"
        );
        description.textContent = String(resultDocument.desc || "");
        meta.textContent = metaFields
          .flatMap((field) => getMetaValue(resultDocument, field))
          .filter(Boolean)
          .join(" / ");

        link.append(title, description);
        if (meta.textContent) {
          link.append(meta);
        }
        item.append(link);
        results.append(item);
      }
    };

    const runSearch = async () => {
      const query = input.value.trim();
      updateUrl(query);

      if (!query) {
        results.replaceChildren();
        status.textContent = emptyText;
        return;
      }

      status.textContent = "Searching...";

      try {
        const index = await indexPromise;
        const hits = await searchIndex(index, query, {
          limit: Number.isFinite(resultLimit) ? resultLimit : 24,
        });

        renderResults(hits);
        status.textContent =
          hits.length > 0
            ? `${hits.length} ${hits.length === 1 ? "result" : "results"}`
            : noResultsText;
      } catch (error) {
        console.error("[orama-search]", error);
        status.textContent = "Search is unavailable right now.";
      }
    };

    input.addEventListener("input", () => {
      void runSearch();
    });

    if (input.value.trim()) {
      void runSearch();
    }
  });
</script>

<style>
  .orama-search {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .orama-search__header {
    display: grid;
    gap: var(--spacing-xs);
  }

  .orama-search--header-card .orama-search__header {
    padding: var(--spacing-base);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .orama-search--header-underlined .orama-search__header {
    padding-block-end: var(--spacing-lg);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .orama-search__title {
    margin: 0;
    font-size: var(--font-size-3xl);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }

  .orama-search__lead {
    max-inline-size: var(--measure-readable);
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .orama-search__panel {
    display: grid;
    gap: var(--spacing-base);
  }

  .orama-search__panel-head {
    display: grid;
    gap: var(--spacing-xs);
  }

  .orama-search__eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  .orama-search__results-title {
    margin: 0;
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }

  .orama-search__help,
  .orama-search__status {
    margin: 0;
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .orama-search__field {
    display: grid;
    gap: var(--spacing-sm);
  }

  .orama-search__field-label {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .orama-search__input {
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font: inherit;
    color: var(--text-primary);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-base);
  }

  .orama-search__input:focus {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .orama-search__results {
    display: grid;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .orama-search--results-card .orama-search__results {
    gap: var(--spacing-sm);
  }

  .orama-search--results-list .orama-search__results {
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .orama-search__result-link {
    display: grid;
    gap: var(--spacing-xs);
    color: inherit;
    text-decoration: none;
  }

  .orama-search--results-card .orama-search__result-link {
    padding: var(--spacing-base);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-base);
  }

  .orama-search--results-list .orama-search__result-link {
    padding-block: var(--spacing-base);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .orama-search__result-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .orama-search--results-card .orama-search__result-link:hover,
  .orama-search--results-card .orama-search__result-link:focus {
    border-color: var(--surface-border-accent);
  }

  .orama-search--results-list .orama-search__result-link:hover,
  .orama-search--results-list .orama-search__result-link:focus-visible {
    color: var(--accent-primary);
  }

  .orama-search__result-title {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .orama-search__result-description {
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .orama-search__result-meta {
    font-size: var(--font-size-sm);
    color: var(--text-tertiary);
  }

  @media (width >= 640px) {
    .orama-search--header-card .orama-search__header {
      padding: var(--spacing-lg);
    }
  }
</style>
