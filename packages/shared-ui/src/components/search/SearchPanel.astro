---
/**
 * Lightweight Search Panel
 *
 * Provides the consistent markup needed by `initSearchPanel` without the previous
 * prop explosion. Only the essentials remain: ids/labels and optional text templates
 * for the auto-managed status + no-results helpers.
 */
import Icon from "@shared-ui/components/visual/Icon.astro";

export interface Props {
  idBase: string;
  label: string;
  placeholder: string;
  ariaControls: string;
  /** Analytics surface key for result-click tracking */
  analyticsSurface?: string;
  /** Text shown when all items visible */
  statusAllText?: string;
  /** Template for results count (use {count}) */
  statusCountTemplate?: string;
  /** Template for no results (use {term}) */
  noResultsTemplate?: string;
}

const {
  idBase,
  label,
  placeholder,
  ariaControls,
  analyticsSurface = "unknown",
  statusAllText = "Showing all results",
  statusCountTemplate = "{count} results",
  noResultsTemplate = 'No results for "{term}"',
} = Astro.props as Props;

const inputId = `${idBase}-input`;
const clearId = `${idBase}-clear`;
const resetId = `${idBase}-reset`;
const statusId = `${idBase}-status`;
const noResultsId = `${idBase}-no-results`;
const inputClasses = "search-panel__input";
---

<div class="search-panel" data-search-root data-search-surface={analyticsSurface}>
  <div class="search-panel__bar">
    <div class="search-panel__field">
      <label for={inputId} class="search-panel__sr">{label}</label>
      <div class="search-panel__icon">
        <Icon name="search" aria-hidden="true" />
      </div>
      <input
        id={inputId}
        type="search"
        class={inputClasses}
        {placeholder}
        aria-controls={ariaControls}
        aria-describedby={statusId}
        autocomplete="off"
        data-search-input
      />
      <button
        id={clearId}
        class="search-panel__clear"
        type="button"
        aria-label="Clear search input"
        data-search-clear
        hidden
        aria-hidden="true"
        tabindex="-1"
      >
        <Icon name="x" aria-hidden="true" />
      </button>
    </div>
    <slot name="controls" />
    <button
      id={resetId}
      class="search-panel__reset"
      type="button"
      aria-label="Reset search"
      aria-controls={ariaControls}
      data-search-reset
    >
      <Icon name="refresh-ccw" class="search-panel__reset-icon" aria-hidden="true" />
      <span>Reset search</span>
    </button>
  </div>
  <div class="search-panel__meta">
    <div
      id={statusId}
      data-search-status
      class="search-panel__status"
      role="status"
      aria-live="polite"
      aria-atomic="true"
      data-search-status-all={statusAllText}
      data-search-status-count={statusCountTemplate}
    >
    </div>
    <div
      id={noResultsId}
      data-search-no-results
      hidden
      data-search-no-results-tpl={noResultsTemplate}
      class="search-panel__no-results"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
    </div>
    <slot name="status" />
    <slot name="no-results" />
  </div>
</div>
<style>
  /* -----------------------------------------------------------------------------
     SearchPanel Component Styles
     Minimal search interface with field, clear button, and reset
     WCAG AAA compliant with proper focus states
     ----------------------------------------------------------------------------- */

  .search-panel {
    display: grid;
    gap: var(--spacing-md);
    inline-size: 100%;
  }

  /* Shell container - wraps entire search panel */
  :global(.search-panel-shell) {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    inline-size: 100%;
    max-inline-size: var(--search-shell-max-inline-size, none);
    min-block-size: var(--search-shell-min-block-size, auto);
    padding: var(--spacing-md) var(--spacing-lg);
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--surface-2) 92%, var(--bg-primary)),
      color-mix(in srgb, var(--surface-1) 96%, transparent)
    );
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
  }

  @media (width >= 640px) {
    :global(.search-panel-shell) {
      padding: var(--spacing-lg) var(--spacing-xl);
    }
  }

  :global(.search-panel-shell .search-panel) {
    gap: var(--spacing-sm);
  }

  /* Bar - contains field and controls */
  .search-panel__bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
  }

  /* Input field container */
  .search-panel__field {
    position: relative;
    flex: 1 1 18rem;
    min-inline-size: 0;
  }

  /* Screen reader only label */
  .search-panel__sr {
    position: absolute !important;
    inline-size: 1px !important;
    block-size: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    white-space: nowrap !important;
    border: 0 !important;
    clip-path: inset(50%) !important;
  }

  /* Search icon - positioned inside input */
  .search-panel__icon {
    /* Positioning */
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;

    /* Layout */
    display: flex;
    align-items: center;
    padding-inline-start: var(--spacing-lg);

    /* Visual styling */
    color: var(--text-secondary);
    pointer-events: none;
  }

  .search-panel__icon :global(svg) {
    display: block;
    inline-size: 1.5rem;
    block-size: 1.5rem;
  }

  /* Search input field */
  @media screen and (prefers-reduced-motion: reduce) {
    .search-panel__input {
      /* Sizing */
      inline-size: 100%;
      padding: var(--spacing-md) 4rem var(--spacing-md) 3.5rem;

      /* Typography */
      font-size: var(--font-size-lg);
      font-weight: var(--font-weight-semibold);
      color: var(--text-primary);

      /* Visual styling */
      background: var(--bg-primary);
      border: 2px solid var(--border-default);
      border-radius: var(--radius-full);

      /* Smooth transitions */
      transition: none;
    }
  }

  .search-panel__input {
    /* Sizing */
    inline-size: 100%;
    padding: var(--spacing-md) 4rem var(--spacing-md) 3.5rem;

    /* Typography */
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);

    /* Visual styling */
    background: var(--bg-primary);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-full);

    /* Smooth transitions */
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  @media (width >= 640px) {
    .search-panel__input {
      font-size: var(--font-size-xl);
    }
  }

  .search-panel__input::placeholder {
    color: var(--text-tertiary);
  }

  .search-panel__input:hover,
  .search-panel__input:focus-visible {
    border-color: var(--accent-strong);
    box-shadow:
      inset 0 0 0 1px var(--accent-strong),
      var(--interactive-shadow-focus);
  }

  .search-panel__input:focus-visible + .search-panel__icon,
  .search-panel__input:hover + .search-panel__icon {
    color: var(--text-primary);
  }

  /* Clear button - removes search query */
  @media screen and (prefers-reduced-motion: reduce) {
    .search-panel__clear {
      padding: var(--spacing-xs);
      color: var(--text-secondary);
      cursor: pointer;
      background: transparent;
      border: none;
      transition: none;
    }
  }

  .search-panel__clear {
    padding: var(--spacing-xs);
    color: var(--text-secondary);
    cursor: pointer;
    background: transparent;
    border: none;
    transition: color var(--transition-fast);
  }

  .search-panel__clear :global(svg) {
    display: block;
    inline-size: 1.2rem;
    block-size: 1.2rem;
  }

  .search-panel__clear:hover,
  .search-panel__clear:focus-visible {
    color: var(--text-primary);
  }

  .search-panel__clear:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* Reset button - clears all filters and search */
  @media screen and (prefers-reduced-motion: reduce) {
    .search-panel__reset {
      /* Layout */
      display: flex;
      gap: var(--spacing-xs);
      align-items: center;
      padding: var(--spacing-sm) var(--spacing-md);

      /* Typography */
      font-weight: var(--font-weight-semibold);
      color: var(--text-primary);

      /* Visual styling */
      cursor: pointer;
      background: color-mix(in srgb, var(--surface-2) 92%, var(--surface-1));
      border: 2px solid transparent;
      border-radius: var(--radius-full);

      /* Smooth transitions */
      transition: none;
    }
  }

  .search-panel__reset {
    /* Layout */
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-md);

    /* Typography */
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);

    /* Visual styling */
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-2) 92%, var(--surface-1));
    border: 2px solid transparent;
    border-radius: var(--radius-full);

    /* Smooth transitions */
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .search-panel__reset:hover,
  .search-panel__reset:focus-visible {
    background: color-mix(in srgb, var(--accent-primary) 10%, var(--surface-1));
    border-color: var(--accent-strong);
    box-shadow: var(--interactive-shadow-focus);
  }

  .search-panel__reset:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .search-panel__reset-icon {
    inline-size: 1rem;
    block-size: 1rem;
  }

  /* Meta section - status and no-results messages */
  .search-panel__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    align-items: center;
    padding-inline: var(--spacing-xs);
  }

  .search-panel__status,
  .search-panel__no-results {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  /* Reduced motion support - disable all animations */
  @media screen and (prefers-reduced-motion: reduce) {
    .search-panel__input,
    .search-panel__clear,
    .search-panel__reset {
      transition: none;
    }
  }
</style>
