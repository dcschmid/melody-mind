---
import Icon from "@shared-ui/components/visual/Icon.astro";

export interface Props {
  idBase: string;
  label: string;
  placeholder: string;
  ariaControls: string;
  analyticsSurface?: string;
  statusAllText?: string;
  statusCountTemplate?: string;
  noResultsTemplate?: string;
}

const {
  idBase,
  label,
  placeholder,
  ariaControls,
  analyticsSurface = "unknown",
  statusAllText = "Showing all results",
  statusCountTemplate = "{count} results",
  noResultsTemplate = 'No results for "{term}"',
} = Astro.props as Props;

const inputId = `${idBase}-input`;
const statusId = `${idBase}-status`;
const noResultsId = `${idBase}-no-results`;
---

<div class="search-panel" data-search-root data-search-surface={analyticsSurface}>
  <div class="search-panel__bar">
    <div class="search-panel__field">
      <label for={inputId} class="search-panel__label">{label}</label>
      <span class="search-panel__icon" aria-hidden="true">
        <Icon name="search" aria-hidden="true" />
      </span>
      <input
        id={inputId}
        type="search"
        class="search-panel__input"
        {placeholder}
        inputmode="search"
        autocapitalize="off"
        aria-controls={ariaControls}
        aria-describedby={statusId}
        autocomplete="off"
        spellcheck="false"
        data-search-input
      />
      <button
        class="search-panel__clear"
        type="button"
        aria-label="Clear search input"
        data-search-clear
        hidden
        aria-hidden="true"
        tabindex="-1"
      >
        <Icon name="x" aria-hidden="true" />
      </button>
    </div>
    <slot name="controls" />
    <button
      class="search-panel__reset"
      type="button"
      aria-label="Reset search"
      aria-controls={ariaControls}
      data-search-reset
    >
      <Icon name="refresh-ccw" class="search-panel__reset-icon" aria-hidden="true" />
      <span>Reset</span>
    </button>
  </div>

  <div class="search-panel__meta">
    <div
      id={statusId}
      data-search-status
      class="search-panel__status"
      role="status"
      aria-live="polite"
      data-search-status-all={statusAllText}
      data-search-status-count={statusCountTemplate}
    >
    </div>
    <div
      id={noResultsId}
      data-search-no-results
      hidden
      data-search-no-results-tpl={noResultsTemplate}
      class="search-panel__no-results"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
    </div>
    <slot name="status" />
    <slot name="no-results" />
  </div>
</div>

<style>
  .search-panel {
    display: grid;
    gap: var(--spacing-md);
    inline-size: 100%;
  }

  .search-panel__bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: end;
  }

  .search-panel__field {
    position: relative;
    flex: 1 1 18rem;
    min-inline-size: 0;
  }

  @media (width <= 480px) {
    .search-panel__bar {
      flex-direction: column;
      align-items: stretch;
    }

    .search-panel__field {
      flex: 1 1 100%;
    }

    .search-panel__reset {
      justify-content: center;
      width: 100%;
    }
  }

  .search-panel__label {
    display: block;
    margin-block-end: var(--spacing-xs);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .search-panel__icon {
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    display: grid;
    place-items: center;
    inline-size: var(--control-min-inline-size);
    block-size: var(--control-min-block-size);
    color: var(--accent-primary);
    pointer-events: none;
  }

  .search-panel__input {
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) calc(var(--control-min-inline-size) + var(--spacing-sm))
      var(--spacing-sm) calc(var(--control-min-inline-size) + var(--spacing-xs));
    font: inherit;
    font-size: var(--font-size-base);
    color: var(--text-primary);
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--accent-primary);
    border-radius: var(--radius-lg);
  }

  .search-panel__input:focus-visible {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px oklch(from var(--accent-primary) l c h / 0.15);
  }

  @media (prefers-reduced-motion: no-preference) {
    .search-panel__input {
      transition:
        box-shadow var(--motion-duration-fast) var(--motion-ease-standard),
        border-color var(--motion-duration-fast) var(--motion-ease-standard);
    }
  }

  .search-panel__input::placeholder {
    color: var(--text-tertiary);
  }

  .search-panel__clear {
    position: absolute;
    inset-block-end: 0;
    inset-inline-end: 0;
    display: grid;
    place-items: center;
    inline-size: var(--control-min-inline-size);
    block-size: var(--control-min-block-size);
    color: var(--text-primary);
    cursor: pointer;
    background: transparent;
    border: 0;
    border-radius: var(--radius-lg);
    opacity: 0;
    transform: scale(0.8);
  }

  .search-panel__clear.visible {
    opacity: 1;
    transform: scale(1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .search-panel__clear {
      transition:
        opacity var(--motion-duration-fast) var(--motion-ease-standard),
        transform var(--motion-duration-fast) var(--motion-ease-standard),
        color var(--motion-duration-fast) var(--motion-ease-standard),
        background var(--motion-duration-fast) var(--motion-ease-standard);
    }
  }

  .search-panel__clear:hover,
  .search-panel__clear:focus-visible {
    color: var(--accent-primary-hover);
    background: var(--surface-2);
  }

  .search-panel__clear :global(svg),
  .search-panel__reset-icon {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .search-panel__reset {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-inline-size: var(--control-min-inline-size);
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    font: inherit;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    cursor: pointer;
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  @media (prefers-reduced-motion: no-preference) {
    .search-panel__reset {
      transition:
        color var(--motion-duration-fast) var(--motion-ease-standard),
        border-color var(--motion-duration-fast) var(--motion-ease-standard),
        background var(--motion-duration-fast) var(--motion-ease-standard),
        transform var(--motion-duration-fast) var(--motion-ease-standard),
        box-shadow var(--motion-duration-fast) var(--motion-ease-standard);
    }

    .search-panel__reset:hover,
    .search-panel__reset:focus-visible {
      box-shadow: 0 2px 8px oklch(from var(--accent-primary) l c h / 0.2);
      transform: translateY(-1px);
    }

    .search-panel__reset:active {
      box-shadow: none;
      transform: translateY(1px);
    }

    .search-panel__reset--animating .search-panel__reset-icon {
      animation: spin 0.3s ease-out;
    }

    @keyframes spin {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }
  }

  .search-panel__meta {
    display: grid;
    gap: var(--spacing-xs);
  }

  .search-panel__status,
  .search-panel__no-results {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  .search-panel__input:focus-visible,
  .search-panel__clear:focus-visible,
  .search-panel__reset:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }
</style>
