---
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  action?: string;
  method?: "get" | "post";
  inputId?: string;
  inputName?: string;
  label: string;
  placeholder?: string;
  clearLabel?: string;
  hintText?: string;
  hintId?: string;
  className?: string;
}

const {
  action = "/search",
  method = "get",
  inputId = "shared-search-form-input",
  inputName = "q",
  label,
  placeholder = "Search...",
  clearLabel = "Clear search",
  hintText,
  hintId = `${inputId}-hint`,
  className = "",
} = Astro.props as Props;

const formClasses = ["search-form", className].filter(Boolean).join(" ");
const describedBy = hintText ? hintId : undefined;
---

<form
  role="search"
  class={formClasses}
  aria-label={label}
  action={action}
  method={method}
>
  <div class="search-form__row">
    <div class="search-form__field">
      <label for={inputId} class="search-form__label search-form__label--visually-hidden">
        {label}
      </label>
      <input
        id={inputId}
        name={inputName}
        type="search"
        inputmode="search"
        autocomplete="off"
        placeholder={placeholder}
        aria-describedby={describedBy}
        class="search-form__input"
      />
      <button type="reset" aria-label={clearLabel} class="search-form__clear">
        <Icon name="x" aria-hidden="true" />
      </button>
    </div>
  </div>
  {
    hintText ? (
      <Paragraph id={hintId} textSize="sm" className="search-form__hint">
        {hintText}
      </Paragraph>
    ) : null
  }
</form>

<style>
  /* -----------------------------------------------------------------------------
     SearchForm Component Styles
     Accessible search input with clear button
     WCAG AAA compliant with high contrast and clear focus states
     ----------------------------------------------------------------------------- */

  .search-form {
    /* Layout */
    display: grid;
    gap: var(--spacing-lg);
    inline-size: min(100%, 68rem);
    margin: 0 auto var(--spacing-3xl);
  }

  /* Form row wrapper - elevated styling */
  .search-form__row {
    display: grid;
    padding: var(--spacing-sm);
    background: linear-gradient(150deg, var(--surface-2), var(--surface-1));
    border: 2px solid var(--border-default);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  /* Input field wrapper */
  @media screen and (prefers-reduced-motion: reduce) {
    .search-form__field {
      position: relative;
      inline-size: 100%;
      background: var(--surface-1);
      border: 1px solid var(--border-muted);
      border-radius: var(--radius-lg);
      transition: none;
    }
  }

  .search-form__field {
    position: relative;
    inline-size: 100%;
    background: var(--surface-1);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-lg);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  /* Focus state - WCAG AAA compliant */
  .search-form__field:has(input:focus-visible) {
    border-color: var(--accent-primary);
    box-shadow:
      inset 0 0 0 1px var(--accent-primary),
      var(--interactive-shadow-focus);
  }

  /* Visually hidden label for accessibility */
  .search-form__label--visually-hidden {
    position: absolute !important;
    inline-size: 1px !important;
    block-size: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    white-space: nowrap !important;
    border: 0 !important;
    clip-path: inset(50%) !important;
  }

  /* Search input field */
  .search-form__input {
    inline-size: 100%;
    padding-block: var(--spacing-base);
    padding-inline: var(--spacing-lg) 3.6rem;
    font-size: var(--font-size-md);
    color: var(--text-primary);
    background: transparent;
    border: none;
    border-radius: var(--radius-lg);
  }

  /* Placeholder styling */
  .search-form__input::placeholder {
    color: var(--text-tertiary);
  }

  /* Clear button - reset search */
  @media screen and (prefers-reduced-motion: reduce) {
    .search-form__clear {
      /* Positioning */
      position: absolute;
      inset-block-start: 50%;
      inset-inline-end: var(--spacing-sm);

      /* Layout */
      display: grid;
      place-items: center;

      /* Sizing - WCAG AAA touch target */
      inline-size: 2.75rem;
      block-size: 2.75rem;

      /* Visual styling */
      color: var(--text-primary);
      cursor: pointer;
      background: var(--surface-2);
      border: 2px solid var(--border-default);
      border-radius: var(--radius-full);

      /* Positioning transform */
      transform: translateY(-50%);

      /* Smooth transitions */
      transition: none;
    }
  }

  .search-form__clear {
    /* Positioning */
    position: absolute;
    inset-block-start: 50%;
    inset-inline-end: var(--spacing-sm);

    /* Layout */
    display: grid;
    place-items: center;

    /* Sizing - WCAG AAA touch target */
    inline-size: 2.75rem;
    block-size: 2.75rem;

    /* Visual styling */
    color: var(--text-primary);
    cursor: pointer;
    background: var(--surface-2);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-full);

    /* Positioning transform */
    transform: translateY(-50%);

    /* Smooth transitions */
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  /* SVG icon sizing */
  .search-form__clear :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
  }

  /* Focus state - WCAG AAA compliant */
  .search-form__clear:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  /* Hover and focus states */
  .search-form__clear:hover,
  .search-form__clear:focus-visible {
    border-color: var(--accent-primary);
    box-shadow: var(--interactive-shadow-focus);
    transform: translateY(-50%) scale(1.03);
  }

  /* Hint text styling */
  .search-form__hint {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  /* Mobile optimizations */
  @media (width <= 380px) {
    .search-form {
      margin-block-end: var(--spacing-2xl);
    }

    .search-form__row {
      padding: var(--spacing-xs);
      border-radius: var(--radius-base);
    }

    .search-form__input {
      padding-inline: var(--spacing-base) 3.2rem;
      font-size: var(--font-size-base);
    }
  }

  /* Reduced motion support - disable animations */
  @media (prefers-reduced-motion: reduce) {
    .search-form__field,
    .search-form__clear {
      transition: none;
    }

    .search-form__clear:hover,
    .search-form__clear:focus-visible {
      transform: translateY(-50%);
    }
  }
</style>
