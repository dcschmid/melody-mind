---
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  action?: string;
  method?: "get" | "post";
  inputId?: string;
  inputName?: string;
  label: string;
  placeholder?: string;
  clearLabel?: string;
  hintText?: string;
  hintId?: string;
  className?: string;
}

const {
  action = "/search",
  method = "get",
  inputId = "shared-search-form-input",
  inputName = "q",
  label,
  placeholder = "Search...",
  clearLabel = "Clear search",
  hintText,
  hintId = `${inputId}-hint`,
  className = "",
} = Astro.props as Props;

const describedBy = hintText ? hintId : undefined;
---

<form
  role="search"
  class:list={["search-form", className]}
  aria-label={label}
  action={action}
  method={method}
>
  <div class="search-form__field">
    <label for={inputId} class="search-form__label">{label}</label>
    <input
      id={inputId}
      name={inputName}
      type="search"
      inputmode="search"
      autocomplete="off"
      placeholder={placeholder}
      aria-describedby={describedBy}
      class="search-form__input"
    />
    <button type="reset" aria-label={clearLabel} class="search-form__clear">
      <Icon name="x" aria-hidden="true" />
    </button>
  </div>
  {
    hintText ? (
      <Paragraph id={hintId} textSize="sm" className="search-form__hint">
        {hintText}
      </Paragraph>
    ) : null
  }
</form>

<style>
  .search-form {
    display: grid;
    gap: var(--spacing-sm);
    inline-size: min(100%, 68rem);
    margin: 0 auto var(--spacing-2xl);
  }

  .search-form__field {
    position: relative;
    display: grid;
    gap: var(--spacing-xs);
  }

  .search-form__label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .search-form__input {
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) calc(var(--control-min-inline-size) + var(--spacing-sm))
      var(--spacing-sm) var(--spacing-base);
    font: inherit;
    font-size: var(--font-size-base);
    color: var(--text-primary);
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .search-form__input::placeholder {
    color: var(--text-tertiary);
  }

  .search-form__input:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--surface-border-accent-strong);
  }

  .search-form__clear {
    position: absolute;
    inset-block-end: 0;
    inset-inline-end: 0;
    display: grid;
    place-items: center;
    inline-size: var(--control-min-inline-size);
    block-size: var(--control-min-block-size);
    color: var(--text-primary);
    cursor: pointer;
    background: transparent;
    border: 0;
    border-radius: var(--radius-lg);
  }

  .search-form__clear:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: -2px;
  }

  .search-form__clear :global(svg) {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .search-form__hint {
    margin: 0;
    color: var(--text-secondary);
  }
</style>
