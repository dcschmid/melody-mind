---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import SimpleSearch from "@shared-ui/components/search/SimpleSearch.astro";

interface SearchItem {
  title: string;
  description?: string;
  url: string;
}

interface Props {
  items: SearchItem[];
  variant?: "default" | "soft";
  initialQuery?: string;
  heroEyebrow?: string;
  title?: string;
  lead?: string;
  tipsTitle?: string;
  tips?: string[];
  resultsEyebrow?: string;
  resultsTitle?: string;
  resultsHelp?: string;
  searchPlaceholder?: string;
  searchEmptyText?: string;
  searchNoResultsText?: string;
  searchLimit?: number;
}

const {
  items,
  variant = "default",
  initialQuery = "",
  heroEyebrow = "",
  title = "",
  lead = "",
  tipsTitle = "Search tips",
  tips = [],
  resultsEyebrow = "Search the archive",
  resultsTitle = "Results",
  resultsHelp = "Results update while you type, and the current query stays in the URL.",
  searchPlaceholder = "Search...",
  searchEmptyText = "Type to search.",
  searchNoResultsText = "No matching results found.",
  searchLimit = 20,
} = Astro.props as Props;

const sectionId = `search-page-section-${variant}`;
---

<section class:list={["search-page-section", `search-page-section--${variant}`]}>
  {
    heroEyebrow || title || lead || tips.length > 0 ? (
      <header class="search-page-section__header">
        <div class="search-page-section__intro">
          {heroEyebrow ? (
            <Paragraph textSize="sm" className="search-page-section__eyebrow">
              {heroEyebrow}
            </Paragraph>
          ) : null}
          {title ? (
            <Headline level="h1" className="search-page-section__title">
              {title}
            </Headline>
          ) : null}
          {lead ? (
            <Paragraph textSize="lg" className="search-page-section__lead">
              {lead}
            </Paragraph>
          ) : null}
        </div>

        {tips.length > 0 ? (
          <aside class="search-page-section__tips" aria-label={tipsTitle}>
            <Paragraph textSize="sm" className="search-page-section__tips-title">
              {tipsTitle}
            </Paragraph>
            <ul class="search-page-section__tips-list">
              {tips.map((tip) => (
                <li class="search-page-section__tips-item">{tip}</li>
              ))}
            </ul>
          </aside>
        ) : null}
      </header>
    ) : null
  }

  <section class="search-page-section__results" aria-labelledby={`${sectionId}-title`}>
    <div class="search-page-section__results-head">
      <Paragraph textSize="sm" className="search-page-section__eyebrow"
        >{resultsEyebrow}</Paragraph
      >
      <Headline level="h2" textSize="lg" className="search-page-section__results-title">
        <span id={`${sectionId}-title`}>{resultsTitle}</span>
      </Headline>
      <Paragraph textSize="base" className="search-page-section__results-help"
        >{resultsHelp}</Paragraph
      >
    </div>

    <SimpleSearch
      idBase={sectionId}
      items={items}
      initialQuery={initialQuery}
      placeholder={searchPlaceholder}
      emptyText={searchEmptyText}
      noResultsText={searchNoResultsText}
      limit={searchLimit}
    />
  </section>
</section>

<style>
  .search-page-section {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .search-page-section__header {
    display: grid;
    gap: var(--spacing-lg);
  }

  .search-page-section__intro,
  .search-page-section__tips,
  .search-page-section__results {
    display: grid;
    gap: var(--spacing-base);
    padding: var(--spacing-lg);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
  }

  .search-page-section__eyebrow,
  .search-page-section__tips-title {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
  }

  .search-page-section__title,
  .search-page-section__results-title {
    margin: 0;
  }

  .search-page-section__lead,
  .search-page-section__results-help {
    margin: 0;
    color: var(--text-secondary);
  }

  .search-page-section__tips-list {
    display: grid;
    gap: var(--spacing-sm);
    padding-inline-start: var(--spacing-lg);
    margin: 0;
    color: var(--text-secondary);
  }

  .search-page-section__results-head {
    display: grid;
    gap: var(--spacing-xs);
  }

  .search-page-section--soft .search-page-section__intro,
  .search-page-section--soft .search-page-section__tips,
  .search-page-section--soft .search-page-section__results {
    background: color-mix(in srgb, var(--surface-1) 84%, transparent);
  }

  @media (width >= 768px) {
    .search-page-section__header {
      grid-template-columns: minmax(0, 2fr) minmax(18rem, 1fr);
      align-items: start;
    }
  }
</style>
