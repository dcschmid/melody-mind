---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import SimpleSearch from "@shared-ui/components/search/SimpleSearch.astro";

interface SearchItem {
  title: string;
  description?: string;
  url: string;
}

interface Props {
  items: SearchItem[];
  variant?: "default" | "soft";
  initialQuery?: string;
  heroEyebrow?: string;
  title?: string;
  lead?: string;
  tipsTitle?: string;
  tips?: string[];
  resultsEyebrow?: string;
  resultsTitle?: string;
  resultsHelp?: string;
  searchPlaceholder?: string;
  searchEmptyText?: string;
  searchNoResultsText?: string;
  searchLimit?: number;
}

const {
  items = [],
  variant = "default",
  initialQuery = "",
  heroEyebrow = "",
  title = "",
  lead = "",
  tipsTitle = "Tips for searching",
  tips = [],
  resultsEyebrow = "Find articles",
  resultsTitle = "Results",
  resultsHelp = "Results appear as you type. Your search is saved in the address bar so you can share or bookmark it.",
  searchPlaceholder = "Search by artist, genre, or decade...",
  searchEmptyText = "Start typing to explore.",
  searchNoResultsText = "No articles match your search. Try different keywords or check your spelling.",
  searchLimit = 20,
} = Astro.props as Props;

const safeVariant = String(variant).replace(/[^a-zA-Z0-9-_]/g, "-");
const sectionId = `search-page-section-${safeVariant}`;

const safeLimit = Math.max(1, Math.min(100, Number(searchLimit) || 20));
const safeItems = Array.isArray(items) ? items : [];

const escapeHtml = (str: string): string =>
  String(str)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");

const safeTitle = escapeHtml(resultsTitle);
---

<section class:list={["search-page-section", `search-page-section--${safeVariant}`]}>
  {
    heroEyebrow || title || lead || tips.length > 0 ? (
      <header class="search-page-section__header" aria-label="Search page introduction">
        <div class="search-page-section__intro">
          {heroEyebrow ? (
            <Paragraph textSize="sm" className="search-page-section__eyebrow">
              {heroEyebrow}
            </Paragraph>
          ) : null}
          {title ? (
            <Headline level="h1" className="search-page-section__title">
              {title}
            </Headline>
          ) : null}
          {lead ? (
            <Paragraph textSize="lg" className="search-page-section__lead">
              {lead}
            </Paragraph>
          ) : null}
        </div>

        {tips.length > 0 ? (
          <aside class="search-page-section__tips">
            <Paragraph textSize="sm" className="search-page-section__tips-title">
              {tipsTitle}
            </Paragraph>
            <ul class="search-page-section__tips-list" aria-label="Search tips">
              {tips.map((tip) => (
                <li class="search-page-section__tips-item">{tip}</li>
              ))}
            </ul>
          </aside>
        ) : null}
      </header>
    ) : null
  }

  <section class="search-page-section__results" aria-labelledby={`${sectionId}-title`}>
    <div class="search-page-section__results-head" aria-label="Search results">
      <Paragraph textSize="sm" className="search-page-section__eyebrow"
        >{resultsEyebrow}</Paragraph
      >
      <Headline
        level="h2"
        textSize="lg"
        className="search-page-section__results-title"
        id={`${sectionId}-title`}
      >
        <span set:html={safeTitle} />
      </Headline>
      <Paragraph textSize="base" className="search-page-section__results-help"
        >{resultsHelp}</Paragraph
      >
    </div>

    <SimpleSearch
      idBase={sectionId}
      items={safeItems}
      initialQuery={initialQuery}
      placeholder={searchPlaceholder}
      emptyText={searchEmptyText}
      noResultsText={searchNoResultsText}
      limit={safeLimit}
    />
  </section>
</section>

<style>
  /* -----------------------------------------------------------------------------
     Layout
     ----------------------------------------------------------------------------- */
  .search-page-section {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .search-page-section__header {
    display: grid;
    gap: var(--spacing-lg);
  }

  .search-page-section__results-head {
    display: grid;
    gap: var(--title-gap-md);
  }

  /* -----------------------------------------------------------------------------
     Panels
     ----------------------------------------------------------------------------- */
  .search-page-section__intro,
  .search-page-section__tips {
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
  }

  .search-page-section__intro {
    display: grid;
    gap: var(--spacing-xs);
    padding: var(--spacing-base);
  }

  .search-page-section__tips {
    display: grid;
    gap: var(--spacing-base);
    align-content: start;
    padding: var(--spacing-base);
  }

  .search-page-section__results {
    display: grid;
    gap: var(--spacing-base);
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
  }

  @media (width >= 640px) {
    .search-page-section__intro,
    .search-page-section__tips {
      padding: var(--spacing-lg);
    }
  }

  /* -----------------------------------------------------------------------------
     Typography
     ----------------------------------------------------------------------------- */
  .search-page-section__eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  .search-page-section__tips-title {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-primary);
  }

  .search-page-section__title {
    padding-block-start: var(--spacing-xs);
    margin: 0;
    color: var(--text-primary);
  }

  .search-page-section__results-title {
    margin: 0;
    color: var(--accent-strong);
  }

  .search-page-section__lead {
    max-width: 65ch;
    margin: 0;
    color: var(--text-secondary);
    hyphens: auto;
    overflow-wrap: break-word;
  }

  .search-page-section__results-help {
    max-width: 55ch;
    margin: 0;
    color: var(--text-secondary);
    hyphens: auto;
    overflow-wrap: break-word;
  }

  .search-page-section__tips-list {
    display: grid;
    gap: var(--spacing-sm);
    padding-inline-start: var(--spacing-md);
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--prose-line-height);
    color: var(--text-secondary);
    hyphens: auto;
    overflow-wrap: break-word;
  }

  @media (width >= 640px) {
    .search-page-section__tips-list {
      padding-inline-start: var(--spacing-lg);
    }
  }

  /* -----------------------------------------------------------------------------
     Variants
     ----------------------------------------------------------------------------- */
  .search-page-section--soft .search-page-section__intro,
  .search-page-section--soft .search-page-section__tips {
    background: color-mix(in srgb, var(--surface-1) 84%, transparent);
  }

  .search-page-section--soft .search-page-section__results {
    background: transparent;
  }

  /* -----------------------------------------------------------------------------
     Responsive
     ----------------------------------------------------------------------------- */
  @media (width >= 768px) {
    .search-page-section__header {
      grid-template-columns: minmax(0, 2fr) minmax(18rem, 1fr);
      align-items: start;
    }
  }
</style>
