---
import type { HTMLAttributes } from "astro/types";
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props extends HTMLAttributes<"a"> {
  aiTools?: string[];
  size?: "sm" | "md";
  className?: string;
  href?: string;
}

/**
 * Badge that highlights AI-generated content.
 * @param aiTools list of AI tools to include in the badge hover/focus text
 * @param size badge size variant ("sm" or "md")
 * @param className additional classes for the root anchor
 * @param href destination url when the badge is clicked
 * @param attributes forwarded HTML attributes
 */
const {
  aiTools = [],
  size = "md",
  className = "",
  href = "/ai-content",
  ...attributes
} = Astro.props as Props;

const sizeClass = size === "sm" ? "ai-content-badge--sm" : "ai-content-badge--md";
const hasTools = aiTools.length > 0;
---

<a
  class:list={[["ai-content-badge", sizeClass], className]}
  href={href}
  title={hasTools
    ? `AI-generated content created with: ${aiTools.join(", ")}`
    : "AI-generated content"}
  aria-label={hasTools
    ? `AI-generated content created with ${aiTools.length} AI tool${
        aiTools.length > 1 ? "s" : ""
      }. Learn more`
    : "AI-generated content. Learn more"}
  {...attributes}
>
  <div class="ai-content-badge__content">
    <span class="ai-content-badge__icon" aria-hidden="true">
      <Icon name="cpu" />
    </span>
    <span class="ai-content-badge__label">AI-generated</span>
  </div>
</a>

<style>
  @media screen and (prefers-reduced-motion: reduce) {
    .ai-content-badge {
      display: inline-flex;
      align-items: center;
      padding: 0;
      font-family: var(--font-sans);
      font-size: var(--font-size-xs);
      font-weight: var(--font-weight-semibold);
      line-height: var(--line-height-tight);
      color: var(--text-secondary);
      letter-spacing: 0.02em;
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--text-secondary) 30%, transparent);
      text-underline-offset: var(--text-underline-offset-base);
      background: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      transition: none;
    }
  }

  .ai-content-badge {
    display: inline-flex;
    align-items: center;
    padding: 0;
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--text-secondary) 30%, transparent);
    text-underline-offset: var(--text-underline-offset-base);
    background: none;
    border: none;
    border-radius: 0;
    box-shadow: none;
    transition:
      color var(--transition-fast),
      text-decoration-color var(--transition-fast);
  }

  .ai-content-badge--sm {
    font-size: var(--font-size-xs);
  }

  .ai-content-badge:hover,
  .ai-content-badge:focus-visible {
    color: var(--accent-primary);
    text-decoration-color: var(--accent-primary);
    background: none;
    border-color: transparent;
    box-shadow: none;
    transform: none;
  }

  .ai-content-badge:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  .ai-content-badge__content {
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
  }

  .ai-content-badge__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
    color: var(--accent-strong);
  }

  .ai-content-badge__icon :global(svg) {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .ai-content-badge__label {
    white-space: nowrap;
  }
</style>
