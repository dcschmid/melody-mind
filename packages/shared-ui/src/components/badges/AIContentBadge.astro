---
import type { HTMLAttributes } from "astro/types";
import Icon from "@shared-ui/components/visual/Icon.astro";

interface Props extends HTMLAttributes<"a"> {
  aiTools?: string[];
  size?: "sm" | "md";
  className?: string;
  href?: string;
}

/**
 * Badge that highlights AI-generated content.
 * @param aiTools list of AI tools to include in the badge hover/focus text
 * @param size badge size variant ("sm" or "md")
 * @param className additional classes for the root anchor
 * @param href destination url when the badge is clicked
 * @param attributes forwarded HTML attributes
 */
const {
  aiTools = [],
  size = "md",
  className = "",
  href = "/ai-content",
  ...attributes
} = Astro.props as Props;

const validSizes = ["sm", "md"] as const;
const safeSize = validSizes.includes(size as (typeof validSizes)[number]) ? size : "md";
const sizeClass = safeSize === "sm" ? "ai-content-badge--sm" : "ai-content-badge--md";
const hasTools = aiTools.length > 0;

const safeHref = href.startsWith("/") || href.startsWith("#") ? href : "/ai-content";

const sanitizeToolName = (name: string) =>
  name
    .replace(/[<>\"'&]/g, "")
    .trim()
    .slice(0, 50);

const safeTools = aiTools.map(sanitizeToolName).filter(Boolean);
---

<a
  class:list={[["ai-content-badge", sizeClass], className]}
  href={safeHref}
  title={hasTools
    ? `AI-generated content created with: ${safeTools.join(", ")}`
    : "AI-generated content"}
  aria-label={hasTools
    ? `AI-generated content created with ${safeTools.length} AI tool${
        safeTools.length > 1 ? "s" : ""
      }. Learn more`
    : "AI-generated content. Learn more"}
  {...attributes}
>
  <div class="ai-content-badge__content">
    <span class="ai-content-badge__icon" aria-hidden="true">
      <Icon name="cpu" />
    </span>
    <span class="ai-content-badge__label">AI-generated</span>
  </div>
</a>

<style>
  @keyframes badge-enter {
    from {
      opacity: 0;
      transform: translateY(4px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-content-badge {
    display: inline-flex;
    align-items: center;
    padding: 0;
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--text-secondary) 30%, transparent);
    text-underline-offset: var(--text-underline-offset-base);
    background: none;
    border: none;
    border-radius: 0;
    box-shadow: none;
    transition:
      color 200ms cubic-bezier(0.25, 1, 0.5, 1),
      text-decoration-color 200ms cubic-bezier(0.25, 1, 0.5, 1),
      outline 150ms cubic-bezier(0.25, 1, 0.5, 1);
    animation: badge-enter 400ms cubic-bezier(0.25, 1, 0.5, 1) backwards;
  }

  .ai-content-badge--sm {
    font-size: calc(var(--font-size-xs) * 0.85);
  }

  .ai-content-badge__content {
    display: flex;
    gap: var(--spacing-xs);
    align-items: center;
  }

  .ai-content-badge__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
    color: var(--accent-primary);
    transition:
      color 200ms cubic-bezier(0.25, 1, 0.5, 1),
      transform 300ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .ai-content-badge__icon :global(svg) {
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .ai-content-badge__label {
    white-space: nowrap;
  }

  .ai-content-badge:hover,
  .ai-content-badge:focus-visible {
    color: var(--accent-primary);
    text-decoration-color: var(--accent-primary);
    background: none;
    border-color: transparent;
    box-shadow: none;
  }

  .ai-content-badge:hover .ai-content-badge__icon,
  .ai-content-badge:focus-visible .ai-content-badge__icon {
    color: var(--accent-primary);
    transform: rotate(8deg);
  }

  .ai-content-badge:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .ai-content-badge {
      display: inline-flex;
      align-items: center;
      padding: 0;
      font-family: var(--font-sans);
      font-size: var(--font-size-xs);
      font-weight: var(--font-weight-semibold);
      line-height: var(--line-height-tight);
      color: var(--text-secondary);
      letter-spacing: 0.02em;
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--text-secondary) 30%, transparent);
      text-underline-offset: var(--text-underline-offset-base);
      background: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      transition: none;
      animation: none;
    }

    .ai-content-badge__icon {
      transform: none;
      transition: none;
    }
  }
</style>
