---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { IconName } from "@shared-ui/components/visual/Icon.astro";

const BUTTON_VARIANTS = ["primary", "secondary"] as const;
const BUTTON_SIZES = ["default", "compact"] as const;
type ButtonVariant = (typeof BUTTON_VARIANTS)[number];
type ButtonSize = (typeof BUTTON_SIZES)[number];

interface Props {
  href: string;
  ariaLabel?: string;
  className?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
  icon?: IconName;
  newTabText?: string;
  disabled?: boolean;
}

const {
  href,
  ariaLabel,
  className = "",
  target = "_self",
  rel,
  variant = "primary",
  size = "default",
  icon,
  newTabText = "opens in a new tab",
  disabled = false,
  "aria-label": ariaLabelAttr,
} = Astro.props as Props & { "aria-label"?: string };

const isRendered = href && !disabled;
const isExternal = target === "_blank";
const securityRel = isExternal ? "noopener noreferrer" : "";
const finalRel = [securityRel, rel].filter(Boolean).join(" ") || undefined;

const classes = [
  "button-link",
  `button-link--${variant}`,
  `button-link--${size}`,
  className,
]
  .filter(Boolean)
  .join(" ");

const resolvedAriaLabel = ariaLabel ?? ariaLabelAttr;
---

{
  isRendered ? (
    <AccessibleExternalLink
      href={href}
      className={classes}
      aria-label={resolvedAriaLabel}
      announceNewTab={isExternal}
      newTabText={newTabText}
      {target}
      rel={finalRel}
    >
      {icon ? <Icon name={icon} class="button-link__icon" aria-hidden="true" /> : null}
      <span class="button-link__label">
        <slot />
      </span>
    </AccessibleExternalLink>
  ) : (
    <span class={`${classes} button-link--disabled`} aria-disabled="true">
      {icon ? <Icon name={icon} class="button-link__icon" aria-hidden="true" /> : null}
      <span class="button-link__label">
        <slot />
      </span>
    </span>
  )
}

<style is:global>
  .button-link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
    inline-size: 100%;
    min-inline-size: var(--control-min-inline-size);
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    text-decoration: none;
    cursor: pointer;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .button-link:hover,
  .button-link:focus-visible {
    background: var(--surface-card-hover);
    border-color: var(--surface-border-accent);
    box-shadow: var(--shadow-sm);
  }

  .button-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--surface-border-accent-strong);
    box-shadow: var(--interactive-shadow-focus);
  }

  .button-link:disabled,
  .button-link--disabled {
    pointer-events: none;
    cursor: not-allowed;
    opacity: 0.5;
  }

  .button-link--primary {
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .button-link--primary:hover,
  .button-link--primary:focus-visible {
    background: var(--accent-primary-hover);
    border-color: var(--accent-primary-hover);
  }

  .button-link--secondary {
    background: var(--surface-panel-raised);
  }

  .button-link--compact {
    padding: var(--spacing-xs) var(--spacing-base);
    font-size: var(--font-size-sm);
  }

  .button-link__icon {
    flex-shrink: 0;
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .button-link__label {
    min-inline-size: 0;
  }

  /* Brand icon colors — simple-icons use currentColor, so we set them explicitly */
  .button-link--secondary .button-link__icon[data-icon="simple-icons:spotify"] {
    color: var(--brand-spotify);
  }

  .button-link--secondary .button-link__icon[data-icon="simple-icons:deezer"] {
    color: var(--brand-deezer);
  }

  .button-link--secondary .button-link__icon[data-icon="simple-icons:applemusic"] {
    color: var(--brand-applemusic);
  }

  @media (width >= 640px) {
    .button-link {
      inline-size: auto;
    }
  }
</style>
