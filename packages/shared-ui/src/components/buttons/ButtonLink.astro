---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";

type ButtonVariant = "primary" | "secondary";
type ButtonSize = "default" | "compact";

interface Props {
  href: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  className?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;
  variant?: ButtonVariant;
  size?: ButtonSize;
  icon?: string;
}

const rawProps = Astro.props as Props & Record<string, unknown>;

const {
  href,
  ariaLabel,
  ariaDescribedBy,
  className = "",
  target = "_self",
  rel,
  variant = "primary",
  size = "default",
  icon,
} = rawProps;

const isExternal = target === "_blank";
const finalRel = isExternal ? `noopener noreferrer ${rel || ""}`.trim() : rel;
const externalLinkText = "opens in a new tab";

const classes = [
  "button-link",
  `button-link--${variant}`,
  `button-link--${size}`,
  className,
]
  .filter(Boolean)
  .join(" ");

const ariaLabelAttr =
  (ariaLabel as string | undefined) ?? (rawProps["aria-label"] as string | undefined);
const ariaDescribedByAttr =
  (ariaDescribedBy as string | undefined) ??
  (rawProps["aria-describedby"] as string | undefined);

const forwardedAttrs = (() => {
  const restAttrs: Record<string, unknown> = { ...rawProps };
  for (const key of [
    "href",
    "ariaLabel",
    "ariaDescribedBy",
    "className",
    "target",
    "rel",
    "variant",
    "size",
    "icon",
    "aria-describedby",
    "aria-label",
  ]) {
    if (key in restAttrs) {
      delete restAttrs[key];
    }
  }
  return restAttrs;
})();
---

<AccessibleExternalLink
  href={href}
  className={classes}
  aria-label={ariaLabelAttr}
  aria-describedby={ariaDescribedByAttr}
  announceNewTab={isExternal}
  newTabText={externalLinkText}
  {target}
  rel={finalRel}
  {...forwardedAttrs}
>
  {icon ? <Icon name={icon} class="button-link__icon" aria-hidden="true" /> : null}
  <span class="button-link__label"><slot /></span>
</AccessibleExternalLink>

<style>
  .button-link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
    inline-size: 100%;
    min-inline-size: var(--control-min-inline-size);
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    text-decoration: none;
    cursor: pointer;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .button-link:hover,
  .button-link:focus {
    background: var(--surface-card-hover);
    border-color: var(--surface-border-accent);
  }

  .button-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--surface-border-accent-strong);
    box-shadow: var(--interactive-shadow-focus);
  }

  .button-link--primary {
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .button-link--primary:hover,
  .button-link--primary:focus {
    background: var(--accent-primary-hover);
    border-color: var(--accent-primary-hover);
  }

  .button-link--secondary {
    background: var(--surface-panel-raised);
  }

  .button-link--compact {
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) var(--spacing-base);
    font-size: var(--font-size-sm);
  }

  .button-link__icon {
    flex-shrink: 0;
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  .button-link__label {
    min-inline-size: 0;
  }

  @media (width >= 640px) {
    .button-link {
      inline-size: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .button-link {
      transition: none;
    }
  }
</style>
