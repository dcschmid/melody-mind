---
type MetaPillGroupElement = "div" | "ul" | "ol";

interface Props extends astroHTML.JSX.HTMLAttributes {
  as?: MetaPillGroupElement;
  className?: string;
  class?: string;
}

const {
  as = "div",
  className = "",
  class: classProp = "",
  ...rest
} = Astro.props as Props;

const classes = ["meta-pill-group", className, classProp].filter(Boolean).join(" ");
const Tag = as;
---

<Tag {...rest} class={classes}>
  <slot />
</Tag>

<style>
  .meta-pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    align-items: center;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .meta-pill-group > :global(*) {
    min-inline-size: 0;
    max-inline-size: 100%;
    overflow-wrap: anywhere;
  }
</style>
