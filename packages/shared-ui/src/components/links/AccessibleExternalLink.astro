---
import VisuallyHidden from "@shared-ui/components/utilities/VisuallyHidden.astro";

interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  announceNewTab?: boolean;
  className?: string;
  newTabText?: string;
  class?: string;
}

const rawProps = Astro.props as Props & Record<string, unknown>;

const {
  announceNewTab,
  className = "",
  newTabText = "opens in a new tab",
  class: classProp = "",
  target,
  rel,
  href,
  "aria-label": ariaLabel,
  "aria-labelledby": ariaLabelledBy,
  "aria-describedby": ariaDescribedBy,
} = rawProps;

const shouldAnnounceNewTab = announceNewTab ?? target === "_blank";
const finalRel =
  target === "_blank"
    ? Array.from(new Set(`noopener noreferrer ${rel || ""}`.trim().split(/\s+/)))
        .filter(Boolean)
        .join(" ")
    : rel;
const normalizeAriaValue = (value: unknown) =>
  typeof value === "string" ? value.trim() || undefined : undefined;

const ariaLabelAttr = normalizeAriaValue(ariaLabel);
const ariaLabelledByAttr = normalizeAriaValue(ariaLabelledBy);
const ariaDescribedByAttr = normalizeAriaValue(ariaDescribedBy);
const finalAriaLabel =
  shouldAnnounceNewTab && ariaLabelAttr && !ariaLabelledByAttr
    ? `${ariaLabelAttr} (${newTabText})`
    : ariaLabelAttr;
const newTabDescriptionId =
  shouldAnnounceNewTab && ariaLabelledByAttr
    ? `external-link-new-tab-${crypto.randomUUID()}`
    : undefined;
const finalAriaDescribedBy =
  [ariaDescribedByAttr, newTabDescriptionId].filter(Boolean).join(" ") || undefined;
---

<a
  {href}
  class:list={[className, classProp]}
  target={target}
  rel={finalRel}
  aria-label={finalAriaLabel}
  aria-labelledby={ariaLabelledByAttr}
  aria-describedby={finalAriaDescribedBy}
>
  <slot />
  {
    shouldAnnounceNewTab ? (
      <VisuallyHidden id={newTabDescriptionId}> ({newTabText})</VisuallyHidden>
    ) : null
  }
</a>
