---
import VisuallyHidden from "@shared-ui/components/utilities/VisuallyHidden.astro";

interface Props extends astroHTML.JSX.AnchorHTMLAttributes {
  announceNewTab?: boolean;
  className?: string;
  newTabText?: string;
  class?: string;
}

const rawProps = Astro.props as Props & Record<string, unknown>;

const {
  announceNewTab,
  className = "",
  newTabText = "opens in a new tab",
  class: classProp = "",
  target,
  rel,
} = rawProps;

const shouldAnnounceNewTab = announceNewTab ?? target === "_blank";
const finalRel =
  target === "_blank"
    ? Array.from(new Set(`noopener noreferrer ${rel || ""}`.trim().split(/\s+/)))
        .filter(Boolean)
        .join(" ")
    : rel;
const normalizeAriaValue = (value: unknown) =>
  typeof value === "string" ? value.trim() || undefined : undefined;

const ariaLabelAttr = normalizeAriaValue(rawProps["aria-label"]);
const ariaLabelledByAttr = normalizeAriaValue(rawProps["aria-labelledby"]);
const ariaDescribedByAttr = normalizeAriaValue(rawProps["aria-describedby"]);
const slotContent = await Astro.slots.render("default");
const strippedContent = slotContent
  .replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, " ")
  .replace(/<style\b[^<]*(?:(?!<\/style>)<[^<]*)*<\/style>/gi, " ")
  .replace(
    /<([a-z][\w:-]*)\b(?=[^>]*\baria-hidden\s*=\s*(?:"true"|'true'|true\b))[^>]*>[\s\S]*?<\/\1>/gi,
    " "
  )
  .replace(
    /<([a-z][\w:-]*)\b(?=[^>]*\baria-hidden\s*=\s*(?:"true"|'true'|true\b))[^>]*\/?>/gi,
    " "
  )
  .replace(/<svg\b[^>]*>[\s\S]*?<\/svg>/gi, " ")
  .replace(/<img\b[^>]*>/gi, " ")
  .replace(/<[^>]+>/g, " ")
  .replace(/&(?:nbsp|#160);/gi, " ")
  .replace(/\s+/g, " ")
  .trim();
const linkText = strippedContent || undefined;
const finalAriaLabel =
  shouldAnnounceNewTab && ariaLabelAttr && !ariaLabelledByAttr
    ? `${ariaLabelAttr} (${newTabText})`
    : ariaLabelAttr;
const newTabDescriptionId =
  shouldAnnounceNewTab && ariaLabelledByAttr
    ? `external-link-new-tab-${crypto.randomUUID()}`
    : undefined;
const finalAriaDescribedBy =
  [ariaDescribedByAttr, newTabDescriptionId].filter(Boolean).join(" ") || undefined;

if (!ariaLabelAttr && !ariaLabelledByAttr && !linkText) {
  throw new Error(
    "AccessibleExternalLink requires visible text content, aria-label, or " +
      "aria-labelledby. Add an explicit accessible name when using icon-only " +
      "or non-text link content."
  );
}

const forwardedAttrs = (() => {
  const restAttrs: Record<string, unknown> = { ...rawProps };
  for (const key of [
    "announceNewTab",
    "className",
    "newTabText",
    "class",
    "aria-label",
    "aria-labelledby",
    "aria-describedby",
  ]) {
    if (key in restAttrs) {
      delete restAttrs[key];
    }
  }
  return restAttrs;
})();
---

<a
  {...forwardedAttrs}
  class:list={[className, classProp]}
  target={target}
  rel={finalRel}
  aria-label={finalAriaLabel}
  aria-labelledby={ariaLabelledByAttr}
  aria-describedby={finalAriaDescribedBy}
>
  <Fragment set:html={slotContent} />
  {
    shouldAnnounceNewTab ? (
      <VisuallyHidden id={newTabDescriptionId}> ({newTabText})</VisuallyHidden>
    ) : null
  }
</a>
