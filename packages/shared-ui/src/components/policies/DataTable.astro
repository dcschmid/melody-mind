---
interface DataTableColumn {
  key: string;
  label: string;
  renderAsCode?: boolean;
  isRowHeader?: boolean;
}

interface Props {
  caption: string;
  columns: readonly DataTableColumn[] | DataTableColumn[];
  rows: readonly Record<string, string>[] | Record<string, string>[];
}

const { caption, columns, rows } = Astro.props as Props;
---

<div class="data-table">
  <table class="data-table__table">
    <caption class="data-table__sr-only">{caption}</caption>
    <thead>
      <tr>
        {columns.map((column) => <th scope="col">{column.label}</th>)}
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            {columns.map((column) => {
              const value = row[column.key] ?? "";
              const content = column.renderAsCode ? <code>{value}</code> : value;

              return column.isRowHeader ? (
                <th class="data-table__row-header" scope="row" data-label={column.label}>
                  {content}
                </th>
              ) : (
                <td data-label={column.label}>{content}</td>
              );
            })}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .data-table {
    position: relative;
    padding: var(--spacing-sm);
    overflow-inline: auto;
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .data-table__table {
    inline-size: 100%;
    min-inline-size: var(--measure-standard);
    border-collapse: collapse;
  }

  .data-table__table th,
  .data-table__table td {
    padding: var(--spacing-md) var(--spacing-sm);
    vertical-align: top;
    color: var(--text-secondary);
    text-align: start;
    overflow-wrap: anywhere;
    border-block-end: 1px solid var(--border-muted);
  }

  .data-table__table thead th {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--accent-primary) 8%, var(--surface-1));
  }

  .data-table__row-header {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .data-table__table code {
    display: inline-block;
    padding: var(--spacing-2xs) var(--spacing-xs);
    font-family: var(--font-mono);
    font-size: var(--font-size-base);
    color: var(--link-default);
    white-space: nowrap;
    background: var(--surface-2);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-sm);
  }

  .data-table__table tbody tr:last-child td {
    border-block-end: 0;
  }

  .data-table__table tbody tr:last-child th {
    border-block-end: 0;
  }

  @media (width <= 640px) {
    .data-table {
      padding: var(--spacing-xs);
      overflow-inline: visible;
    }

    .data-table__table {
      min-inline-size: 0;
    }

    .data-table__table thead {
      position: var(--sr-only);
      inline-size: var(--sr-only-width);
      block-size: var(--sr-only-height);
      padding: var(--sr-only-padding);
      margin: var(--sr-only-margin);
      overflow: var(--sr-only-overflow);
      white-space: var(--sr-only-white-space);
      border: var(--sr-only-border);
      clip-path: var(--sr-only-clip-path);
    }

    .data-table__table tbody {
      display: grid;
      gap: var(--spacing-sm);
    }

    .data-table__table tr {
      display: grid;
      padding: var(--spacing-sm);
      background: color-mix(in srgb, var(--surface-2) 58%, var(--surface-1));
      border: 1px solid var(--border-muted);
      border-radius: var(--radius-md);
    }

    .data-table__table th,
    .data-table__table td {
      display: grid;
      grid-template-columns: minmax(6rem, 34%) minmax(0, 1fr);
      gap: var(--spacing-sm);
      align-items: start;
      padding: var(--spacing-sm) 0;
      border-block-end: 1px solid var(--border-muted);
    }

    .data-table__table th::before,
    .data-table__table td::before {
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-semibold);
      color: var(--text-secondary);
      content: attr(data-label);
    }

    .data-table__table code {
      max-inline-size: 100%;
      overflow-wrap: anywhere;
      white-space: normal;
    }

    .data-table__table tbody tr:last-child td,
    .data-table__table tbody tr:last-child th {
      border-block-end: 1px solid var(--border-muted);
    }

    .data-table__table tbody tr th:last-child,
    .data-table__table tbody tr td:last-child {
      border-block-end: 0;
    }
  }

  .data-table__sr-only {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }
</style>
