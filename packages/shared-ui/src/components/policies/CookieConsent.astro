---
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  fathomSiteId?: string;
}

const { fathomSiteId = "" } = Astro.props as Props;
---

<div
  class="cookie-consent"
  data-cookie-consent
  data-fathom-site-id={fathomSiteId}
  role="dialog"
  aria-modal="true"
  aria-label="Cookie consent"
  aria-describedby="cookie-consent-description"
  hidden
>
  <Paragraph
    id="cookie-consent-description"
    textSize="sm"
    className="cookie-consent__text"
  >
    We use essential storage for core site functions. Analytics with Fathom is optional
    and only turns on if you give consent.
  </Paragraph>
  <div class="cookie-consent__actions">
    <button
      type="button"
      class="cookie-consent__button cookie-consent__button--secondary"
      data-cookie-action="reject"
    >
      Essential only
    </button>
    <button
      type="button"
      class="cookie-consent__button cookie-consent__button--primary"
      data-cookie-action="accept"
    >
      Allow analytics
    </button>
  </div>
</div>

<script>
  import { CONSENT_EVENTS } from "@shared-utils/constants/events";
  import {
    dispatchConsentChange,
    getDoNotTrackEnabled,
    getRuntimeAnalyticsAllowed,
    readConsentPreference,
    setRuntimeAnalyticsAllowed,
    writeConsentPreference,
    type ConsentPreference,
  } from "@shared-utils/utils/consent/clientConsent";

  const FATHOM_SCRIPT_SELECTOR = "script[data-cookie-consent-fathom='true']";
  const banner = document.querySelector<HTMLElement>("[data-cookie-consent]");
  if (!banner) {
    throw new Error("CookieConsent banner root not found");
  }

  const fathomSiteId = banner.dataset.fathomSiteId || "";
  const fathomEnabled = fathomSiteId.length > 0;
  let lastFocusBeforeOpen: Element | null = null;

  const loadFathomScript = (): void => {
    if (!fathomEnabled || document.querySelector(FATHOM_SCRIPT_SELECTOR)) {
      return;
    }
    const script = document.createElement("script");
    script.src = "https://cdn.usefathom.com/script.js";
    script.defer = true;
    script.setAttribute("data-site", fathomSiteId);
    script.setAttribute("data-honor-dnt", "true");
    script.setAttribute("data-cookie-consent-fathom", "true");
    script.addEventListener("load", () => {
      setFathomTrackingEnabled(getRuntimeAnalyticsAllowed());
    });
    document.head.appendChild(script);
  };

  const removeFathomScript = (): void => {
    const existing = document.querySelector(FATHOM_SCRIPT_SELECTOR);
    if (existing?.parentNode) {
      existing.parentNode.removeChild(existing);
    }
  };

  const setFathomTrackingEnabled = (enabled: boolean): void => {
    if (!window.fathom) {
      return;
    }
    if (enabled && typeof window.fathom.enableTrackingForMe === "function") {
      window.fathom.enableTrackingForMe();
    }
    if (!enabled && typeof window.fathom.blockTrackingForMe === "function") {
      window.fathom.blockTrackingForMe();
    }
  };

  const hideBanner = (): void => {
    banner.setAttribute("hidden", "true");
    if (lastFocusBeforeOpen && "focus" in lastFocusBeforeOpen) {
      (lastFocusBeforeOpen as HTMLElement).focus();
    }
    lastFocusBeforeOpen = null;
  };

  const showBanner = (shouldMoveFocus: boolean): void => {
    banner.removeAttribute("hidden");
    if (!shouldMoveFocus) {
      return;
    }
    banner.querySelector<HTMLElement>("[data-cookie-action]")?.focus();
  };

  const applyConsent = (
    consent: ConsentPreference,
    shouldDispatchEvent: boolean
  ): void => {
    const dntEnabled = getDoNotTrackEnabled();
    const analyticsAllowed = consent.analytics === true && !dntEnabled;
    setRuntimeAnalyticsAllowed(analyticsAllowed);

    if (fathomEnabled) {
      try {
        if (analyticsAllowed) {
          loadFathomScript();
        } else {
          removeFathomScript();
        }
      } catch {
        // Ignore script management failures.
      }
    }

    setFathomTrackingEnabled(analyticsAllowed);
    hideBanner();

    if (shouldDispatchEvent) {
      dispatchConsentChange(consent, dntEnabled);
    }
  };

  const openBanner = (): void => {
    lastFocusBeforeOpen = document.activeElement;
    showBanner(true);
  };

  const storedConsent = readConsentPreference();
  if (storedConsent) {
    applyConsent(storedConsent, false);
  } else {
    showBanner(false);
  }

  banner.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) {
      return;
    }
    const action = target.getAttribute("data-cookie-action");
    if (action !== "accept" && action !== "reject") {
      return;
    }
    const consent = writeConsentPreference(action === "accept");
    applyConsent(consent, true);
  });

  window.addEventListener(CONSENT_EVENTS.OPEN, openBanner);
</script>

<style>
  .cookie-consent {
    position: fixed;
    inset-block-end: var(--spacing-base);
    inset-inline: var(--spacing-base);
    z-index: 60;
    display: grid;
    gap: var(--spacing-base);
    max-inline-size: 34rem;
    padding: var(--spacing-lg);
    margin-inline: auto;
    color: var(--text-primary);
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .cookie-consent__text {
    margin: 0;
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .cookie-consent__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: flex-end;
  }

  .cookie-consent__button {
    min-block-size: var(--control-min-block-size);
    padding: var(--control-padding-block) var(--control-padding-inline);
    font: inherit;
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .cookie-consent__button--secondary {
    color: var(--text-primary);
    background: var(--surface-panel-bg);
  }

  .cookie-consent__button--primary {
    color: var(--button-text-accent);
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .cookie-consent__button:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (width <= 640px) {
    .cookie-consent {
      inset-inline: var(--spacing-sm);
      padding: var(--spacing-base);
    }

    .cookie-consent__actions {
      flex-direction: column;
    }

    .cookie-consent__button {
      inline-size: 100%;
    }
  }
</style>
