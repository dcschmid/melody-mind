---
interface Props extends astroHTML.JSX.HTMLAttributes {
  as?: "section" | "div" | "aside" | "article";
  variant?: "default" | "accent" | "subtle" | "plain";
  padding?: "default" | "compact" | "spacious";
  className?: string;
  class?: string;
  role?: string;
  "aria-label"?: string;
  "aria-labelledby"?: string;
  id?: string;
  tabindex?: number;
}

const {
  as = "section",
  variant = "default",
  padding = "default",
  className = "",
  class: classProp = "",
  role: roleAttr,
  "aria-label": ariaLabel,
  "aria-labelledby": ariaLabelledBy,
  id,
  tabindex,
  ...rest
} = Astro.props as Props;

const Tag = as;
const classes = [
  "section-surface",
  `section-surface--${variant}`,
  `section-surface--padding-${padding}`,
  className,
  classProp,
]
  .filter(Boolean)
  .join(" ");

const safeProps = {
  ...rest,
  ...(roleAttr && { role: roleAttr }),
  ...(ariaLabel && { "aria-label": ariaLabel }),
  ...(ariaLabelledBy && { "aria-labelledby": ariaLabelledBy }),
  ...(id && { id }),
  ...(tabindex !== undefined && { tabindex }),
};
---

<Tag {...safeProps} class={classes}>
  <slot />
</Tag>

<style>
  .section-surface {
    display: flex;
    flex-direction: column;
    gap: var(--section-surface-inner-gap);
    min-height: 4rem;
    padding: clamp(var(--spacing-md), 4vw, var(--spacing-2xl));
    contain: layout style;
    font-kerning: normal;
    line-height: var(--line-height-normal);
    background: var(--section-surface-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    text-rendering: optimizelegibility;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .section-surface > :global(* + *) {
    padding-top: var(--spacing-xs);
  }

  @media (hover: hover) and (pointer: fine) {
    .section-surface:hover:not(.section-surface--plain),
    .section-surface:focus:not(.section-surface--plain) {
      background: color-mix(in srgb, var(--accent-primary) 6%, var(--surface-1));
      border-color: var(--surface-border-accent);
    }
  }

  .section-surface--accent {
    background: var(--section-surface-accent-bg);
    border-color: var(--surface-border-accent);
    box-shadow: var(--shadow-sm);
  }

  .section-surface--subtle {
    background: color-mix(in srgb, var(--surface-1) 86%, transparent);
    box-shadow: none;
  }

  .section-surface--plain {
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .section-surface--padding-compact {
    padding: var(--spacing-lg);
  }

  .section-surface--padding-spacious {
    padding: clamp(var(--spacing-xl), 2.8vw, var(--spacing-3xl));
  }

  @media (width >= 768px) {
    .section-surface {
      gap: var(--spacing-xl);
      min-height: 6rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-surface {
      transition: none;
    }
  }
</style>
