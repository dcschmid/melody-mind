---
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

// EmptyState stays intentionally small: callers pass copy and optional ARIA behavior.
interface Props extends astroHTML.JSX.HTMLAttributes {
  title?: string;
  description?: string;
  role?: "status" | "note" | "alert";
  live?: "off" | "polite" | "assertive";
  atomic?: boolean;
  className?: string;
  class?: string;
}

const {
  title,
  description,
  role = "status",
  live = "polite",
  atomic = true,
  className = "",
  class: classProp = "",
  ...rest
} = Astro.props as Props;

// Preserve the shared block class while still allowing local extension hooks.
const classes = ["empty-state", className, classProp].filter(Boolean).join(" ");
---

<!-- Default live-region behavior makes async empty results announce politely. -->
<div
  {...rest}
  class={classes}
  role={role}
  aria-live={live}
  aria-atomic={atomic ? "true" : "false"}
>
  {
    title ? (
      <Paragraph textSize="lg" className="empty-state__title">
        {title}
      </Paragraph>
    ) : null
  }
  {
    description ? (
      <Paragraph textSize="sm" className="empty-state__description">
        {description}
      </Paragraph>
    ) : null
  }
</div>

<style>
  /* Token-driven panel surface so empty states stay aligned with cards and dialogs. */
  .empty-state {
    padding: var(--spacing-2xl) var(--spacing-xl);
    color: var(--text-secondary);
    text-align: center;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 78%, transparent),
      var(--shadow-sm);
  }

  /* Title keeps the stronger text token for a clear empty-state hierarchy. */
  .empty-state__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    letter-spacing: var(--letter-spacing-tight);
  }

  /* Body copy stays softer, but with enough spacing to read as a follow-up message. */
  .empty-state__description {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
</style>
