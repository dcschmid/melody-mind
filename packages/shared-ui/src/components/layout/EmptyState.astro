---
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

// EmptyState stays intentionally small: callers pass copy and optional ARIA behavior.
interface Props extends astroHTML.JSX.HTMLAttributes {
  title?: string;
  description?: string;
  role?: "status" | "note" | "alert";
  live?: "off" | "polite" | "assertive";
  atomic?: boolean;
  className?: string;
  class?: string;
}

const {
  title,
  description,
  role = "status",
  live = "polite",
  atomic = true,
  className = "",
  class: classProp = "",
  ...rest
} = Astro.props as Props;

// Preserve the shared block class while still allowing local extension hooks.
const classes = ["empty-state", className, classProp].filter(Boolean).join(" ");
---

<!-- Default live-region behavior makes async empty results announce politely. -->
<div {...rest} class={classes} role={role} aria-live={live} aria-atomic={atomic}>
  {
    title ? (
      <Paragraph textSize="lg" className="empty-state__title">
        {title}
      </Paragraph>
    ) : null
  }
  {
    description ? (
      <Paragraph textSize="sm" className="empty-state__description">
        {description}
      </Paragraph>
    ) : null
  }
</div>

<style>
  .empty-state[hidden] {
    display: none;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .empty-state {
      padding: var(--spacing-2xl) var(--spacing-xl);
      color: var(--text-secondary);
      text-align: start;
      background: color-mix(
        in srgb,
        var(--accent-primary) 4%,
        var(--surface-panel-raised)
      );
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-sm);
      transition: none;
    }
  }

  .empty-state {
    padding: var(--spacing-2xl) var(--spacing-xl);
    color: var(--text-secondary);
    text-align: start;
    background: color-mix(in srgb, var(--accent-primary) 4%, var(--surface-panel-raised));
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--motion-duration-fast) var(--motion-ease-standard),
      box-shadow var(--motion-duration-fast) var(--motion-ease-standard),
      background var(--motion-duration-fast) var(--motion-ease-standard);
  }

  @media (width <= 480px) {
    .empty-state {
      padding: var(--spacing-xl) var(--spacing-lg);
    }
  }

  .empty-state:hover,
  .empty-state:focus {
    background: color-mix(in srgb, var(--accent-primary) 6%, var(--surface-panel-raised));
    box-shadow: var(--shadow-base);
    transform: translateY(var(--motion-distance-xs));
  }

  .empty-state:focus-within {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .empty-state__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    letter-spacing: var(--letter-spacing-tight);
  }

  .empty-state__description {
    margin: var(--spacing-md) 0 0;
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
</style>
