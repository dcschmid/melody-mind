---
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props extends astroHTML.JSX.HTMLAttributes {
  title?: string;
  description?: string;
  role?: "status" | "note" | "alert";
  live?: "off" | "polite" | "assertive";
  atomic?: boolean;
  className?: string;
  class?: string;
}

const {
  title,
  description,
  role = "status",
  live = "polite",
  atomic = true,
  className = "",
  class: classProp = "",
  ...rest
} = Astro.props as Props;

const classes = ["empty-state", className, classProp].filter(Boolean).join(" ");
---

<div
  {...rest}
  class={classes}
  role={role}
  aria-live={live}
  aria-atomic={atomic ? "true" : "false"}
>
  {
    title ? (
      <Paragraph textSize="lg" className="empty-state__title">
        {title}
      </Paragraph>
    ) : null
  }
  {
    description ? (
      <Paragraph textSize="sm" className="empty-state__description">
        {description}
      </Paragraph>
    ) : null
  }
</div>

<style>
  .empty-state {
    padding: var(--spacing-2xl) var(--spacing-xl);
    color: var(--text-secondary);
    text-align: center;
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  .empty-state__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    letter-spacing: var(--letter-spacing-tight);
  }

  .empty-state__description {
    margin-block-start: var(--spacing-md);
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
</style>
