---
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { AppShellFooterConfig, AppShellLink } from "@shared-utils/utils/appShell";
import type { ImageMetadata } from "astro";

import ThemeToggle from "@shared-ui/components/actions/ThemeToggle.astro";

interface Props {
  footerConfig: AppShellFooterConfig;
  brandLogoSrc: string | ImageMetadata;
  brandLogoAlt?: string;
  brandHref?: string;
  brandAriaLabel?: string;
}

interface FooterGroup {
  id: string;
  title: string;
  links: AppShellLink[];
  ariaLabel: string;
}

const {
  footerConfig,
  brandLogoSrc,
  brandLogoAlt = "Melody Mind",
  brandHref = "/",
  brandAriaLabel = "Go to the MelodyMind homepage",
} = Astro.props as Props;
const logoSrc = typeof brandLogoSrc === "string" ? brandLogoSrc : brandLogoSrc.src;
const logoWidth = typeof brandLogoSrc === "string" ? 700 : brandLogoSrc.width;
const logoHeight = typeof brandLogoSrc === "string" ? 232 : brandLogoSrc.height;
const getFooterFathomEvent = (groupId: string, link: AppShellLink): string => {
  if (groupId === "support") {
    return `Support: ${link.label}`;
  }

  if (groupId === "legal") {
    return `Legal: ${link.label}`;
  }

  return `External: ${link.label}`;
};

const footerGroups: FooterGroup[] = [
  {
    id: "explore",
    title: footerConfig.exploreTitle || "Explore",
    links: footerConfig.exploreLinks,
    ariaLabel: "Music footer navigation",
  },
  {
    id: "support",
    title: footerConfig.supportTitle || "Support",
    links: footerConfig.supportLinks,
    ariaLabel: "Music support links",
  },
  {
    id: "legal",
    title: footerConfig.legalTitle || "Legal",
    links: footerConfig.legalLinks,
    ariaLabel: "Music legal links",
  },
].filter((group) => group.links.length > 0);
---

<footer class="music-footer">
  <div class="music-footer__inner">
    <div class="music-footer__brand">
      <a class="music-footer__brand-link" href={brandHref} aria-label={brandAriaLabel}>
        <img
          class="music-footer__logo"
          src={logoSrc}
          width={logoWidth}
          height={logoHeight}
          alt={brandLogoAlt}
          loading="lazy"
          decoding="async"
        />
      </a>
      <p class="music-footer__brand-text">{footerConfig.brandText}</p>
    </div>

    <div class="music-footer__nav-grid">
      {
        footerGroups.map((group) => (
          <section
            class="music-footer__group"
            aria-labelledby={`music-footer-${group.id}`}
          >
            <h2 class="music-footer__group-title" id={`music-footer-${group.id}`}>
              {group.title}
            </h2>
            <nav class="music-footer__nav" aria-label={group.ariaLabel}>
              <ul class="music-footer__link-list">
                {group.links.map((link) => (
                  <li class="music-footer__link-item">
                    <a
                      class="music-footer__link"
                      href={link.href}
                      target={link.target}
                      rel={link.rel}
                      data-fathom-event={getFooterFathomEvent(group.id, link)}
                      data-fathom-label={link.label}
                    >
                      <span>{link.label}</span>
                      {link.target === "_blank" && (
                        <Icon
                          name="external-link"
                          class="music-footer__link-icon"
                          aria-hidden="true"
                        />
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </section>
        ))
      }

      {
        footerConfig.showSettings && (
          <section
            class="music-footer__group music-footer__group--settings"
            aria-labelledby="music-footer-settings"
          >
            <h2 class="music-footer__group-title" id="music-footer-settings">
              {footerConfig.settingsTitle || "Settings"}
            </h2>
            <div class="music-footer__settings">
              <ThemeToggle />
              <button
                class="music-footer__settings-button"
                type="button"
                data-cc="manage"
              >
                Cookie settings
              </button>
            </div>
          </section>
        )
      }
    </div>

    <div class="music-footer__bottom">
      <p class="music-footer__copyright">{footerConfig.copyrightText}</p>
    </div>
  </div>
</footer>

<style>
  .music-footer {
    --music-footer-accent: var(--music-accent-primary, var(--accent-primary));
    --music-footer-ink: var(--text-primary);
    --music-footer-muted: var(--text-secondary);
    --music-footer-line: var(--border-muted);
    --music-footer-ease-out: var(--motion-ease-standard);
    --music-footer-space-2xs: var(--spacing-2xs, 0.125rem);
    --music-footer-space-xs: var(--spacing-xs, 0.25rem);
    --music-footer-space-sm: var(--spacing-sm, 0.5rem);
    --music-footer-space-md: var(--spacing-md, 0.75rem);
    --music-footer-space-lg: var(--spacing-lg, 1.5rem);
    --music-footer-radius-base: var(--radius-base, 0.5rem);
    --music-footer-target-size: var(--control-min-block-size, 2.5rem);
    --music-footer-logo-min: 8.2rem;
    --music-footer-logo-max: 10.4rem;
    --music-footer-link-icon-size: 0.78rem;

    position: relative;
    color: var(--music-footer-ink);
    background: transparent;
  }

  .music-footer__inner {
    position: relative;
    display: grid;
    gap: clamp(1rem, 2.5vw, 1.7rem);
    max-inline-size: 90rem;
    padding: clamp(var(--music-footer-space-lg), 3vw, 2.25rem) clamp(1rem, 4vw, 4rem) 1rem;
    margin-inline: auto;
  }

  .music-footer__inner::before {
    position: absolute;
    inset-block-start: 0;
    inset-inline: clamp(1rem, 4vw, 4rem);
    block-size: 1px;
    content: "";
    background: color-mix(
      in srgb,
      var(--music-footer-accent) 18%,
      var(--music-footer-line)
    );
  }

  .music-footer__brand {
    display: grid;
    gap: var(--music-footer-space-sm);
    align-content: start;
    max-inline-size: 31rem;
  }

  .music-footer__brand-link {
    display: inline-flex;
    inline-size: fit-content;
    border-radius: var(--music-footer-radius-base);
  }

  .music-footer__brand-link:focus-visible {
    outline: 2px solid var(--music-footer-accent);
    outline-offset: 4px;
  }

  .music-footer__logo {
    inline-size: clamp(var(--music-footer-logo-min), 14vw, var(--music-footer-logo-max));
    block-size: auto;
  }

  .music-footer__brand-text {
    max-inline-size: 36ch;
    margin: 0;
    font-size: clamp(0.84rem, 0.8rem + 0.12vw, 0.94rem);
    line-height: 1.55;
    color: var(--music-footer-muted);
    text-wrap: pretty;
  }

  .music-footer__nav-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--music-footer-space-md) clamp(1rem, 3vw, 2rem);
  }

  .music-footer__group {
    display: grid;
    gap: var(--music-footer-space-sm);
    align-content: start;
  }

  .music-footer__group-title {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 750;
    line-height: 1.2;
    color: var(--music-footer-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-wrap: balance;
  }

  .music-footer__nav {
    display: grid;
  }

  .music-footer__link-list {
    display: grid;
    gap: var(--music-footer-space-2xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .music-footer__link-item {
    display: flex;
  }

  .music-footer__link {
    display: inline-flex;
    gap: var(--music-footer-space-xs);
    align-items: center;
    justify-content: flex-start;
    inline-size: fit-content;
    min-block-size: var(--music-footer-target-size);
    padding-inline: var(--music-footer-space-2xs);
    font-size: 0.84rem;
    line-height: 1.25;
    color: var(--music-footer-muted);
    text-decoration: none;
    border-radius: var(--music-footer-radius-base);
  }

  .music-footer__link:hover,
  .music-footer__link:focus {
    color: var(--music-footer-accent);
  }

  .music-footer__link:focus-visible {
    outline: 2px solid var(--music-footer-accent);
    outline-offset: 4px;
  }

  .music-footer__link-icon {
    inline-size: var(--music-footer-link-icon-size);
    block-size: var(--music-footer-link-icon-size);
    opacity: 0.68;
  }

  .music-footer__settings {
    display: flex;
    flex-wrap: wrap;
    gap: var(--music-footer-space-sm);
    align-items: center;
  }

  .music-footer__settings-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: var(--music-footer-target-size);
    padding: var(--music-footer-space-sm) var(--music-footer-space-md);
    font: inherit;
    font-size: 0.84rem;
    line-height: 1.25;
    color: var(--music-footer-muted);
    cursor: pointer;
    background: transparent;
    border: 1px solid var(--music-footer-line);
    border-radius: var(--music-footer-radius-base);
  }

  .music-footer__settings-button:hover,
  .music-footer__settings-button:focus {
    color: var(--music-footer-accent);
    border-color: color-mix(
      in srgb,
      var(--music-footer-accent) 48%,
      var(--music-footer-line)
    );
  }

  .music-footer__settings-button:focus-visible {
    outline: 2px solid var(--music-footer-accent);
    outline-offset: 4px;
  }

  .music-footer__bottom {
    padding-block-start: var(--music-footer-space-md);
    border-block-start: 1px solid
      color-mix(in srgb, var(--music-footer-accent) 12%, var(--music-footer-line));
  }

  .music-footer__copyright {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--music-footer-muted) 86%, var(--music-footer-accent));
  }

  @media (width >= 760px) {
    .music-footer__inner {
      grid-template-columns: minmax(16rem, 1fr) minmax(0, 1.6fr);
      align-items: start;
    }

    .music-footer__nav-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .music-footer__bottom {
      grid-column: 1 / -1;
    }
  }

  @media (width <= 560px) {
    .music-footer__inner {
      padding-block-start: var(--music-footer-space-md);
      padding-inline: 1rem;
    }

    .music-footer__nav-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .music-footer__group--settings {
      padding-block-start: var(--music-footer-space-xs);
    }
  }

  :global([data-theme="dark"]) .music-footer {
    --music-footer-accent: var(--music-accent-primary, var(--accent-primary));
    --music-footer-ink: var(--text-primary);
    --music-footer-muted: var(--text-secondary);
    --music-footer-line: var(--border-muted);
  }
</style>
