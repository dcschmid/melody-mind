---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import Paragraph from "../typography/Paragraph.astro";
import ThemeToggle from "../actions/ThemeToggle.astro";
import type { AppShellFooterConfig } from "@shared-utils/utils/appShell";

type FooterLink = AppShellFooterConfig["exploreLinks"][number];
type FooterConfig = AppShellFooterConfig;

interface Props {
  footerConfig?: FooterConfig;
  brandTitle?: string;
  brandText?: string;
  exploreTitle?: string;
  exploreLinks?: FooterLink[];
  supportTitle?: string;
  supportLinks?: FooterLink[];
  legalTitle?: string;
  legalLinks?: FooterLink[];
  settingsTitle?: string;
  showSettings?: boolean;
  themeStatusPrefix?: string;
  copyrightText?: string;
}

const {
  footerConfig,
  brandTitle = "MelodyMind",
  brandText = "Curated guides, playlists, and tools for focused listening.",
  exploreTitle = "Explore",
  exploreLinks = [],
  supportTitle = "Support",
  supportLinks = [],
  legalTitle = "Legal",
  legalLinks = [],
  settingsTitle = "Settings",
  showSettings = true,
  themeStatusPrefix = "Theme",
  copyrightText = `© ${new Date().getFullYear()} MelodyMind`,
} = Astro.props as Props;

const resolvedFooterConfig = {
  brandTitle,
  brandText,
  exploreTitle,
  exploreLinks,
  supportTitle,
  supportLinks,
  legalTitle,
  legalLinks,
  settingsTitle,
  showSettings,
  themeStatusPrefix,
  copyrightText,
  ...footerConfig,
};
---

<footer class="site-footer footer-shell" role="contentinfo">
  <div class="footer-shell__container">
    <div class="footer-shell__main">
      <div class="site-footer__grid">
        <div class="site-footer__section site-footer__section--brand">
          <Paragraph textSize="sm" className="site-footer__title">
            {resolvedFooterConfig.brandTitle}
          </Paragraph>
          <Paragraph textSize="sm" className="site-footer__text">
            {resolvedFooterConfig.brandText}
          </Paragraph>
        </div>

        <div class="site-footer__section">
          <Paragraph textSize="sm" className="site-footer__title">
            {resolvedFooterConfig.exploreTitle}
          </Paragraph>
          <nav aria-label="Footer navigation" class="site-footer__nav">
            {
              resolvedFooterConfig.exploreLinks.map((link) => (
                <AccessibleExternalLink
                  className="site-footer__link"
                  href={link.href}
                  target={link.target}
                  rel={link.rel}
                >
                  {link.label}
                </AccessibleExternalLink>
              ))
            }
          </nav>
        </div>

        <div class="site-footer__section">
          <Paragraph textSize="sm" className="site-footer__title">
            {resolvedFooterConfig.supportTitle}
          </Paragraph>
          <nav aria-label="Support links" class="site-footer__nav">
            {
              resolvedFooterConfig.supportLinks.map((link) => (
                <AccessibleExternalLink
                  className="site-footer__link"
                  href={link.href}
                  target={link.target}
                  rel={link.rel}
                >
                  {link.label}
                </AccessibleExternalLink>
              ))
            }
          </nav>
        </div>

        <div class="site-footer__section">
          <Paragraph textSize="sm" className="site-footer__title">
            {resolvedFooterConfig.legalTitle}
          </Paragraph>
          <nav aria-label="Legal navigation" class="site-footer__nav">
            {
              resolvedFooterConfig.legalLinks.map((link) => (
                <AccessibleExternalLink
                  className="site-footer__link"
                  href={link.href}
                  target={link.target}
                  rel={link.rel}
                >
                  {link.label}
                </AccessibleExternalLink>
              ))
            }
          </nav>
        </div>

        {
          resolvedFooterConfig.showSettings && (
            <div class="site-footer__section">
              <Paragraph textSize="sm" className="site-footer__title">
                {resolvedFooterConfig.settingsTitle}
              </Paragraph>
              <nav aria-label="Settings navigation" class="site-footer__nav">
                <ThemeToggle />
              </nav>
              <div class="site-footer__status-list">
                <Paragraph
                  textSize="sm"
                  className="site-footer__theme-status"
                  data-theme-status
                  role="status"
                  aria-live="polite"
                >
                  {resolvedFooterConfig.themeStatusPrefix}: system
                </Paragraph>
              </div>
            </div>
          )
        }
      </div>

      <div class="footer-shell__bottom site-footer__meta">
        <Paragraph textSize="sm">{resolvedFooterConfig.copyrightText}</Paragraph>
      </div>
    </div>
  </div>
</footer>

<script>
  import { THEME_EVENTS } from "@shared-utils/constants/events";
  import { getStoredTheme, getSystemTheme } from "@shared-utils/utils/theme/themeStorage";

  const themeStatusElement = document.querySelector<HTMLElement>("[data-theme-status]");

  const themeMessages = {
    light: "Theme: bright listening",
    dark: "Theme: night listening",
    system: "Theme: following your rhythm",
  } as const;

  const renderThemeStatus = () => {
    if (!themeStatusElement) {
      return;
    }
    const storedTheme = getStoredTheme();
    const resolvedTheme = storedTheme ?? getSystemTheme();
    const message = themeMessages[resolvedTheme] ?? themeMessages.system;
    themeStatusElement.textContent = message;
  };

  renderThemeStatus();
  window.addEventListener(THEME_EVENTS.CHANGED, () => renderThemeStatus());
</script>

<style>
  /* -----------------------------------------------------------------------------
     Footer Component Styles (includes former FooterShell)
     Site footer with navigation links and settings
     WCAG AAA compliant with proper touch targets and focus states
     ----------------------------------------------------------------------------- */

  .footer-shell {
    margin-block-start: var(--spacing-4xl);
    background: color-mix(in srgb, var(--surface-1) 64%, var(--bg-primary));
    border-block-start: 1px solid color-mix(in srgb, var(--accent-primary) 12%, var(--surface-border-soft));
  }

  .footer-shell__container {
    display: grid;
    gap: var(--spacing-2xl);
    padding-block: var(--spacing-2xl) var(--spacing-xl);
  }

  .footer-shell__main {
    display: block;
  }

  .footer-shell__bottom {
    display: block;
    padding-block-start: var(--spacing-lg);
  }

  @media (width >= 768px) {
    .footer-shell {
      margin-block-start: clamp(var(--spacing-4xl), 8vw, 6rem);
    }

    .footer-shell__container {
      gap: var(--spacing-3xl);
      padding-block: var(--spacing-3xl) var(--spacing-2xl);
    }
  }

  .site-footer {
    background: transparent;
  }

  .site-footer .footer-shell__container {
    max-inline-size: min(82rem, var(--page-max-width));
    padding: var(--spacing-2xl) var(--spacing-lg);
    margin: 0 auto;
    color: var(--text-primary);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  @media (width >= 640px) {
    .site-footer__grid {
      grid-template-columns: minmax(0, 1.3fr) repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1024px) {
    .site-footer__grid {
      grid-template-columns: minmax(0, 1.4fr) repeat(4, minmax(0, 0.85fr));
      gap: clamp(var(--spacing-xl), 2vw, var(--spacing-2xl));
    }
  }

  .site-footer__section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
    min-inline-size: 0;
    padding: 0;
    padding-inline-start: var(--spacing-sm);
  }

  .site-footer__section--brand {
    padding-inline-start: 0;
  }

  .site-footer__title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .site-footer__text {
    max-inline-size: 30ch;
    font-size: var(--font-size-sm);
    line-height: var(--prose-line-height);
    color: var(--text-secondary);
  }

  /* Brand section uses warmer accent for visual distinction */
  .site-footer__section--brand .site-footer__title {
    color: var(--accent-primary);
  }

  .site-footer__section--brand .site-footer__text {
    color: color-mix(in srgb, var(--text-secondary) 85%, var(--accent-primary) 15%);
  }

  .site-footer__nav {
    display: grid;
    gap: var(--spacing-sm);
  }

  .site-footer__link {
    display: flex;
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--accent-primary);
    transform: translateX(var(--motion-distance-xs));
  }

  .site-footer__link:focus-visible {
    outline-offset: var(--focus-ring-offset);
  }

  .site-footer__meta {
    padding-block-start: var(--spacing-xl);
    font-size: var(--font-size-xs);
    color: color-mix(in srgb, var(--text-secondary) 88%, var(--accent-primary) 12%);
  }

  .site-footer__meta::before {
    display: block;
    block-size: 1px;
    margin-block-end: var(--spacing-xl);
    content: "";
    background: color-mix(in srgb, var(--accent-primary) 8%, var(--surface-border-soft));
  }

  .site-footer__theme-status {
    margin: 0;
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  .site-footer__status-list {
    display: grid;
    gap: var(--spacing-xs);
    padding-block-start: var(--spacing-sm);
  }

  @media (width >= 768px) {
    .site-footer .footer-shell__container {
      padding-inline: var(--spacing-xl);
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-footer__link {
      transition: none;
    }
  }
</style>
