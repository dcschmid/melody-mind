---
import FooterShell from "./FooterShell.astro";
import Paragraph from "../typography/Paragraph.astro";
import ThemeToggle from "../actions/ThemeToggle.astro";

interface FooterLink {
  href: string;
  label: string;
  target?: "_blank" | "_self";
  rel?: string;
}

interface Props {
  brandTitle?: string;
  brandText?: string;
  exploreTitle?: string;
  exploreLinks?: FooterLink[];
  supportTitle?: string;
  supportLinks?: FooterLink[];
  legalTitle?: string;
  legalLinks?: FooterLink[];
  settingsTitle?: string;
  showSettings?: boolean;
  cookieSettingsLabel?: string;
  themeStatusPrefix?: string;
  cookiesWaitingLabel?: string;
  cookiesAllowedLabel?: string;
  cookiesEssentialLabel?: string;
  copyrightText?: string;
}

const {
  brandTitle = "Brand",
  brandText = "Curated guides, playlists, and tools for focused listening.",
  exploreTitle = "Explore",
  exploreLinks = [],
  supportTitle = "Support",
  supportLinks = [],
  legalTitle = "Legal",
  legalLinks = [],
  settingsTitle = "Settings",
  showSettings = true,
  cookieSettingsLabel = "Cookie settings",
  themeStatusPrefix = "Theme",
  cookiesWaitingLabel = "Cookies: waiting",
  cookiesAllowedLabel = "Cookies: analytics allowed",
  cookiesEssentialLabel = "Cookies: essential only",
  copyrightText = `© ${new Date().getFullYear()} MelodyMind. All rights reserved.`,
} = Astro.props as Props;
---

<FooterShell class="site-footer">
  <div class="site-footer__grid">
    <div class="site-footer__section">
      <div data-animate="soft-fade">
        <Paragraph textSize="sm" className="site-footer__title">
          {brandTitle}
        </Paragraph>
        <Paragraph textSize="sm" className="site-footer__text">
          {brandText}
        </Paragraph>
      </div>
    </div>

    <div class="site-footer__section">
      <div class="site-footer__motion site-footer__motion--fast" data-animate="rise-in">
        <Paragraph textSize="sm" className="site-footer__title">
          {exploreTitle}
        </Paragraph>
        <nav aria-label="Footer navigation" class="site-footer__nav">
          {
            exploreLinks.map((link) => (
              <a
                class="site-footer__link"
                href={link.href}
                target={link.target}
                rel={link.rel}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    <div class="site-footer__section">
      <div class="site-footer__motion site-footer__motion--base" data-animate="rise-in">
        <Paragraph textSize="sm" className="site-footer__title">
          {supportTitle}
        </Paragraph>
        <nav aria-label="Support links" class="site-footer__nav">
          {
            supportLinks.map((link) => (
              <a
                class="site-footer__link"
                href={link.href}
                target={link.target}
                rel={link.rel}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    <div class="site-footer__section">
      <div class="site-footer__motion site-footer__motion--slow" data-animate="rise-in">
        <Paragraph textSize="sm" className="site-footer__title">
          {legalTitle}
        </Paragraph>
        <nav aria-label="Legal navigation" class="site-footer__nav">
          {
            legalLinks.map((link) => (
              <a
                class="site-footer__link"
                href={link.href}
                target={link.target}
                rel={link.rel}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    {
      showSettings && (
        <div class="site-footer__section">
          <div
            class="site-footer__motion site-footer__motion--settings"
            data-animate="rise-in"
          >
            <Paragraph textSize="sm" className="site-footer__title">
              {settingsTitle}
            </Paragraph>
            <nav aria-label="Settings navigation" class="site-footer__nav">
              <ThemeToggle />
              <button
                type="button"
                class="site-footer__link site-footer__cookie-button"
                data-cookie-settings-trigger
              >
                {cookieSettingsLabel}
              </button>
            </nav>
            <div class="site-footer__status-list">
              <Paragraph
                textSize="sm"
                className="site-footer__cookie-status"
                data-theme-status
              >
                {themeStatusPrefix}: system
              </Paragraph>
              <Paragraph
                textSize="sm"
                className="site-footer__cookie-status"
                data-cookie-consent-status
                data-cookie-waiting-label={cookiesWaitingLabel}
                data-cookie-allowed-label={cookiesAllowedLabel}
                data-cookie-essential-label={cookiesEssentialLabel}
              >
                {cookiesWaitingLabel}
              </Paragraph>
            </div>
          </div>
        </div>
      )
    }
  </div>

  <div slot="bottom" class="site-footer__meta">
    <Paragraph textSize="sm">{copyrightText}</Paragraph>
  </div>
</FooterShell>

<script>
  import {
    CONSENT_EVENTS,
    THEME_EVENTS,
    dispatchCustomEvent,
  } from "@shared-utils/constants/events";
  import {
    readConsentPreference,
    type ConsentPreference,
  } from "@shared-utils/utils/consent/clientConsent";
  import { getStoredTheme, getSystemTheme } from "@shared-utils/utils/theme/themeStorage";

  const trigger = document.querySelector<HTMLElement>("[data-cookie-settings-trigger]");
  const themeStatusElement = document.querySelector<HTMLElement>("[data-theme-status]");
  const statusElement = document.querySelector<HTMLElement>(
    "[data-cookie-consent-status]"
  );

  const renderStatus = (consent: ConsentPreference | null = readConsentPreference()) => {
    if (!statusElement) {
      return;
    }
    const waitingLabel = statusElement.dataset.cookieWaitingLabel || "Cookies: waiting";
    const allowedLabel =
      statusElement.dataset.cookieAllowedLabel || "Cookies: analytics allowed";
    const essentialLabel =
      statusElement.dataset.cookieEssentialLabel || "Cookies: essential only";
    if (!consent) {
      statusElement.textContent = waitingLabel;
      return;
    }
    statusElement.textContent = consent.analytics ? allowedLabel : essentialLabel;
  };

  const renderThemeStatus = () => {
    if (!themeStatusElement) {
      return;
    }
    const storedTheme = getStoredTheme();
    const resolvedTheme = storedTheme ?? getSystemTheme();
    themeStatusElement.textContent = `Theme: ${resolvedTheme} (${storedTheme ? "manual" : "system"})`;
  };

  renderStatus();
  renderThemeStatus();

  trigger?.addEventListener("click", () => dispatchCustomEvent(CONSENT_EVENTS.OPEN));

  window.addEventListener(CONSENT_EVENTS.CHANGED, () => renderStatus());
  window.addEventListener(THEME_EVENTS.CHANGED, () => renderThemeStatus());
</script>

<style>
  /* -----------------------------------------------------------------------------
     Footer Component Styles
     Site footer with navigation links and settings
     WCAG AAA compliant with proper touch targets and focus states
     ----------------------------------------------------------------------------- */

  .site-footer {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 28%, transparent),
        transparent 40%
      ),
      transparent;
  }

  .site-footer :global(.footer-shell__container) {
    max-inline-size: 72rem;
    padding: var(--spacing-2xl) var(--spacing-lg);
    margin: 0 auto;
    color: var(--text-primary);
  }

  /* Footer grid - responsive columns */
  .site-footer__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-xl);
  }

  @media (width >= 640px) {
    .site-footer__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (width >= 1024px) {
    .site-footer__grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  /* Footer section - column container */
  .site-footer__section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    min-inline-size: 0;
    padding: var(--spacing-lg);
    background: color-mix(in srgb, var(--surface-1) 72%, transparent);
    border: 1px solid var(--surface-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-1) 62%, transparent);
  }

  /* Section title */
  .site-footer__title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Section text */
  .site-footer__text {
    font-size: var(--font-size-base);
    line-height: var(--prose-line-height);
    color: var(--text-secondary);
  }

  /* Navigation container */
  .site-footer__nav {
    display: grid;
    gap: var(--spacing-xs);
  }

  /* Navigation links - WCAG AAA touch targets */
  .site-footer__link {
    display: flex;
    align-items: center;
    min-block-size: 48px;
    padding: var(--spacing-xs) var(--spacing-sm);
    margin-inline: calc(var(--spacing-sm) * -1);
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--accent-primary);
    background: var(--surface-chip-bg);
    border-color: var(--surface-border-accent-strong);
  }

  .site-footer__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    box-shadow: var(--interactive-shadow-strong);
  }

  /* Meta section - copyright and bottom content */
  .site-footer__meta {
    padding-block-start: var(--spacing-lg);
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  /* Cookie settings button */
  .site-footer__cookie-button {
    font-family: inherit;
    text-align: start;
    cursor: pointer;
    background: none;
    border: 0;
  }

  /* Cookie and theme status text */
  .site-footer__cookie-status {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  /* Status list container */
  .site-footer__status-list {
    display: grid;
    gap: var(--spacing-xs);
    padding-block-start: var(--spacing-sm);
    margin-block-start: var(--spacing-sm);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .site-footer__motion {
    display: grid;
    gap: var(--spacing-sm);
  }

  .site-footer__motion--fast {
    --motion-delay: var(--motion-delay-fast);
  }

  .site-footer__motion--base {
    --motion-delay: var(--motion-delay-base);
  }

  .site-footer__motion--slow {
    --motion-delay: var(--motion-delay-slow);
  }

  .site-footer__motion--settings {
    --motion-delay: 280ms;
  }

  @media (width <= 639px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (width >= 768px) {
    .site-footer :global(.footer-shell__container) {
      padding-inline: var(--spacing-xl);
    }

    .site-footer__grid {
      gap: var(--spacing-2xl);
    }
  }

  /* Reduced motion support - disable transitions */
  @media screen and (prefers-reduced-motion: reduce) {
    .site-footer__link {
      transition: none;
    }
  }
</style>
