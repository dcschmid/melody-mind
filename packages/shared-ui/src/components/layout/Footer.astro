---
import FooterShell from "./FooterShell.astro";
import Paragraph from "../typography/Paragraph.astro";
import ThemeToggle from "../actions/ThemeToggle.astro";
import type { AppShellFooterConfig } from "@shared-utils/utils/appShell";

type FooterLink = AppShellFooterConfig["exploreLinks"][number];
type FooterConfig = AppShellFooterConfig;

interface Props {
  footerConfig?: FooterConfig;
  brandTitle?: string;
  brandText?: string;
  exploreTitle?: string;
  exploreLinks?: FooterLink[];
  supportTitle?: string;
  supportLinks?: FooterLink[];
  legalTitle?: string;
  legalLinks?: FooterLink[];
  settingsTitle?: string;
  showSettings?: boolean;
  themeStatusPrefix?: string;
  copyrightText?: string;
}

const {
  footerConfig,
  brandTitle = "Brand",
  brandText = "Curated guides, playlists, and tools for focused listening.",
  exploreTitle = "Explore",
  exploreLinks = [],
  supportTitle = "Support",
  supportLinks = [],
  legalTitle = "Legal",
  legalLinks = [],
  settingsTitle = "Settings",
  showSettings = true,
  themeStatusPrefix = "Theme",
  copyrightText = `© ${new Date().getFullYear()} MelodyMind. All rights reserved.`,
} = Astro.props as Props;

const resolvedFooterConfig = {
  brandTitle,
  brandText,
  exploreTitle,
  exploreLinks,
  supportTitle,
  supportLinks,
  legalTitle,
  legalLinks,
  settingsTitle,
  showSettings,
  themeStatusPrefix,
  copyrightText,
  ...footerConfig,
};
---

<FooterShell class="site-footer">
  <div class="site-footer__grid">
    <div class="site-footer__section">
      <div data-animate="soft-fade">
        <Paragraph textSize="sm" className="site-footer__title">
          {resolvedFooterConfig.brandTitle}
        </Paragraph>
        <Paragraph textSize="sm" className="site-footer__text">
          {resolvedFooterConfig.brandText}
        </Paragraph>
      </div>
    </div>

    <div class="site-footer__section">
      <div class="site-footer__motion site-footer__motion--fast" data-animate="rise-in">
        <Paragraph textSize="sm" className="site-footer__title">
          {resolvedFooterConfig.exploreTitle}
        </Paragraph>
        <nav aria-label="Footer navigation" class="site-footer__nav">
          {
            resolvedFooterConfig.exploreLinks.map((link) => (
              <a
                class="site-footer__link"
                href={link.href}
                target={link.target}
                rel={link.rel}
                aria-label={
                  link.target === "_blank"
                    ? `${link.label} (opens in a new tab)`
                    : undefined
                }
              >
                {link.label}
                {link.target === "_blank" ? (
                  <span class="site-footer__sr"> (opens in a new tab)</span>
                ) : null}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    <div class="site-footer__section">
      <div class="site-footer__motion site-footer__motion--base" data-animate="rise-in">
        <Paragraph textSize="sm" className="site-footer__title">
          {resolvedFooterConfig.supportTitle}
        </Paragraph>
        <nav aria-label="Support links" class="site-footer__nav">
          {
            resolvedFooterConfig.supportLinks.map((link) => (
              <a
                class="site-footer__link"
                href={link.href}
                target={link.target}
                rel={link.rel}
                aria-label={
                  link.target === "_blank"
                    ? `${link.label} (opens in a new tab)`
                    : undefined
                }
              >
                {link.label}
                {link.target === "_blank" ? (
                  <span class="site-footer__sr"> (opens in a new tab)</span>
                ) : null}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    <div class="site-footer__section">
      <div class="site-footer__motion site-footer__motion--slow" data-animate="rise-in">
        <Paragraph textSize="sm" className="site-footer__title">
          {resolvedFooterConfig.legalTitle}
        </Paragraph>
        <nav aria-label="Legal navigation" class="site-footer__nav">
          {
            resolvedFooterConfig.legalLinks.map((link) => (
              <a
                class="site-footer__link"
                href={link.href}
                target={link.target}
                rel={link.rel}
                aria-label={
                  link.target === "_blank"
                    ? `${link.label} (opens in a new tab)`
                    : undefined
                }
              >
                {link.label}
                {link.target === "_blank" ? (
                  <span class="site-footer__sr"> (opens in a new tab)</span>
                ) : null}
              </a>
            ))
          }
        </nav>
      </div>
    </div>

    {
      resolvedFooterConfig.showSettings && (
        <div class="site-footer__section">
          <div
            class="site-footer__motion site-footer__motion--settings"
            data-animate="rise-in"
          >
            <Paragraph textSize="sm" className="site-footer__title">
              {resolvedFooterConfig.settingsTitle}
            </Paragraph>
            <nav aria-label="Settings navigation" class="site-footer__nav">
              <ThemeToggle />
            </nav>
            <div class="site-footer__status-list">
              <Paragraph
                textSize="sm"
                className="site-footer__cookie-status"
                data-theme-status
              >
                {resolvedFooterConfig.themeStatusPrefix}: system
              </Paragraph>
            </div>
          </div>
        </div>
      )
    }
  </div>

  <div slot="bottom" class="site-footer__meta">
    <Paragraph textSize="sm">{resolvedFooterConfig.copyrightText}</Paragraph>
  </div>
</FooterShell>

<script>
  import { THEME_EVENTS } from "@shared-utils/constants/events";
  import { getStoredTheme, getSystemTheme } from "@shared-utils/utils/theme/themeStorage";

  const themeStatusElement = document.querySelector<HTMLElement>("[data-theme-status]");

  const renderThemeStatus = () => {
    if (!themeStatusElement) {
      return;
    }
    const storedTheme = getStoredTheme();
    const resolvedTheme = storedTheme ?? getSystemTheme();
    themeStatusElement.textContent = `Theme: ${resolvedTheme} (${storedTheme ? "manual" : "system"})`;
  };

  renderThemeStatus();
  window.addEventListener(THEME_EVENTS.CHANGED, () => renderThemeStatus());
</script>

<style>
  /* -----------------------------------------------------------------------------
     Footer Component Styles
     Site footer with navigation links and settings
     WCAG AAA compliant with proper touch targets and focus states
     ----------------------------------------------------------------------------- */

  .site-footer {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 28%, transparent),
        transparent 40%
      ),
      transparent;
  }

  .site-footer :global(.footer-shell__container) {
    max-inline-size: min(82rem, var(--page-max-width));
    padding: var(--spacing-2xl) var(--spacing-lg);
    margin: 0 auto;
    color: var(--text-primary);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  @media (width >= 640px) {
    .site-footer__grid {
      grid-template-columns: minmax(0, 1.3fr) repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1024px) {
    .site-footer__grid {
      grid-template-columns: minmax(0, 1.4fr) repeat(4, minmax(0, 0.85fr));
      gap: clamp(var(--spacing-xl), 2vw, var(--spacing-2xl));
    }
  }

  .site-footer__section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
    min-inline-size: 0;
    padding: 0;
  }

  .site-footer__section:first-child {
    padding-inline-end: clamp(0rem, 1vw, var(--spacing-base));
  }

  .site-footer__title {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .site-footer__text {
    max-inline-size: 30ch;
    font-size: var(--font-size-sm);
    line-height: var(--prose-line-height);
    color: var(--text-secondary);
  }

  .site-footer__nav {
    display: grid;
    gap: var(--spacing-2xs);
  }

  .site-footer__link {
    display: flex;
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    text-decoration: none;
    border: 0;
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--accent-primary);
    transform: translateX(var(--motion-distance-xs));
  }

  .site-footer__link:focus-visible {
    outline-offset: calc(var(--focus-ring-offset) * 2);
  }

  .site-footer__meta {
    padding-block-start: var(--spacing-lg);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .site-footer__cookie-button {
    font-family: inherit;
    text-align: start;
    cursor: pointer;
    background: none;
    border: 0;
  }

  .site-footer__cookie-status {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
  }

  .site-footer__status-list {
    display: grid;
    gap: var(--spacing-xs);
    padding-block-start: var(--spacing-sm);
    margin-block-start: var(--spacing-sm);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .site-footer__sr {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: var(--sr-only-clip-path);
  }

  .site-footer__motion {
    display: grid;
    gap: var(--spacing-sm);
  }

  .site-footer__motion--fast {
    --motion-delay: var(--motion-delay-fast);
  }

  .site-footer__motion--base {
    --motion-delay: var(--motion-delay-base);
  }

  .site-footer__motion--slow {
    --motion-delay: var(--motion-delay-slow);
  }

  .site-footer__motion--settings {
    --motion-delay: 280ms;
  }

  @media (width <= 639px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (width >= 768px) {
    .site-footer :global(.footer-shell__container) {
      padding-inline: var(--spacing-xl);
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .site-footer__link {
      transition: none;
    }
  }
</style>
