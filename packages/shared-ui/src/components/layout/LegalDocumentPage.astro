---
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import LegalDocumentSection from "@shared-ui/components/layout/LegalDocumentSection.astro";
import StaticPageHero from "@shared-ui/components/layout/StaticPageHero.astro";

interface Highlight {
  label: string;
  value: string;
}

interface Section {
  body: readonly string[] | string[];
  icon: string;
  title: string;
}

interface Props {
  eyebrow: string;
  highlights: readonly Highlight[] | Highlight[];
  highlightsLabel: string;
  lead: string;
  sections: readonly Section[] | Section[];
  title: string;
}

const { eyebrow, highlights, highlightsLabel, lead, sections, title } = Astro.props;
---

<Stack className="legal-document" gap="2xl">
  <StaticPageHero
    eyebrow={eyebrow}
    {highlights}
    {highlightsLabel}
    lead={lead}
    title={title}
  />

  <AutoGrid className="legal-document__content-grid" preset="legal" gap="section">
    {
      sections.map((section) => (
        <LegalDocumentSection
          icon={section.icon}
          title={section.title}
          body={section.body}
        />
      ))
    }
  </AutoGrid>
</Stack>

<style>
  .legal-document {
    position: relative;
    isolation: isolate;
  }

  .legal-document::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(
        circle at top left,
        color-mix(in srgb, var(--accent-primary) 10%, transparent),
        transparent 34rem
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-overlay) 62%, transparent),
        transparent 22rem
      );
  }

  .legal-document__content-grid {
    padding: var(--spacing-lg);
    background: color-mix(in srgb, var(--surface-1) 54%, transparent);
    border: 1px solid var(--surface-border-subtle);
    border-radius: var(--radius-xl);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-1) 68%, transparent);
  }

  @media (width >= 1100px) {
    .legal-document__content-grid {
      padding: var(--spacing-xl);
    }
  }
</style>
