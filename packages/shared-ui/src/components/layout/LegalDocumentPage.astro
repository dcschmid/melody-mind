---
import Stack from "@shared-ui/components/layout/Stack.astro";
import LegalDocumentSection from "@shared-ui/components/layout/LegalDocumentSection.astro";
import StaticPageHero from "@shared-ui/components/layout/StaticPageHero.astro";

interface Highlight {
  label: string;
  value: string;
}

interface Section {
  body: readonly string[] | string[];
  icon: string;
  title: string;
}

interface Props {
  eyebrow: string;
  highlights: readonly Highlight[] | Highlight[];
  highlightsAriaLabel: string;
  lead: string;
  sections: readonly Section[] | Section[];
  title: string;
}

const { eyebrow, highlights, highlightsAriaLabel, lead, sections, title } = Astro.props;
---

<Stack className="legal-document" gap="2xl">
  <StaticPageHero
    eyebrow={eyebrow}
    {highlights}
    {highlightsAriaLabel}
    lead={lead}
    title={title}
  />

  {
    sections && sections.length > 0 && (
      <div className="legal-document__content">
        {sections.map((section) => (
          <LegalDocumentSection
            icon={section.icon}
            title={section.title}
            body={section.body}
          />
        ))}
      </div>
    )
  }
</Stack>

<style>
  .legal-document__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }
</style>
