---
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Highlight {
  label: string;
  value: string;
  valueColor?: "default" | "accent" | "success" | "warning" | "error" | "info";
  accentBar?: boolean;
}

interface Props extends astroHTML.JSX.HTMLAttributes {
  badge?: string;
  eyebrow?: string;
  highlights: readonly Highlight[] | Highlight[];
  highlightsAriaLabel: string;
  lead: string;
  leadClassName?: string;
  leadTextAlign?: "left" | "center" | "right";
  leadTextSize?: "sm" | "base" | "lg" | "xl";
  highlightAccent?: boolean;
  statusBadge?: {
    label: string;
    variant: "success" | "warning" | "error" | "info";
    pulse?: boolean;
  };
  title: string;
  titleClassName?: string;
  titleLevel?: "h1" | "h2";
  titleTextAlign?: "left" | "center" | "right";
  titleTextSize?: "xl" | "2xl";
  class?: string;
}

const {
  badge,
  eyebrow,
  highlights,
  highlightsAriaLabel,
  lead,
  leadClassName,
  leadTextAlign = "left",
  leadTextSize = "lg",
  highlightAccent = false,
  statusBadge,
  title,
  titleClassName,
  titleLevel = "h1",
  titleTextAlign = "left",
  titleTextSize = "2xl",
  class: className,
  ...rest
} = Astro.props;

const valueColorMap = {
  default: "var(--text-primary)",
  accent: "var(--accent-primary)",
  success: "var(--color-success)",
  warning: "var(--color-warning)",
  error: "var(--color-error)",
  info: "var(--color-info)",
} as const;

const statusBadgeColorMap = {
  success: "var(--color-success)",
  warning: "var(--color-warning)",
  error: "var(--color-error)",
  info: "var(--color-info)",
} as const;
---

<header {...rest} class:list={["static-page-hero", className]}>
  <Stack className="static-page-hero__main" gap="base">
    {
      statusBadge ? (
        <div
          class:list={[
            "static-page-hero__status-badge",
            statusBadge.pulse !== false ? "static-page-hero__status-badge--pulse" : "",
          ]}
          style={`--status-badge-color: ${statusBadgeColorMap[statusBadge.variant]}`}
          aria-live="polite"
          role="status"
        >
          {statusBadge.label}
        </div>
      ) : badge ? (
        <div class="static-page-hero__badge">{badge}</div>
      ) : eyebrow ? (
        <Paragraph textSize="sm" className="static-page-hero__eyebrow">
          {eyebrow}
        </Paragraph>
      ) : null
    }
    {
      title ? (
        <Headline
          level={titleLevel}
          textSize={titleTextSize}
          textAlign={titleTextAlign}
          className={`static-page-hero__title ${titleClassName || ""}`.trim()}
        >
          {title}
        </Headline>
      ) : null
    }
    {
      lead ? (
        <Paragraph
          textSize={leadTextSize}
          textAlign={leadTextAlign}
          className={`static-page-hero__lead ${leadClassName || ""}`.trim()}
        >
          {lead}
        </Paragraph>
      ) : null
    }
  </Stack>

  <AutoGrid
    className="static-page-hero__highlights"
    aria-label={highlightsAriaLabel}
    preset="highlights"
    gap="md"
  >
    {
      highlights.map((highlight) => (
        <Stack class="static-page-hero__highlight" gap="sm">
          {highlightAccent && highlight.accentBar !== false && (
            <span
              class="static-page-hero__highlight-accent-bar"
              aria-hidden="true"
              translate="no"
            />
          )}
          <p
            class="static-page-hero__highlight-value"
            style={
              highlight.valueColor && highlight.valueColor !== "default"
                ? `color: ${valueColorMap[highlight.valueColor]}`
                : undefined
            }
          >
            {highlight.value}
          </p>
          <p class="static-page-hero__highlight-label">{highlight.label}</p>
        </Stack>
      ))
    }
  </AutoGrid>
</header>

<style>
  /* Hero entrance: staggered fade-in with editorial restraint */
  @media screen and (prefers-reduced-motion: reduce) {
    .static-page-hero {
      position: relative;
      display: grid;
      gap: var(--spacing-xl);
      padding: var(--spacing-2xl) 0;
      background: color-mix(in srgb, var(--color-accent-primary) 4%, var(--surface-1));
      animation: none;
    }
  }

  .static-page-hero {
    position: relative;
    display: grid;
    gap: var(--spacing-xl);
    padding: var(--spacing-2xl) 0;
    background: color-mix(in srgb, var(--color-accent-primary) 4%, var(--surface-1));
    animation: hero-reveal 0.6s cubic-bezier(0.25, 1, 0.5, 1) both;
  }

  :global([data-theme="dark"]) .static-page-hero {
    background: color-mix(
      in srgb,
      var(--color-dark-accent-primary) 8%,
      var(--color-dark-surface-1)
    );
  }

  :global([data-theme="dark"]) .static-page-hero__highlight {
    background: color-mix(
      in srgb,
      var(--color-dark-accent-primary) 8%,
      var(--color-dark-surface-1) 90%
    );
  }

  :global([data-theme="dark"]) .static-page-hero__highlight:hover,
  :global([data-theme="dark"]) .static-page-hero__highlight:focus {
    background: color-mix(
      in srgb,
      var(--color-dark-accent-primary) 12%,
      var(--color-dark-surface-1) 85%
    );
  }

  @keyframes hero-reveal {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .static-page-hero,
    .static-page-hero__main,
    .static-page-hero__highlights,
    .static-page-hero__status-badge--pulse {
      animation: none;
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .static-page-hero__main {
      gap: var(--spacing-xl);
      max-inline-size: var(--measure-wide);
      animation: none;
    }
  }

  .static-page-hero__main {
    gap: var(--spacing-xl);
    max-inline-size: var(--measure-wide);
    animation: hero-reveal 0.6s cubic-bezier(0.25, 1, 0.5, 1) 0.1s both;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .static-page-hero__highlights {
      animation: none;
    }
  }

  .static-page-hero__highlights {
    animation: hero-reveal 0.6s cubic-bezier(0.25, 1, 0.5, 1) 0.25s both;
  }

  .static-page-hero__eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    font-kerning: normal;
    font-variant: small-caps;
    color: var(--link-default);
    letter-spacing: var(--letter-spacing-widest);
  }

  .static-page-hero__title {
    margin: 0 0 var(--spacing-sm);
    font-size: clamp(2rem, 5vw, var(--font-size-4xl));
    font-weight: var(--heading-font-weight);
    font-kerning: normal;
    line-height: var(--heading-line-height);
    letter-spacing: var(--heading-letter-spacing);
  }

  .static-page-hero__lead {
    margin: var(--spacing-md) 0 0;
    font-size: clamp(var(--font-size-base), 2.5vw, var(--font-size-lg));
    line-height: 1.6;
    color: var(--text-secondary);
    word-break: break-word;
  }

  @media (width >= 720px) {
    .static-page-hero__lead {
      font-size: var(--font-size-lg);
    }
  }

  .static-page-hero__badge {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-widest);
    background: color-mix(in srgb, var(--color-accent-primary) 8%, var(--surface-1));
    border-radius: var(--radius-sm);
  }

  :global([data-theme="dark"]) .static-page-hero__badge {
    color: var(--color-dark-accent-strong);
    background: color-mix(
      in srgb,
      var(--color-dark-accent-primary) 12%,
      var(--color-dark-surface-1)
    );
  }

  .static-page-hero__badge:focus-visible {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  :global([data-theme="dark"]) .static-page-hero__badge:focus-visible {
    outline-color: var(--color-dark-accent-primary);
  }

  .static-page-hero__status-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--status-badge-color);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-widest);
    background: color-mix(in srgb, var(--status-badge-color) 10%, var(--surface-1));
    border-radius: var(--radius-sm);
  }

  .static-page-hero__status-badge:focus-visible {
    outline: 2px solid var(--status-badge-color);
    outline-offset: 2px;
  }

  .static-page-hero__status-badge--pulse {
    animation: status-glow-pulse 2.8s ease-in-out infinite;
  }

  @keyframes status-glow-pulse {
    0%,
    100% {
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--surface-1) 72%, transparent),
        0 0 0 0 color-mix(in srgb, var(--status-badge-color) 0%, transparent);
    }

    50% {
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--surface-1) 72%, transparent),
        0 0 4px 1px color-mix(in srgb, var(--status-badge-color) 25%, transparent);
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global([data-theme="dark"]) .static-page-hero__status-badge--pulse {
      animation: none;
    }
  }

  :global([data-theme="dark"]) .static-page-hero__status-badge--pulse {
    animation-name: status-glow-pulse-dark;
  }

  @keyframes status-glow-pulse-dark {
    0%,
    100% {
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--color-dark-surface-1) 72%, transparent),
        0 0 0 0 color-mix(in srgb, var(--status-badge-color) 0%, transparent);
    }

    50% {
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--color-dark-surface-1) 72%, transparent),
        0 0 4px 1px color-mix(in srgb, var(--status-badge-color) 25%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .static-page-hero__status-badge--pulse {
      animation: none;
    }
  }

  .static-page-hero__highlight {
    position: relative;
    align-content: start;
    padding: var(--spacing-base) 0;
    border-bottom: 1px solid var(--surface-border-soft);
  }

  .static-page-hero__highlight:last-child {
    border-bottom: none;
  }

  .static-page-hero__highlight:hover,
  .static-page-hero__highlight:focus {
    background: color-mix(in srgb, var(--color-accent-primary) 8%, var(--surface-1) 90%);
  }

  .static-page-hero__highlight-accent-bar {
    position: absolute;
    inset-inline-start: 0;
    top: 0;
    display: block;
    inline-size: var(--spacing-2xs);
    block-size: 100%;
    min-block-size: 2.5rem;
    background: color-mix(in srgb, var(--accent-primary) 85%, transparent);
    border-radius: var(--radius-sm);
  }

  .static-page-hero__highlight-value,
  .static-page-hero__highlight-label {
    padding-inline-start: var(--spacing-lg);
    margin: 0;
  }

  .static-page-hero__highlight-value {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    font-variant-numeric: tabular-nums;
    color: var(--text-primary);
    letter-spacing: var(--letter-spacing-wide);
    word-break: break-word;
  }

  .static-page-hero__highlight-label {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    line-height: 1.4;
    color: var(--text-secondary);
    word-break: break-word;
  }

  @media (width >= 720px) {
    .static-page-hero__title {
      font-size: var(--font-size-4xl);
    }
  }
</style>
