---
import BackToTop from "@shared-ui/components/navigation/BackToTop.astro";
import SkipLink from "@shared-ui/components/navigation/SkipLink.astro";
import { THEME_EVENTS } from "@shared-utils/constants/events";
import { STORAGE_KEYS } from "@shared-utils/constants/storage";
import "../../styles/master-theme.css";
import "../../styles/animations.css";

interface Props {
  lang?: string;
  dir?: string;
  bodyClass?: string;
  mainClass?: string;
  mainId?: string;
  contentShellClass?: string;
  showSkipLink?: boolean;
  enableThemeInit?: boolean;
  colorScheme?: string;
  themeColorDark?: string;
  themeColorLight?: string;
  appTitle?: string;
  manifestPath?: string;
  googleSiteVerification?: string;
  appleMobileWebAppCapable?: boolean;
  appleMobileWebAppStatusBarStyle?: string;
}

const {
  lang = "en",
  dir = "ltr",
  bodyClass = "",
  mainClass = "",
  mainId = "main-content",
  contentShellClass = "",
  showSkipLink = true,
  enableThemeInit = true,
  colorScheme = "dark light",
  themeColorDark = "#08131a",
  themeColorLight = "#f6f1e8",
  appTitle = "MelodyMind",
  manifestPath = "/site.webmanifest",
  googleSiteVerification = import.meta.env.GOOGLE_SITE_VERIFICATION ||
    "ImN0-TS4_aAOFIXaGxvsGSmqsgHxI94WARi8bW7fm9M",
  appleMobileWebAppCapable = true,
  appleMobileWebAppStatusBarStyle = "black-translucent",
} = Astro.props as Props;

const bodyClasses = ["app__body", bodyClass].filter(Boolean).join(" ");
const mainClasses = ["app__main", mainClass].filter(Boolean).join(" ");
const contentShellClasses = contentShellClass.trim();
const themeInitScript = enableThemeInit
  ? `
    (() => {
      const THEME_STORAGE_KEY = ${JSON.stringify(STORAGE_KEYS.THEME)};
      const DARK_QUERY = "(prefers-color-scheme: dark)";
      const THEME_CHANGE_EVENT = ${JSON.stringify(THEME_EVENTS.CHANGED)};

      const isTheme = (value) => value === "light" || value === "dark";
      const readStoredTheme = () => {
        try {
          const stored = window.localStorage.getItem(THEME_STORAGE_KEY);
          return isTheme(stored) ? stored : null;
        } catch {
          return null;
        }
      };
      const getSystemTheme = () =>
        window.matchMedia(DARK_QUERY).matches ? "dark" : "light";

      const applyTheme = (theme, source) => {
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.style.colorScheme = theme;
        window.dispatchEvent(
          new CustomEvent(THEME_CHANGE_EVENT, {
            detail: { theme, source },
          })
        );
      };

      const storedTheme = readStoredTheme();
      const resolvedTheme = storedTheme ?? getSystemTheme();
      applyTheme(resolvedTheme, storedTheme ? "manual" : "system");

      window.matchMedia(DARK_QUERY).addEventListener("change", () => {
        if (readStoredTheme()) {
          return;
        }

        applyTheme(getSystemTheme(), "system");
      });
    })();
  `
  : "";
---

<!doctype html>
<html lang={lang} class="app" dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="color-scheme" content={colorScheme} />
    <meta
      name="theme-color"
      content={themeColorDark}
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content={themeColorLight}
      media="(prefers-color-scheme: light)"
    />
    {
      appleMobileWebAppCapable && (
        <meta name="apple-mobile-web-app-capable" content="yes" />
      )
    }
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content={appleMobileWebAppStatusBarStyle}
    />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content={appTitle} />
    <meta name="google-site-verification" content={googleSiteVerification} />
    <link rel="manifest" href={manifestPath} />
    {enableThemeInit && <script is:inline set:html={themeInitScript} />}
    <slot name="head" />
  </head>
  <body class={bodyClasses}>
    {showSkipLink && <SkipLink />}
    {
      contentShellClasses ? (
        <div class={contentShellClasses}>
          <slot name="body-start" />
          <slot name="before-main" />
          <main id={mainId} tabindex="-1" role="main" class={mainClasses}>
            <slot />
          </main>
          <BackToTop />
          <slot name="after-main" />
          <slot name="body-end" />
        </div>
      ) : (
        <>
          <slot name="body-start" />
          <slot name="before-main" />
          <main id={mainId} tabindex="-1" role="main" class={mainClasses}>
            <slot />
          </main>
          <BackToTop />
          <slot name="after-main" />
          <slot name="body-end" />
        </>
      )
    }
  </body>
</html>

<style>
  .app {
    color: var(--text-primary);
    background: var(--page-background);
    background-color: var(--bg-primary);
  }

  .app__body {
    position: relative;
    min-block-size: 100vb;
    margin: 0;
    overflow-x: clip;
    color: var(--text-primary);
    background: var(--page-background);
    background-color: var(--bg-primary);
  }

  .app__main {
    position: relative;
    min-block-size: 0;
    isolation: isolate;
  }

  .app__main::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-overlay) 52%, transparent),
      transparent 12rem
    );
  }

  .app__main::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(
        180deg,
        transparent,
        color-mix(in srgb, var(--surface-1) 16%, transparent) 35%,
        transparent 65%
      ),
      radial-gradient(
        circle at 85% 14rem,
        color-mix(in srgb, var(--accent-muted) 8%, transparent),
        transparent 24rem
      );
    opacity: 0.85;
  }

  @media (prefers-reduced-motion: reduce) {
    .app__main::before,
    .app__main::after {
      opacity: 0;
    }
  }
</style>
