---
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import VisuallyHidden from "@shared-ui/components/utilities/VisuallyHidden.astro";

interface Props extends astroHTML.JSX.HTMLAttributes {
  copy?: string;
  emptyDescription?: string;
  fallbackImage: string;
  maxItems?: number;
  storageKey: string;
  title?: string;
  titleId?: string;
  className?: string;
  class?: string;
}

const {
  copy = "Return to the guides you opened most recently.",
  emptyDescription = "No recent guides yet. Open an article and it will appear here.",
  fallbackImage,
  maxItems = 3,
  storageKey,
  title = "Recently read",
  titleId,
  className = "",
  class: classProp = "",
  ...rest
} = Astro.props as Props;

const classes = ["recent-reads-panel", className, classProp].filter(Boolean).join(" ");
const resolvedTitleId = titleId ?? `recent-reads-title-${crypto.randomUUID()}`;
---

<section {...rest} class={classes} aria-labelledby={resolvedTitleId}>
  <div class="section-header recent-reads-panel__header">
    <div class="section-header__copy">
      <h2 id={resolvedTitleId} class="section-header__title recent-reads-panel__title">
        {title}
      </h2>
      <p class="section-header__description recent-reads-panel__description">{copy}</p>
    </div>
  </div>

  <div
    class="recent-reads-panel__mount"
    data-recent-reads="true"
    data-storage-key={storageKey}
    data-max-items={String(maxItems)}
    data-fallback-image={fallbackImage}
  >
    <div class="recent-reads-panel__results" data-role="container" hidden>
      <ul class="recent-reads-panel__list" data-role="list"></ul>
    </div>

    <VisuallyHidden
      data-role="status"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    />

    <EmptyState
      class="recent-reads-panel__empty"
      data-role="empty"
      description={emptyDescription}
      role="status"
      live="polite"
      hidden
    />
  </div>
</section>

<script>
  import { initRecentReadsPanels } from "@shared-ui/scripts/init/recentReads";

  initRecentReadsPanels();
</script>

<style>
  .recent-reads-panel {
    display: grid;
    gap: var(--spacing-lg);
  }

  .recent-reads-panel__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    align-items: flex-start;
    padding-block-end: var(--spacing-md);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .recent-reads-panel__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    letter-spacing: var(--letter-spacing-tight);
  }

  .recent-reads-panel__description {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text-tertiary);
    letter-spacing: var(--letter-spacing-normal);
  }

  @media (width >= 640px) {
    .recent-reads-panel__header {
      flex-direction: row;
      align-items: end;
      justify-content: space-between;
    }
  }

  .recent-reads-panel__results {
    display: block;
  }

  .recent-reads-panel__empty {
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__list) {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: clamp(var(--spacing-base), 2vw, var(--spacing-xl));
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__item) {
    inline-size: 100%;
    min-inline-size: 0;
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__link) {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    inline-size: 100%;
    min-inline-size: 0;
    block-size: 100%;
    overflow: hidden;
    color: var(--text-primary);
    text-decoration: none;
    background: var(--surface-panel-raised);
    border: 1px solid var(--surface-border-soft);
    border-radius: calc(var(--radius-xl) + var(--spacing-xs));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 74%, transparent),
      var(--shadow-base);
    transition:
      box-shadow var(--transition-base) var(--motion-ease-standard),
      transform var(--transition-base) var(--motion-ease-standard);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .recent-reads-panel__mount :global(.recent-reads-panel__link) {
      transition: none;
    }
  }

  /* stylelint-disable-next-line a11y/selector-pseudo-class-focus -- Keyboard focus uses shadow and outline without motion. */
  .recent-reads-panel__mount :global(.recent-reads-panel__link:hover) {
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 74%, transparent),
      var(--shadow-lg);
    transform: translateY(-2px);
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__link:focus-visible) {
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 74%, transparent),
      var(--interactive-shadow-focus),
      var(--shadow-lg);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    /* stylelint-disable-next-line a11y/selector-pseudo-class-focus -- Reduced motion only neutralizes the hover transform; focus has no transform. */
    .recent-reads-panel__mount :global(.recent-reads-panel__link:hover) {
      transform: none;
    }
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__link):focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__media) {
    position: relative;
    inline-size: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface-chip-bg);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__media::after) {
    content: none;
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__image) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__body) {
    display: flex;
    align-items: start;
    padding: var(--spacing-base);
  }

  .recent-reads-panel__mount :global(.recent-reads-panel__title) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: var(--font-size-lg);
    font-weight: var(--heading-font-weight);
    line-height: var(--heading-line-height);
    color: var(--heading-color);
    letter-spacing: var(--heading-letter-spacing);
    text-wrap: balance;
    overflow-wrap: break-word;
    /* stylelint-disable-next-line property-no-deprecated */
    -webkit-box-orient: block-axis;
  }

  .recent-reads-panel__mount
    :global(.recent-reads-panel__link:hover .recent-reads-panel__title),
  .recent-reads-panel__mount
    :global(.recent-reads-panel__link:focus-visible .recent-reads-panel__title) {
    color: color-mix(in srgb, var(--heading-color) 85%, var(--accent-primary) 15%);
  }

  @media (width >= 40rem) {
    .recent-reads-panel__mount :global(.recent-reads-panel__list) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 64rem) {
    .recent-reads-panel__mount :global(.recent-reads-panel__list) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .recent-reads-panel__mount :global(.recent-reads-panel__body) {
      padding: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    }
  }
</style>
