{
  "name": "melody-mind",
  "private": true,
  "version": "1.0.0",
  "description": "MelodyMind Music and Quiz apps",
  "pnpm": {
    "overrides": {
      "sharp": "^0.35.2",
      "yaml": ">=2.8.3"
    }
  },
  "scripts": {
    "build": "pnpm build:music",
    "build:all": "turbo run build",
    "build:music": "turbo run build --filter=music",
    "build:quiz": "turbo run build --filter=quiz",
    "generate:webp-assets": "node apps/music/scripts/generate-webp-assets.mjs",
    "dev": "turbo run dev",
    "dev:music": "cd apps/music && pnpm dev",
    "dev:music:background": "cd apps/music && pnpm dev:background",
    "dev:music:logs": "cd apps/music && pnpm dev:logs",
    "dev:music:status": "cd apps/music && pnpm dev:status",
    "dev:music:stop": "cd apps/music && pnpm dev:stop",
    "dev:quiz": "cd apps/quiz && pnpm dev",
    "preview": "turbo run preview --filter=music",
    "preview:quiz": "turbo run preview --filter=quiz",
    "lint": "turbo run lint --filter=music",
    "lint:all": "turbo run lint",
    "lint:check": "turbo run lint:check --filter=music",
    "lint:check:all": "turbo run lint:check",
    "lint:check:quiz": "turbo run lint:check --filter=quiz",
    "format": "turbo run format --filter=music",
    "format:all": "turbo run format",
    "format:check": "turbo run format:check --filter=music",
    "format:check:all": "turbo run format:check",
    "format:check:quiz": "turbo run format:check --filter=quiz",
    "indexnow:submit": "pnpm --filter music indexnow:submit",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.15",
    "@eslint/js": "^10.0.1",
    "astro": "^7.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
