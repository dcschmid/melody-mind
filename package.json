{
  "name": "melody-mind-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "MelodyMind - Music Knowledge Platform (Monorepo)",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:knowledge": "turbo run build --filter=knowledge",
    "build:quiz": "turbo run build --filter=quiz",
    "build:podcasts": "turbo run build --filter=podcasts",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "husky": "^9.1.7"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
