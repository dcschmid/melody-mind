{
  "name": "melody-mind-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "MelodyMind - Music Knowledge Platform (Monorepo)",
  "scripts": {
    "build": "turbo run build",
    "build:knowledge": "turbo run build --filter=knowledge",
    "build:quiz": "turbo run build --filter=quiz",
    "build:podcasts": "turbo run build --filter=podcasts",
    "dev": "turbo run dev",
    "dev:knowledge": "cd apps/knowledge && pnpm dev",
    "dev:quiz": "cd apps/quiz && pnpm dev",
    "dev:podcasts": "cd apps/podcasts && pnpm dev",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.7",
    "@eslint/js": "^10.0.1",
    "astro": "^6.0.8",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.0.2",
    "turbo": "^2.8.20",
    "typescript-eslint": "^8.57.1"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
