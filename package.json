{
  "name": "melody-mind-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "MelodyMind Music app",
  "pnpm": {
    "overrides": {
      "sharp": "^0.34.5",
      "yaml": ">=2.8.3"
    }
  },
  "scripts": {
    "build": "pnpm build:music",
    "build:all": "turbo run build",
    "build:music": "turbo run build --filter=music",
    "generate:webp-assets": "node scripts/generate-webp-assets.mjs",
    "dev": "pnpm dev:music",
    "dev:music": "cd apps/music && pnpm dev",
    "preview": "turbo run preview --filter=music",
    "lint": "turbo run lint --filter=music",
    "lint:all": "turbo run lint",
    "lint:check": "turbo run lint:check --filter=music",
    "lint:check:all": "turbo run lint:check",
    "format": "turbo run format --filter=music",
    "format:all": "turbo run format",
    "format:check": "turbo run format:check --filter=music",
    "format:check:all": "turbo run format:check",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@double-great/stylelint-a11y": "^3.4.9",
    "@eslint/js": "^10.0.1",
    "astro": "^6.1.6",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.7.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
