{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.example"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"],
      "passThroughEnv": ["NODE_OPTIONS"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**"],
      "outputLogs": "new-only"
    },
    "lint:check": {
      "inputs": ["src/**"],
      "outputLogs": "new-only"
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "clean": {
      "cache": false,
      "outputs": [".turbo/**", "dist/**", ".astro/**"]
    }
  }
}
