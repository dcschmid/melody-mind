{
  "name": "quiz",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "description": "MelodyMind Quiz - Music history quizzes",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "build:production": "NODE_ENV=production pnpm build",
    "preview": "astro preview",
    "lint": "pnpm format && eslint --fix \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "lint:check": "eslint \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx}\""
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "astro": "^6.0.0",
    "astro-capo": "^0.0.1",
    "astro-icon": "^1.1.5",
    "astro-meta-tags": "^0.4.1",
    "astro-minify-html-swc": "^0.1.11",
    "astro-robots-txt": "^1.0.0",
    "lightningcss": "^1.31.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "packageManager": "pnpm@9.15.0"
}
