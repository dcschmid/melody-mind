---
import SharedFooter from "@shared-ui/components/Footer.astro";

const year = new Date().getFullYear();
---

<SharedFooter
  brandTitle="Melody Mind"
  brandText="Curated guides and playlists to help you listen more closely and discover new sounds."
  exploreLinks={[
    { href: "/", label: "Knowledge" },
    {
      href: "https://podcasts.melody-mind.de",
      label: "Podcasts",
      target: "_blank",
      rel: "noopener noreferrer",
    },
  ]}
  supportLinks={[
    {
      href: "https://www.paypal.me/dcschmid",
      label: "PayPal",
      target: "_blank",
      rel: "noopener noreferrer",
    },
    {
      href: "https://www.buymeacoffee.com/dcschmid",
      label: "Buy Me a Coffee",
      target: "_blank",
      rel: "noopener noreferrer",
    },
  ]}
  legalLinks={[
    { href: "/imprint", label: "Legal Notice" },
    { href: "/privacy", label: "Privacy Policy" },
    { href: "/ai-content", label: "AI Content" },
  ]}
  cookieSettingsLabel="Cookie settings"
  themeStatusPrefix="Theme"
  cookiesWaitingLabel="Cookies: waiting"
  cookiesAllowedLabel="Cookies: analytics allowed"
  cookiesEssentialLabel="Cookies: essential only"
  copyrightText={`© ${year} MelodyMind. All rights reserved.`}
/>
