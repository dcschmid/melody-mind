---
import SharedSiteHeader from "@shared-ui/components/Shared/SiteHeader.astro";

interface NavItem {
  href: string;
  label: string;
  icon?: string;
}

interface Props {
  showIcons?: boolean;
}

const { showIcons = true } = Astro.props as Props;

const navItems: NavItem[] = [{ href: "/", label: "All Quizzes", icon: "grid" }];
---

<SharedSiteHeader
  {showIcons}
  {navItems}
  brandHref="/"
  brandText="Melody Mind"
  brandMark="MM"
  brandAriaLabel="Go to the Melody Mind homepage"
  menuOpenLabel="Open main menu"
  menuCloseLabel="Close main menu"
  menuText="Menu"
  navAriaLabel="Primary navigation"
/>
