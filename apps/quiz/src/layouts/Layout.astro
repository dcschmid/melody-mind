---
import { getCollection } from "astro:content";
import AppShellLayout from "@shared-ui/components/layout/AppShellLayout.astro";
import SearchPalette from "@shared-ui/components/search/SearchPalette.astro";
import type { PageSeoResult } from "@shared-utils/utils/seo/buildPageSeo";
import { getCollectionCached } from "@shared-utils/utils/content/getCollectionCached";
import { buildAppShellConfig, navFromQuiz } from "@shared-utils/utils/appShellConfig";
import {
  KNOWLEDGE_SITE_URL,
  MUSIC_SITE_URL,
  buildExternalAppLink,
} from "@shared-utils/utils/appShell";
import { quizBrandLogo, quizBrandLogoUrl, quizHeroImageUrl } from "../utils/quizImages";
import { getQuizImage } from "../utils/quizImages";

import type { CollectionEntry } from "astro:content";
import type { QuizQuestion } from "../content.config";

type QuizEntry = CollectionEntry<"quizzes">;

interface Props {
  imageWidth?: number;
  imageHeight?: number;
  pageSeo: PageSeoResult;
  showHeader?: boolean;
  showHeaderIcons?: boolean;
  showFooter?: boolean;
}

const quizAppShellConfig = buildAppShellConfig({
  rssTitle: "MelodyMind Quiz RSS Feed",
  brandLogoAlt: "Melody Mind Quiz",
  brandAriaLabel: "Go to the Melody Mind homepage",
  navAriaLabel: "Primary navigation",
  headerNavItems: navFromQuiz(),
  footerBrandText:
    "Curated guides and playlists to help you listen more closely and discover new sounds.",
  footerExploreLinks: [
    buildExternalAppLink({ href: KNOWLEDGE_SITE_URL, label: "Knowledge" }),
    buildExternalAppLink({ href: MUSIC_SITE_URL, label: "Music" }),
  ],
});
const categoryLabels: Record<QuizEntry["data"]["category"], string> = {
  decade: "Decade quiz",
  "genre-evolution": "Genre evolution",
  mixed: "Mixed quiz",
};
const allEntries = await getCollectionCached("quizzes", { getCollection });
const entries = allEntries as QuizEntry[];
const searchItems = entries
  .filter((entry) => !entry.data.draft)
  .map((entry) => {
    const questionCount = entry.data.questions.length;
    const difficulties = Array.from(
      new Set(entry.data.questions.map((question: QuizQuestion) => question.difficulty))
    );
    const displayMeta = [
      categoryLabels[entry.data.category],
      `${questionCount} questions`,
      difficulties.join(", "),
    ]
      .filter(Boolean)
      .join(" · ");

    return {
      url: `/${entry.id}`,
      title: entry.data.title,
      type: "Quiz",
      description: entry.data.description,
      imageUrl: getQuizImage(entry.id)?.src || "",
      imageAlt: `Cover image for the quiz: ${entry.data.title}`,
      displayMeta,
    };
  });

const {
  pageSeo,
  imageWidth,
  imageHeight,
  showHeader = true,
  showHeaderIcons = true,
  showFooter = true,
} = Astro.props;
---

<AppShellLayout
  shellConfig={quizAppShellConfig}
  resolveLogoUrl={quizBrandLogoUrl}
  resolveFallbackImageUrl={quizHeroImageUrl}
  brandLogoSrc={quizBrandLogo}
  brandLogoAlt=""
  {pageSeo}
  {imageWidth}
  {imageHeight}
  {showHeader}
  {showHeaderIcons}
  {showFooter}
>
  <slot />
  <SearchPalette
    configId="quiz-search-palette-config"
    inputLabel="Search quizzes, decades, genres, and topics"
    placeholder="Search quizzes, decades, genres, and topics"
    emptyTitle="Start with a decade, genre, or quiz topic."
    emptyTitleWithQuery="No quiz matched that search."
    emptyText="Try one of these searches to find a quiz."
    emptyTextWithQuery="Try a broader decade, genre, or one of these quiz searches."
    suggestions={["1980s", "K-pop", "reggae", "hip hop"]}
    groupLabels={{ quiz: "Quizzes", quizzes: "Quizzes" }}
    items={searchItems}
    mediaAspectRatio="3 / 2"
  />
</AppShellLayout>
