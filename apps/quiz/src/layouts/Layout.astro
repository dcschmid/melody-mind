---
import AppShellLayout from "@shared-ui/components/layout/AppShellLayout.astro";
import type { PageSeoResult } from "@shared-utils/utils/seo/buildPageSeo";
import { quizBrandLogo, quizBrandLogoUrl, quizHeroImageUrl } from "../utils/quizImages";
import { quizAppShellConfig } from "../utils/appShellConfig";

interface Props {
  imageWidth?: number;
  imageHeight?: number;
  pageSeo: PageSeoResult;
  showHeader?: boolean;
  showHeaderIcons?: boolean;
  showFooter?: boolean;
  ogMusic?: {
    creator?: string;
    album?: string;
    musician?: string;
  };
  audioSrc?: string;
  audioType?: string;
  episodeNumber?: number;
  seriesName?: string;
  seriesUrl?: string;
  prevUrl?: string;
  nextUrl?: string;
  disableAlternateLanguages?: boolean;
  authorName?: string;
}

const {
  pageSeo,
  imageWidth,
  imageHeight,
  ogMusic,
  audioSrc,
  audioType,
  episodeNumber,
  seriesName,
  seriesUrl,
  showHeader = true,
  showHeaderIcons = true,
  showFooter = true,
  prevUrl,
  nextUrl,
  disableAlternateLanguages,
  authorName,
} = Astro.props;
---

<AppShellLayout
  shellConfig={quizAppShellConfig}
  resolveLogoUrl={quizBrandLogoUrl}
  resolveFallbackImageUrl={quizHeroImageUrl}
  brandLogoSrc={quizBrandLogo}
  brandLogoAlt=""
  {pageSeo}
  {imageWidth}
  {imageHeight}
  {showHeader}
  {showHeaderIcons}
  {showFooter}
  {ogMusic}
  {audioSrc}
  {audioType}
  {episodeNumber}
  {seriesName}
  {seriesUrl}
  {prevUrl}
  {nextUrl}
  {disableAlternateLanguages}
  {authorName}
>
  <slot />
</AppShellLayout>
