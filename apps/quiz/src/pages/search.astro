---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import OramaSearchSection from "../components/OramaSearchSection.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

export const prerender = true;

const initialQuery = Astro.url.searchParams.get("q")?.trim() ?? "";

const title = "Search Melody Mind Quizzes";
const description = "Find quizzes by title, topic, question, answer, or explanation.";
const currentUrl = resolvePageUrl(Astro.site, "/search");
const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  structuredData: [] as StructuredData[],
  fallbackKeywords: [
    "quiz search",
    "music quiz",
    "music trivia",
    "quiz topics",
    "music knowledge",
  ],
  index: false,
  follow: true,
  maxImagePreview: "large",
  brandSuffix: " - MelodyMind Quiz",
});

const searchIndexUrl = "/search-index.json";
---

<Layout {pageSeo}>
  <PageShell className="page-shell--grid">
    <OramaSearchSection
      searchIndexUrl={searchIndexUrl}
      initialQuery={initialQuery}
      title={title}
      lead={description}
      placeholder="Search quiz titles, questions, or topics..."
      emptyText="Type a quiz title, question, or keyword."
      noResultsText="No matching quizzes found."
      resultLimit={24}
    />
  </PageShell>
</Layout>
