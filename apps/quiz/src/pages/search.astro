---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import SearchPageSection from "@shared-ui/components/search/SearchPageSection.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

export const prerender = true;

const initialQuery = Astro.url.searchParams.get("q")?.trim() ?? "";

const title = "Search Melody Mind Quizzes";
const description = "Search Melody Mind quiz titles and descriptions.";
const currentUrl = resolvePageUrl(Astro.site, "/search");
const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  structuredData: [] as StructuredData[],
  fallbackKeywords: [
    "quiz search",
    "music quiz",
    "music trivia",
    "quiz topics",
    "music knowledge",
  ],
  index: false,
  follow: true,
  maxImagePreview: "large",
  brandSuffix: " - MelodyMind Quiz",
});

const searchIndexUrl = "/search-index.json";
---

<Layout {pageSeo}>
  <PageShell className="page-shell--night page-shell--grid">
    <SearchPageSection
      searchIndexUrl={searchIndexUrl}
      initialQuery={initialQuery}
      title={title}
      lead={description}
      resultsEyebrow="Search the quiz archive"
      resultsTitle="Results"
      resultsHelp="Results update while you type, and the current query stays in the URL."
      searchPlaceholder="Search quiz titles or descriptions..."
      searchEmptyText="Type a quiz title or keyword."
      searchNoResultsText="No matching quizzes found."
      searchLimit={24}
    />
  </PageShell>
</Layout>
