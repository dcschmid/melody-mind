---
/**
 * Quiz Overview Page
 *
 * Displays all available quizzes organized by category.
 */
import Layout from "@layouts/Layout.astro";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { getCollectionCached } from "@shared-utils/utils/content/getCollectionCached";
import {
  buildBreadcrumbListSchema,
  buildCollectionPageSchema,
  buildQuizItemListSchema,
} from "@shared-utils/utils/seo/seoSchema";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import type { QuizData } from "../content.config";
import {
  getQuizImage,
  getQuizImageUrl,
  quizHeroImage,
  quizHeroImageUrl,
} from "../utils/quizImages";

export const prerender = true;

interface QuizEntry {
  id: string;
  data: QuizData;
}

const allQuizzes = await getCollectionCached("quizzes", { getCollection });
const quizzes: QuizEntry[] = allQuizzes.map((q: any) => ({
  id: q.id,
  data: q.data as QuizData,
}));

const quizzesByCategory = {
  decade: quizzes.filter((q) => q.data.category === "decade"),
  "genre-evolution": quizzes.filter((q) => q.data.category === "genre-evolution"),
  mixed: quizzes.filter((q) => q.data.category === "mixed"),
};

const featuredQuiz =
  quizzes.find((q) => q.id === "from-pop-to-streaming-pop") ??
  quizzesByCategory["genre-evolution"][0] ??
  quizzes[0];

const categoryLabels = {
  decade: "Decade Quizzes",
  "genre-evolution": "Genre Evolution",
  mixed: "Mixed Topics",
};

const quizIndexSections = [
  {
    id: "genre",
    title: categoryLabels["genre-evolution"],
    description:
      "Explore how genres transformed over time, from blues to rock, jazz to neo soul.",
    quizzes: quizzesByCategory["genre-evolution"],
  },
  {
    id: "mixed",
    title: categoryLabels.mixed,
    description: "Comprehensive quizzes covering multiple topics and time periods.",
    quizzes: quizzesByCategory.mixed,
  },
];

const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, "/");

const seoBreadcrumbs = [{ name: "Home", url: currentUrl }];
const itemListId = `${currentUrl}#quiz-itemlist`;

const breadcrumbSchema = buildBreadcrumbListSchema(seoBreadcrumbs);
const collectionPageSchema = buildCollectionPageSchema({
  url: currentUrl,
  name: "Music History Quizzes And Trivia",
  description:
    "Play music history quizzes on decades, genres, artists, and cultural shifts from rock and roll to modern streaming pop.",
  lang: "en",
  image:
    getQuizImageUrl("from-pop-to-streaming-pop", baseUrl) ?? quizHeroImageUrl(baseUrl),
  mainEntityId: itemListId,
});

const itemListSchema = buildQuizItemListSchema({
  quizzes: quizzes.map((quiz) => ({
    slug: quiz.id,
    title: quiz.data.title,
    description: quiz.data.description,
    url: `${baseUrl}/${quiz.id}/`,
    image: getQuizImageUrl(quiz.id, baseUrl) ?? quizHeroImageUrl(baseUrl),
    keywords: quiz.data.featuredTopics,
  })),
  listName: "Music Knowledge Quizzes",
  itemListId,
});

const indexImage =
  getQuizImageUrl("from-pop-to-streaming-pop", baseUrl) ?? quizHeroImageUrl(baseUrl);

const pageSeo = buildPageSeo({
  title: "Music History Quizzes And Trivia",
  description:
    "Play music history quizzes on decades, genres, artists, and cultural shifts from rock and roll to modern streaming pop.",
  url: currentUrl,
  image: indexImage,
  imageAlt: "Music History Quizzes And Trivia - MelodyMind Quiz",
  contentKind: "generic",
  structuredData: [collectionPageSchema, breadcrumbSchema, itemListSchema].filter(
    Boolean
  ) as StructuredData[],
  fallbackKeywords: [
    "music quiz",
    "music trivia",
    "rock history quiz",
    "jazz quiz",
    "music knowledge",
  ],
  maxImagePreview: "large",
  autoSocialImage: true,
  generateSocialImage: ({ title: genTitle }) => {
    void genTitle;
    return undefined;
  },
  authorName: "MelodyMind Quiz",
  index: true,
  brandSuffix: " - MelodyMind Quiz",
});
---

<Layout {pageSeo}>
  <PageShell className="page-shell--grid">
    <div class="quiz-page">
      <HeroTeaser
        id="quiz-home-hero"
        class="quiz-hero"
        title="Music Quizzes"
        description="Challenge yourself with quizzes covering music history, genres, and artists. Each question is grounded in research-driven content."
        titleLevel="h1"
        imageSrc={quizHeroImage}
        imageAlt="A colorful music-themed collage representing pop eras and quiz topics."
        imageWidth={1024}
        imageHeight={683}
        imageLoading="eager"
        imageSizes="(max-width: 640px) 100vw, (max-width: 960px) 50vw, 40vw"
        mediaAspectRatio="3 / 2"
      />

      {
        featuredQuiz && (
          <section class="quiz-featured" aria-labelledby="featured-quiz-heading">
            <div class="quiz-featured__content">
              <p class="quiz-featured__eyebrow">Featured quiz</p>
              <h2 id="featured-quiz-heading" class="quiz-featured__title">
                {featuredQuiz.data.title}
              </h2>
              <p class="quiz-featured__description">{featuredQuiz.data.description}</p>
              <a class="quiz-featured__link" href={`/${featuredQuiz.id}`}>
                Play featured quiz
              </a>
            </div>
            <div class="quiz-featured__media" aria-hidden="true">
              <Image
                class="quiz-featured__image"
                src={getQuizImage(featuredQuiz.id) ?? quizHeroImage}
                alt=""
                width={720}
                height={480}
                loading="eager"
                sizes="(max-width: 767px) 100vw, 42vw"
              />
            </div>
          </section>
        )
      }

      {
        quizzesByCategory.decade.length > 0 && (
          <section class="quiz-section" aria-labelledby="decade-heading">
            <Headline level="h2" textSize="2xl" className="quiz-section__title">
              <span id="decade-heading">{categoryLabels.decade}</span>
            </Headline>
            <Paragraph textSize="base" className="quiz-section__description">
              Test your knowledge of music from different decades, from the birth of rock
              and roll to modern streaming pop.
            </Paragraph>
            <ol class="quiz-section__timeline" aria-label={categoryLabels.decade}>
              {quizzesByCategory.decade.map((quiz) => (
                <li>
                  <a class="quiz-section__timeline-link" href={`/${quiz.id}`}>
                    <Image
                      class="quiz-section__timeline-image"
                      src={getQuizImage(quiz.id) ?? quizHeroImage}
                      alt=""
                      width={180}
                      height={120}
                      loading="lazy"
                      sizes="(max-width: 639px) 5rem, 8rem"
                    />
                    <span class="quiz-section__timeline-year">{quiz.data.title}</span>
                    <span class="quiz-section__timeline-copy">
                      {quiz.data.description}
                    </span>
                    <span class="quiz-section__timeline-action">
                      <Icon
                        name="play"
                        class="quiz-section__action-icon"
                        aria-hidden="true"
                      />
                      Play
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        )
      }

      {
        quizIndexSections.map((section) =>
          section.quizzes.length > 0 ? (
            <section class="quiz-section" aria-labelledby={`${section.id}-heading`}>
              <Headline level="h2" textSize="2xl" className="quiz-section__title">
                <span id={`${section.id}-heading`}>{section.title}</span>
              </Headline>
              <Paragraph textSize="base" className="quiz-section__description">
                {section.description}
              </Paragraph>
              <ul class="quiz-section__index" aria-label={section.title}>
                {section.quizzes.map((quiz) => (
                  <li>
                    <a class="quiz-section__index-link" href={`/${quiz.id}`}>
                      <Image
                        class="quiz-section__index-image"
                        src={getQuizImage(quiz.id) ?? quizHeroImage}
                        alt=""
                        width={180}
                        height={120}
                        loading="lazy"
                        sizes="(max-width: 639px) 5rem, 9rem"
                      />
                      <span class="quiz-section__index-copy">
                        <span class="quiz-section__index-title">{quiz.data.title}</span>
                        <span class="quiz-section__index-description">
                          {quiz.data.description}
                        </span>
                      </span>
                      <span class="quiz-section__index-action">
                        <Icon
                          name="play"
                          class="quiz-section__action-icon"
                          aria-hidden="true"
                        />
                        Play
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ) : null
        )
      }

      {
        quizzes.length === 0 && (
          <EmptyState
            class="quiz-empty"
            title="No quizzes available yet"
            description="Check back soon for new music quizzes!"
          />
        )
      }
    </div>
  </PageShell>
</Layout>

<style>
  .quiz-page {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3xl);
  }

  .quiz-featured {
    display: grid;
    gap: var(--spacing-lg);
    align-items: stretch;
    padding-block: var(--spacing-lg);
    overflow: hidden;
    border-block: 1px solid var(--surface-border-soft);
  }

  @media (width >= 768px) {
    .quiz-featured {
      grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.72fr);
    }
  }

  .quiz-featured__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
    justify-content: center;
  }

  .quiz-featured__eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  .quiz-featured__title,
  .quiz-featured__description {
    margin: 0;
  }

  .quiz-featured__title {
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    letter-spacing: 0;
  }

  .quiz-featured__description {
    max-inline-size: var(--measure-readable);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .quiz-featured__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: fit-content;
    min-block-size: var(--control-min-block-size);
    padding: calc(var(--spacing-sm) + 0.2rem) var(--spacing-base);
    font-weight: 700;
    color: var(--accent-contrast);
    text-decoration: none;
    background: var(--accent-primary);
    border: 1px solid var(--accent-primary);
    border-radius: var(--radius-md);
  }

  .quiz-featured__link:hover,
  .quiz-featured__link:focus-visible {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
  }

  .quiz-featured__media {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--surface-chip-bg);
    border-radius: var(--radius-lg);
  }

  .quiz-featured__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .quiz-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  @media (width >= 768px) {
    .quiz-section {
      gap: var(--spacing-xl);
    }
  }

  .quiz-section__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  @media (width >= 640px) {
    .quiz-section__title {
      font-size: var(--font-size-xl);
    }
  }

  .quiz-section__description {
    max-inline-size: var(--measure-readable);
    margin: 0;
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .quiz-section__index {
    display: grid;
    padding: 0;
    margin: 0;
    list-style: none;
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .quiz-section__index-link {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr) auto;
    gap: var(--spacing-base);
    align-items: center;
    padding-block: var(--spacing-base);
    color: inherit;
    text-decoration: none;
    border-block-end: 1px solid var(--surface-border-soft);
  }

  @media (width >= 640px) {
    .quiz-section__index-link {
      grid-template-columns: 9rem minmax(0, 1fr) auto;
      gap: var(--spacing-lg);
      padding-block: var(--spacing-lg);
    }
  }

  .quiz-section__index-image {
    display: block;
    inline-size: 5rem;
    block-size: calc(5rem * 2 / 3);
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-md);
  }

  .quiz-section__index-copy {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .quiz-section__index-title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }

  .quiz-section__index-description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .quiz-section__index-action {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-block-size: 2.75rem;
    padding: 0.62rem 1rem;
    font-weight: 700;
    line-height: 1;
    color: var(--accent-contrast);
    background-color: var(--accent-primary);
    border: 1px solid color-mix(in srgb, var(--accent-primary) 70%, transparent);
    border-radius: var(--radius-full);
    box-shadow: 0 0.55rem 1.25rem
      color-mix(in srgb, var(--accent-primary) 18%, transparent);
  }

  .quiz-section__action-icon {
    flex: 0 0 auto;
    inline-size: 1rem;
    block-size: 1rem;
  }

  .quiz-section__index-link:hover .quiz-section__index-title,
  .quiz-section__index-link:focus-visible .quiz-section__index-title {
    color: var(--accent-strong);
  }

  .quiz-section__index-link:hover .quiz-section__index-action,
  .quiz-section__index-link:focus-visible .quiz-section__index-action {
    color: var(--accent-contrast);
    background-color: var(--accent-primary-hover);
    border-color: color-mix(in srgb, var(--accent-primary-hover) 76%, transparent);
    box-shadow: 0 0.8rem 1.65rem
      color-mix(in srgb, var(--accent-primary) 24%, transparent);
  }

  @media (width <= 639px) {
    .quiz-section__index-link {
      grid-template-columns: 4.75rem minmax(0, 1fr) auto;
      gap: var(--spacing-sm);
      min-block-size: 6.5rem;
      padding-block: calc(var(--spacing-sm) + 0.25rem);
    }

    .quiz-section__index-image {
      grid-row: 1 / 3;
      align-self: start;
      inline-size: 4.75rem;
      block-size: calc(4.75rem * 2 / 3);
      aspect-ratio: 3 / 2;
    }

    .quiz-section__index-copy {
      display: contents;
    }

    .quiz-section__index-title {
      grid-column: 2;
      align-self: end;
      font-size: var(--font-size-base);
    }

    .quiz-section__index-description {
      grid-column: 2 / -1;
      -webkit-line-clamp: 2;
      font-size: var(--font-size-sm);
      line-height: 1.45;
    }

    .quiz-section__index-action {
      grid-column: 3;
      place-self: end;
      min-block-size: var(--control-min-block-size-compact);
      padding-inline: var(--spacing-sm);
    }
  }

  .quiz-section__timeline {
    display: grid;
    gap: var(--spacing-sm);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .quiz-section__timeline-link {
    display: grid;
    grid-template-columns: 5rem minmax(4.5rem, 6rem) minmax(0, 1fr) auto;
    gap: var(--spacing-base);
    align-items: center;
    padding-block: var(--spacing-base);
    color: inherit;
    text-decoration: none;
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .quiz-section__timeline li:first-child .quiz-section__timeline-link {
    border-block-start: 1px solid var(--surface-border-soft);
  }

  @media (width >= 640px) {
    .quiz-section__timeline-link {
      grid-template-columns: 8rem minmax(5rem, 7rem) minmax(0, 1fr) auto;
      gap: var(--spacing-lg);
      padding-block: var(--spacing-lg);
    }
  }

  .quiz-section__timeline-image {
    display: block;
    inline-size: 5rem;
    block-size: calc(5rem * 2 / 3);
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center;
    border-radius: var(--radius-md);
  }

  .quiz-section__timeline-year {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--text-primary);
  }

  .quiz-section__timeline-copy {
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .quiz-section__timeline-action {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-block-size: 2.75rem;
    padding: 0.62rem 1rem;
    font-weight: 700;
    line-height: 1;
    color: var(--accent-contrast);
    background-color: var(--accent-primary);
    border: 1px solid color-mix(in srgb, var(--accent-primary) 70%, transparent);
    border-radius: var(--radius-full);
    box-shadow: 0 0.55rem 1.25rem
      color-mix(in srgb, var(--accent-primary) 18%, transparent);
  }

  .quiz-section__timeline-link:hover .quiz-section__timeline-year,
  .quiz-section__timeline-link:focus-visible .quiz-section__timeline-year {
    color: var(--accent-strong);
  }

  .quiz-section__timeline-link:hover .quiz-section__timeline-action,
  .quiz-section__timeline-link:focus-visible .quiz-section__timeline-action {
    color: var(--accent-contrast);
    background-color: var(--accent-primary-hover);
    border-color: color-mix(in srgb, var(--accent-primary-hover) 76%, transparent);
    box-shadow: 0 0.8rem 1.65rem
      color-mix(in srgb, var(--accent-primary) 24%, transparent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .quiz-section__index-action,
    .quiz-section__timeline-action {
      transition:
        background-color 160ms ease,
        border-color 160ms ease,
        box-shadow 160ms ease,
        color 160ms ease,
        transform 160ms ease;
    }

    .quiz-section__index-link:hover .quiz-section__index-action,
    .quiz-section__index-link:focus-visible .quiz-section__index-action,
    .quiz-section__timeline-link:hover .quiz-section__timeline-action,
    .quiz-section__timeline-link:focus-visible .quiz-section__timeline-action {
      transform: translateY(-1px);
    }
  }

  @media (width >= 640px) {
    .quiz-section__index-image {
      inline-size: 9rem;
      block-size: 6rem;
    }

    .quiz-section__timeline-image {
      inline-size: 8rem;
      block-size: calc(8rem * 2 / 3);
    }
  }

  @media (width <= 639px) {
    .quiz-section__timeline-link {
      grid-template-columns: 4.75rem minmax(0, 1fr) auto;
      gap: var(--spacing-sm);
      min-block-size: 6.5rem;
      padding-block: calc(var(--spacing-sm) + 0.25rem);
    }

    .quiz-section__timeline-image {
      grid-row: 1 / 3;
      align-self: start;
      inline-size: 4.75rem;
      block-size: calc(4.75rem * 2 / 3);
      aspect-ratio: 3 / 2;
    }

    .quiz-section__timeline-year {
      grid-column: 2;
      align-self: end;
      font-size: var(--font-size-base);
    }

    .quiz-section__timeline-copy {
      display: -webkit-box;
      grid-column: 2 / -1;
      overflow: hidden;
      -webkit-line-clamp: 2;
      font-size: var(--font-size-sm);
      line-height: 1.45;
      -webkit-box-orient: vertical;
    }

    .quiz-section__timeline-action {
      grid-column: 3;
      place-self: end;
      min-block-size: var(--control-min-block-size-compact);
      padding-inline: var(--spacing-sm);
    }
  }
</style>
