---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import NotFoundContent from "@shared-ui/components/layout/NotFoundContent.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

export const prerender = true;

const canonical = resolvePageUrl(Astro.site, "/404");

const pageSeo = buildPageSeo({
  title: "Quiz not found",
  description:
    "The quiz you're looking for doesn't exist. Browse all quizzes to find something new.",
  url: canonical,
  brandSuffix: " - MelodyMind Quiz",
  index: false,
  follow: false,
});
---

<Layout {pageSeo} showHeaderIcons={false} showFooter={false}>
  <PageShell
    className="page-shell--aurora page-shell--grid"
    containerClass="page-shell__container--narrow"
  >
    <main>
      <NotFoundContent
        title="Quiz not found"
        description="The quiz you're looking for doesn't exist, has been moved, or the URL is incorrect."
        buttons={[
          { href: "/", label: "Browse all quizzes", variant: "primary" },
          {
            href: "https://melody-mind.de/",
            label: "Go to Knowledge",
            variant: "secondary",
          },
        ]}
      />
    </main>
  </PageShell>
</Layout>
