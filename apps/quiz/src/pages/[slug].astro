---
/**
 * Quiz Detail Page
 *
 * Renders an individual quiz with questions and interactive quiz logic.
 */
import Layout from "@layouts/Layout.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { getCollectionEntries } from "@shared-utils/utils/content/getCollectionEntries";
import {
  buildBreadcrumbListSchema,
  buildQuizSchema,
} from "@shared-utils/utils/seo/seoSchema";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import type { QuizData, QuizQuestion } from "../content.config";
import { getQuizImageUrl, quizHeroImageUrl } from "../utils/quizImages";

export const prerender = true;

interface Props {
  quiz: {
    id: string;
    data: QuizData;
  };
}

export async function getStaticPaths() {
  const quizzes = await getCollectionEntries("quizzes");
  return quizzes.map((quiz: any) => ({
    params: { slug: quiz.id },
    props: { quiz: { id: quiz.id, data: quiz.data } },
  }));
}

const { quiz } = Astro.props as Props;

const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, `/${quiz.id}`);

const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: quiz.data.title, url: currentUrl },
];

const breadcrumbSchema = buildBreadcrumbListSchema(seoBreadcrumbs);

const quizSeoTitle = quiz.data.seoTitle || `${quiz.data.title} Music Quiz`;
const quizSeoDescription = quiz.data.seoDescription || quiz.data.description;
const quizImage = getQuizImageUrl(quiz.id, baseUrl) ?? quizHeroImageUrl(baseUrl);
const quizFeaturedTopics = quiz.data.featuredTopics.length
  ? quiz.data.featuredTopics
  : [quiz.data.category.replace(/-/g, " "), ...quiz.data.relatedArticles];

const quizSchema = buildQuizSchema({
  title: quiz.data.title,
  description: quizSeoDescription,
  url: currentUrl,
  numberOfQuestions: quiz.data.questionsPerSession,
  topics: quizFeaturedTopics,
  keywords: quizFeaturedTopics,
});

const pageSeo = buildPageSeo({
  title: quizSeoTitle,
  description: quizSeoDescription,
  url: currentUrl,
  image: quizImage,
  structuredData: [breadcrumbSchema, quizSchema] as StructuredData[],
  brandSuffix: " - MelodyMind Quiz",
});

const questionsData = quiz.data.questions.map((q: QuizQuestion) => ({
  question: q.question,
  type: q.type,
  difficulty: q.difficulty,
  options: q.options,
  correct: q.correct,
  explanation: q.explanation,
  source: q.source,
  sourceLine: q.sourceLine,
}));

const passingScore = quiz.data.passingScore;
const questionsPerSession = quiz.data.questionsPerSession;
const totalPoolSize = quiz.data.questions.length;
---

<Layout {pageSeo} showHeaderIcons={false} showFooter={false}>
  <PageShell
    className="page-shell--aurora page-shell--grid"
    containerClass="page-shell__container--narrow"
  >
    <div
      class="quiz-detail"
      data-analytics-quiz="true"
      data-analytics-quiz-slug={quiz.id}
      data-analytics-quiz-category={quiz.data.category}
    >
      <div class="quiz-detail__content">
        <main class="quiz-detail__main">
          <section class="quiz-detail__progress-shell" aria-label="Quiz progress">
            <div id="quiz-progress-container"></div>
          </section>

          <section class="quiz-detail__panel" aria-labelledby="quiz-play-heading">
            <div class="quiz-detail__panel-header">
              <Headline level="h2" textSize="lg" className="quiz-detail__panel-title">
                <span id="quiz-play-heading">Answer the question</span>
              </Headline>
            </div>

            <div id="quiz-question-container"></div>
            <div id="quiz-result-container"></div>
          </section>

          <div class="quiz-detail__nav" id="quiz-nav">
            <button
              type="button"
              id="quiz-nav-prev"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--prev"
              hidden
            >
              <Icon name="arrow-left" class="quiz-detail__nav-icon" aria-hidden="true" />
              Previous
            </button>

            <button
              type="button"
              id="quiz-check-answer"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--check"
            >
              Check Answer
            </button>

            <button
              type="button"
              id="quiz-nav-next"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--next"
            >
              Next
              <Icon name="arrow-right" class="quiz-detail__nav-icon" aria-hidden="true" />
            </button>

            <button
              type="button"
              id="quiz-nav-submit"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--submit"
              hidden
            >
              <Icon
                name="tabler:circle-check"
                class="quiz-detail__nav-icon"
                aria-hidden="true"
              />
              Show Results
            </button>
          </div>
        </main>
      </div>
    </div>
  </PageShell>

  <script
    is:inline
    type="application/json"
    id="quiz-questions-data"
    set:html={JSON.stringify(questionsData)}
  />
  <span id="quiz-passing-score" data-value={passingScore} hidden></span>
  <span id="quiz-questions-per-session" data-value={questionsPerSession} hidden></span>
  <span id="quiz-total-pool-size" data-value={totalPoolSize} hidden></span>
</Layout>

<script>
  import { initQuiz, type QuizQuestion } from "../scripts/quiz/quizClient";

  document.addEventListener("DOMContentLoaded", () => {
    const questionsEl = document.getElementById("quiz-questions-data");
    const passingScoreEl = document.getElementById("quiz-passing-score");
    const questionsPerSessionEl = document.getElementById("quiz-questions-per-session");

    if (!questionsEl || !passingScoreEl || !questionsPerSessionEl) {
      return;
    }

    const questions: QuizQuestion[] = JSON.parse(questionsEl.textContent || "[]");
    const passingScore: number = parseInt(passingScoreEl.dataset.value || "70", 10);
    const questionsPerSession: number = parseInt(
      questionsPerSessionEl.dataset.value || "20",
      10
    );

    initQuiz(questions, passingScore, questionsPerSession);
  });
</script>

<style>
  .quiz-detail {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  .quiz-detail__header {
    position: relative;
  }

  .quiz-detail__hero {
    display: grid;
    gap: 0.6rem;
    padding: 0.5rem 0 0.75rem;
    border-block-end: 1px solid var(--surface-border-soft);
  }

  @media (width >= 960px) {
    .quiz-detail__hero {
      grid-template-columns: minmax(0, 1fr) minmax(12rem, 14rem);
      gap: 0.85rem;
      align-items: center;
      padding: 0 0 0.75rem;
    }
  }

  .quiz-detail__hero-main {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .quiz-detail__breadcrumb a {
    font-size: 1.125rem;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .quiz-detail__breadcrumb a:hover,
  .quiz-detail__breadcrumb a:focus-visible {
    color: var(--accent-primary);
  }

  .quiz-detail__title {
    margin: 0;
    font-size: clamp(1.45rem, 4vi, 2rem);
    line-height: 1.04;
    color: var(--text-primary);
    letter-spacing: -0.045em;
  }

  .quiz-detail__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .quiz-detail__badge {
    display: inline-flex;
    align-items: center;
    min-block-size: 1.9rem;
    padding: 0.3rem 0.65rem;
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--text-secondary);
    background: var(--surface-pill-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  .quiz-detail__hero-media {
    position: relative;
    justify-self: end;
    max-inline-size: 11rem;
    min-block-size: 6.5rem;
    overflow: hidden;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    opacity: 0.9;
  }

  @media (width <= 959px) {
    .quiz-detail__hero-media {
      display: none;
    }
  }

  .quiz-detail__hero-image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .quiz-detail__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (width <= 639px) {
    .quiz-detail__content {
      gap: 1.1rem;
    }
  }

  .quiz-detail__progress-shell,
  .quiz-detail__panel,
  .quiz-detail__footer {
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .quiz-detail__progress-shell,
  .quiz-detail__panel {
    padding: 0.85rem;
  }

  .quiz-detail__panel {
    margin-block-start: 1rem;
  }

  @media (width >= 640px) {
    .quiz-detail__progress-shell,
    .quiz-detail__panel {
      padding: 0.9rem;
    }

    .quiz-detail__panel {
      margin-block-start: 1.25rem;
    }
  }

  .quiz-detail__panel-header {
    margin-block-end: 0.35rem;
  }

  .quiz-detail__panel-title,
  .quiz-detail__footer-title {
    margin: 0;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  .quiz-detail__panel-title {
    font-size: 1.125rem;
    color: var(--text-secondary);
  }

  .quiz-detail__nav {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-block-start: 0.7rem;
  }

  @media (width >= 640px) {
    .quiz-detail__nav {
      flex-flow: row wrap;
      justify-content: center;
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .quiz-detail__nav-btn {
      display: inline-flex;
      gap: 0.55rem;
      align-items: center;
      justify-content: center;
      inline-size: 100%;
      min-block-size: 3rem;
      padding: 0.8rem 1rem;
      font-weight: 700;
      color: var(--text-primary);
      cursor: pointer;
      background: var(--surface-pill-bg);
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-full);
      transition: none;
    }
  }

  .quiz-detail__nav-btn {
    display: inline-flex;
    gap: 0.55rem;
    align-items: center;
    justify-content: center;
    inline-size: 100%;
    min-block-size: 3rem;
    padding: 0.8rem 1rem;
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    background: var(--surface-pill-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  @media (width >= 640px) {
    .quiz-detail__nav-btn {
      inline-size: auto;
      min-inline-size: 10rem;
    }
  }

  .quiz-detail__nav-btn:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .quiz-detail__nav-btn:focus-visible,
  .quiz-detail__nav-btn:hover:not(:disabled) {
    border-color: var(--surface-border-accent);
    box-shadow: var(--interactive-shadow-focus);
    transform: translateY(-1px);
  }

  .quiz-detail__nav-btn--check,
  .quiz-detail__nav-btn--submit {
    color: var(--accent-contrast);
    background: var(--accent-primary);
  }

  .quiz-detail__nav-icon {
    flex: 0 0 auto;
    inline-size: var(--spacing-base);
    block-size: var(--spacing-base);
  }

  .quiz-detail__footer {
    padding: 0.65rem 0.85rem;
  }

  .quiz-detail__footer-head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .quiz-detail__source {
    margin: 0;
    font-size: var(--font-size-base);
    line-height: 1.5;
    color: var(--text-secondary);
  }

  :global(#quiz-progress-container .quiz-progress) {
    display: grid;
    gap: 0.65rem;
  }

  @media (width >= 768px) {
    :global(#quiz-progress-container .quiz-progress) {
      grid-template-columns: minmax(0, 1.2fr) minmax(14rem, 0.8fr);
      column-gap: 1rem;
      align-items: start;
    }
  }

  :global(#quiz-progress-container .quiz-progress__eyebrow) {
    margin: 0;
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  @media (width >= 768px) {
    :global(#quiz-progress-container .quiz-progress__eyebrow) {
      grid-row: 1;
      grid-column: 1 / -1;
    }
  }

  :global(#quiz-progress-container .quiz-progress__headline),
  :global(#quiz-progress-container .quiz-progress__stats) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  @media (width >= 768px) {
    :global(#quiz-progress-container .quiz-progress__headline) {
      grid-row: 2;
      grid-column: 1;
    }

    :global(#quiz-progress-container .quiz-progress__bar) {
      grid-row: 3;
      grid-column: 1 / -1;
    }

    :global(#quiz-progress-container .quiz-progress__stats) {
      grid-row: 4;
      grid-column: 1 / -1;
    }
  }

  :global(#quiz-progress-container .quiz-progress__index) {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--text-primary);
  }

  :global(#quiz-progress-container .quiz-progress__target),
  :global(#quiz-progress-container .quiz-progress__stat-label) {
    font-size: var(--font-size-base);
    color: var(--text-secondary);
  }

  :global(#quiz-progress-container .quiz-progress__target) {
    display: none;
  }

  @media (width >= 768px) {
    :global(#quiz-progress-container .quiz-progress__target) {
      display: block;
    }
  }

  :global(#quiz-progress-container .quiz-progress__bar) {
    block-size: 0.8rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface-border-soft) 88%, transparent);
    border-radius: var(--radius-full);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global(#quiz-progress-container .quiz-progress__fill) {
      block-size: 100%;
      background: linear-gradient(90deg, var(--accent-primary), var(--accent-strong));
      border-radius: inherit;
      transition: none;
    }
  }

  :global(#quiz-progress-container .quiz-progress__fill) {
    block-size: 100%;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-strong));
    border-radius: inherit;
    transition: inline-size var(--transition-fast);
  }

  :global(#quiz-progress-container .quiz-progress__stats) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
  }

  @media (width <= 639px) {
    :global(#quiz-progress-container .quiz-progress__stats) {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  :global(#quiz-progress-container .quiz-progress__stat) {
    display: flex;
    flex-direction: row;
    gap: 0.6rem;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.5rem 0.6rem;
    background: var(--surface-chip-bg);
    border: 1px solid var(--surface-border-subtle);
    border-radius: var(--radius-full);
  }

  @media (width <= 639px) {
    :global(#quiz-progress-container .quiz-progress__stat) {
      align-items: center;
      padding: 0.55rem 0.75rem;
      border-radius: 0.85rem;
    }
  }

  :global(#quiz-progress-container .quiz-progress__stat-label) {
    white-space: nowrap;
  }

  @media (width <= 639px) {
    :global(#quiz-progress-container .quiz-progress__stat-label) {
      line-height: 1.25;
      white-space: normal;
    }
  }

  :global(#quiz-progress-container .quiz-progress__stat-value) {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
  }

  :global(#quiz-question-container .quiz-question) {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  :global(#quiz-question-container .quiz-question__topline) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  :global(#quiz-question-container .quiz-question__number),
  :global(#quiz-question-container .quiz-question__type),
  :global(#quiz-question-container .quiz-question__badge) {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    min-block-size: 2rem;
    padding: 0.35rem 0.7rem;
    font-size: var(--font-size-base);
    font-weight: 700;
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  :global(#quiz-question-container .quiz-question__number) {
    color: var(--text-primary);
    background: var(--surface-chip-bg);
    border-color: var(--surface-border-accent);
  }

  :global(#quiz-question-container .quiz-question__type) {
    color: var(--text-secondary);
    background: var(--surface-pill-bg);
  }

  :global(#quiz-question-container .quiz-question__badge--correct) {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--color-success) 18%, var(--surface-pill-bg));
    border-color: color-mix(
      in srgb,
      var(--color-success) 56%,
      var(--surface-border-soft)
    );
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-success) 18%, transparent);
  }

  :global(#quiz-question-container .quiz-question__badge--incorrect) {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--color-error) 16%, var(--surface-pill-bg));
    border-color: color-mix(in srgb, var(--color-error) 56%, var(--surface-border-soft));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-error) 16%, transparent);
  }

  :global(#quiz-question-container .quiz-question__badge svg) {
    inline-size: var(--spacing-base);
    block-size: var(--spacing-base);
  }

  :global(#quiz-question-container .quiz-question__card) {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
  }

  :global(#quiz-question-container .quiz-question__prompt),
  :global(#quiz-question-container .quiz-question__hint) {
    margin: 0;
    color: var(--text-secondary);
  }

  :global(#quiz-question-container .quiz-question__prompt) {
    font-size: var(--font-size-base);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  :global(#quiz-question-container .quiz-question__text) {
    margin: 0;
    font-size: clamp(1.125rem, 3vi, 1.35rem);
    line-height: 1.4;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  :global(#quiz-question-container .quiz-question__options) {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global(#quiz-question-container .quiz-question__option) {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 0.7rem;
      align-items: center;
      inline-size: 100%;
      padding: 0.85rem 0.9rem;
      color: var(--text-primary);
      text-align: start;
      cursor: pointer;
      background: var(--surface-pill-bg);
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-lg);
      transition: none;
    }
  }

  :global(#quiz-question-container .quiz-question__option) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.7rem;
    align-items: center;
    inline-size: 100%;
    padding: 0.85rem 0.9rem;
    color: var(--text-primary);
    text-align: start;
    cursor: pointer;
    background: var(--surface-pill-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  @media (width <= 639px) {
    :global(#quiz-question-container .quiz-question__option) {
      min-block-size: 3.5rem;
      padding: 1rem;
    }
  }

  :global(#quiz-question-container .quiz-question__option:hover:not(:disabled)),
  :global(#quiz-question-container .quiz-question__option:focus-visible) {
    border-color: var(--surface-border-accent);
    transform: translateY(-1px);
  }

  :global(#quiz-question-container .quiz-question__option:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  :global(#quiz-question-container .quiz-question__option:disabled) {
    cursor: default;
  }

  :global(#quiz-question-container .quiz-question__option--selected) {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-primary) 14%, transparent),
      color-mix(in srgb, var(--accent-primary) 8%, var(--surface-pill-bg))
    );
    border-color: color-mix(
      in srgb,
      var(--accent-primary) 52%,
      var(--surface-border-soft)
    );
    box-shadow:
      inset 0.28rem 0 0 color-mix(in srgb, var(--accent-primary) 88%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--accent-primary) 14%, transparent);
  }

  :global(#quiz-question-container .quiz-question__option--correct) {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-success) 18%, transparent),
      color-mix(in srgb, var(--color-success) 8%, var(--surface-pill-bg))
    );
    border-color: color-mix(
      in srgb,
      var(--color-success) 58%,
      var(--surface-border-soft)
    );
    box-shadow:
      inset 0.28rem 0 0 color-mix(in srgb, var(--color-success) 88%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-success) 16%, transparent);
  }

  :global(#quiz-question-container .quiz-question__option--incorrect) {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-error) 16%, transparent),
      color-mix(in srgb, var(--color-error) 7%, var(--surface-pill-bg))
    );
