---
/**
 * Quiz Detail Page
 *
 * Renders an individual quiz with questions and interactive quiz logic.
 */
import Layout from "@layouts/Layout.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { getCollection } from "astro:content";
import { getCollectionCached } from "@shared-utils/utils/content/getCollectionCached";
import {
  buildBreadcrumbListSchema,
  buildQuizSchema,
  buildSpeakableSpecificationSchema,
} from "@shared-utils/utils/seo/seoSchema";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import type { QuizData, QuizQuestion } from "../content.config";
import { getQuizImageUrl, quizHeroImageUrl } from "../utils/quizImages";

export const prerender = true;

interface Props {
  quiz: {
    id: string;
    data: QuizData;
  };
}

export async function getStaticPaths() {
  const quizzes = await getCollectionCached("quizzes", { getCollection });
  return quizzes.map((quiz: any) => ({
    params: { slug: quiz.id },
    props: { quiz: { id: quiz.id, data: quiz.data } },
  }));
}

const { quiz } = Astro.props as Props;

const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, `/${quiz.id}`);

const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: quiz.data.title, url: currentUrl },
];

const breadcrumbSchema = buildBreadcrumbListSchema(seoBreadcrumbs);

const quizSeoTitle = quiz.data.seoTitle || `${quiz.data.title} Music Quiz`;
const quizSeoDescription = quiz.data.seoDescription || quiz.data.description;
const quizImage = getQuizImageUrl(quiz.id, baseUrl) ?? quizHeroImageUrl(baseUrl);
const quizFeaturedTopics = quiz.data.featuredTopics.length
  ? quiz.data.featuredTopics
  : [quiz.data.category.replace(/-/g, " "), ...quiz.data.relatedArticles];

const quizSchema = buildQuizSchema({
  title: quiz.data.title,
  description: quizSeoDescription,
  url: currentUrl,
  numberOfQuestions: quiz.data.questionsPerSession,
  topics: quizFeaturedTopics,
  keywords: quizFeaturedTopics,
});

const speakableSchema = buildSpeakableSpecificationSchema({
  cssSelectors: [
    "h1",
    ".quiz-detail__panel-header + p",
    ".quiz-detail__panel-header + div p:first-of-type",
  ],
});

const structuredDataList = [
  breadcrumbSchema,
  quizSchema,
  ...(speakableSchema ? [speakableSchema] : []),
] as StructuredData[];

const pageSeo = buildPageSeo({
  title: quizSeoTitle,
  description: quizSeoDescription,
  url: currentUrl,
  image: quizImage,
  imageAlt: `Cover image for the quiz: ${quiz.data.title}`,
  contentKind: "generic",
  structuredData: structuredDataList,
  authorName: "MelodyMind Quiz",
  maxImagePreview: "large",
  autoSocialImage: true,
  generateSocialImage: ({ title: genTitle }) => {
    void genTitle;
    return undefined;
  },
  brandSuffix: " - MelodyMind Quiz",
});

const questionsData = quiz.data.questions.map((q: QuizQuestion) => ({
  question: q.question,
  type: q.type,
  difficulty: q.difficulty,
  options: q.options,
  correct: q.correct,
  explanation: q.explanation,
  source: q.source,
  sourceLine: q.sourceLine,
}));

const passingScore = quiz.data.passingScore;
const questionsPerSession = quiz.data.questionsPerSession;
const totalPoolSize = quiz.data.questions.length;
const categoryLabel =
  quiz.data.category === "genre-evolution"
    ? "Genre evolution"
    : quiz.data.category === "decade"
      ? "Decade quiz"
      : "Mixed topic";
---

<Layout {pageSeo} showHeaderIcons={false} showFooter={false}>
  <PageShell className="page-shell--grid" containerClass="page-shell__container--narrow">
    <div class="quiz-detail">
      <div class="quiz-detail__content">
        <main class="quiz-detail__main">
          <header class="quiz-detail__hero" aria-labelledby="quiz-title">
            <div class="quiz-detail__hero-main">
              <a class="quiz-detail__breadcrumb" href="/">All quizzes</a>
              <h1 id="quiz-title" class="quiz-detail__title">{quiz.data.title}</h1>
              <p class="quiz-detail__meta">
                {categoryLabel} / {questionsPerSession} questions / {passingScore}% pass
                mark
              </p>
            </div>
          </header>

          <section class="quiz-detail__progress-shell" aria-label="Quiz progress">
            <div id="quiz-progress-container"></div>
          </section>

          <section class="quiz-detail__panel" aria-labelledby="quiz-play-heading">
            <div class="quiz-detail__panel-header">
              <Headline level="h2" textSize="2xl" className="quiz-detail__panel-title">
                <span id="quiz-play-heading">Current question</span>
              </Headline>
            </div>

            <div id="quiz-question-container"></div>
            <div id="quiz-result-container"></div>
          </section>

          <div class="quiz-detail__nav" id="quiz-nav">
            <button
              type="button"
              id="quiz-nav-prev"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--prev"
              hidden
            >
              <Icon name="arrow-left" class="quiz-detail__nav-icon" aria-hidden="true" />
              Previous
            </button>

            <button
              type="button"
              id="quiz-check-answer"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--check"
            >
              Check Answer
            </button>

            <button
              type="button"
              id="quiz-nav-next"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--next"
            >
              Next
              <Icon name="arrow-right" class="quiz-detail__nav-icon" aria-hidden="true" />
            </button>

            <button
              type="button"
              id="quiz-nav-submit"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--submit"
              hidden
            >
              <Icon
                name="tabler:circle-check"
                class="quiz-detail__nav-icon"
                aria-hidden="true"
              />
              Show Results
            </button>
          </div>
        </main>
      </div>
    </div>
  </PageShell>

  <script
    is:inline
    type="application/json"
    id="quiz-questions-data"
    set:html={JSON.stringify(questionsData)}
  />
  <span id="quiz-passing-score" data-value={passingScore} hidden></span>
  <span id="quiz-questions-per-session" data-value={questionsPerSession} hidden></span>
  <span id="quiz-total-pool-size" data-value={totalPoolSize} hidden></span>
</Layout>

<script>
  import { initQuiz, type QuizQuestion } from "../scripts/quiz/quizClient";

  document.addEventListener("DOMContentLoaded", () => {
    try {
      const questionsEl = document.getElementById("quiz-questions-data");
      const passingScoreEl = document.getElementById("quiz-passing-score");
      const questionsPerSessionEl = document.getElementById("quiz-questions-per-session");

      if (!questionsEl || !passingScoreEl || !questionsPerSessionEl) {
        console.warn("[quiz] Missing quiz data elements");
        return;
      }

      const questions: QuizQuestion[] = JSON.parse(questionsEl.textContent || "[]");
      const passingScore: number = parseInt(passingScoreEl.dataset.value || "70", 10);
      const questionsPerSession: number = parseInt(
        questionsPerSessionEl.dataset.value || "20",
        10
      );

      initQuiz(questions, passingScore, questionsPerSession);
    } catch (e) {
      console.error("[quiz] Failed to initialize quiz:", e);
    }
  });
</script>

<style>
  .quiz-detail {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
    min-inline-size: 0;
    padding-block-start: calc(var(--site-header-height) + var(--spacing-lg));
  }

  @media (width >= 640px) {
    .quiz-detail {
      padding-block-start: 0;
    }
  }

  .quiz-detail__hero {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-sm) + 0.15rem);
    padding-block-end: var(--spacing-base);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .quiz-detail__hero-main {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-xs) + 0.15rem);
  }

  .quiz-detail__breadcrumb {
    inline-size: fit-content;
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--text-secondary);
    text-decoration: none;
  }

  .quiz-detail__breadcrumb:hover,
  .quiz-detail__breadcrumb:focus-visible {
    color: var(--accent-primary);
  }

  .quiz-detail__title,
  .quiz-detail__meta {
    margin: 0;
  }

  .quiz-detail__title {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    letter-spacing: 0;
    text-wrap: balance;
  }

  .quiz-detail__meta {
    max-inline-size: var(--measure-readable);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  @media (width >= 640px) {
    .quiz-detail__title {
      font-size: var(--font-size-2xl);
    }
  }

  .quiz-detail__content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
  }

  .quiz-detail__progress-shell,
  .quiz-detail__panel {
    padding: var(--spacing-base) 0;
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .quiz-detail__panel {
    margin-block-start: 0;
    border-block-end: 1px solid var(--surface-border-soft);
  }

  @media (width >= 640px) {
    .quiz-detail__progress-shell,
    .quiz-detail__panel {
      padding: calc(var(--spacing-base) + 0.25rem) 0;
    }

    .quiz-detail__panel {
      margin-block-start: 0;
    }
  }

  .quiz-detail__panel-header {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: inset(50%);
  }

  .quiz-detail__panel-title {
    margin: 0;
    font-size: var(--font-size-base);
    color: var(--text-secondary);
    letter-spacing: 0;
  }

  .quiz-detail__nav {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-sm) + 0.05rem);
    padding: var(--spacing-sm);
    margin-block-start: var(--spacing-base);
    background: color-mix(in srgb, var(--surface-1) 92%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  @media (width >= 640px) {
    .quiz-detail__nav {
      flex-flow: row wrap;
      justify-content: center;
      padding: 0;
      background: transparent;
      border: 0;
      border-radius: 0;
      box-shadow: none;
    }
  }

  .quiz-detail__nav-btn[hidden] {
    display: none;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .quiz-detail__nav-btn {
      display: inline-flex;
      gap: calc(var(--spacing-sm) + 0.05rem);
      align-items: center;
      justify-content: center;
      inline-size: 100%;
      min-block-size: var(--control-min-block-size);
      padding: calc(var(--spacing-sm) + 0.3rem) var(--spacing-base);
      font-weight: 700;
      color: var(--text-primary);
      cursor: pointer;
      background: color-mix(in srgb, var(--surface-1) 76%, transparent);
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-lg);
      transition: none;
    }
  }

  .quiz-detail__nav-btn {
    display: inline-flex;
    gap: calc(var(--spacing-sm) + 0.05rem);
    align-items: center;
    justify-content: center;
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: calc(var(--spacing-sm) + 0.3rem) var(--spacing-base);
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 76%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  @media (width >= 640px) {
    .quiz-detail__nav-btn {
      inline-size: auto;
      min-inline-size: 10rem;
    }
  }

  .quiz-detail__nav-btn:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .quiz-detail__nav-btn:focus-visible,
  .quiz-detail__nav-btn:hover:not(:disabled) {
    border-color: var(--surface-border-accent);
    box-shadow: var(--interactive-shadow-focus);
    transform: translateY(-1px);
  }

  .quiz-detail__nav-btn--check,
  .quiz-detail__nav-btn--submit {
    color: var(--accent-contrast);
    background: var(--accent-primary);
  }

  .quiz-detail__nav-icon {
    flex: 0 0 auto;
    inline-size: var(--spacing-base);
    block-size: var(--spacing-base);
  }
</style>

<!--
  JS-rendered quiz components (progress, question, result).
  These MUST use :global because the HTML is injected via quizClient.ts
  template strings, not by Astro's templating system.
-->
<style is:global>
  #quiz-progress-container .quiz-progress {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--spacing-sm);
    align-items: center;
  }

  #quiz-progress-container .quiz-progress__headline {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--spacing-xs) + 0.2rem);
    align-items: baseline;
  }

  #quiz-progress-container .quiz-progress__index {
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: var(--text-primary);
  }

  #quiz-progress-container .quiz-progress__target {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
  }

  #quiz-progress-container .quiz-progress__bar {
    block-size: 0.45rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface-border-soft) 88%, transparent);
    border-radius: var(--radius-md);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    #quiz-progress-container .quiz-progress__fill {
      block-size: 100%;
      background: linear-gradient(90deg, var(--accent-primary), var(--accent-strong));
      border-radius: inherit;
      transition: none;
    }
  }

  #quiz-progress-container .quiz-progress__fill {
    block-size: 100%;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-strong));
    border-radius: inherit;
    transition: inline-size var(--transition-fast);
  }

  #quiz-question-container .quiz-question {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  #quiz-question-container .quiz-question__topline {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--spacing-xs) + 0.2rem);
    align-items: center;
  }

  #quiz-question-container .quiz-question__type,
  #quiz-question-container .quiz-question__badge {
    display: inline-flex;
    gap: calc(var(--spacing-xs) + 0.08rem);
    align-items: center;
    min-block-size: var(--control-min-block-size-compact);
    padding: calc(var(--spacing-sm) - 0.15rem) var(--control-padding-inline-compact);
    font-size: var(--font-size-sm);
    font-weight: 700;
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-base);
  }

  #quiz-question-container .quiz-question__type {
    color: var(--text-secondary);
    background: transparent;
  }

  #quiz-question-container .quiz-question__badge--correct {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--color-success) 18%, var(--surface-1));
    border-color: color-mix(
      in srgb,
      var(--color-success) 56%,
      var(--surface-border-soft)
    );
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-success) 18%, transparent);
  }

  #quiz-question-container .quiz-question__badge--incorrect {
    color: var(--text-primary);
    background: color-mix(in srgb, var(--color-error) 16%, var(--surface-1));
    border-color: color-mix(in srgb, var(--color-error) 56%, var(--surface-border-soft));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-error) 16%, transparent);
  }

  #quiz-question-container .quiz-question__badge svg {
    inline-size: var(--spacing-base);
    block-size: var(--spacing-base);
  }

  #quiz-question-container .quiz-question__badge[hidden] {
    display: none;
  }

  #quiz-question-container .quiz-question__card {
    display: flex;
    flex-direction: column;
    gap: var(--stack-gap-sm);
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
  }

  #quiz-question-container .quiz-question__hint {
    margin: 0;
    color: var(--text-secondary);
  }

  #quiz-question-container .quiz-question__text {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: 1.4;
    color: var(--text-primary);
    letter-spacing: 0;
  }

  #quiz-question-container .quiz-question__options {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing-sm) + 0.15rem);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    #quiz-question-container .quiz-question__option {
      position: relative;
      box-sizing: border-box;
      display: grid;
      grid-template-columns: minmax(1.35rem, auto) minmax(0, 1fr) auto;
      gap: calc(var(--spacing-sm) + 0.2rem);
      align-items: center;
      inline-size: 100%;
      padding: calc(var(--spacing-sm) + 0.35rem) calc(var(--spacing-base) - 0.1rem);
      color: var(--text-primary);
      text-align: start;
      cursor: pointer;
      background: color-mix(in srgb, var(--surface-1) 76%, transparent);
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-md);
      transition: none;
    }
  }

  #quiz-question-container .quiz-question__option {
    position: relative;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(1.35rem, auto) minmax(0, 1fr) auto;
    gap: calc(var(--spacing-sm) + 0.2rem);
    align-items: center;
    inline-size: 100%;
    padding: calc(var(--spacing-sm) + 0.35rem) calc(var(--spacing-base) - 0.1rem);
    color: var(--text-primary);
    text-align: start;
    cursor: pointer;
    background: color-mix(in srgb, var(--surface-1) 76%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-md);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  #quiz-question-container .quiz-question__option-control {
    inline-size: 1.25rem;
    block-size: 1.25rem;
    margin: 0;
    accent-color: var(--accent-primary);
    cursor: inherit;
  }

  @media (width <= 639px) {
    #quiz-question-container .quiz-question__option {
      min-block-size: 3.5rem;
      padding: 1rem;
    }
  }

  #quiz-question-container .quiz-question__option:focus-within {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  #quiz-question-container
    .quiz-question__option:has(.quiz-question__option-control:disabled) {
    cursor: default;
  }

  #quiz-question-container
    .quiz-question__option:hover:not(:has(.quiz-question__option-control:disabled)),
  #quiz-question-container
    .quiz-question__option:focus-within:not(
      :has(.quiz-question__option-control:disabled)
    ) {
    border-color: var(--surface-border-accent);
    transform: translateY(-1px);
  }

  #quiz-question-container .quiz-question__option--selected {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-primary) 14%, transparent),
      color-mix(in srgb, var(--accent-primary) 8%, var(--surface-1))
    );
    border-color: color-mix(
      in srgb,
      var(--accent-primary) 52%,
      var(--surface-border-soft)
    );
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent-primary) 18%, transparent);
  }

  #quiz-question-container .quiz-question__option--correct {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-success) 18%, transparent),
      color-mix(in srgb, var(--color-success) 8%, var(--surface-1))
    );
    border-color: color-mix(
      in srgb,
      var(--color-success) 58%,
      var(--surface-border-soft)
    );
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-success) 18%, transparent);
  }

  #quiz-question-container .quiz-question__option--incorrect {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-error) 16%, transparent),
      color-mix(in srgb, var(--color-error) 7%, var(--surface-1))
    );
    border-color: color-mix(in srgb, var(--color-error) 58%, var(--surface-border-soft));
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-error) 16%, transparent);
  }

  #quiz-question-container .quiz-question__option-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #quiz-question-container .quiz-question__option-status svg,
  #quiz-question-container .quiz-question__explanation-header svg,
  #quiz-result-container .quiz-result__btn svg {
    inline-size: calc(var(--spacing-base) + var(--spacing-2xs));
    block-size: calc(var(--spacing-base) + var(--spacing-2xs));
  }

  #quiz-question-container .quiz-question__option-text {
    font-size: var(--font-size-base);
    line-height: 1.4;
  }

  #quiz-question-container .quiz-question__option-status--correct {
    color: var(--color-success);
  }

  #quiz-question-container .quiz-question__option-status--incorrect {
    color: var(--color-error);
  }

  #quiz-question-container .quiz-question__explanation {
    box-sizing: border-box;
    inline-size: 100%;
    padding: calc(var(--spacing-sm) + 0.35rem) calc(var(--spacing-base) - 0.05rem);
    background: color-mix(in srgb, var(--surface-1) 78%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  #quiz-question-container .quiz-question__explanation-header {
    display: inline-flex;
    gap: calc(var(--spacing-sm) + 0.05rem);
    align-items: center;
    margin-block-end: 0.65rem;
    font-weight: 700;
    color: var(--text-primary);
  }

