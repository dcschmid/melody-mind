---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import AppHeadResources from "@shared-ui/components/meta/AppHeadResources.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import SkipLink from "@shared-ui/components/navigation/SkipLink.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";
import Footer from "@shared-ui/components/layout/Footer.astro";
import SearchPalette from "@shared-ui/components/search/SearchPalette.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { buildDefaultCopyrightText, MUSIC_SITE_URL } from "@shared-utils/utils/appShell";
import BackToTop from "@shared-ui/components/navigation/BackToTop.astro";
import SiteHeader from "@shared-ui/components/navigation/SiteHeader.astro";
import type { HeaderNavItem } from "@shared-ui/components/navigation/HeaderNav.astro";
import {
  ensureTrailingSlash,
  resolveAbsoluteUrl,
  resolveBaseUrl,
} from "@shared-utils/utils/siteUrls";
import { normalizeWhitespace } from "@shared-utils/utils/format";
import melodyMindLogo from "../assets/melody-mind-logo.webp";
import { musicAppShellConfig } from "../utils/appShellConfig";
import { getAlbumCoverImage, musicDefaultOgImageUrl } from "../utils/musicImages";
import { getAvailableAlbums } from "../utils/albums";
import { formatDuration } from "../utils/albumPresentation";
import FathomEventsScript from "@shared-ui/components/analytics/FathomEventsScript.astro";

import type { ImageMetadata } from "astro";
import type { PageSeoResult } from "@shared-utils/utils/seo/buildPageSeo";
import type { IconName } from "@shared-ui/components/visual/Icon.astro";
import type { OpenGraphMusicMeta } from "@shared-ui/components/meta/seo.types";
import type { Song } from "../types/album";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  type?: "website" | "article" | "musicAlbum";
  ogMusic?: OpenGraphMusicMeta;
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
  canonical?: string;
  language?: string;
  locale?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  structuredData?: Array<Record<string, unknown>>;
  index?: boolean;
  follow?: boolean;
  pageSeo?: PageSeoResult;
  mainClass?: string;
  contentShellClass?: string;
}

const {
  title,
  description,
  image = musicDefaultOgImageUrl,
  imageWidth,
  imageHeight,
  imageType,
  type = "website",
  ogMusic,
  publishedTime,
  modifiedTime,
  keywords = [],
  canonical,
  language = "en",
  locale = "en-US",
  breadcrumbs = [],
  structuredData = [],
  index = true,
  follow = true,
  pageSeo,
  mainClass = "",
  contentShellClass = "",
} = Astro.props as Props;

const siteTitle = "MelodyMind Music";
const defaultOgImageWidth = 700;
const defaultOgImageHeight = 368;
const normalizedTitle = normalizeWhitespace(title || siteTitle);
const fullTitle = normalizedTitle.toLowerCase().includes(siteTitle.toLowerCase())
  ? normalizedTitle
  : `${normalizedTitle} | ${siteTitle}`;
const siteUrl = resolveBaseUrl(MUSIC_SITE_URL);
const canonicalPath = canonical
  ? new URL(canonical, `${siteUrl}/`).pathname
  : Astro.url.pathname;
const currentUrl = resolveAbsoluteUrl(siteUrl, ensureTrailingSlash(canonicalPath));
const imageUrl = resolveAbsoluteUrl(siteUrl, image);
const shellConfig = musicAppShellConfig;
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;
const normalizedDescription = normalizeWhitespace(description || "");
const defaultKeywords = ["music", "album", "ai music", "melodymind"];
const publishDate = publishedTime ? new Date(publishedTime) : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime) : undefined;

const computedSeo = buildPageSeo({
  title: fullTitle,
  description: normalizedDescription,
  url: currentUrl,
  image: imageUrl,
  imageAlt:
    type === "article" || type === "musicAlbum"
      ? `Cover artwork for ${normalizedTitle}`
      : `Cover artwork for ${siteTitle}`,
  type,
  structuredData: structuredData as StructuredData[],
  fallbackKeywords: [...defaultKeywords, ...keywords],
  descriptionSource: "base",
  breadcrumbs,
  index,
  follow,
  maxImagePreview: "large",
  maxSnippet: -1,
  maxVideoPreview: -1,
  ogLocale: locale.replace("-", "_"),
  twitterCreator: "@melodymind",
  brandSuffix: false,
  autoSocialImage: true,
  generateSocialImage: ({ title: genTitle }) => {
    void genTitle;
    return undefined;
  },
  ...(publishDate ? { publishDate } : {}),
  ...(modifiedDate ? { modifiedDate } : {}),
});

const pageSeoResolved = pageSeo ?? computedSeo;
const resolvedImageWidth =
  imageWidth ?? (image === musicDefaultOgImageUrl ? defaultOgImageWidth : undefined);
const resolvedImageHeight =
  imageHeight ?? (image === musicDefaultOgImageUrl ? defaultOgImageHeight : undefined);
const resolvedImageType = imageType ?? "image/webp";

const seoProps = {
  title: pageSeoResolved.title || fullTitle,
  description: pageSeoResolved.description || normalizedDescription,
  keywords: pageSeoResolved.keywordArray || [],
  canonical: pageSeoResolved.canonical,
  robots: pageSeoResolved.robots,
  structuredDataExtra: pageSeoResolved.structuredData,
  ...(pageSeoResolved.image ? { image: pageSeoResolved.image } : {}),
  ...(pageSeoResolved.imageAlt ? { imageAlt: pageSeoResolved.imageAlt } : {}),
  ...(pageSeoResolved.publishDate ? { publishDate: pageSeoResolved.publishDate } : {}),
  ...(pageSeoResolved.modifiedDate ? { modifiedDate: pageSeoResolved.modifiedDate } : {}),
  ...(pageSeoResolved.authorName ? { authorName: pageSeoResolved.authorName } : {}),
};
const mainClasses = ["music-layout__main", mainClass].filter(Boolean).join(" ");
const contentShellClasses = ["music-layout__container", contentShellClass]
  .filter(Boolean)
  .join(" ");
const isAlbumLayout = mainClass.split(/\s+/).includes("music-layout__main--album");
const bodyClasses = ["music-layout", isAlbumLayout ? "music-layout--album" : ""]
  .filter(Boolean)
  .join(" ");
const homeNavItem: HeaderNavItem = {
  href: "/",
  label: "Home",
  icon: "home",
};
const albumsNavItem: HeaderNavItem = {
  href: "/#albums-list",
  label: "Albums",
  icon: "music",
};
const genresNavItem: HeaderNavItem = {
  href: "/#genre-heading",
  label: "Genres",
  icon: "sparkles",
};
const latestReleasesNavItem: HeaderNavItem = {
  href: "/#latest-releases",
  label: "Latest Releases",
  icon: "sparkles",
};
const searchNavItem: HeaderNavItem = {
  href: "/?search=1",
  label: "Search",
  icon: "search",
};
const headerNavItems: HeaderNavItem[] = [
  homeNavItem,
  albumsNavItem,
  genresNavItem,
  ...shellConfig.header.navItems.map((item) => ({
    href: item.href,
    label: item.label,
    icon: (item.icon || "music") as IconName,
    ...(item.target ? { target: item.target } : {}),
    ...(item.rel ? { rel: item.rel } : {}),
  })),
  searchNavItem,
  latestReleasesNavItem,
];
const availableAlbums = await getAvailableAlbums();
const getImageSource = (image: string | ImageMetadata): string =>
  typeof image === "string" ? image : image.src;
const searchItems = availableAlbums.flatMap((album) => {
  const image = getAlbumCoverImage(album.coverImage);
  const albumDurationSeconds = album.songs.reduce(
    (acc: number, song: Song) => acc + (song.durationSeconds || 0),
    0
  );
  const albumDuration = albumDurationSeconds ? formatDuration(albumDurationSeconds) : "";
  const imageUrl = getImageSource(image);
  const imageAlt = `Cover art for the album ${album.title}`;
  const albumItem = {
    url: `/${album.id}/`,
    title: album.title,
    type: "Album",
    description: album.metaDescription || album.description,
    imageUrl,
    imageAlt,
    displayMeta: [album.genre || "", `${album.songs.length} tracks`, albumDuration]
      .filter(Boolean)
      .join(" · "),
  };
  const trackItems = album.songs.map((song: Song) => {
    const duration = song.durationSeconds ? formatDuration(song.durationSeconds) : "";

    return {
      url: `/${album.id}/#album-playlist-${album.id}`,
      title: song.title,
      type: "Track",
      description:
        song.description ||
        (song.isInstrumental ? "Instrumental track." : "") ||
        album.description,
      imageUrl,
      imageAlt,
      displayMeta: [`Track ${song.trackNumber}`, album.title, album.genre, duration]
        .filter(Boolean)
        .join(" · "),
    };
  });

  return [albumItem, ...trackItems];
});
const mobileGenreLinks = Array.from(
  new Set(
    availableAlbums
      .map((album) => album.genre)
      .filter((genre): genre is string => Boolean(genre))
  )
)
  .sort((a, b) => a.localeCompare(b, "en", { sensitivity: "base" }))
  .slice(0, 4)
  .map((genre) => ({
    href: `/?genre=${encodeURIComponent(genre)}#albums-list`,
    label: genre,
  }));
---

<MasterLayout
  lang={language}
  bodyClass={bodyClasses}
  mainClass={mainClasses}
  contentShellClass={contentShellClasses}
  showSkipLink={false}
  enableThemeInit={true}
  appTitle="MM Music"
  manifestPath="/site.webmanifest?v=20260507"
  faviconVersion="20260507"
  faviconSvgPath="/favicon.svg"
  googleSiteVerification="ImN0-TS4_aAOFIXaGxvsGSmqsgHxI94WARi8bW7fm9M"
  showBackToTop={false}
>
  <Fragment slot="head">
    <AppHeadResources />
    <SEO
      {...seoProps}
      {...resolvedImageWidth ? { imageWidth: resolvedImageWidth } : {}}
      {...resolvedImageHeight ? { imageHeight: resolvedImageHeight } : {}}
      {...resolvedImageType ? { imageType: resolvedImageType } : {}}
      {...ogMusic ? { ogMusic } : {}}
      {...pageSeoResolved.openGraph && {
        openGraph: {
          ...pageSeoResolved.openGraph,
          locale: pageSeoResolved.openGraph.locale || locale.replace("-", "_"),
        },
      }}
      ogSiteName={siteTitle}
      {...pageSeoResolved.twitter && { twitter: pageSeoResolved.twitter }}
      {...pageSeoResolved.canonical && { twitterUrl: pageSeoResolved.canonical }}
      twitterSite="@melodymind"
    />
    <meta name="language" content={language} />
    <!-- Fathom - beautiful, simple website analytics -->
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="CHTCRKPK" defer
    ></script>
    <!-- / Fathom -->
  </Fragment>

  <SkipLink slot="body-start" />
  <SiteHeader
    slot="before-main"
    brandLogoSrc={melodyMindLogo}
    brandLogoAlt="Melody Mind"
    brandAriaLabel="Go to MelodyMind Music"
    navAriaLabel="Music navigation"
    navItems={headerNavItems}
    searchHref={searchNavItem.href}
    {currentPath}
    mobileExtraLinks={mobileGenreLinks}
    mobileExtraHeading="Explore genres"
    mobilePrimaryCtaHref="/#albums-list"
    mobilePrimaryCtaLabel="Browse Albums"
    mobileSecondaryCtaHref="/?search=1"
    mobileSecondaryCtaLabel="Search Music"
  />

  <Footer
    slot="after-main"
    brandLogoSrc={melodyMindLogo}
    brandLogoAlt="Melody Mind"
    brandAriaLabel="Go to MelodyMind Music"
    footerConfig={{
      ...shellConfig.footer,
      showSettings: true,
      copyrightText: buildDefaultCopyrightText(new Date().getFullYear()),
    }}
  />

  <AutoInitScript slot="body-end" />
  <SearchPalette
    slot="body-end"
    configId="music-search-palette-config"
    inputLabel="Search albums and tracks"
    placeholder="Search albums and tracks"
    emptyTitle="Start with a record, genre, or mood."
    emptyTitleWithQuery="No match on the shelf."
    emptyText="Try one of these searches to browse the catalog."
    emptyTextWithQuery="Try a shorter title, a genre, or one of these listening cues."
    suggestions={["Neon Hearts", "Gothic Metal", "instrumental", "dawn"]}
    groupLabels={{
      album: "Albums",
      albums: "Albums",
      track: "Tracks",
      tracks: "Tracks",
      genre: "Genres",
      genres: "Genres",
    }}
    items={searchItems}
    routeHrefs={["/"]}
  />
  <BackToTop slot="body-end" />
  <FathomEventsScript slot="body-end" />
  <script slot="body-end" is:inline>
    (() => {
      if (!("serviceWorker" in navigator)) {
        return;
      }

      window.addEventListener(
        "load",
        () => {
          navigator.serviceWorker
            .register("/service-worker.js")
            .then((registration) => {
              document.addEventListener("visibilitychange", () => {
                if (document.visibilityState === "visible") {
                  registration.update();
                }
              });
            })
            .catch(() => {
              /* Service worker support is progressive; playback must keep working without it. */
            });
        },
        { once: true }
      );
    })();
  </script>

  <slot />
</MasterLayout>

<style>
  :global(.music-layout) {
    --music-accent-primary: oklch(40% 0.13 16deg);
    --music-accent-strong: oklch(38% 0.125 16deg);

    background: var(--bg-primary);
  }

  :global([data-theme="dark"] .music-layout) {
    --music-accent-primary: oklch(78% 0.16 286deg);
    --music-accent-strong: oklch(80% 0.13 252deg);

    background: var(--bg-primary);
  }

  :global(.music-layout.music-layout--album) {
    background: var(--bg-primary);
  }

  :global([data-theme="dark"] .music-layout.music-layout--album) {
    background: var(--bg-primary);
  }

  :global(.music-layout__main) {
    position: relative;
    isolation: isolate;
  }

  :global(.music-layout__container) {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0;
    max-inline-size: var(--max-width);
    padding-block: clamp(var(--spacing-sm), 2vw, var(--spacing-xl));
    padding-inline: var(--spacing-sm);
    padding-bottom: 0;
    margin: 0 auto;
  }

  :global(.music-layout__container.music-layout__container--album),
  :global(.music-layout__container.music-layout__container--home) {
    inline-size: 100%;
    max-inline-size: none;
    padding: 0;
    margin: 0;
    overflow-x: clip;
  }

  @media (width >= 480px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-base);
    }
  }

  @media (width >= 768px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-xl);
    }
  }

  @media (width >= 1024px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-2xl);
    }
  }

  @media (width >= 1280px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-3xl);
    }
  }
</style>
