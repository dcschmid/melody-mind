---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import AppHeadResources from "@shared-ui/components/meta/AppHeadResources.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import SkipLink from "@shared-ui/components/navigation/SkipLink.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { buildDefaultCopyrightText, MUSIC_SITE_URL } from "@shared-utils/utils/appShell";
import {
  ensureTrailingSlash,
  resolveAbsoluteUrl,
  resolveBaseUrl,
} from "@shared-utils/utils/siteUrls";
import { normalizeWhitespace } from "@shared-utils/utils/format";
import { musicAppShellConfig } from "../utils/appShellConfig";
import { musicHeroImageUrl } from "../utils/musicImages";
import SearchPalette from "../components/search/Palette.astro";
import BackToTop from "../components/layout/BackToTop.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";

import type { PageSeoResult } from "@shared-utils/utils/seo/buildPageSeo";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
  canonical?: string;
  language?: string;
  locale?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  structuredData?: Array<Record<string, unknown>>;
  index?: boolean;
  follow?: boolean;
  pageSeo?: PageSeoResult;
  mainClass?: string;
  contentShellClass?: string;
}

const {
  title,
  description,
  image = musicHeroImageUrl,
  type = "website",
  publishedTime,
  modifiedTime,
  keywords = [],
  canonical,
  language = "en",
  locale = "en-US",
  breadcrumbs = [],
  structuredData = [],
  index = true,
  follow = true,
  pageSeo,
  mainClass = "",
  contentShellClass = "",
} = Astro.props as Props;

const siteTitle = "MelodyMind Music";
const normalizedTitle = normalizeWhitespace(title || siteTitle);
const fullTitle = normalizedTitle.toLowerCase().includes(siteTitle.toLowerCase())
  ? normalizedTitle
  : `${normalizedTitle} | ${siteTitle}`;
const siteUrl = resolveBaseUrl(MUSIC_SITE_URL);
const canonicalPath = canonical
  ? new URL(canonical, `${siteUrl}/`).pathname
  : Astro.url.pathname;
const currentUrl = resolveAbsoluteUrl(siteUrl, ensureTrailingSlash(canonicalPath));
const imageUrl = resolveAbsoluteUrl(siteUrl, image);
const shellConfig = musicAppShellConfig;
const normalizedDescription = normalizeWhitespace(description || "");
const defaultKeywords = ["music", "album", "ai music", "melodymind"];
const publishDate = publishedTime ? new Date(publishedTime) : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime) : undefined;

const computedSeo = buildPageSeo({
  title: fullTitle,
  description: normalizedDescription,
  url: currentUrl,
  image: imageUrl,
  imageAlt:
    type === "article"
      ? `Cover artwork for ${normalizedTitle}`
      : `Cover artwork for ${siteTitle}`,
  type: type === "article" ? "article" : "website",
  structuredData: structuredData as StructuredData[],
  fallbackKeywords: [...defaultKeywords, ...keywords],
  breadcrumbs,
  index,
  follow,
  maxImagePreview: "large",
  maxSnippet: -1,
  maxVideoPreview: -1,
  ogLocale: locale.replace("-", "_"),
  twitterCreator: "@melodymind",
  brandSuffix: false,
  autoSocialImage: true,
  generateSocialImage: ({ title: genTitle }) => {
    void genTitle;
    return undefined;
  },
  ...(publishDate ? { publishDate } : {}),
  ...(modifiedDate ? { modifiedDate } : {}),
});

const pageSeoResolved = pageSeo ?? computedSeo;

const seoProps = {
  title: pageSeoResolved.title || fullTitle,
  description: pageSeoResolved.description || normalizedDescription,
  keywords: pageSeoResolved.keywordArray || [],
  canonical: pageSeoResolved.canonical,
  robots: pageSeoResolved.robots,
  structuredDataExtra: pageSeoResolved.structuredData,
  ...(pageSeoResolved.image ? { image: pageSeoResolved.image } : {}),
  ...(pageSeoResolved.imageAlt ? { imageAlt: pageSeoResolved.imageAlt } : {}),
  ...(pageSeoResolved.publishDate ? { publishDate: pageSeoResolved.publishDate } : {}),
  ...(pageSeoResolved.modifiedDate ? { modifiedDate: pageSeoResolved.modifiedDate } : {}),
  ...(pageSeoResolved.authorName ? { authorName: pageSeoResolved.authorName } : {}),
};
const mainClasses = ["music-layout__main", mainClass].filter(Boolean).join(" ");
const contentShellClasses = ["music-layout__container", contentShellClass]
  .filter(Boolean)
  .join(" ");
---

<MasterLayout
  lang={language}
  bodyClass="music-layout"
  mainClass={mainClasses}
  contentShellClass={contentShellClasses}
  showSkipLink={false}
  enableThemeInit={true}
  appTitle="Melody Mind Music"
  showBackToTop={false}
>
  <Fragment slot="head">
    <AppHeadResources />
    <SEO
      {...seoProps}
      {...pageSeoResolved.openGraph && {
        openGraph: {
          ...pageSeoResolved.openGraph,
          locale: pageSeoResolved.openGraph.locale || locale.replace("-", "_"),
        },
      }}
      ogSiteName={siteTitle}
      {...pageSeoResolved.twitter && { twitter: pageSeoResolved.twitter }}
      {...pageSeoResolved.canonical && { twitterUrl: pageSeoResolved.canonical }}
      twitterSite="@melodymind"
    />
    <meta name="language" content={language} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  </Fragment>

  <SkipLink slot="body-start" />
  <Header slot="before-main" />

  <Footer
    slot="after-main"
    footerConfig={{
      ...shellConfig.footer,
      showSettings: true,
      copyrightText: buildDefaultCopyrightText(new Date().getFullYear()),
    }}
  />

  <AutoInitScript slot="body-end" />
  <SearchPalette slot="body-end" />
  <BackToTop slot="body-end" />

  <slot />
</MasterLayout>

<style>
  :global(.music-layout) {
    --music-accent-primary: oklch(46% 0.128 16deg);
    --music-accent-strong: oklch(38% 0.125 16deg);

    background:
      radial-gradient(circle at 92% 8%, oklch(90% 0.052 61deg / 0.34), transparent 36rem),
      linear-gradient(180deg, oklch(98% 0.016 75deg), oklch(94% 0.031 72deg));
  }

  :global([data-theme="dark"] .music-layout) {
    --music-accent-primary: oklch(74% 0.18 286deg);
    --music-accent-strong: oklch(75% 0.16 252deg);

    background:
      radial-gradient(
        ellipse at 78% 20%,
        oklch(44% 0.179 303deg / 0.38),
        transparent 48rem
      ),
      radial-gradient(
        circle at 24% 12%,
        oklch(36% 0.143 252deg / 0.28),
        transparent 26rem
      ),
      linear-gradient(180deg, oklch(13% 0.038 255deg), oklch(9% 0.028 252deg));
  }

  :global(.music-layout__main) {
    position: relative;
    isolation: isolate;
  }

  :global(.music-layout__main)::before {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    content: "";
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 14%, transparent),
      transparent 22rem
    );
  }

  :global(.music-layout__main--album)::before {
    display: none;
  }

  :global([data-theme="dark"] .music-layout__main)::before {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 18%, transparent),
      transparent 22rem
    );
  }

  :global(.music-layout__container) {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0;
    max-inline-size: var(--max-width);
    padding-block: clamp(var(--spacing-sm), 2vw, var(--spacing-xl));
    padding-inline: var(--spacing-sm);
    padding-bottom: 0;
    margin: 0 auto;
  }

  :global(.music-layout__container.music-layout__container--album),
  :global(.music-layout__container.music-layout__container--home) {
    inline-size: 100%;
    max-inline-size: none;
    padding: 0;
    margin: 0;
    overflow-x: clip;
  }

  @media (width >= 480px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-base);
    }
  }

  @media (width >= 768px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-xl);
    }
  }

  @media (width >= 1024px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-2xl);
    }
  }

  @media (width >= 1280px) {
    :global(
      .music-layout__container:not(
        .music-layout__container--album,
        .music-layout__container--home
      )
    ) {
      padding-inline: var(--spacing-3xl);
    }
  }
</style>
