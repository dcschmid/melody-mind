---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import AppHeadResources from "@shared-ui/components/meta/AppHeadResources.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import SiteHeader from "@shared-ui/components/navigation/SiteHeader.astro";
import SkipLink from "@shared-ui/components/navigation/SkipLink.astro";
import SharedFooter from "@shared-ui/components/layout/Footer.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { buildDefaultCopyrightText, MUSIC_SITE_URL } from "@shared-utils/utils/appShell";
import {
  ensureTrailingSlash,
  resolveAbsoluteUrl,
  resolveBaseUrl,
} from "@shared-utils/utils/siteUrls";
import { normalizeWhitespace } from "@shared-utils/utils/format";
import { musicAppShellConfig } from "../utils/appShellConfig";
import { musicHeroImageUrl } from "../utils/musicImages";
import MusicSearchPalette from "../components/MusicSearchPalette.astro";
import melodyMindLogo from "../assets/melody-mind-logo.webp";

import type { PageSeoResult } from "@shared-utils/utils/seo/buildPageSeo";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  keywords?: string[];
  canonical?: string;
  language?: string;
  locale?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  structuredData?: Array<Record<string, unknown>>;
  index?: boolean;
  follow?: boolean;
  pageSeo?: PageSeoResult;
}

const {
  title,
  description,
  image = musicHeroImageUrl,
  type = "website",
  publishedTime,
  modifiedTime,
  keywords = [],
  canonical,
  language = "en",
  locale = "en-US",
  breadcrumbs = [],
  structuredData = [],
  index = true,
  follow = true,
  pageSeo,
} = Astro.props as Props;

const siteTitle = "MelodyMind Music";
const normalizedTitle = normalizeWhitespace(title || siteTitle);
const fullTitle = normalizedTitle.toLowerCase().includes(siteTitle.toLowerCase())
  ? normalizedTitle
  : `${normalizedTitle} | ${siteTitle}`;
const siteUrl = resolveBaseUrl(MUSIC_SITE_URL);
const canonicalPath = canonical
  ? new URL(canonical, `${siteUrl}/`).pathname
  : Astro.url.pathname;
const currentUrl = resolveAbsoluteUrl(siteUrl, ensureTrailingSlash(canonicalPath));
const imageUrl = resolveAbsoluteUrl(siteUrl, image);
const shellConfig = musicAppShellConfig;
const normalizedDescription = normalizeWhitespace(description || "");
const defaultKeywords = ["music", "album", "ai music", "melodymind"];
const publishDate = publishedTime ? new Date(publishedTime) : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime) : undefined;

const computedSeo = buildPageSeo({
  title: fullTitle,
  description: normalizedDescription,
  url: currentUrl,
  image: imageUrl,
  imageAlt:
    type === "article"
      ? `Cover artwork for ${normalizedTitle}`
      : `Cover artwork for ${siteTitle}`,
  type: type === "article" ? "article" : "website",
  structuredData: structuredData as StructuredData[],
  fallbackKeywords: [...defaultKeywords, ...keywords],
  breadcrumbs,
  index,
  follow,
  maxImagePreview: "large",
  maxSnippet: -1,
  maxVideoPreview: -1,
  ogLocale: locale.replace("-", "_"),
  twitterCreator: "@melodymind",
  brandSuffix: false,
  autoSocialImage: true,
  generateSocialImage: ({ title: genTitle }) => {
    void genTitle;
    return undefined;
  },
  ...(publishDate ? { publishDate } : {}),
  ...(modifiedDate ? { modifiedDate } : {}),
});

const pageSeoResolved = pageSeo ?? computedSeo;

const seoProps = {
  title: pageSeoResolved.title || fullTitle,
  description: pageSeoResolved.description || normalizedDescription,
  keywords: pageSeoResolved.keywordArray || [],
  canonical: pageSeoResolved.canonical,
  robots: pageSeoResolved.robots,
  structuredDataExtra: pageSeoResolved.structuredData,
  ...(pageSeoResolved.image ? { image: pageSeoResolved.image } : {}),
  ...(pageSeoResolved.imageAlt ? { imageAlt: pageSeoResolved.imageAlt } : {}),
  ...(pageSeoResolved.publishDate ? { publishDate: pageSeoResolved.publishDate } : {}),
  ...(pageSeoResolved.modifiedDate ? { modifiedDate: pageSeoResolved.modifiedDate } : {}),
  ...(pageSeoResolved.authorName ? { authorName: pageSeoResolved.authorName } : {}),
};
const searchNavItem = {
  href: "/?search=1",
  label: "Search",
  icon: "search",
};
---

<MasterLayout
  lang={language}
  bodyClass="music-layout"
  mainClass="music-layout__main"
  contentShellClass="music-layout__container"
  showSkipLink={false}
  enableThemeInit={true}
  appTitle="Melody Mind Music"
>
  <Fragment slot="head">
    <AppHeadResources />
    <SEO
      {...seoProps}
      {...pageSeoResolved.openGraph && {
        openGraph: {
          ...pageSeoResolved.openGraph,
          locale: pageSeoResolved.openGraph.locale || locale.replace("-", "_"),
        },
      }}
      ogSiteName={siteTitle}
      {...pageSeoResolved.twitter && { twitter: pageSeoResolved.twitter }}
      {...pageSeoResolved.canonical && { twitterUrl: pageSeoResolved.canonical }}
      twitterSite="@melodymind"
    />
    <meta name="language" content={language} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  </Fragment>

  <SkipLink slot="body-start" />
  <SiteHeader
    slot="before-main"
    headerConfig={{
      ...shellConfig.header,
      navItems: [searchNavItem, ...shellConfig.header.navItems],
      showBrand: true,
      brandText: "",
      brandLogoSrc: melodyMindLogo,
      brandLogoAlt: "Melody Mind",
      brandLogoWidth: 700,
      brandLogoHeight: 232,
    }}
  />

  <SharedFooter
    slot="after-main"
    footerConfig={{
      ...shellConfig.footer,
      showSettings: true,
      copyrightText: buildDefaultCopyrightText(new Date().getFullYear()),
    }}
  />

  <AutoInitScript slot="body-end" />
  <MusicSearchPalette slot="body-end" />

  <slot />
</MasterLayout>

<style>
  :global(.music-layout) {
    background: var(--page-background);
  }

  :global(.music-layout__main) {
    position: relative;
    isolation: isolate;
  }

  :global(.music-layout__main)::before {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    content: "";
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 14%, transparent),
      transparent 22rem
    );
  }

  :global([data-theme="dark"] .music-layout__main)::before {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 18%, transparent),
      transparent 22rem
    );
  }

  :global(.music-layout__container) {
    position: relative;
    z-index: 1;
    display: grid;
    gap: clamp(var(--spacing-base), 3vw, var(--spacing-2xl));
    max-inline-size: var(--max-width);
    padding-block: clamp(var(--spacing-sm), 2vw, var(--spacing-xl));
    padding-inline: var(--spacing-sm);
    padding-bottom: max(var(--spacing-sm), env(safe-area-inset-bottom));
    margin: 0 auto;
  }

  :global(.music-layout .site-header__brand) {
    padding-inline: clamp(var(--spacing-sm), 1vw, var(--spacing-base));
  }

  :global(.music-layout .site-header__brand--logo-only .site-header__brand-logo-wrap) {
    inline-size: clamp(
      calc(var(--control-min-block-size) * 3.65),
      14vw,
      calc(var(--control-min-block-size) * 5.45)
    );
    block-size: auto;
    aspect-ratio: 700 / 232;
    overflow: visible;
  }

  :global(.music-layout .site-header__brand-logo) {
    display: block;
    inline-size: 100%;
    block-size: auto;
    object-fit: contain;
    object-position: left center;
  }

  :global(.astro-search-backdrop) {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 1000);
    display: grid;
    place-items: start center;
    padding: clamp(var(--spacing-base), 10vh, var(--spacing-3xl)) var(--spacing-base);
    background: var(--surface-scrim);
    backdrop-filter: blur(0.75rem);
  }

  :global(.astro-search-modal) {
    display: grid;
    gap: var(--spacing-sm);
    inline-size: min(100%, 42rem);
    max-block-size: min(42rem, calc(100dvh - var(--spacing-3xl)));
    overflow: hidden;
    color: var(--text-primary);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-lg);
  }

  :global(.astro-search-input-wrap) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--spacing-xs);
    align-items: center;
    padding: var(--spacing-sm);
    border-bottom: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-icon) {
    inline-size: var(--icon-size-md);
    block-size: var(--icon-size-md);
    color: var(--text-tertiary);
  }

  :global(.astro-search-input) {
    min-inline-size: 0;
    padding: var(--spacing-xs) 0;
    font: inherit;
    color: inherit;
    outline: 0;
    background: transparent;
    border: 0;
  }

  :global(.astro-search-input::placeholder) {
    color: var(--text-tertiary);
  }

  :global(.astro-search-shortcut),
  :global(.astro-search-key kbd) {
    min-inline-size: 1.65rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--text-tertiary);
    text-align: center;
    background: var(--surface-2);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-results) {
    display: grid;
    gap: var(--spacing-2xs);
    min-block-size: 8rem;
    max-block-size: min(28rem, 52dvh);
    padding: 0 var(--spacing-xs);
    margin: 0;
    overflow-y: auto;
    list-style: none;
  }

  :global(.astro-search-results > li) {
    display: grid;
    gap: var(--spacing-2xs);
  }

  :global(.astro-search-empty) {
    padding: var(--spacing-xl) var(--spacing-base);
    color: var(--text-tertiary);
    text-align: center;
  }

  :global(.astro-search-group-label) {
    padding: var(--spacing-sm) var(--spacing-xs) var(--spacing-2xs);
    font-size: 0.75rem;
    font-weight: var(--font-weight-semibold);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0;
  }

  :global(.astro-search-result) {
    display: grid;
    gap: var(--spacing-2xs);
    inline-size: 100%;
    padding: var(--spacing-sm);
    color: inherit;
    text-align: start;
    cursor: pointer;
    background: transparent;
    border: 0;
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-result[data-selected="true"]),
  :global(.astro-search-result:hover),
  :global(.astro-search-result:focus) {
    background: color-mix(in srgb, var(--accent-primary) 12%, transparent);
  }

  :global(.astro-search-result-title) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2xs);
    align-items: baseline;
    font-weight: var(--font-weight-semibold);
  }

  :global(.astro-search-result-type) {
    font-size: 0.78rem;
    color: var(--accent-primary);
    text-transform: uppercase;
  }

  :global(.astro-search-result-desc) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-tertiary);
    -webkit-box-orient: vertical;
  }

  :global(.astro-search-footer) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: flex-end;
    padding: var(--spacing-sm);
    font-size: 0.78rem;
    color: var(--text-tertiary);
    border-top: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-key) {
    display: inline-flex;
    gap: var(--spacing-2xs);
    align-items: center;
  }

  @media (width >= 480px) {
    :global(.music-layout__container) {
      padding-inline: var(--spacing-base);
    }
  }

  @media (width >= 768px) {
    :global(.music-layout__container) {
      padding-inline: var(--spacing-xl);
    }
  }

  @media (width >= 1024px) {
    :global(.music-layout__container) {
      padding-inline: var(--spacing-2xl);
    }
  }

  @media (width >= 1280px) {
    :global(.music-layout__container) {
      padding-inline: var(--spacing-3xl);
    }
  }
</style>
