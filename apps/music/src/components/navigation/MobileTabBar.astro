---
import Icon from "@components/visual/Icon.astro";

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props as Props;
const isHome = currentPath === "/";
const isDiscover =
  currentPath.startsWith("/genre/") || currentPath.startsWith("/series/");
---

<nav class="mobile-tab-bar" aria-label="Primary mobile navigation">
  <a class="mobile-tab-bar__link" href="/" aria-current={isHome ? "page" : undefined}>
    <Icon name="home" class="mobile-tab-bar__icon" aria-hidden="true" />
    <span>Home</span>
  </a>
  <a
    class="mobile-tab-bar__link"
    href="/#discover"
    aria-current={isDiscover ? "page" : undefined}
  >
    <Icon name="compass" class="mobile-tab-bar__icon" aria-hidden="true" />
    <span>Discover</span>
  </a>
  <a class="mobile-tab-bar__link" href="/?search=1" data-enhanced-search-trigger="true">
    <Icon name="search" class="mobile-tab-bar__icon" aria-hidden="true" />
    <span>Search</span>
  </a>
</nav>

<style>
  .mobile-tab-bar {
    display: none;
  }

  @media (width <= 760px) {
    .mobile-tab-bar {
      position: fixed;
      inset-block-end: 0;
      inset-inline: 0;
      z-index: 82;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      min-block-size: calc(4rem + env(safe-area-inset-bottom));
      padding: 0.25rem 0.5rem env(safe-area-inset-bottom);
      color: var(--text-secondary);
      background: var(--surface-1);
      border-block-start: 1px solid var(--border-default);
      box-shadow: 0 -0.5rem 1.5rem oklch(0% 0 0deg / 0.22);
    }

    .mobile-tab-bar__link {
      position: relative;
      display: grid;
      gap: 0.2rem;
      place-items: center;
      min-block-size: 3.5rem;
      padding: 0.25rem;
      font-size: 0.78rem;
      font-weight: var(--font-weight-bold);
      line-height: 1;
      color: inherit;
      text-decoration: none;
      border-radius: var(--radius-base);
    }

    .mobile-tab-bar__link[aria-current="page"] {
      color: var(--accent-primary);
      background: color-mix(in srgb, var(--accent-primary) 10%, transparent);
    }

    .mobile-tab-bar__link[aria-current="page"]::after {
      position: absolute;
      inset-block-start: 0.1rem;
      inline-size: 1.6rem;
      block-size: 0.16rem;
      content: "";
      background: currentcolor;
      border-radius: var(--radius-full);
    }

    .mobile-tab-bar__icon {
      inline-size: 1.2rem;
      block-size: 1.2rem;
    }

    :global(body) {
      padding-block-end: calc(4rem + env(safe-area-inset-bottom));
    }
  }

  @media (forced-colors: active) {
    .mobile-tab-bar {
      background: Canvas;
      border-color: CanvasText;
    }
  }
</style>
