---
import AutoGrid from "@components/layout/AutoGrid.astro";
import Stack from "@components/layout/Stack.astro";
import Headline from "@components/typography/Headline.astro";
import Paragraph from "@components/typography/Paragraph.astro";
import ContentCard from "@components/cards/ContentCard.astro";
import type { RelatedContentCardItem } from "./relatedContent";

interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  copy?: string;
  listAriaLabel?: string;
  items: RelatedContentCardItem[];
  mediaObjectFit?: "cover" | "contain";
}

const {
  id = "related-content-section",
  eyebrow = "Related",
  title,
  copy,
  listAriaLabel = title,
  items = [],
  mediaObjectFit = "contain",
} = Astro.props as Props;

const titleId = `${id}-title`;
const defaultCoverImage = "/default-cover.jpg";
const RELATED_COVER_IMAGE_SIZES =
  "(max-width: 640px) 7.5rem, (max-width: 760px) 44vw, (max-width: 1180px) 28vw, min(18rem, calc((100vw - 10rem) / 5))";
---

{
  items.length ? (
    <section class="related-content-section" id={id} aria-labelledby={titleId}>
      <Stack className="related-content-section__header" gap="base">
        <Stack className="related-content-section__copy-block" gap="xs">
          <p class="related-content-section__eyebrow">{eyebrow}</p>
          <Headline level="h2" textSize="2xl" className="related-content-section__title">
            <span id={titleId}>{title}</span>
          </Headline>
          {copy ? (
            <Paragraph textSize="base" className="related-content-section__copy">
              {copy}
            </Paragraph>
          ) : null}
        </Stack>
      </Stack>

      <AutoGrid
        as="ul"
        className="related-content-section__grid"
        preset="cards"
        gap="lg"
        ariaLabel={listAriaLabel}
      >
        {items.map((item) => (
          <li class="related-content-section__item">
            <ContentCard
              id={item.id}
              class="related-content-section__card"
              dataTestId="related-content-card"
              href={item.href}
              variant="default"
              size="compact"
              mediaAspectRatio="1 / 1"
              mediaObjectFit={mediaObjectFit}
              imageSrc={item.imageSrc || defaultCoverImage}
              imageAlt={
                item.imageAlt ?? (item.imageSrc ? `Cover image for ${item.title}` : "")
              }
              imageWidth={1024}
              imageHeight={1024}
              imageSizes={RELATED_COVER_IMAGE_SIZES}
              title={item.title}
              description={item.description}
              metaItems={item.metaItems || []}
              descriptionLineClamp={2}
              ctaSrText={item.ctaSrText || "Opens content"}
            />
          </li>
        ))}
      </AutoGrid>
    </section>
  ) : null
}

<style>
  .related-content-section {
    display: grid;
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    padding-block: clamp(var(--spacing-lg), 2.5vw, var(--spacing-2xl));
    padding-inline: 0;
    margin-block-start: var(--spacing-xl);
    border-block-start: 1px solid var(--surface-border-accent);
  }

  .related-content-section__copy-block {
    max-inline-size: var(--measure-copy-compact);
  }

  .related-content-section__eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .related-content-section__title {
    margin: 0;
    font-size: var(--font-size-xl);
    line-height: 1.08;
    color: var(--text-primary);
  }

  .related-content-section__copy {
    max-inline-size: var(--measure-copy-narrow);
    margin: 0;
    font-size: var(--font-size-xs);
    line-height: 1.55;
    color: var(--text-secondary);
  }

  .related-content-section__grid {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .related-content-section__item {
    display: grid;
    min-inline-size: 0;
  }

  @media (width >= 50rem) {
    .related-content-section__header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }
  }

  @media (width < 40rem) {
    .related-content-section {
      gap: var(--spacing-lg);
    }

    .related-content-section__header {
      gap: var(--spacing-md);
    }
  }
</style>

<style is:global>
  .related-content-section__card {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-panel-raised) 92%, var(--accent-primary) 8%),
        var(--surface-panel-raised) 54%
      ),
      var(--surface-panel-raised);
    border-color: color-mix(in srgb, var(--surface-border-accent) 64%, transparent);
    border-radius: var(--radius-md);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 58%, transparent),
      0 1.2rem 2.7rem color-mix(in srgb, var(--surface-shadow) 18%, transparent);
  }

  .related-content-section .related-content-section__grid.auto-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: clamp(1rem, 1.6vw, 1.4rem);
    align-items: stretch;
  }

  .related-content-section__card.content-card--interactive:hover,
  .related-content-section__card.content-card--interactive:focus-within {
    border-color: color-mix(
      in srgb,
      var(--accent-primary) 56%,
      var(--surface-border-accent)
    );
    transform: translateY(-3px);
  }

  .related-content-section__card .content-card__media {
    background: color-mix(
      in srgb,
      var(--surface-panel-raised) 82%,
      var(--text-primary) 18%
    );
    border-block-end-color: color-mix(
      in srgb,
      var(--surface-border-accent) 54%,
      transparent
    );
  }

  .related-content-section__card .content-card__media::after {
    position: absolute;
    inset: 0;
    display: block;
    pointer-events: none;
    content: "";
    background: linear-gradient(180deg, transparent 62%, rgb(0 0 0 / 28%));
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 8%);
  }

  .related-content-section__card .content-card__content {
    flex: 1;
    block-size: 100%;
  }

  .related-content-section__card .content-card__body {
    gap: var(--spacing-sm);
    padding: clamp(var(--spacing-base), 1.6vw, var(--spacing-lg));
  }

  .related-content-section__card .content-card__title {
    font-size: clamp(1rem, 1rem + 0.32vw, 1.16rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  .related-content-section__card .content-card__description {
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: color-mix(in srgb, var(--text-secondary) 90%, var(--text-primary) 10%);
  }

  .related-content-section__card .content-card__meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm) var(--spacing-base);
    padding-block-start: var(--spacing-sm);
    margin-block-start: auto;
    font-size: var(--font-size-xs);
  }

  .related-content-section__card .content-card__meta-item {
    gap: var(--spacing-xs);
    min-inline-size: 0;
    color: color-mix(in srgb, var(--text-secondary) 88%, var(--text-primary) 12%);
  }

  .related-content-section__card .content-card__meta-item:first-child {
    grid-column: 1 / -1;
    max-inline-size: 100%;
    color: color-mix(in srgb, var(--text-primary) 88%, var(--accent-primary) 12%);
  }

  .related-content-section__card .content-card__meta-item span {
    min-inline-size: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .related-content-section__card .content-card__meta-icon {
    inline-size: var(--icon-size-xs);
    block-size: var(--icon-size-xs);
  }

  @media (width <= 1180px) {
    .related-content-section .related-content-section__grid.auto-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (width <= 760px) {
    .related-content-section .related-content-section__grid.auto-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      min-inline-size: 0;
    }
  }

  @media (width < 40rem) {
    .related-content-section__card .content-card__content {
      display: grid;
      grid-template-columns: minmax(5.75rem, 7.5rem) minmax(0, 1fr);
      align-items: stretch;
    }

    .related-content-section__card .content-card__media {
      border-block-end: 0;
      border-inline-end: 1px solid
        color-mix(in srgb, var(--surface-border-accent) 48%, transparent);
    }

    .related-content-section__card .content-card__body {
      min-inline-size: 0;
      padding: var(--spacing-sm);
    }

    .related-content-section__card .content-card__description {
      display: none;
    }

    .related-content-section__card .content-card__meta {
      grid-template-columns: 1fr;
      gap: var(--spacing-xs);
      padding-block-start: var(--spacing-xs);
    }

    .related-content-section__card .content-card__meta-item:first-child {
      color: color-mix(in srgb, var(--text-primary) 88%, var(--accent-primary) 12%);
    }
  }

  @media (width <= 440px) {
    .related-content-section .related-content-section__grid.auto-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
