---
import { getCollection } from "astro:content";

import { getAlbumCoverImage } from "../../utils/musicImages";

import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import type { Song } from "../../types/album";

type AlbumEntry = CollectionEntry<"albums">;

const availableAlbums: AlbumEntry[] = await getCollection(
  "albums",
  (entry: AlbumEntry) => entry.data.isAvailable
);

const getImageSource = (image: string | ImageMetadata): string =>
  typeof image === "string" ? image : image.src;
const getImageWidth = (image: string | ImageMetadata): number | undefined =>
  typeof image === "string" ? undefined : image.width;
const getImageHeight = (image: string | ImageMetadata): number | undefined =>
  typeof image === "string" ? undefined : image.height;

const searchArtworkItems = availableAlbums.map((entry: AlbumEntry) => {
  const image = getAlbumCoverImage(entry.data.coverImage);

  return {
    albumUrl: `/${entry.id}/`,
    title: entry.data.title,
    description: entry.data.metaDescription || entry.data.description,
    genre: entry.data.genre || "",
    imageUrl: getImageSource(image),
    imageWidth: getImageWidth(image),
    imageHeight: getImageHeight(image),
    trackCount: entry.data.songs.length,
    totalDurationSeconds: entry.data.songs.reduce(
      (acc: number, song: Song) => acc + (song.durationSeconds || 0),
      0
    ),
    trackTitles: entry.data.songs.map((song: Song) => song.title),
    tracks: entry.data.songs.map((song: Song) => ({
      title: song.title,
      trackNumber: song.trackNumber,
      durationSeconds: song.durationSeconds || 0,
      description: song.description || "",
      isInstrumental: Boolean(song.isInstrumental),
    })),
  };
});
---

<astro-search-palette
  index-url="/search-index.json"
  shortcut="mod+k"
  placeholder="Search albums and tracks"
  result-limit="8"
  group-by="type"></astro-search-palette>
<script
  id="music-search-artwork-data"
  is:inline
  type="application/json"
  set:html={JSON.stringify(searchArtworkItems)}
/>

<script>
  import "../../scripts/searchPalette";
</script>

<style>
  :global(.astro-search-backdrop) {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 1000);
    display: grid;
    place-items: start center;
    padding: clamp(var(--spacing-base), 10vh, var(--spacing-3xl)) var(--spacing-base);
    background: var(--surface-scrim);
    backdrop-filter: blur(0.75rem);
  }

  @media (hover: none), (pointer: coarse) {
    :global(.astro-search-backdrop) {
      backdrop-filter: blur(0.35rem);
    }
  }

  :global(.astro-search-modal) {
    --search-palette-accent: var(--music-accent-primary, var(--accent-primary));
    --search-palette-accent-strong: var(
      --music-accent-strong,
      var(--accent-primary-hover)
    );

    display: grid;
    gap: var(--spacing-sm);
    inline-size: min(100%, 46rem);
    max-block-size: min(42rem, calc(100dvh - var(--spacing-3xl)));
    overflow: hidden;
    color: var(--text-primary);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-lg);
  }

  :global(.astro-search-input-wrap) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--spacing-xs);
    align-items: center;
    padding: var(--spacing-sm);
    border-bottom: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-icon) {
    inline-size: var(--icon-size-md);
    block-size: var(--icon-size-md);
    color: var(--text-tertiary);
  }

  :global(.astro-search-input) {
    min-inline-size: 0;
    padding: var(--spacing-xs) 0;
    font: inherit;
    color: inherit;
    background: transparent;
    border: 0;
  }

  :global(.astro-search-input:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-input::placeholder) {
    color: var(--text-tertiary);
  }

  :global(.astro-search-shortcut),
  :global(.astro-search-key kbd) {
    min-inline-size: 1.65rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--text-tertiary);
    text-align: center;
    background: var(--surface-2);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-results) {
    display: grid;
    gap: 0;
    min-block-size: 8rem;
    max-block-size: min(28rem, 52dvh);
    padding: 0 var(--spacing-xs);
    margin: 0;
    overflow-y: auto;
    list-style: none;
  }

  :global(.astro-search-results > li) {
    display: grid;
    gap: var(--spacing-2xs);
  }

  :global(.astro-search-empty) {
    display: grid;
    gap: var(--spacing-sm);
    justify-items: center;
    padding: var(--spacing-xl) var(--spacing-base);
    color: var(--text-tertiary);
    text-align: center;
  }

  :global(.astro-search-empty__title),
  :global(.astro-search-empty__text) {
    max-inline-size: 34rem;
    margin: 0;
  }

  :global(.astro-search-empty__title) {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text-primary);
  }

  :global(.astro-search-empty__text) {
    font-size: 0.88rem;
    line-height: 1.5;
  }

  :global(.astro-search-empty__suggestions) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    justify-content: center;
    margin-block-start: var(--spacing-xs);
  }

  :global(.astro-search-empty__suggestion) {
    min-block-size: 2rem;
    padding: 0 var(--spacing-sm);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    background: var(--surface-2);
    border: 1px solid var(--surface-border-soft);
    border-radius: 999px;
  }

  :global(.astro-search-empty__suggestion:hover),
  :global(.astro-search-empty__suggestion:focus-visible) {
    color: var(--search-palette-accent);
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  :global(.astro-search-group-label) {
    position: sticky;
    inset-block-start: 0;
    z-index: 1;
    padding: var(--spacing-sm) var(--spacing-xs) var(--spacing-xs);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--surface-panel-bg);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-result) {
    display: grid;
    grid-template-columns: 3.75rem minmax(0, 1fr);
    gap: var(--spacing-sm);
    align-items: center;
    inline-size: 100%;
    padding: calc(var(--spacing-sm) - var(--spacing-2xs)) var(--spacing-sm);
    color: inherit;
    text-align: start;
    cursor: pointer;
    background: transparent;
    border: 0;
    border-block-end: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-result:not(:has(.astro-search-result-artwork))) {
    grid-template-columns: minmax(0, 1fr);
  }

  :global(.astro-search-result-artwork) {
    inline-size: 3.75rem;
    block-size: 3.75rem;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--search-palette-accent) 16%, transparent),
      color-mix(in srgb, var(--surface-2) 92%, transparent)
    );
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
    box-shadow: 0 0.45rem 1rem oklch(18% 0.032 45deg / 0.12);
  }

  :global(.astro-search-result-artwork__image) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  :global(.astro-search-result-content) {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    :global(.astro-search-result:hover),
    :global(.astro-search-result:focus-visible) {
      background: color-mix(in srgb, var(--search-palette-accent) 12%, transparent);
    }
  }

  :global(.astro-search-result[data-selected="true"]),
  :global(.astro-search-result:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    background: color-mix(in srgb, var(--search-palette-accent) 14%, transparent);
  }

  :global(.astro-search-result-title) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
  }

  :global(.astro-search-result-type) {
    font-size: 0.78rem;
    color: var(--search-palette-accent);
    text-transform: uppercase;
  }

  :global(.astro-search-result-meta) {
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.78rem;
    line-height: 1.35;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  :global(.astro-search-result-desc) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 1;
    font-size: 0.86rem;
    line-height: 1.4;
    color: var(--text-tertiary);
    -webkit-box-orient: vertical;
  }

  :global(.astro-search-footer) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: flex-end;
    padding: var(--spacing-sm);
    font-size: 0.78rem;
    color: var(--text-tertiary);
    border-top: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-key) {
    display: inline-flex;
    gap: var(--spacing-2xs);
    align-items: center;
  }

  @media (width <= 520px) {
    :global(.astro-search-backdrop) {
      padding-inline: var(--spacing-sm);
    }

    :global(.astro-search-result) {
      grid-template-columns: 3.1rem minmax(0, 1fr);
      gap: var(--spacing-xs);
      padding-inline: var(--spacing-xs);
    }

    :global(.astro-search-result-artwork) {
      inline-size: 3.1rem;
      block-size: 3.1rem;
    }

    :global(.astro-search-result-desc) {
      display: none;
    }
  }
</style>
