---
interface SearchPaletteItem {
  url: string;
  title: string;
  type?: string;
  description?: string;
  imageUrl?: string;
  imageAlt?: string;
  displayMeta?: string;
}

interface Props {
  configId: string;
  emptyText: string;
  emptyTextWithQuery: string;
  emptyTitle: string;
  emptyTitleWithQuery: string;
  groupLabels?: Record<string, string>;
  indexUrl?: string;
  inputLabel: string;
  /**
   * Deprecated/optional. Result enrichment (thumbnail + meta) is now sourced at
   * runtime from the fetched search index, not inlined per page. Accepted for
   * backward compatibility but no longer serialized into the page.
   */
  items?: SearchPaletteItem[];
  mediaAspectRatio?: string;
  placeholder: string;
  resultLimit?: number;
  resultsLabel?: string;
  routeHrefs?: string[];
  suggestions?: string[];
}

const {
  configId,
  emptyText,
  emptyTextWithQuery,
  emptyTitle,
  emptyTitleWithQuery,
  groupLabels = {},
  indexUrl = "/search-index.json",
  inputLabel,
  mediaAspectRatio = "1 / 1",
  placeholder,
  resultLimit = 8,
  resultsLabel = "Search results",
  routeHrefs = ["/search"],
  suggestions = [],
} = Astro.props;

const config = {
  emptyText,
  emptyTextWithQuery,
  emptyTitle,
  emptyTitleWithQuery,
  groupLabels,
  inputLabel,
  resultsLabel,
  routeHrefs,
  suggestions,
};
---

<div
  class="search-palette-root"
  style={`--search-palette-media-aspect-ratio: ${mediaAspectRatio};`}
  data-enhanced-search="true"
  data-enhanced-search-config-id={configId}
  data-enhanced-search-results-id={`${configId}-results`}
  data-index-url={indexUrl}
  data-placeholder={placeholder}
  data-result-limit={String(resultLimit)}
>
</div>
<script
  id={configId}
  is:inline
  type="application/json"
  set:html={JSON.stringify(config)}
/>

<script>
  import "../../scripts/search/searchPaletteLoader";
</script>

<style>
  :global(.astro-search-backdrop) {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 1000);
    display: grid;
    place-items: start center;
    padding: clamp(var(--spacing-base), 10vh, var(--spacing-3xl)) var(--spacing-base);
    background: var(--surface-scrim);
    backdrop-filter: blur(0.75rem);
  }

  @media (hover: none), (pointer: coarse) {
    :global(.astro-search-backdrop) {
      backdrop-filter: blur(0.35rem);
    }
  }

  :global(.astro-search-modal) {
    --search-palette-accent: var(--music-accent-primary, var(--accent-primary));
    --search-palette-accent-strong: var(
      --music-accent-strong,
      var(--accent-primary-hover)
    );

    display: grid;
    gap: var(--spacing-sm);
    inline-size: min(100%, 46rem);
    max-block-size: min(42rem, calc(100dvh - var(--spacing-3xl)));
    overflow: hidden;
    color: var(--text-primary);
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-lg);
  }

  :global(.astro-search-input-wrap) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: var(--spacing-xs);
    align-items: center;
    padding: var(--spacing-sm);
    border-bottom: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-icon) {
    inline-size: var(--icon-size-md);
    block-size: var(--icon-size-md);
    color: var(--text-tertiary);
  }

  :global(.astro-search-input) {
    min-inline-size: 0;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) 0;
    font: inherit;
    color: inherit;
    background: transparent;
    border: 0;
  }

  :global(.astro-search-input:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-input::placeholder) {
    color: var(--text-tertiary);
  }

  :global(.astro-search-shortcut),
  :global(.astro-search-key kbd) {
    min-inline-size: 1.65rem;
    padding: 0.125rem 0.375rem;
    font-size: var(--font-size-xs);
    line-height: 1.4;
    color: var(--text-tertiary);
    text-align: center;
    background: var(--surface-2);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-results) {
    display: grid;
    gap: 0;
    min-block-size: 8rem;
    max-block-size: min(28rem, 52dvh);
    padding: 0 var(--spacing-xs);
    margin: 0;
    overflow-y: auto;
    list-style: none;
  }

  :global(.astro-search-filters) {
    display: flex;
    gap: var(--spacing-xs);
    padding: 0 var(--spacing-sm) var(--spacing-sm);
    overflow-x: auto;
    border-bottom: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-filter) {
    min-block-size: var(--control-min-block-size);
    padding: 0.45rem 0.8rem;
    font: inherit;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--text-secondary);
    cursor: pointer;
    background: var(--surface-2);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  :global(.astro-search-filter[aria-pressed="true"]) {
    color: var(--accent-contrast);
    background: var(--search-palette-accent);
    border-color: transparent;
  }

  :global(.astro-search-results > li) {
    display: grid;
    gap: var(--spacing-2xs);
  }

  :global(.astro-search-result-group__list) {
    display: grid;
    gap: var(--spacing-2xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  :global(.astro-search-empty) {
    display: grid;
    gap: var(--spacing-sm);
    justify-items: center;
    padding: var(--spacing-xl) var(--spacing-base);
    color: var(--text-tertiary);
    text-align: center;
  }

  :global(.astro-search-filter-empty) {
    display: grid;
    gap: var(--spacing-sm);
    justify-items: center;
    padding: var(--spacing-xl) var(--spacing-base);
    color: var(--text-tertiary);
    text-align: center;
  }

  :global(.astro-search-filter-empty__title),
  :global(.astro-search-filter-empty__text) {
    max-inline-size: 34rem;
    margin: 0;
  }

  :global(.astro-search-filter-empty__title) {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    line-height: 1.35;
    color: var(--text-primary);
  }

  :global(.astro-search-filter-empty__text) {
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }

  :global(.astro-search-result[hidden]),
  :global(.astro-search-results > li[hidden]) {
    display: none;
  }

  :global(.astro-search-empty__title),
  :global(.astro-search-empty__text) {
    max-inline-size: 34rem;
    margin: 0;
  }

  :global(.astro-search-empty__title) {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    line-height: 1.35;
    color: var(--text-primary);
  }

  :global(.astro-search-empty__text) {
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }

  :global(.astro-search-empty__suggestions) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    justify-content: center;
    margin-block-start: var(--spacing-xs);
  }

  :global(.astro-search-empty__suggestion) {
    min-block-size: var(--control-min-block-size);
    padding: 0 var(--spacing-sm);
    font: inherit;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--text-secondary);
    cursor: pointer;
    background: var(--surface-2);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-full);
  }

  :global(.astro-search-empty__suggestion:hover),
  :global(.astro-search-empty__suggestion:focus-visible) {
    color: var(--search-palette-accent);
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  :global(.astro-search-group-label) {
    position: sticky;
    inset-block-start: 0;
    z-index: 1;
    padding: var(--spacing-sm) var(--spacing-xs) var(--spacing-xs);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--surface-panel-bg);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-result) {
    display: grid;
    grid-template-columns: 3.75rem minmax(0, 1fr) auto;
    gap: var(--spacing-sm);
    align-items: center;
    inline-size: 100%;
    padding: calc(var(--spacing-sm) - var(--spacing-2xs)) var(--spacing-sm);
    color: inherit;
    text-align: start;
    cursor: pointer;
    background: transparent;
    border: 0;
    border-block-end: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
  }

  :global(.astro-search-result[hidden]) {
    display: none;
  }

  :global(.astro-search-result:not(:has(.astro-search-result-media))) {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  :global(.astro-search-result-media) {
    display: grid;
    place-items: center;
    inline-size: 3.75rem;
    aspect-ratio: var(--search-palette-media-aspect-ratio, 1 / 1);
    overflow: hidden;
    background: color-mix(in srgb, var(--search-palette-accent) 16%, var(--surface-2));
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-sm);
    box-shadow: 0 0.45rem 1rem oklch(0% 0 0deg / 0.25);
  }

  :global(.astro-search-result-media__image) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  :global(.astro-search-result-media__mark) {
    display: grid;
    place-items: center;
    inline-size: 100%;
    block-size: 100%;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: var(--search-palette-accent);
  }

  :global(.astro-search-result-content) {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    :global(.astro-search-result:hover),
    :global(.astro-search-result:focus-visible) {
      background: color-mix(in srgb, var(--search-palette-accent) 12%, transparent);
    }
  }

  :global(.astro-search-result[data-selected="true"]),
  :global(.astro-search-result:focus-visible) {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    background: color-mix(in srgb, var(--search-palette-accent) 14%, transparent);
  }

  :global(.astro-search-result-title) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    align-items: baseline;
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
  }

  :global(.astro-search-result-type) {
    font-size: var(--font-size-xs);
    color: var(--search-palette-accent);
    text-transform: uppercase;
  }

  :global(.astro-search-result-meta) {
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: var(--font-size-xs);
    line-height: 1.35;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  :global(.astro-search-result-desc) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 1;
    font-size: var(--font-size-xs);
    line-height: 1.4;
    color: var(--text-tertiary);
    -webkit-box-orient: vertical;
  }

  :global(.astro-search-result-action) {
    align-self: center;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    color: var(--search-palette-accent);
  }

  :global(.astro-search-footer) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: flex-end;
    padding: var(--spacing-sm);
    font-size: var(--font-size-xs);
    color: var(--text-tertiary);
    border-top: 1px solid var(--surface-border-soft);
  }

  :global(.astro-search-key) {
    display: inline-flex;
    gap: var(--spacing-2xs);
    align-items: center;
  }

  @media (width <= 520px) {
    :global(.astro-search-backdrop) {
      padding-inline: var(--spacing-sm);
    }

    :global(.astro-search-result) {
      grid-template-columns: 3.1rem minmax(0, 1fr) auto;
      gap: var(--spacing-xs);
      padding-inline: var(--spacing-xs);
    }

    :global(.astro-search-result-media) {
      inline-size: 3.1rem;
    }

    :global(.astro-search-result-desc) {
      display: none;
    }
  }
</style>
