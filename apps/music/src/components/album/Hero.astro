---
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { CoverImage } from "../home/types";

interface Fact {
  label: string;
  value: string | number;
}

interface Props {
  coverImage: CoverImage;
  coverImageHeight?: number;
  coverImageWidth?: number;
  description: string;
  facts: Fact[];
  id: string;
  title: string;
}

const { coverImage, coverImageHeight, coverImageWidth, description, facts, id, title } =
  Astro.props;

const genreFact = facts.find((fact) => fact.label === "Genre");
const visibleFacts = facts.filter((fact) => fact.label !== "Genre");
const titleId = `album-page-title-${id}`;
---

<section class="album-hero" id={`album-hero-${id}`} aria-labelledby={titleId}>
  <div class="album-hero__lockup">
    <figure class="album-hero__cover-lockup">
      <OptimizedImage
        src={coverImage}
        alt={`Cover art for the album ${title}`}
        class="album-hero__cover-image"
        width={coverImageWidth || 900}
        height={coverImageHeight || 900}
        loading="eager"
        decoding="async"
        sizes="(max-width: 420px) 7rem, (max-width: 760px) 8.6rem, (min-width: 1280px) 26.5rem, 46vw"
        fetchpriority="high"
      />
    </figure>

    <div class="album-hero__title-panel">
      {
        genreFact && (
          <p class="album-hero__eyebrow">
            <Icon name="disc" class="album-hero__eyebrow-icon" aria-hidden="true" />
            {genreFact.value}
          </p>
        )
      }
      <h1 class="album-hero__title" id={titleId}>{title}</h1>
    </div>

    <p class="album-hero__description">{description}</p>

    <ul class="album-hero__facts" aria-label="Album facts">
      {
        visibleFacts.map((fact) => (
          <li class="album-hero__fact">
            <span class="album-hero__fact-label">{fact.label}</span>
            <span class="album-hero__fact-value">{fact.value}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .album-hero {
    --album-hero-accent: var(--music-album-accent, var(--accent-primary));
    --album-hero-ink: var(--music-album-ink, var(--text-primary));
    --album-hero-muted: var(--music-album-muted, var(--text-secondary));
    --album-hero-line: var(--music-album-line, var(--surface-border-soft));
    --album-hero-cover-radius: var(--radius-md);
    --album-hero-cover-shadow: var(--shadow-xl);
    --album-hero-cover-shadow-mobile: var(--shadow-lg);
    --album-hero-fact-radius: var(--radius-base);

    position: relative;
    box-sizing: border-box;
    display: grid;
    inline-size: 100%;
    min-inline-size: 0;
    min-block-size: min(42rem, calc(100svh - 4.5rem));
    padding: max(clamp(1.5rem, 5vw, 3.8rem), 6rem) clamp(1.25rem, 5vw, 4.5rem)
      clamp(1.5rem, 5vw, 3.8rem);
    overflow: hidden;
    isolation: isolate;
  }

  .album-hero__lockup {
    display: grid;
    gap: clamp(var(--spacing-lg), 5vw, calc(var(--spacing-3xl) + var(--spacing-xs)));
    align-items: center;
    inline-size: 100%;
    min-inline-size: 0;
    max-inline-size: 86rem;
    margin-inline: auto;
  }

  .album-hero__cover-lockup {
    display: grid;
    justify-self: center;
    inline-size: min(100%, 26.5rem);
    min-inline-size: 0;
    margin: 0;
    overflow: hidden;
    background: var(--music-album-paper, var(--surface-panel-bg));
    border: 1px solid color-mix(in srgb, var(--album-hero-accent) 38%, transparent);
    border-radius: var(--album-hero-cover-radius);
    box-shadow: var(--album-hero-cover-shadow);
  }

  .album-hero__cover-lockup :global(.album-hero__cover-image) {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 1 / 1;
    outline: 1px solid rgb(0 0 0 / 10%);
    outline-offset: -1px;
    object-fit: cover;
  }

  .album-hero__title-panel {
    display: grid;
    gap: clamp(var(--spacing-md), 2vw, calc(var(--spacing-base) + var(--spacing-xs)));
    align-content: center;
    min-inline-size: 0;
  }

  .album-hero__eyebrow {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    inline-size: fit-content;
    margin: 0;
    font-size: clamp(0.7rem, 0.67rem + 0.15vw, 0.82rem);
    font-weight: 800;
    line-height: 1;
    color: var(--album-hero-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .album-hero__eyebrow-icon {
    flex: 0 0 auto;
  }

  .album-hero__title {
    max-inline-size: 13ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2.8rem, 2.2rem + 3vw, 5.35rem);
    font-weight: 500;
    line-height: 0.96;
    color: var(--album-hero-ink);
    letter-spacing: 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .album-hero__description {
    max-inline-size: 58ch;
    margin: 0;
    font-size: clamp(1rem, 0.96rem + 0.18vw, 1.13rem);
    line-height: 1.7;
    color: var(--album-hero-muted);
    text-wrap: pretty;
    overflow-wrap: anywhere;
  }

  .album-hero__facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, max-content));
    gap: 0 clamp(var(--spacing-lg), 4vw, var(--spacing-3xl));
    align-items: start;
    padding: 0;
    margin: 0;
    color: var(--album-hero-muted);
    list-style: none;
    border-block-start: 1px solid var(--album-hero-line);
  }

  .album-hero__fact {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
    padding-block-start: var(--spacing-sm);
  }

  .album-hero__fact-label {
    font-size: 0.76rem;
    font-weight: 800;
    line-height: 1.1;
    color: var(--album-hero-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .album-hero__fact-value {
    min-inline-size: 0;
    font-size: 0.92rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.25;
    color: var(--album-hero-ink);
    overflow-wrap: anywhere;
  }

  :global([data-theme="dark"])
    .album-hero__cover-lockup
    :global(.album-hero__cover-image) {
    outline-color: rgb(255 255 255 / 10%);
  }

  @media (width <= 760px) {
    .album-hero {
      inline-size: 100vw;
      max-inline-size: 100vw;
      min-block-size: auto;
      padding: 5.35rem 1rem 0.8rem;
    }

    .album-hero__lockup {
      grid-template-columns: minmax(6.75rem, 38vw) minmax(0, 1fr);
      gap: var(--spacing-sm);
      place-items: start;
      inline-size: calc(100vw - 2rem);
      max-inline-size: calc(100vw - 2rem);
    }

    .album-hero__cover-lockup {
      grid-row: 1 / span 2;
      justify-self: start;
      inline-size: 100%;
      max-inline-size: 8.6rem;
      border-radius: var(--radius-base);
      box-shadow: var(--album-hero-cover-shadow-mobile);
    }

    .album-hero__title-panel {
      grid-column: 2;
      gap: var(--spacing-sm);
      align-content: start;
      inline-size: 100%;
      min-inline-size: 0;
      max-inline-size: 100%;
      min-block-size: 100%;
    }

    .album-hero__eyebrow {
      font-size: 0.62rem;
    }

    .album-hero__title {
      max-inline-size: 100%;
      font-size: clamp(1.18rem, 5.4vw, 1.55rem);
      font-weight: 600;
      line-height: 1.02;
      text-wrap: balance;
      overflow-wrap: break-word;
      white-space: normal;
    }

    .album-hero__description {
      grid-column: 1 / -1;
      max-inline-size: 100%;
      font-size: clamp(0.82rem, 2.8vw, 0.9rem);
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .album-hero__facts {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-column: 1 / -1;
      gap: var(--spacing-sm);
      inline-size: 100%;
      max-inline-size: calc(100vw - 2rem);
      margin-block-start: var(--spacing-2xs);
    }

    .album-hero__fact {
      gap: var(--spacing-xs);
      min-inline-size: 0;
      padding-block-start: var(--spacing-sm);
    }

    .album-hero__fact-label,
    .album-hero__fact-value {
      font-size: clamp(0.74rem, 2.4vw, 0.8rem);
      overflow-wrap: anywhere;
      white-space: normal;
    }
  }

  @media (width <= 420px) {
    .album-hero__facts {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (480px <= width <= 760px) {
    .album-hero__cover-lockup {
      grid-row: 1 / span 3;
    }

    .album-hero__description {
      grid-column: 2;
    }
  }

  @media (width < 820px) {
    .album-hero__title {
      max-inline-size: 100%;
    }
  }

  @media (width >= 820px) {
    .album-hero__lockup {
      grid-template-columns: minmax(17rem, 0.72fr) minmax(28rem, 1fr);
    }

    .album-hero__cover-lockup {
      grid-row: 1 / span 3;
    }

    .album-hero__title-panel,
    .album-hero__description,
    .album-hero__facts {
      grid-column: 2;
    }
  }
</style>
