---
import Icon from "@shared-ui/components/visual/Icon.astro";
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import type { AlbumData } from "../../types/album";
import { formatDuration } from "../../utils/albumPresentation";
import { getAlbumCoverImage } from "../../utils/musicImages";

interface Props {
  albums: AlbumData[];
  title?: string;
}

const { albums, title = "Similar Albums" } = Astro.props;
const RELATED_COVER_IMAGE_WIDTHS = [96, 144, 192, 256];
const RELATED_COVER_IMAGE_SIZES =
  "(max-width: 700px) 5rem, (max-width: 1100px) 6rem, 7rem";

const getDurationLabel = (album: AlbumData) => {
  const totalDurationSeconds = album.songs.reduce(
    (total, song) => total + (song.durationSeconds || 0),
    0
  );

  return totalDurationSeconds ? formatDuration(totalDurationSeconds) : "";
};
---

{
  albums.length > 0 && (
    <section class="related-albums" aria-labelledby="related-albums-heading">
      <div class="related-albums__header">
        <h2 id="related-albums-heading" class="related-albums__title">
          {title}
        </h2>
      </div>

      <ul class="related-albums__list" aria-label={title}>
        {albums.map((album) => {
          const durationLabel = getDurationLabel(album);

          return (
            <li class="related-albums__item">
              <a class="related-albums__card" href={`/${album.id}/`}>
                <OptimizedImage
                  src={getAlbumCoverImage(album.coverImage)}
                  alt={`Cover art for the album ${album.title}`}
                  class="related-albums__image"
                  width={128}
                  height={128}
                  widths={RELATED_COVER_IMAGE_WIDTHS}
                  sizes={RELATED_COVER_IMAGE_SIZES}
                  loading="lazy"
                  decoding="async"
                />
                <span class="related-albums__copy">
                  {album.genre && (
                    <span class="related-albums__kicker">{album.genre}</span>
                  )}
                  <span class="related-albums__album-title">{album.title}</span>
                  <span class="related-albums__description">{album.description}</span>
                  <span class="related-albums__meta">
                    <span class="related-albums__meta-item">
                      <Icon name="disc" aria-hidden="true" />
                      {album.songs.length} tracks
                    </span>
                    {durationLabel && (
                      <span class="related-albums__meta-item">
                        <Icon name="clock" aria-hidden="true" />
                        {durationLabel}
                      </span>
                    )}
                  </span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )
}

<style>
  .related-albums {
    --related-albums-gap: clamp(0.8rem, 2vw, 1.1rem);
    --related-albums-card-gap: 0.85rem;
    --related-albums-cover-size: 7rem;
    --related-albums-radius: var(--radius-md);
    --related-albums-shadow:
      0 0 0 1px color-mix(in srgb, var(--music-album-ink) 5%, transparent),
      0 1rem 2rem oklch(5% 0.02 255deg / 0.18);

    display: grid;
    gap: var(--related-albums-gap);
    color: var(--music-album-ink);
  }

  .related-albums__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
  }

  .related-albums__title {
    margin: 0;
    font-size: clamp(1.25rem, 1.07rem + 0.7vw, 1.7rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .related-albums__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--related-albums-gap);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .related-albums__card {
    display: grid;
    grid-template-columns: var(--related-albums-cover-size) minmax(0, 1fr);
    gap: var(--related-albums-card-gap);
    align-items: center;
    min-block-size: 8.5rem;
    padding: 0.75rem;
    color: inherit;
    text-decoration: none;
    background: color-mix(in srgb, var(--music-album-paper) 76%, transparent);
    border: 1px solid var(--music-album-line);
    border-radius: var(--related-albums-radius);
    box-shadow: var(--related-albums-shadow);
  }

  .related-albums__card :global(.related-albums__image) {
    display: block;
    inline-size: var(--related-albums-cover-size);
    block-size: var(--related-albums-cover-size);
    aspect-ratio: 1 / 1;
    outline: 1px solid oklch(100% 0 0deg / 0.12);
    outline-offset: -1px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  .related-albums__copy {
    display: grid;
    gap: 0.25rem;
    min-inline-size: 0;
  }

  .related-albums__kicker {
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.68rem;
    font-weight: 800;
    line-height: 1.15;
    color: var(--music-album-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .related-albums__album-title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.15;
    text-wrap: balance;
    -webkit-box-orient: vertical;
  }

  .related-albums__description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: 0.84rem;
    line-height: 1.4;
    color: var(--music-album-muted);
    -webkit-box-orient: vertical;
  }

  .related-albums__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
    color: var(--music-album-muted);
  }

  .related-albums__meta-item {
    display: inline-flex;
    gap: 0.25rem;
    align-items: center;
  }

  .related-albums__card:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (width <= 900px) {
    .related-albums__list {
      grid-template-columns: 1fr;
    }
  }

  @media (width <= 520px) {
    .related-albums {
      --related-albums-cover-size: 5rem;
      --related-albums-card-gap: 0.68rem;
    }

    .related-albums__card {
      min-block-size: 6.35rem;
      padding: 0.62rem;
    }

    .related-albums__description {
      -webkit-line-clamp: 1;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .related-albums__card {
      transition:
        background 180ms cubic-bezier(0.22, 1, 0.36, 1),
        border-color 180ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .related-albums__card:hover,
    .related-albums__card:focus-visible {
      background: color-mix(
        in srgb,
        var(--music-album-paper) 86%,
        var(--music-album-accent) 8%
      );
      border-color: color-mix(
        in srgb,
        var(--music-album-accent) 42%,
        var(--music-album-line)
      );
      transform: translateY(-0.08rem);
    }
  }
</style>
