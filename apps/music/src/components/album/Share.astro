---
import Icon from "@shared-ui/components/visual/Icon.astro";
import { isHttpShareUrl } from "@utils/shareUrl";

interface Props {
  contentDescription: string;
  contentTitle: string;
  shareUrl: string;
}

const { contentDescription, contentTitle, shareUrl } = Astro.props as Props;

const shareTitle = `${contentTitle} | Melody Mind`;
const sanitizedDesc = contentDescription.replace(/\r\n|\r|\n/g, " ").trim();
const shareText = sanitizedDesc ? `${contentTitle} - ${sanitizedDesc}` : contentTitle;
const shareMailSubject = encodeURIComponent(shareTitle);
const shareMailBody = encodeURIComponent(
  sanitizedDesc ? `${sanitizedDesc}\n\n${shareUrl}` : shareUrl
);
const mastodonShareUrl = `https://mastodon.social/share?text=${encodeURIComponent(
  `${shareText} ${shareUrl}`
)}`;

const hasValidUrl = isHttpShareUrl(shareUrl);
---

{
  hasValidUrl && (
    <section
      class="album-share-section"
      id="album-share"
      aria-labelledby="album-share-title"
      data-album-share-root
      data-share-url={shareUrl}
      data-share-title={shareTitle}
      data-share-text={shareText}
    >
      <div class="album-share-section__header">
        <Icon name="send" class="album-share-section__header-icon" aria-hidden="true" />
        <h2 class="album-share-section__title" id="album-share-title">
          Share this album
        </h2>
      </div>

      <p
        class="album-share-section__note"
        data-share-status
        role="status"
        aria-live="polite"
        aria-atomic="true"
      >
        Copy the link or share it by email.
      </p>

      <div class="album-share-section__actions" role="group" aria-label="Share options">
        <button
          class="album-share-section__button album-share-section__button--primary"
          type="button"
          data-share="copy"
          data-fathom-event="Share: Copy"
          aria-label="Copy link to this album"
        >
          <Icon name="copy" class="album-share-section__button-icon" aria-hidden="true" />
          <span data-copy-label>Copy link</span>
        </button>
        <a
          class="album-share-section__button"
          href={`mailto:?subject=${shareMailSubject}&body=${shareMailBody}`}
          data-fathom-event="Share: Email"
          aria-label="Share via email"
        >
          <Icon name="mail" class="album-share-section__button-icon" aria-hidden="true" />
          <span>Email</span>
        </a>
        <a
          class="album-share-section__button"
          href={mastodonShareUrl}
          target="_blank"
          rel="noreferrer noopener"
          data-fathom-event="Share: Mastodon"
          aria-label="Share on Mastodon, opens in a new tab"
        >
          <Icon
            name="message-circle"
            class="album-share-section__button-icon"
            aria-hidden="true"
          />
          <span>Mastodon</span>
        </a>
        {/* Revealed only when the browser supports the Web Share API. */}
        <button
          class="album-share-section__button"
          type="button"
          data-share="native"
          data-fathom-event="Share: Native"
          aria-label="Share with your device"
          hidden
        >
          <Icon name="send" class="album-share-section__button-icon" aria-hidden="true" />
          <span>Share</span>
        </button>
      </div>
    </section>
  )
}

<script>
  const shareRoots = Array.from(
    document.querySelectorAll<HTMLElement>("[data-album-share-root]")
  ).filter((root) => root.dataset.shareBound !== "true");

  shareRoots.forEach((shareSection) => {
    shareSection.dataset.shareBound = "true";

    const shareUrl = shareSection.dataset.shareUrl || "";
    const shareTitle = shareSection.dataset.shareTitle || "";
    const shareText = shareSection.dataset.shareText || "";
    const statusEl = shareSection.querySelector<HTMLElement>("[data-share-status]");
    const copyButton =
      shareSection.querySelector<HTMLButtonElement>('[data-share="copy"]');
    const copyLabel = shareSection.querySelector<HTMLElement>("[data-copy-label]");
    const nativeShareButton = shareSection.querySelector<HTMLButtonElement>(
      '[data-share="native"]'
    );
    const canNativeShare = "share" in navigator && typeof navigator.share === "function";
    const defaultStatus = "Copy the link or send it from your device.";
    const fallbackStatus = "Copy the link or share it by email.";
    let resetTimer: number | undefined;

    if (nativeShareButton && canNativeShare) {
      nativeShareButton.hidden = false;
      if (statusEl) {
        statusEl.textContent = defaultStatus;
      }
    } else if (statusEl) {
      statusEl.textContent = fallbackStatus;
    }

    const setStatus = (message: string) => {
      if (!statusEl) {
        return;
      }

      statusEl.textContent = message;

      if (resetTimer) {
        window.clearTimeout(resetTimer);
      }

      resetTimer = window.setTimeout(() => {
        statusEl.textContent = nativeShareButton?.hidden ? fallbackStatus : defaultStatus;
        if (copyButton && copyLabel) {
          copyButton.dataset.state = "idle";
          copyLabel.textContent = "Copy link";
        }
      }, 2400);
    };

    const copyLink = async () => {
      try {
        if (!navigator.clipboard || !shareUrl) {
          throw new Error("Clipboard unavailable");
        }

        await navigator.clipboard.writeText(shareUrl);

        if (copyButton && copyLabel) {
          copyButton.dataset.state = "copied";
          copyLabel.textContent = "Copied";
        }

        setStatus("Link copied.");
      } catch {
        setStatus("Copy failed. Use your browser share or address bar instead.");
      }
    };

    copyButton?.addEventListener("click", () => {
      copyLink();
    });

    nativeShareButton?.addEventListener("click", async () => {
      if (!navigator.share) {
        copyLink();
        return;
      }

      try {
        await navigator.share({ title: shareTitle, text: shareText, url: shareUrl });
        setStatus("Ready to share.");
      } catch (error) {
        if (error instanceof Error && error.name === "AbortError") {
          return;
        }

        copyLink();
      }
    });
  });
</script>

<style>
  .album-share-section {
    --album-share-gap: calc(var(--spacing-base) - var(--spacing-2xs));
    --album-share-header-gap: calc(var(--spacing-sm) + var(--spacing-2xs));
    --album-share-actions-gap: var(--spacing-sm);
    --album-share-padding: clamp(
      var(--spacing-base),
      2vw,
      calc(var(--spacing-base) + var(--spacing-xs))
    );
    --album-share-mobile-inline-padding: var(--spacing-base);
    --album-share-button-min-block-size: 2.75rem;
    --album-share-button-padding-block: var(--spacing-sm);
    --album-share-button-padding-inline: var(--spacing-md);
    --album-share-button-gap: calc(var(--spacing-sm) - var(--spacing-2xs));
    --album-share-button-font-size: var(--font-size-xs, 0.86rem);
    --album-share-button-font-weight: var(--font-weight-semibold, 650);
    --album-share-button-transition-duration: 160ms;
    --album-share-header-icon-size: calc(var(--spacing-base) + var(--spacing-2xs));
    --album-share-button-icon-size: calc(var(--spacing-base) - var(--spacing-2xs));
    --album-share-radius: var(--radius-md);
    --album-share-button-radius: var(--radius-base);
    --album-share-shadow: var(--shadow-lg, 0 1rem 2rem oklch(20% 0.04 45deg / 0.08));

    display: grid;
    gap: var(--album-share-gap);
    padding: var(--album-share-padding);
    color: var(--music-album-ink);
    background: color-mix(in srgb, var(--music-album-paper) 72%, transparent);
    border: 1px solid var(--music-album-line);
    border-radius: var(--album-share-radius);
    box-shadow: var(--album-share-shadow);
  }

  .album-share-section__header {
    display: flex;
    gap: var(--album-share-header-gap);
    align-items: center;
  }

  .album-share-section__header-icon {
    inline-size: var(--album-share-header-icon-size);
    block-size: var(--album-share-header-icon-size);
    color: var(--music-album-accent);
  }

  .album-share-section__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--music-album-ink);
    text-transform: none;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .album-share-section__note {
    max-inline-size: 28ch;
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.45;
    color: var(--music-album-muted);
    text-wrap: pretty;
  }

  .album-share-section__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--album-share-actions-gap);
  }

  .album-share-section__button {
    display: inline-flex;
    gap: var(--album-share-button-gap);
    align-items: center;
    justify-content: center;
    min-block-size: var(--album-share-button-min-block-size);
    padding: var(--album-share-button-padding-block)
      var(--album-share-button-padding-inline);
    font: inherit;
    font-size: var(--album-share-button-font-size);
    font-weight: var(--album-share-button-font-weight);
    color: var(--music-album-ink);
    text-decoration: none;
    cursor: pointer;
    background: color-mix(in srgb, var(--music-album-paper-soft) 56%, transparent);
    border: 1px solid
      color-mix(in srgb, var(--music-album-accent) 20%, var(--music-album-line));
    border-radius: var(--album-share-button-radius);
    transition-timing-function: cubic-bezier(0.23, 1, 0.32, 1);
    transition-duration: var(--album-share-button-transition-duration);
    transition-property: transform, color, background-color, border-color;
  }

  .album-share-section__button[hidden] {
    display: none;
  }

  .album-share-section__button--primary,
  .album-share-section__button[data-state="copied"] {
    color: var(--music-album-paper);
    background: var(--music-album-accent);
    border-color: var(--music-album-accent);
  }

  .album-share-section__button:focus-visible {
    color: var(--music-album-paper);
    outline: var(--focus-ring-width, 2px) solid var(--music-album-accent);
    outline-offset: var(--focus-ring-offset, 3px);
    background: var(--music-album-accent);
    border-color: var(--music-album-accent);
  }

  .album-share-section__button:active {
    transform: scale(0.97);
  }

  .album-share-section__button-icon {
    inline-size: var(--album-share-button-icon-size);
    block-size: var(--album-share-button-icon-size);
  }

  @media (width <= 760px) {
    .album-share-section {
      padding: 0;
      overflow: hidden;
      background: color-mix(in srgb, var(--music-album-paper) 62%, transparent);
      border-radius: var(--album-share-button-radius);
      box-shadow: none;
    }

    .album-share-section__header {
      padding: var(--spacing-base) var(--album-share-mobile-inline-padding) 0;
    }

    .album-share-section__note {
      max-inline-size: none;
      padding: 0 var(--album-share-mobile-inline-padding);
    }

    .album-share-section__actions {
      grid-template-columns: minmax(0, 1fr);
      padding: 0 var(--album-share-mobile-inline-padding)
        var(--album-share-mobile-inline-padding);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .album-share-section__button:hover,
    .album-share-section__button:focus-visible {
      color: var(--music-album-paper);
      background: var(--music-album-accent);
      border-color: var(--music-album-accent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .album-share-section__button {
      transition: none;
    }

    .album-share-section__button:active {
      transform: none;
    }
  }
</style>
