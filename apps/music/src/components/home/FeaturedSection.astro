---
import type { Entry } from "./types";
import OptimizedImage from "@shared-ui/components/media/OptimizedImage.astro";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  albums: Entry[];
  headingId?: string;
  limit?: number;
  title: string;
  viewAllHref?: string;
  viewAllLabel: string;
}

const FEATURED_ALBUM_LIMIT = 6;
const FEATURED_ALBUM_IMAGE_SIZES =
  "(max-width: 760px) calc((100vw - 4rem) / 3), (max-width: 1024px) calc((100vw - 7rem) / 4), min(15rem, calc((100vw - 10rem) / 6))";
const FEATURED_ALBUM_IMAGE_WIDTHS = [160, 240, 320, 480];

const {
  albums,
  headingId = "featured-albums-heading",
  limit = FEATURED_ALBUM_LIMIT,
  title,
  viewAllHref = "#albums-list",
  viewAllLabel,
} = Astro.props;
const normalizedLimit = Number.isFinite(limit)
  ? Math.max(1, Math.floor(limit))
  : FEATURED_ALBUM_LIMIT;
const featuredAlbums = albums.slice(0, normalizedLimit);
---

{
  featuredAlbums.length > 0 && (
    <section
      class="featured-albums"
      aria-labelledby={headingId}
      data-testid="featured-albums"
    >
      <SectionHeader
        {headingId}
        title={title}
        linkHref={viewAllHref}
        linkLabel={viewAllLabel}
      />
      <ul class="featured-albums__list" aria-label={title}>
        {featuredAlbums.map((album) => (
          <li class="featured-albums__item">
            <a class="featured-albums__link" href={`/${album.id}`}>
              <OptimizedImage
                src={album.imageSrc}
                alt={`Cover art for the album ${album.title}`}
                class="featured-albums__image"
                width={320}
                height={320}
                widths={FEATURED_ALBUM_IMAGE_WIDTHS}
                sizes={FEATURED_ALBUM_IMAGE_SIZES}
                loading="lazy"
                decoding="async"
              />
              <span class="featured-albums__title">{album.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .featured-albums {
    display: grid;
    gap: var(--spacing-base);
  }

  .featured-albums__list {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: clamp(var(--spacing-md), 1.4vw, var(--spacing-base));
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .featured-albums__link {
    display: grid;
    gap: var(--spacing-sm);
    color: var(--music-home-ink);
    text-decoration: none;
  }

  .featured-albums__link :global(.featured-albums__image) {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    outline: 1px solid rgb(0 0 0 / 10%);
    outline-offset: -1px;
    object-fit: cover;
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-base);
  }

  :global([data-theme="dark"]) .featured-albums__link :global(.featured-albums__image) {
    outline-color: rgb(255 255 255 / 10%);
  }

  .featured-albums__title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  .featured-albums__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (width <= 1024px) {
    .featured-albums__list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (width <= 760px) {
    .featured-albums__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-md);
      min-inline-size: 0;
    }

    .featured-albums__item {
      min-inline-size: 0;
    }

    .featured-albums__title {
      font-size: 0.95rem;
      text-align: start;
    }
  }

  @media (width <= 420px) {
    .featured-albums__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .featured-albums__link {
      transition: transform var(--motion-duration-base) var(--motion-ease-standard);
    }

    .featured-albums__link:hover,
    .featured-albums__link:focus:not(:focus-visible) {
      transform: translateY(calc(-1 * var(--motion-distance-xs)));
    }
  }
</style>
