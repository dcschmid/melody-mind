---
import EmptyState from "@components/layout/EmptyState.astro";
import ContentCard from "@components/cards/ContentCard.astro";
import SectionHeader from "@components/layout/SectionHeader.astro";
import { getAlbumVisibleCountLabel } from "./albumGridLabels";
import type { Entry } from "./types";

interface Props {
  albums: Entry[];
  emptyDescription: string;
  headingId?: string;
  initialGenreValue: string;
  initialVisibleAlbumCount: number;
  showHeader?: boolean;
  title: string;
}

const {
  albums,
  emptyDescription,
  headingId = "albums-heading",
  initialGenreValue,
  initialVisibleAlbumCount,
  showHeader = true,
  title,
} = Astro.props;
const GRID_COVER_IMAGE_SIZES =
  "(max-width: 640px) 7.5rem, (max-width: 760px) 44vw, (max-width: 1180px) 28vw, min(18rem, calc((100vw - 10rem) / 5))";
---

<section class="album-grid-section" aria-labelledby={headingId}>
  {
    showHeader && (
      <SectionHeader headingId={headingId} title={title} hideIcon>
        {albums.length > 0 && (
          <p
            class="album-grid-section__results"
            aria-live="polite"
            aria-atomic="true"
            data-album-results
          >
            {getAlbumVisibleCountLabel(initialVisibleAlbumCount, initialGenreValue)}
          </p>
        )}
      </SectionHeader>
    )
  }

  <ul class="album-grid-section__grid" id="albums-list">
    {
      albums.map((album) => (
        <li
          class="album-grid-section__item"
          data-album
          data-album-card
          data-album-title={album.title}
          data-album-published-at={album.publishedAtTime}
          data-album-card-genre={album.mainGenre || ""}
          hidden={!album.isVisible}
          aria-hidden={album.isVisible ? "false" : "true"}
        >
          <ContentCard
            id={`album-card-${album.id}`}
            class="album-grid-section__card"
            href={`/${album.id}`}
            dataTestId="album-grid-card"
            variant="default"
            size="compact"
            mediaAspectRatio="1 / 1"
            mediaObjectFit="cover"
            imageSrc={album.imageSrc}
            imageAlt={`Cover art for the album ${album.title}`}
            imageWidth={1024}
            imageHeight={1024}
            imageSizes={GRID_COVER_IMAGE_SIZES}
            title={album.title}
            description={album.description}
            metaItems={[
              ...(album.genre ? [{ iconName: "disc" as const, label: album.genre }] : []),
              { iconName: "music" as const, label: `${album.trackCount} tracks` },
              ...(album.totalDurationLabel
                ? [{ iconName: "clock" as const, label: album.totalDurationLabel }]
                : []),
            ]}
            ctaSrText={`Open album ${album.title}`}
          />
        </li>
      ))
    }
  </ul>
  {albums.length === 0 && <EmptyState description={emptyDescription} />}
</section>

<script>
  import { getAlbumVisibleCountLabel } from "./albumGridLabels";

  const albumControls = document.querySelector("[data-album-controls]");
  const albumList = document.querySelector("#albums-list");

  if (albumControls instanceof HTMLFormElement && albumList instanceof HTMLElement) {
    const sortSelect = albumControls.querySelector("[data-album-sort]");
    const results = document.querySelector("[data-album-results]");
    const collator = new Intl.Collator("en", {
      numeric: true,
      sensitivity: "base",
    });
    const defaultSortValue = "date";
    const sortParamName = "sort";
    const genreParamName = "genre";

    const cards = Array.from(
      albumList.querySelectorAll("[data-album-card]")
    ) as HTMLElement[];

    const getGenreButtons = () =>
      Array.from(albumControls.querySelectorAll<HTMLButtonElement>("[data-album-genre]"));

    const isValidSortValue = (value: string | null) =>
      value === "date" || value === "title";

    const isValidGenreValue = (value: string) =>
      getGenreButtons().some((button) => button.value === value);

    const getSelectedGenreValue = () =>
      getGenreButtons().find((button) => button.getAttribute("aria-pressed") === "true")
        ?.value || "";

    const setSelectedGenreValue = (value: string) => {
      for (const button of getGenreButtons()) {
        button.setAttribute("aria-pressed", String(button.value === value));
      }
    };

    const applyControlsFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const sortValue = params.get(sortParamName);
      const genreValue = params.get(genreParamName) ?? params.get("album-genre") ?? "";

      if (sortSelect instanceof HTMLSelectElement) {
        sortSelect.value = isValidSortValue(sortValue)
          ? sortValue || defaultSortValue
          : defaultSortValue;
      }

      setSelectedGenreValue(isValidGenreValue(genreValue) ? genreValue : "");
    };

    const syncUrlToControls = (sortValue: string, genreValue: string) => {
      const url = new URL(window.location.href);

      if (sortValue === defaultSortValue) {
        url.searchParams.delete(sortParamName);
      } else {
        url.searchParams.set(sortParamName, sortValue);
      }

      if (genreValue) {
        url.searchParams.set(genreParamName, genreValue);
      } else {
        url.searchParams.delete(genreParamName);
      }
      url.searchParams.delete("album-genre");

      window.history.replaceState(null, "", `${url.pathname}${url.search}${url.hash}`);
    };

    const updateAlbums = ({ syncUrl = false } = {}) => {
      const sortValue =
        sortSelect instanceof HTMLSelectElement ? sortSelect.value : defaultSortValue;
      const genreValue = getSelectedGenreValue();

      const sortedCards = [...cards].sort((a, b) => {
        if (sortValue === "date") {
          const aDate = Number(a.dataset.albumPublishedAt || 0);
          const bDate = Number(b.dataset.albumPublishedAt || 0);
          return (
            bDate - aDate ||
            collator.compare(a.dataset.albumTitle || "", b.dataset.albumTitle || "")
          );
        }

        return collator.compare(a.dataset.albumTitle || "", b.dataset.albumTitle || "");
      });

      let visibleCount = 0;
      for (const card of sortedCards) {
        const isVisible = !genreValue || card.dataset.albumCardGenre === genreValue;
        card.hidden = !isVisible;
        card.setAttribute("aria-hidden", String(!isVisible));
        if (isVisible) {
          visibleCount += 1;
        }
        albumList.append(card);
      }

      if (results instanceof HTMLElement) {
        results.textContent = getAlbumVisibleCountLabel(visibleCount, genreValue);
      }

      if (syncUrl) {
        syncUrlToControls(sortValue, genreValue);
      }
    };

    for (const button of getGenreButtons()) {
      button.addEventListener("click", () => {
        setSelectedGenreValue(button.value);
        updateAlbums({ syncUrl: true });
      });
    }

    albumControls.addEventListener("change", () => updateAlbums({ syncUrl: true }));
    window.addEventListener("popstate", () => {
      applyControlsFromUrl();
      updateAlbums();
    });
    applyControlsFromUrl();
    updateAlbums();
  }
</script>

<style>
  .album-grid-section {
    --album-card-gap: clamp(1rem, 1.6vw, 1.4rem);
    --album-card-radius: var(--radius-md);
    --album-card-results-size: var(--font-size-xs);
    --album-card-bg: color-mix(in srgb, var(--music-home-paper) 86%, transparent);
    --album-card-bg-hover: color-mix(
      in srgb,
      var(--music-home-paper) 92%,
      var(--music-home-accent) 8%
    );
    --album-card-border-hover: color-mix(
      in srgb,
      var(--music-home-accent) 42%,
      var(--music-home-line)
    );
    --album-card-border: color-mix(
      in srgb,
      var(--music-home-line) 78%,
      var(--music-home-accent) 22%
    );
    --album-card-lift: -0.06rem;
    --album-card-ease-out: cubic-bezier(0.22, 1, 0.36, 1);

    display: grid;
    gap: var(--album-card-gap);
  }

  .album-grid-section__results {
    margin: 0;
    font-size: var(--album-card-results-size);
    font-weight: 700;
    color: var(--music-home-muted);
  }

  .album-grid-section__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--album-card-gap);
    align-items: stretch;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .album-grid-section__item {
    display: grid;
    min-inline-size: 0;
    contain-intrinsic-size: 22rem 18rem;
    content-visibility: auto;
  }

  .album-grid-section__item[hidden] {
    display: none;
  }

  .album-grid-section__card:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (width <= 1180px) {
    .album-grid-section__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (width <= 760px) {
    .album-grid-section__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      min-inline-size: 0;
    }
  }

  @media (width <= 440px) {
    .album-grid-section__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .album-grid-section__card {
      transition:
        transform 180ms var(--album-card-ease-out),
        background-color 160ms var(--album-card-ease-out),
        border-color 160ms var(--album-card-ease-out);
    }

    .album-grid-section__card:active {
      transform: scale(0.985);
    }

    @media (hover: hover) and (pointer: fine) {
      /* stylelint-disable-next-line a11y/selector-pseudo-class-focus */
      .album-grid-section__card:hover {
        transform: translateY(var(--album-card-lift));
      }
    }
  }
</style>

<style is:global>
  .album-grid-section__card {
    background:
      linear-gradient(
        180deg,
        color-mix(
          in srgb,
          var(--music-home-paper-soft) 84%,
          var(--music-home-accent) 16%
        ),
        var(--album-card-bg) 56%
      ),
      var(--album-card-bg);
    border-color: var(--album-card-border);
    border-radius: var(--album-card-radius);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--music-home-ink) 10%, transparent),
      0 1rem 2.3rem color-mix(in srgb, var(--surface-shadow) 18%, transparent);
  }

  .album-grid-section__card.content-card--interactive:hover,
  .album-grid-section__card.content-card--interactive:focus-within {
    background:
      linear-gradient(
        180deg,
        color-mix(
          in srgb,
          var(--music-home-paper-soft) 78%,
          var(--music-home-accent) 22%
        ),
        var(--album-card-bg-hover) 56%
      ),
      var(--album-card-bg-hover);
    border-color: var(--album-card-border-hover);
  }

  .album-grid-section__card .content-card__media {
    position: relative;
    background: color-mix(
      in srgb,
      var(--music-home-paper-soft) 86%,
      var(--music-home-ink) 14%
    );
    border-block-end-color: color-mix(in srgb, var(--music-home-line) 58%, transparent);
  }

  /* Soft accent glow that blooms over the cover on hover/focus. */
  .album-grid-section__card .content-card__media::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    content: "";
    background: radial-gradient(
      120% 90% at 50% 100%,
      color-mix(in srgb, var(--music-home-accent) 42%, transparent),
      transparent 62%
    );
    mix-blend-mode: screen;
    opacity: 0;
  }

  .album-grid-section__card.content-card--interactive:hover .content-card__media::before,
  .album-grid-section__card.content-card--interactive:focus-within
    .content-card__media::before {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .album-grid-section__card .content-card__media::before {
      transition: opacity 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }
  }

  .album-grid-section__card .content-card__media::after {
    position: absolute;
    inset: 0;
    display: block;
    pointer-events: none;
    content: "";
    background: linear-gradient(180deg, transparent 62%, rgb(0 0 0 / 26%));
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 8%);
  }

  .album-grid-section__card .content-card__content {
    flex: 1;
    block-size: 100%;
  }

  .album-grid-section__card .content-card__body {
    gap: var(--spacing-sm);
    padding: clamp(var(--spacing-base), 1.5vw, var(--spacing-lg));
  }

  .album-grid-section__card .content-card__title {
    font-size: clamp(1rem, 1rem + 0.24vw, 1.12rem);
    line-height: 1.16;
    letter-spacing: 0;
  }

  .album-grid-section__card .content-card__description {
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: color-mix(in srgb, var(--music-home-muted) 88%, var(--music-home-ink) 12%);
  }

  .album-grid-section__card .content-card__meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm) var(--spacing-base);
    padding-block-start: var(--spacing-sm);
    margin-block-start: auto;
    font-size: var(--font-size-xs);
    border-block-start-color: color-mix(in srgb, var(--music-home-line) 62%, transparent);
  }

  .album-grid-section__card .content-card__meta-item {
    gap: var(--spacing-xs);
    min-inline-size: 0;
    color: color-mix(in srgb, var(--music-home-muted) 90%, var(--music-home-ink) 10%);
  }

  .album-grid-section__card .content-card__meta-item:first-child {
    grid-column: 1 / -1;
    max-inline-size: 100%;
    color: color-mix(in srgb, var(--music-home-ink) 88%, var(--music-home-accent) 12%);
  }

  .album-grid-section__card .content-card__meta-item span {
    min-inline-size: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .album-grid-section__card .content-card__meta-icon {
    inline-size: var(--icon-size-xs);
    block-size: var(--icon-size-xs);
  }

  @media (width < 40rem) {
    .album-grid-section__card .content-card__content {
      display: grid;
      grid-template-columns: minmax(5.75rem, 7.5rem) minmax(0, 1fr);
      align-items: stretch;
    }

    .album-grid-section__card .content-card__media {
      border-block-end: 0;
      border-inline-end: 1px solid
        color-mix(in srgb, var(--music-home-line) 52%, transparent);
    }

    .album-grid-section__card .content-card__body {
      min-inline-size: 0;
      padding: var(--spacing-sm);
    }

    .album-grid-section__card .content-card__description {
      display: none;
    }

    .album-grid-section__card .content-card__meta {
      grid-template-columns: 1fr;
      gap: var(--spacing-xs);
      padding-block-start: var(--spacing-xs);
    }

    .album-grid-section__card .content-card__meta-item:first-child {
      color: color-mix(in srgb, var(--music-home-ink) 88%, var(--music-home-accent) 12%);
    }
  }
</style>
