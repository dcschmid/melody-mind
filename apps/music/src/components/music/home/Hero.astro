---
import { getImage } from "astro:assets";
import Icon from "@components/visual/Icon.astro";
import OptimizedImage from "@components/media/OptimizedImage.astro";
import type { FeaturedAlbum } from "./types";

interface Props {
  featuredAlbum?: FeaturedAlbum;
  eyebrow: string;
  exploreAlbumsHref?: string;
  exploreAlbumsLabel: string;
}

const {
  featuredAlbum,
  eyebrow,
  exploreAlbumsHref = "#main-genres-heading",
  exploreAlbumsLabel,
} = Astro.props as Props;
const queueScriptId = featuredAlbum
  ? `featured-player-queue-${featuredAlbum.id}`
  : undefined;
const ambientImage = featuredAlbum
  ? await getImage({
      src: featuredAlbum.imageSrc,
      width: 480,
      height: 480,
      fit: "cover",
      format: "webp",
    })
  : undefined;
---

<section class="music-home-hero" aria-labelledby="music-home-title">
  {
    featuredAlbum ? (
      <>
        <div class="music-home-hero__ambient" aria-hidden="true">
          <span
            class="music-home-hero__ambient-image"
            style={`--music-home-ambient-image: url("${ambientImage?.src}");`}
          />
        </div>

        <a
          class="music-home-hero__cover-link"
          href={`/${featuredAlbum.id}/`}
          aria-label={`Open album ${featuredAlbum.title}`}
        >
          <OptimizedImage
            src={featuredAlbum.imageSrc}
            alt={`Cover art for the album ${featuredAlbum.title}`}
            class="music-home-hero__cover"
            width={640}
            height={640}
            widths={[240, 360, 480, 640]}
            sizes="(max-width: 760px) min(64vw, 15rem), min(34vw, 25rem)"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            formats={["avif"]}
          />
        </a>

        <div class="music-home-hero__copy">
          <p class="music-home-hero__eyebrow">
            <Icon name="flame" aria-hidden="true" />
            {eyebrow}
          </p>
          <h1 id="music-home-title" class="music-home-hero__title">
            {featuredAlbum.title}
          </h1>
          <p class="music-home-hero__description">{featuredAlbum.description}</p>
          <ul class="music-home-hero__meta" aria-label="Featured album details">
            {featuredAlbum.genre && <li>{featuredAlbum.genre}</li>}
            <li>{featuredAlbum.trackCount} tracks</li>
            {featuredAlbum.totalDurationLabel && (
              <li>{featuredAlbum.totalDurationLabel}</li>
            )}
          </ul>
          <div class="music-home-hero__actions">
            <button
              class="music-home-hero__button music-home-hero__button--primary"
              type="button"
              data-player-load
              data-player-queue-id={queueScriptId}
            >
              <Icon name="tabler:player-play-filled" aria-hidden="true" />
              Play album
            </button>
            <a
              class="music-home-hero__button music-home-hero__button--secondary"
              href={`/${featuredAlbum.id}/`}
            >
              View album
              <Icon name="chevron-right" aria-hidden="true" />
            </a>
          </div>
        </div>

        <script
          id={queueScriptId}
          is:inline
          type="application/json"
          set:html={JSON.stringify(featuredAlbum.queue)}
        />
      </>
    ) : (
      <div class="music-home-hero__copy music-home-hero__copy--empty">
        <p class="music-home-hero__eyebrow">MelodyMind Music</p>
        <h1 id="music-home-title" class="music-home-hero__title">
          Albums for deep listening
        </h1>
        <a
          class="music-home-hero__button music-home-hero__button--primary"
          href={exploreAlbumsHref}
        >
          {exploreAlbumsLabel}
        </a>
      </div>
    )
  }
</section>

<style>
  .music-home-hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(16rem, 0.78fr) minmax(22rem, 1.22fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
    min-block-size: min(44rem, 82svh);
    padding: max(6rem, clamp(5rem, 9vw, 8rem)) clamp(1rem, 5vw, 4.5rem)
      clamp(2.5rem, 6vw, 5rem);
    overflow: hidden;
    isolation: isolate;
  }

  .music-home-hero__ambient {
    position: absolute;
    inset: 0;
    z-index: -2;
    overflow: hidden;
    opacity: 0.2;
  }

  .music-home-hero__ambient::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(
        90deg,
        var(--bg-primary) 0%,
        transparent 45%,
        var(--bg-primary) 100%
      ),
      linear-gradient(0deg, var(--bg-primary) 0%, transparent 55%, var(--bg-primary) 100%);
  }

  .music-home-hero__ambient-image {
    position: absolute;
    inset: 0;
    display: block;
    inline-size: 100%;
    block-size: 100%;
    background-image: var(--music-home-ambient-image);
    background-position: center;
    background-size: cover;
    filter: blur(2.5rem) saturate(0.85);
    transform: scale(1.12);
  }

  .music-home-hero__cover-link {
    display: block;
    justify-self: end;
    inline-size: min(100%, 25rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--accent-primary) 32%, var(--border-default));
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xl);
  }

  .music-home-hero__cover-link :global(.music-home-hero__cover) {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .music-home-hero__copy {
    display: grid;
    gap: clamp(0.85rem, 2vw, 1.25rem);
    max-inline-size: 42rem;
  }

  .music-home-hero__copy--empty {
    grid-column: 1 / -1;
  }

  .music-home-hero__eyebrow {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    color: var(--music-home-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .music-home-hero__title {
    max-inline-size: 13ch;
    margin: 0;
    font-size: clamp(2.75rem, 2rem + 3vw, 5rem);
    font-weight: var(--font-weight-bold);
    line-height: 0.98;
    text-wrap: balance;
  }

  .music-home-hero__description {
    max-inline-size: 58ch;
    margin: 0;
    font-size: clamp(var(--font-size-base), 0.95rem + 0.35vw, 1.2rem);
    line-height: 1.6;
    color: var(--music-home-muted);
    text-wrap: pretty;
  }

  .music-home-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1.25rem;
    padding: 0;
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--text-secondary);
    list-style: none;
  }

  .music-home-hero__meta li + li {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
  }

  .music-home-hero__meta li + li::before {
    color: var(--music-home-accent);
    content: "·";
  }

  .music-home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-start: 0.25rem;
  }

  .music-home-hero__button {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
    min-block-size: var(--control-min-block-size);
    padding: 0.75rem 1.3rem;
    font: inherit;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: var(--radius-full);
  }

  .music-home-hero__button--primary {
    color: var(--button-text-accent);
    background: var(--music-home-accent);
  }

  .music-home-hero__button--secondary {
    color: var(--music-home-ink);
    background: var(--surface-1);
    border-color: var(--music-home-line);
  }

  .music-home-hero__button--primary:hover,
  .music-home-hero__button--primary:focus-visible {
    background: var(--music-home-accent-strong);
  }

  .music-home-hero__button--secondary:hover,
  .music-home-hero__button--secondary:focus-visible {
    border-color: var(--music-home-accent);
  }

  @media (width <= 760px) {
    .music-home-hero {
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
      min-block-size: auto;
      padding: 5.75rem 1rem 2.25rem;
    }

    .music-home-hero__cover-link {
      justify-self: center;
      inline-size: min(64vw, 15rem);
    }

    .music-home-hero__ambient {
      display: none;
    }

    .music-home-hero__copy {
      inline-size: 100%;
      max-inline-size: 32rem;
      margin-inline: auto;
    }

    .music-home-hero__title {
      max-inline-size: 14ch;
      font-size: clamp(2.15rem, 11vw, 3.5rem);
    }

    .music-home-hero__actions {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }

  @media (width <= 420px) {
    .music-home-hero__actions {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (forced-colors: active) {
    .music-home-hero__ambient {
      display: none;
    }
  }
</style>
