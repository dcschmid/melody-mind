---
import Icon from "@components/visual/Icon.astro";
import OptimizedImage from "@components/media/OptimizedImage.astro";
import type { HeroItem } from "./types";

interface Props {
  albums: HeroItem[];
  description: string;
  editorialDeck: string;
  eyebrow: string;
  exploreAlbumsHref?: string;
  exploreAlbumsLabel: string;
  latestReleasesLabel: string;
  title: string;
}

const {
  albums,
  description,
  editorialDeck,
  eyebrow,
  exploreAlbumsHref = "#main-genres-heading",
  exploreAlbumsLabel,
  latestReleasesLabel,
  title,
} = Astro.props;
const showcaseAlbums = albums.slice(0, 5);
const HERO_COVER_IMAGE_WIDTHS = [192, 256, 320, 480, 640];
const HERO_COVER_IMAGE_SIZES =
  "(max-width: 860px) calc((100vw - 3rem) / 3), (max-width: 1180px) 16rem, 18rem";
---

<section class="music-home-hero" aria-labelledby="music-home-title">
  <div class="music-home-hero__copy">
    <p class="music-home-hero__eyebrow">
      <Icon name="disc" class="music-home-hero__eyebrow-icon" aria-hidden="true" />
      {eyebrow}
    </p>
    <h1 id="music-home-title" class="music-home-hero__title">{title}</h1>
    <p class="music-home-hero__description">{description}</p>
    <p class="music-home-hero__deck">{editorialDeck}</p>
    <nav class="music-home-hero__actions" aria-label="Hero actions">
      <a
        href={exploreAlbumsHref}
        class="music-home-hero__button music-home-hero__button--primary"
      >
        <Icon name="play" class="music-home-hero__button-icon" aria-hidden="true" />
        {exploreAlbumsLabel}
      </a>
      <a
        href="#latest-releases"
        class="music-home-hero__button music-home-hero__button--ghost"
      >
        {latestReleasesLabel}
        <Icon
          name="chevron-right"
          class="music-home-hero__button-icon"
          aria-hidden="true"
        />
      </a>
    </nav>
  </div>

  {
    showcaseAlbums.length > 0 && (
      <div class="music-home-hero__showcase" aria-label="Recent album covers">
        {showcaseAlbums.map((album, index) => (
          <figure
            class:list={[
              "music-home-hero__showcase-card",
              index === 0 && "music-home-hero__showcase-card--lead",
            ]}
            style={`--cover-index: ${index}`}
          >
            <OptimizedImage
              src={album.imageSrc}
              alt=""
              class="music-home-hero__showcase-image"
              width={480}
              height={480}
              widths={HERO_COVER_IMAGE_WIDTHS}
              sizes={HERO_COVER_IMAGE_SIZES}
              loading={index === 0 ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={index === 0 ? "high" : "low"}
              formats={["avif"]}
            />
            <figcaption class="music-home-hero__showcase-title">{album.title}</figcaption>
          </figure>
        ))}
      </div>
    )
  }
</section>

<style>
  .music-home-hero {
    --music-home-hero-button-shadow: 0 1rem 2rem oklch(0% 0 0deg / 0.35);
    --music-home-hero-card-shadow: 0 1.5rem 3rem oklch(0% 0 0deg / 0.3);
    --music-home-hero-title-shadow: 0 0.1rem 0.8rem oklch(0% 0 0deg / 0.65);
    --music-home-hero-title-scrim: oklch(0% 0 0deg / 0.72);

    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(1.5rem, 4.5vw, 3.5rem);
    align-items: center;
    min-block-size: clamp(30rem, 58svh, 37rem);
    padding: max(clamp(1.5rem, 4.5vw, 3.75rem), 5.75rem) clamp(1.25rem, 5vw, 4.5rem)
      clamp(1rem, 3vw, 2.25rem);
    overflow: hidden;
    isolation: isolate;
  }

  .music-home-hero__copy {
    display: grid;
    gap: clamp(0.9rem, 2vw, 1.25rem);
    max-inline-size: 43rem;
  }

  .music-home-hero__eyebrow {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    color: var(--music-home-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .music-home-hero__eyebrow-icon {
    color: var(--music-home-accent);
  }

  .music-home-hero__title {
    max-inline-size: 9.5ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(3rem, 2.2rem + 3.2vw, 5.25rem);
    font-weight: var(--font-weight-bold);
    line-height: 0.96;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .music-home-hero__description,
  .music-home-hero__deck {
    max-inline-size: 54ch;
    margin: 0;
    font-size: var(--font-size-md);
    line-height: 1.62;
    color: var(--music-home-muted);
    text-wrap: pretty;
  }

  .music-home-hero__deck {
    max-inline-size: 45ch;
    font-size: var(--font-size-base);
    line-height: 1.6;
  }

  .music-home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-block-start: 0.4rem;
  }

  .music-home-hero__button {
    display: inline-flex;
    gap: 0.55rem;
    align-items: center;
    justify-content: center;
    min-block-size: 2.75rem;
    padding: 0.72rem 1.35rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1;
    text-decoration: none;
    border: 1px solid transparent;
    border-radius: 999px;
  }

  .music-home-hero__button--primary {
    color: var(--music-home-paper);
    background-color: var(--music-home-accent);
    box-shadow: var(--music-home-hero-button-shadow);
  }

  .music-home-hero__button--ghost {
    color: var(--music-home-ink);
    background: oklch(18% 0.037 255deg / 0.44);
    border-color: var(--music-home-line);
  }

  .music-home-hero__button-icon {
    flex: 0 0 auto;
  }

  .music-home-hero__showcase {
    position: relative;
    display: grid;
    align-items: end;
    justify-content: center;
    justify-self: center;
    inline-size: min(100%, 42rem);
    min-block-size: clamp(15rem, 28vw, 20rem);
    margin-block-start: 0.4rem;
    perspective: 70rem;
  }

  /* Soft luminous halo behind the floating cover stack. */
  .music-home-hero__showcase::before {
    position: absolute;
    inset: -18% -8%;
    z-index: -1;
    pointer-events: none;
    content: "";
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--music-home-accent) 36%, transparent),
      transparent 72%
    );
    opacity: 0.85;
    filter: blur(2.5rem);
  }

  .music-home-hero__showcase-card {
    position: relative;
    display: block;
    inline-size: clamp(8rem, 12.5vw, 14rem);
    aspect-ratio: 1 / 1;
    margin: 0;
    overflow: hidden;
    color: oklch(98% 0.014 75deg);
    text-decoration: none;
    border: 1px solid var(--music-home-line);
    border-radius: 0.65rem;
    box-shadow: var(--music-home-hero-card-shadow);
  }

  .music-home-hero__showcase-card--lead {
    border-color: color-mix(
      in srgb,
      var(--music-home-accent) 62%,
      oklch(98% 0.014 75deg)
    );
    box-shadow:
      var(--music-home-hero-card-shadow),
      0 0 1.5rem color-mix(in srgb, var(--music-home-accent) 22%, transparent);
  }

  .music-home-hero__showcase-card :global(.music-home-hero__showcase-image) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    aspect-ratio: 1 / 1;
    outline: 1px solid oklch(0% 0 0deg / 0.1);
    outline-color: oklch(100% 0 0deg / 0.1);
    outline-offset: -1px;
    object-fit: cover;
  }

  .music-home-hero__showcase-title {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    padding: 2rem 0.65rem 0.65rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.15;
    text-align: center;
    text-shadow: var(--music-home-hero-title-shadow);
    background: var(--music-home-hero-title-scrim);
  }

  .music-home-hero__button:hover,
  .music-home-hero__button:focus-visible {
    border-color: color-mix(in srgb, var(--music-home-accent) 42%, transparent);
  }

  .music-home-hero__button--primary:hover,
  .music-home-hero__button--primary:focus-visible {
    background-color: var(--music-home-accent-strong);
  }

  .music-home-hero__button:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (width > 860px) {
    .music-home-hero {
      grid-template-columns: minmax(22rem, 0.9fr) minmax(28rem, 1.1fr);
    }

    .music-home-hero__showcase-card {
      position: absolute;
      inset-block-start: 50%;
      inset-inline-start: 50%;
      transform: translate(-50%, -50%) translateX(var(--cover-x, 0))
        scale(var(--cover-scale, 1));
    }

    /* Five art-directed cover positions: lead, near, mid, far, edge. */
    .music-home-hero__showcase-card:not(:first-child) .music-home-hero__showcase-title {
      inline-size: 1px;
      block-size: 1px;
      padding: 0;
      overflow: hidden;
      white-space: nowrap;
      clip-path: inset(50%);
    }

    .music-home-hero__showcase-card:nth-child(1) {
      --cover-x: -5.8rem;
      --cover-scale: 1.12;

      z-index: 5;
    }

    .music-home-hero__showcase-card:nth-child(2) {
      --cover-x: 3.6rem;
      --cover-scale: 0.94;

      z-index: 4;
    }

    .music-home-hero__showcase-card:nth-child(3) {
      --cover-x: 10.4rem;
      --cover-scale: 0.84;

      z-index: 3;
    }

    .music-home-hero__showcase-card:nth-child(4) {
      --cover-x: 16rem;
      --cover-scale: 0.76;

      z-index: 2;
    }

    .music-home-hero__showcase-card:nth-child(5) {
      --cover-x: 20.6rem;
      --cover-scale: 0.68;

      z-index: 1;
    }
  }

  @media (width <= 860px) {
    .music-home-hero {
      gap: 2rem;
      align-content: start;
      inline-size: 100dvw;
      max-inline-size: 100dvw;
      min-block-size: auto;
      padding: 6.45rem 1rem 2.25rem;
      overflow: hidden;
    }

    .music-home-hero__copy,
    .music-home-hero__description,
    .music-home-hero__deck {
      inline-size: min(100%, 22rem);
      min-inline-size: 0;
      max-inline-size: 22rem;
      overflow-wrap: break-word;
    }

    .music-home-hero__title {
      max-inline-size: 10.5ch;
      font-size: clamp(2.25rem, 12vw, 4.1rem);
    }

    .music-home-hero__description {
      font-size: var(--font-size-sm);
      line-height: 1.55;
    }

    .music-home-hero__deck {
      font-size: var(--font-size-sm);
      line-height: 1.55;
    }

    .music-home-hero__actions {
      flex-direction: column;
      justify-content: center;
      inline-size: min(100%, 22rem);
    }

    .music-home-hero__button--primary {
      inline-size: min(100%, 16rem);
    }

    .music-home-hero__button--ghost {
      min-block-size: 2.5rem;
      padding: 0.45rem 0.35rem;
      color: var(--music-home-accent);
      background: transparent;
      border-color: transparent;
    }

    .music-home-hero__showcase {
      display: flex;
      gap: 0.65rem;
      justify-content: flex-start;
      inline-size: 100%;
      max-inline-size: 100%;
      min-block-size: auto;
      padding-inline: 0;
      overflow: hidden;
      perspective: none;
    }

    .music-home-hero__showcase-card {
      position: relative;
      inset-block-start: auto;
      inset-inline-start: auto;
      flex: 0 0 calc((100% - 1.3rem) / 3);
      inline-size: calc((100% - 1.3rem) / 3);
      min-inline-size: 0;
      transform: none;
    }

    .music-home-hero__showcase-card:nth-child(n + 4) {
      display: none;
    }

    .music-home-hero__showcase-card--lead {
      inline-size: calc((100% - 1.3rem) / 3);
    }

    .music-home-hero__showcase-title {
      padding: 1.75rem 0.55rem 0.55rem;
      font-size: var(--font-size-xs);
    }
  }

  @media (width <= 520px) {
    .music-home-hero__showcase {
      justify-self: start;
      inline-size: min(100%, 22rem);
      max-inline-size: 22rem;
    }

    .music-home-hero__showcase-card {
      flex-basis: calc((100% - 0.65rem) / 2);
      inline-size: calc((100% - 0.65rem) / 2);
    }

    .music-home-hero__showcase-card:nth-child(n + 3) {
      display: none;
    }

    .music-home-hero__showcase-card--lead {
      inline-size: calc((100% - 0.65rem) / 2);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .music-home-hero__button {
      transition:
        transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
        border-color 180ms cubic-bezier(0.22, 1, 0.36, 1),
        background-color 180ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .music-home-hero__button:active {
      transform: scale(0.97);
    }

    /* Gentle staggered entrance for the floating covers. */
    .music-home-hero__showcase-card {
      animation: music-home-hero-cover-in 560ms calc(var(--cover-index, 0) * 70ms)
        cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .music-home-hero__copy {
      animation: music-home-hero-copy-in 620ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  }

  @keyframes music-home-hero-copy-in {
    from {
      opacity: 0;
      transform: translateY(0.9rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes music-home-hero-cover-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }
</style>
