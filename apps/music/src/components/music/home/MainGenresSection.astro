---
import Icon from "@components/visual/Icon.astro";
import OptimizedImage from "@components/media/OptimizedImage.astro";
import SectionHeader from "@components/layout/SectionHeader.astro";
import type { IconName } from "@components/visual/Icon.astro";
import type { Entry } from "./types";

interface MainGenreItem {
  slug: string;
  title: string;
  albumCount: number;
  albums: Entry[];
  iconName: IconName;
  description?: string;
}

interface Props {
  genres: MainGenreItem[];
  title: string;
  headingId?: string;
  showDescriptions?: boolean;
}

const {
  genres,
  title,
  headingId = "main-genres-heading",
  showDescriptions = false,
} = Astro.props as Props;
---

{
  genres.length > 0 && (
    <section
      class:list={["genre-directory", { "genre-directory--expanded": showDescriptions }]}
      aria-labelledby={headingId}
    >
      <SectionHeader {headingId} iconName="tag" {title} />

      <ul class="genre-directory__list">
        {genres.map((genre) => {
          const covers = genre.albums.slice(0, 3);
          const albumLabel = `${genre.albumCount} ${genre.albumCount === 1 ? "album" : "albums"}`;

          return (
            <li class="genre-directory__item">
              <a
                class="genre-directory__link"
                href={`/genre/${genre.slug}/`}
                aria-label={`${genre.title}, ${albumLabel}`}
              >
                <span class="genre-directory__copy">
                  <strong class="genre-directory__title">{genre.title}</strong>
                  <span class="genre-directory__count">{albumLabel}</span>
                  {showDescriptions && genre.description ? (
                    <span class="genre-directory__description">{genre.description}</span>
                  ) : null}
                </span>

                <span class="genre-directory__visual" aria-hidden="true">
                  {showDescriptions ? (
                    <span class="genre-directory__fallback">
                      <Icon name={genre.iconName} />
                    </span>
                  ) : covers.length > 0 ? (
                    <span class="genre-directory__covers">
                      {covers.map((album, index) => (
                        <span
                          class="genre-directory__cover"
                          style={`--genre-directory-cover-index: ${index};`}
                        >
                          <OptimizedImage
                            src={album.imageSrc}
                            alt=""
                            width={64}
                            height={64}
                            widths={[48, 64, 96]}
                            sizes="3rem"
                            loading="lazy"
                            decoding="async"
                          />
                        </span>
                      ))}
                    </span>
                  ) : (
                    <span class="genre-directory__fallback">
                      <Icon name={genre.iconName} />
                    </span>
                  )}
                  <Icon name="chevron-right" class="genre-directory__arrow" />
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )
}

<style>
  .genre-directory {
    --genre-directory-accent: var(--music-home-accent, var(--accent-primary));
    --genre-directory-ink: var(--music-home-ink, var(--text-primary));
    --genre-directory-line: var(--music-home-line, var(--border-default));
    --genre-directory-muted: var(--music-home-muted, var(--text-tertiary));
    --genre-directory-paper: var(--music-home-paper, var(--surface-1));

    display: grid;
    gap: var(--spacing-lg);
  }

  .genre-directory__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(2rem, 5vw, 5rem);
    padding: 0;
    margin: 0;
    list-style: none;
    border-block-start: 1px solid var(--genre-directory-line);
  }

  .genre-directory__item {
    min-inline-size: 0;
    border-block-end: 1px solid var(--genre-directory-line);
  }

  .genre-directory__link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--spacing-lg);
    align-items: center;
    min-block-size: 6rem;
    padding: var(--spacing-base) var(--spacing-md);
    color: var(--genre-directory-ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  .genre-directory__copy {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .genre-directory__title {
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: var(--font-size-lg);
    line-height: 1.15;
    white-space: nowrap;
  }

  .genre-directory__count {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.25;
    color: var(--genre-directory-muted);
  }

  .genre-directory__description {
    display: -webkit-box;
    max-inline-size: 62ch;
    margin-block-start: var(--spacing-xs);
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: var(--genre-directory-muted);
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  .genre-directory__visual {
    display: flex;
    gap: var(--spacing-base);
    align-items: center;
    justify-content: flex-end;
  }

  .genre-directory__covers {
    display: flex;
    justify-content: flex-end;
    min-inline-size: 6.75rem;
    padding-inline-start: 1.25rem;
  }

  .genre-directory__cover {
    position: relative;
    z-index: calc(3 - var(--genre-directory-cover-index));
    display: block;
    inline-size: 3rem;
    block-size: 3rem;
    margin-inline-start: -1.25rem;
    overflow: hidden;
    background: var(--genre-directory-paper);
    border: 1px solid color-mix(in srgb, var(--genre-directory-ink) 16%, transparent);
    border-radius: var(--radius-sm);
  }

  .genre-directory__cover :global(img) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .genre-directory__fallback {
    display: grid;
    place-items: center;
    inline-size: 3rem;
    block-size: 3rem;
    color: var(--genre-directory-muted);
    background: var(--genre-directory-paper);
    border: 1px solid var(--genre-directory-line);
    border-radius: var(--radius-sm);
  }

  .genre-directory__fallback :global(svg),
  .genre-directory__arrow {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .genre-directory__arrow {
    flex: 0 0 auto;
    color: var(--genre-directory-accent);
  }

  .genre-directory__link:hover,
  .genre-directory__link:focus-visible {
    background: color-mix(in srgb, var(--genre-directory-accent) 7%, transparent);
  }

  .genre-directory__link:hover .genre-directory__title,
  .genre-directory__link:focus-visible .genre-directory__title {
    color: var(--genre-directory-accent);
  }

  .genre-directory__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .genre-directory--expanded {
    gap: var(--spacing-lg);
  }

  .genre-directory--expanded .genre-directory__link {
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    min-block-size: 9rem;
    padding: clamp(var(--spacing-base), 1.6vw, var(--spacing-lg)) var(--spacing-md);
  }

  .genre-directory--expanded .genre-directory__copy {
    gap: var(--spacing-xs);
  }

  .genre-directory--expanded .genre-directory__description {
    max-inline-size: 56ch;
    margin-block-start: var(--spacing-sm);
    line-height: 1.6;
  }

  .genre-directory--expanded .genre-directory__visual {
    gap: var(--spacing-base);
  }

  .genre-directory--expanded .genre-directory__fallback {
    inline-size: 3.5rem;
    block-size: 3.5rem;
    color: var(--genre-directory-accent);
  }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .genre-directory__link,
    .genre-directory__title,
    .genre-directory__cover {
      transition:
        color var(--motion-duration-fast) var(--motion-ease-standard),
        background-color var(--motion-duration-fast) var(--motion-ease-standard),
        transform var(--motion-duration-fast) var(--motion-ease-standard);
    }

    .genre-directory__link:hover .genre-directory__cover,
    .genre-directory__link:focus-visible .genre-directory__cover {
      transform: translateY(-0.1rem);
    }
  }

  @media (width <= 760px) {
    .genre-directory__list {
      grid-template-columns: minmax(0, 1fr);
      column-gap: 0;
    }

    .genre-directory__link {
      min-block-size: 5.5rem;
      padding-block: var(--spacing-md);
      padding-inline: var(--spacing-sm);
    }

    .genre-directory--expanded .genre-directory__link {
      min-block-size: 8.5rem;
      padding-block: var(--spacing-lg);
      padding-inline: var(--spacing-sm);
    }
  }

  @media (width <= 520px) {
    .genre-directory__link {
      gap: var(--spacing-sm);
    }

    .genre-directory__visual {
      gap: var(--spacing-sm);
    }

    .genre-directory__covers {
      min-inline-size: 5.5rem;
    }

    .genre-directory__cover {
      inline-size: 2.6rem;
      block-size: 2.6rem;
      margin-inline-start: -1.15rem;
    }

    .genre-directory--expanded .genre-directory__link,
    .genre-directory--expanded .genre-directory__visual {
      gap: var(--spacing-sm);
    }

    .genre-directory--expanded .genre-directory__fallback {
      inline-size: 2.75rem;
      block-size: 2.75rem;
    }
  }
</style>
