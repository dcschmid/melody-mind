---
import SectionHeader from "@components/layout/SectionHeader.astro";
import { getAlbumVisibleCountLabel } from "./albumGridLabels";

interface Props {
  controlsLabel: string;
  idPrefix: string;
  initialGenreValue: string;
  initialSortValue: string;
  initialVisibleAlbumCount: number;
  newestFirstLabel: string;
  sortAlphabeticallyLabel: string;
  sortByLabel: string;
  title: string;
}

const {
  controlsLabel,
  idPrefix,
  initialGenreValue,
  initialSortValue,
  initialVisibleAlbumCount,
  newestFirstLabel,
  sortAlphabeticallyLabel,
  sortByLabel,
  title,
} = Astro.props;

const headingId = `${idPrefix}-heading`;
---

<section class="genre-filter" aria-labelledby={headingId}>
  <SectionHeader headingId={headingId} title={title} iconName="disc">
    <div class="genre-filter__summary">
      <form class="genre-filter__controls" aria-label={controlsLabel} data-album-controls>
        <label class="genre-filter__sort">
          <span class="genre-filter__sort-label">{sortByLabel}</span>
          <select
            class="genre-filter__sort-select"
            name="album-sort"
            aria-controls="albums-list"
            data-album-sort
          >
            <option value="date" selected={initialSortValue === "date"}>
              {newestFirstLabel}
            </option>
            <option value="title" selected={initialSortValue === "title"}>
              {sortAlphabeticallyLabel}
            </option>
          </select>
        </label>
      </form>
      <p
        class="genre-filter__results"
        aria-live="polite"
        aria-atomic="true"
        data-album-results
      >
        {getAlbumVisibleCountLabel(initialVisibleAlbumCount, initialGenreValue)}
      </p>
    </div>
  </SectionHeader>
</section>

<style>
  .genre-filter {
    display: grid;
    gap: var(--spacing-sm, 0.5rem);
  }

  .genre-filter :global(.section-header) {
    align-items: center;
  }

  .genre-filter__summary {
    display: flex;
    flex: 0 1 auto;
    gap: clamp(1rem, 2.4vw, 2rem);
    align-items: center;
    justify-content: flex-end;
    min-inline-size: min(100%, 24rem);
  }

  .genre-filter__controls {
    display: flex;
    flex: 0 0 auto;
    justify-content: flex-end;
  }

  .genre-filter__sort {
    display: inline-flex;
    gap: var(--spacing-sm, 0.5rem);
    align-items: center;
    min-block-size: 2.15rem;
  }

  .genre-filter__sort-label {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--music-home-muted);
  }

  .genre-filter__sort-select {
    display: inline-flex;
    align-items: center;
    min-block-size: 2.15rem;
    padding: 0.45rem var(--spacing-md, 0.75rem);
    font: inherit;
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--music-home-muted);
    cursor: pointer;
    background: color-mix(in srgb, var(--music-home-paper) 64%, transparent);
    border: 1px solid var(--music-home-line);
    border-radius: 999px;
  }

  .genre-filter__results {
    flex: 0 0 auto;
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: 700;
    line-height: 1.2;
    color: var(--music-home-muted);
    white-space: nowrap;
  }

  .genre-filter__sort-select:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  @media (width <= 760px) {
    .genre-filter :global(.section-header) {
      align-items: flex-start;
    }

    .genre-filter__summary {
      flex: 1 1 100%;
      flex-wrap: wrap;
      gap: 0.65rem 1rem;
      justify-content: space-between;
      min-inline-size: 0;
    }

    .genre-filter__controls {
      flex: 1 1 auto;
      justify-content: stretch;
    }

    .genre-filter__sort {
      flex: 1 1 auto;
      justify-content: space-between;
      min-inline-size: min(100%, 18rem);
    }

    .genre-filter__sort-select {
      min-inline-size: 0;
      max-inline-size: 12rem;
    }
  }
</style>
