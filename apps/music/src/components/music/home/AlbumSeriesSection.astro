---
import OptimizedImage from "@components/media/OptimizedImage.astro";
import SectionHeader from "@components/layout/SectionHeader.astro";
import Icon from "@components/visual/Icon.astro";
import type { Entry } from "./types";

interface AlbumSeriesItem {
  slug: string;
  title: string;
  eyebrow: string;
  shortDescription?: string;
  albums: Entry[];
}

interface Props {
  series: AlbumSeriesItem[];
  title: string;
  headingId?: string;
  showHeader?: boolean;
  showDescriptions?: boolean;
}

const {
  series,
  title,
  headingId = "album-series-heading",
  showHeader = true,
  showDescriptions = false,
} = Astro.props as Props;
---

{
  series.length > 0 && (
    <section
      class:list={[
        "series-directory",
        {
          "series-directory--expanded": showDescriptions,
          "series-directory--headerless": !showHeader,
        },
      ]}
      aria-labelledby={showHeader ? headingId : undefined}
      aria-label={showHeader ? undefined : title}
    >
      {showHeader && <SectionHeader {headingId} iconName="book-open" {title} />}

      <ul class="series-directory__list">
        {series.map((item) => {
          const covers = item.albums.slice(0, 3);
          const albumLabel = `${item.albums.length} ${item.albums.length === 1 ? "album" : "albums"}`;

          return (
            <li class="series-directory__item">
              <a
                class="series-directory__link"
                href={`/series/${item.slug}/`}
                aria-label={`${item.title}, ${albumLabel}`}
              >
                <span class="series-directory__copy">
                  <span class="series-directory__eyebrow">{item.eyebrow}</span>
                  <strong class="series-directory__title">{item.title}</strong>
                  <span class="series-directory__count">{albumLabel}</span>
                  {showDescriptions && item.shortDescription ? (
                    <span class="series-directory__description">
                      {item.shortDescription}
                    </span>
                  ) : null}
                </span>

                <span class="series-directory__visual" aria-hidden="true">
                  <span class="series-directory__covers">
                    {covers.map((album, index) => (
                      <span
                        class="series-directory__cover-step"
                        style={`--series-directory-cover-index: ${index};`}
                      >
                        <span class="series-directory__cover-number">
                          {String(index + 1).padStart(2, "0")}
                        </span>
                        <span class="series-directory__cover">
                          <OptimizedImage
                            src={album.imageSrc}
                            alt=""
                            width={72}
                            height={72}
                            widths={[48, 72, 96]}
                            sizes="3.25rem"
                            loading="lazy"
                            decoding="async"
                          />
                        </span>
                      </span>
                    ))}
                  </span>
                  <Icon name="chevron-right" class="series-directory__arrow" />
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </section>
  )
}

<style>
  .series-directory {
    --series-directory-accent: var(--music-home-accent, var(--accent-primary));
    --series-directory-ink: var(--music-home-ink, var(--text-primary));
    --series-directory-line: var(--music-home-line, var(--border-default));
    --series-directory-muted: var(--music-home-muted, var(--text-tertiary));
    --series-directory-paper: var(--music-home-paper, var(--surface-1));

    display: grid;
    gap: var(--spacing-base);
  }

  .series-directory__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(2rem, 5vw, 5rem);
    padding: 0;
    margin: 0;
    list-style: none;
    border-block-start: 1px solid var(--series-directory-line);
  }

  .series-directory--headerless .series-directory__list {
    border-block-start: 0;
  }

  .series-directory__item {
    min-inline-size: 0;
    border-block-end: 1px solid var(--series-directory-line);
  }

  .series-directory__link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--spacing-base);
    align-items: center;
    min-block-size: 6.5rem;
    padding: var(--spacing-sm) var(--spacing-xs);
    color: var(--series-directory-ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }

  .series-directory__copy {
    display: grid;
    gap: var(--spacing-2xs);
    min-inline-size: 0;
  }

  .series-directory__eyebrow,
  .series-directory__count {
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    white-space: nowrap;
  }

  .series-directory__eyebrow {
    color: var(--series-directory-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  .series-directory__title {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: var(--font-size-lg);
    line-height: 1.15;
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  .series-directory__count {
    color: var(--series-directory-muted);
  }

  .series-directory__description {
    display: -webkit-box;
    max-inline-size: 62ch;
    margin-block-start: var(--spacing-xs);
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: var(--font-size-sm);
    line-height: 1.5;
    color: var(--series-directory-muted);
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  .series-directory__visual {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: flex-end;
  }

  .series-directory__covers {
    display: flex;
    justify-content: flex-end;
    min-inline-size: 7.25rem;
    padding-inline-start: 1.35rem;
  }

  .series-directory__cover-step {
    position: relative;
    z-index: calc(3 - var(--series-directory-cover-index));
    display: block;
    margin-inline-start: -1.35rem;
  }

  .series-directory__cover-number {
    display: none;
  }

  .series-directory__cover {
    display: block;
    inline-size: 3.25rem;
    block-size: 3.25rem;
    overflow: hidden;
    background: var(--series-directory-paper);
    border: 1px solid color-mix(in srgb, var(--series-directory-ink) 16%, transparent);
    border-radius: var(--radius-sm);
  }

  .series-directory__cover :global(img) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .series-directory__arrow {
    flex: 0 0 auto;
    inline-size: 1rem;
    block-size: 1rem;
    color: var(--series-directory-accent);
  }

  .series-directory__link:hover,
  .series-directory__link:focus-visible {
    background: color-mix(in srgb, var(--series-directory-accent) 7%, transparent);
  }

  .series-directory__link:hover .series-directory__title,
  .series-directory__link:focus-visible .series-directory__title {
    color: var(--series-directory-accent);
  }

  .series-directory__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .series-directory--expanded {
    gap: var(--spacing-lg);
  }

  .series-directory--expanded .series-directory__link {
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    min-block-size: 10rem;
    padding: clamp(var(--spacing-base), 1.6vw, var(--spacing-lg)) var(--spacing-md);
  }

  .series-directory--expanded .series-directory__copy {
    gap: var(--spacing-xs);
  }

  .series-directory--expanded .series-directory__description {
    max-inline-size: 54ch;
    margin-block-start: var(--spacing-sm);
    line-height: 1.6;
  }

  .series-directory--expanded .series-directory__visual {
    gap: var(--spacing-lg);
  }

  .series-directory--expanded .series-directory__covers {
    gap: var(--spacing-xs);
    min-inline-size: auto;
    padding-inline-start: 0;
  }

  .series-directory--expanded .series-directory__cover-step {
    display: grid;
    gap: var(--spacing-2xs);
    margin-inline-start: 0;
  }

  .series-directory--expanded .series-directory__cover-number {
    display: block;
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--series-directory-accent);
  }

  .series-directory--expanded .series-directory__cover {
    inline-size: 3.75rem;
    block-size: 3.75rem;
    margin-inline-start: -1.65rem;
  }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .series-directory__link,
    .series-directory__title,
    .series-directory__cover {
      transition:
        color var(--motion-duration-fast) var(--motion-ease-standard),
        background-color var(--motion-duration-fast) var(--motion-ease-standard),
        transform var(--motion-duration-fast) var(--motion-ease-standard);
    }

    .series-directory__link:hover .series-directory__cover,
    .series-directory__link:focus-visible .series-directory__cover {
      transform: translateY(-0.1rem);
    }
  }

  @media (width <= 760px) {
    .series-directory__list {
      grid-template-columns: minmax(0, 1fr);
      column-gap: 0;
    }

    .series-directory__link {
      min-block-size: 6rem;
      padding-inline: 0;
    }

    .series-directory--expanded .series-directory__link {
      min-block-size: 9.5rem;
      padding-block: var(--spacing-lg);
      padding-inline: var(--spacing-sm);
    }
  }

  @media (width <= 520px) {
    .series-directory__link,
    .series-directory__visual {
      gap: var(--spacing-sm);
    }

    .series-directory__covers {
      min-inline-size: 5.75rem;
    }

    .series-directory__cover-step {
      margin-inline-start: -1.15rem;
    }

    .series-directory__cover {
      inline-size: 2.75rem;
      block-size: 2.75rem;
    }

    .series-directory--expanded .series-directory__link,
    .series-directory--expanded .series-directory__visual {
      gap: var(--spacing-sm);
    }

    .series-directory--expanded .series-directory__covers {
      min-inline-size: auto;
      padding-inline-start: 0;
    }

    .series-directory--expanded .series-directory__cover-step {
      margin-inline-start: 0;
    }

    .series-directory--expanded .series-directory__cover {
      inline-size: 2.75rem;
      block-size: 2.75rem;
    }
  }
</style>
