---
import FeatureLinkListSection from "./FeatureLinkListSection.astro";
import type { Entry } from "./types";

interface AlbumSeriesItem {
  slug: string;
  title: string;
  eyebrow: string;
  shortDescription: string;
  albums: Entry[];
}

interface Props {
  series: AlbumSeriesItem[];
  title: string;
}

const { series, title } = Astro.props as Props;
const items = series.map((item) => {
  const album = item.albums[0];

  return {
    id: `series-${item.slug}`,
    href: `/series/${item.slug}/`,
    eyebrow: item.eyebrow,
    title: item.title,
    description: item.shortDescription,
    metaIconName: "disc" as const,
    metaLabel: `${item.albums.length} ${item.albums.length === 1 ? "album" : "albums"}`,
    ...(album
      ? {
          image: {
            src: album.imageSrc,
            alt: `Cover art for the album ${album.title}`,
          },
        }
      : {}),
  };
});
---

<FeatureLinkListSection
  headingId="album-series-heading"
  iconName="book-open"
  {items}
  {title}
/>
