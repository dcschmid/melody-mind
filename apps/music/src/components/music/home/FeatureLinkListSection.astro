---
import Icon from "@components/visual/Icon.astro";
import OptimizedImage from "@components/media/OptimizedImage.astro";
import SectionHeader from "@components/layout/SectionHeader.astro";
import type { IconName } from "@components/visual/Icon.astro";
import type { CoverImage } from "./types";

interface FeatureLinkImage {
  src: CoverImage;
  alt: string;
}

interface FeatureLinkListItem {
  id: string;
  href: string;
  eyebrow: string;
  title: string;
  description: string;
  metaIconName: IconName;
  metaLabel: string;
  image?: FeatureLinkImage;
  iconName?: IconName;
}

interface Props {
  headingId: string;
  iconName: IconName;
  items: FeatureLinkListItem[];
  title: string;
}

const { headingId, iconName, items, title } = Astro.props as Props;
---

{
  items.length > 0 && (
    <section class="feature-link-list" aria-labelledby={headingId}>
      <SectionHeader {headingId} {title} {iconName} />

      <ul class="feature-link-list__list">
        {items.map((item) => (
          <li class="feature-link-list__item">
            <a
              id={item.id}
              class="feature-link-list__card"
              href={item.href}
              aria-labelledby={`${item.id}-title`}
            >
              <span class="feature-link-list__copy">
                <p class="feature-link-list__eyebrow">{item.eyebrow}</p>
                <h3 id={`${item.id}-title`} class="feature-link-list__title">
                  {item.title}
                </h3>
                <p class="feature-link-list__description">{item.description}</p>
                <span class="feature-link-list__meta">
                  <Icon name={item.metaIconName} aria-hidden="true" />
                  {item.metaLabel}
                </span>
              </span>

              <span class="feature-link-list__visual" aria-hidden="true">
                {item.image ? (
                  <span class="feature-link-list__cover-wrap">
                    <OptimizedImage
                      src={item.image.src}
                      alt={item.image.alt}
                      class="feature-link-list__image"
                      width={96}
                      height={96}
                      widths={[72, 96, 128]}
                      sizes="(max-width: 760px) 3.6rem, 5rem"
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                ) : (
                  item.iconName && (
                    <span class="feature-link-list__icon-shell">
                      <Icon name={item.iconName} class="feature-link-list__icon" />
                    </span>
                  )
                )}
                <Icon name="chevron-right" class="feature-link-list__arrow" />
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .feature-link-list {
    display: grid;
    gap: var(--spacing-base);
  }

  .feature-link-list__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-auto-rows: 1fr;
    gap: var(--spacing-base);
    align-items: stretch;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .feature-link-list__item {
    display: grid;
    align-self: stretch;
    min-inline-size: 0;
    min-block-size: 0;
  }

  .feature-link-list__card {
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(0.875rem, 1.5vw, 1.5rem);
    align-items: stretch;
    block-size: 100%;
    min-block-size: 8rem;
    padding: clamp(0.875rem, 1.5vw, 1.25rem);
    color: var(--music-home-ink);
    text-decoration: none;
    background: color-mix(in srgb, var(--music-home-paper) 76%, transparent);
    border: 1px solid var(--music-home-line);
    border-radius: var(--radius-md);
  }

  .feature-link-list__copy {
    display: grid;
    grid-template-rows: auto auto auto auto;
    gap: 0.45rem;
    align-content: start;
    min-inline-size: 0;
  }

  .feature-link-list__eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    color: var(--music-home-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .feature-link-list__title {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 3;
    font-family: var(--font-sans);
    font-size: clamp(1.3rem, 1.12rem + 0.65vw, 1.8rem);
    font-weight: var(--font-weight-semibold);
    line-height: 1.08;
    color: var(--music-home-ink);
    letter-spacing: 0;
    text-wrap: balance;
    -webkit-box-orient: vertical;
  }

  .feature-link-list__description {
    display: -webkit-box;
    max-inline-size: 76ch;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 4;
    font-size: clamp(var(--font-size-sm), 0.86rem + 0.35vw, var(--font-size-md));
    line-height: 1.48;
    color: var(--music-home-muted);
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  .feature-link-list__meta {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    margin-block-start: 0.15rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--music-home-accent);
  }

  .feature-link-list__card:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .feature-link-list__visual {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    align-self: center;
    justify-content: flex-end;
    min-inline-size: clamp(7rem, 12vw, 11rem);
    padding-inline-start: 0.5rem;
  }

  .feature-link-list__cover-wrap {
    display: block;
    inline-size: clamp(4rem, 5vw, 5rem);
  }

  .feature-link-list__image {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 1 / 1;
    outline: 1px solid oklch(100% 0 0deg / 0.16);
    outline-offset: -1px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    box-shadow: 0 0.7rem 1.8rem oklch(0% 0 0deg / 0.22);
  }

  .feature-link-list__icon-shell {
    display: grid;
    place-items: center;
    inline-size: clamp(4rem, 6vw, 5.4rem);
    block-size: clamp(4rem, 6vw, 5.4rem);
    color: var(--music-home-accent);
    background: color-mix(in srgb, var(--music-home-paper-soft) 72%, transparent);
    border: 1px solid color-mix(in srgb, var(--music-home-accent) 34%, transparent);
    border-radius: var(--radius-md);
    box-shadow: 0 0.8rem 2rem oklch(0% 0 0deg / 0.18);
  }

  .feature-link-list__icon {
    inline-size: clamp(1.45rem, 2.4vw, 2rem);
    block-size: clamp(1.45rem, 2.4vw, 2rem);
  }

  .feature-link-list__arrow {
    flex: 0 0 auto;
    color: var(--music-home-accent);
  }

  .feature-link-list__card:hover .feature-link-list__title,
  .feature-link-list__card:focus-visible .feature-link-list__title {
    color: var(--music-home-accent);
  }

  @media (hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
    .feature-link-list__card,
    .feature-link-list__cover-wrap,
    .feature-link-list__icon-shell,
    .feature-link-list__title {
      transition:
        color var(--motion-duration-fast) var(--motion-ease-standard),
        transform var(--motion-duration-fast) var(--motion-ease-standard),
        border-color var(--motion-duration-fast) var(--motion-ease-standard);
    }

    .feature-link-list__card:hover .feature-link-list__cover-wrap,
    .feature-link-list__card:focus-visible .feature-link-list__cover-wrap {
      transform: translateY(-0.12rem);
    }

    .feature-link-list__card:hover .feature-link-list__icon-shell,
    .feature-link-list__card:focus-visible .feature-link-list__icon-shell {
      border-color: color-mix(in srgb, var(--music-home-accent) 68%, transparent);
      transform: translateY(-0.12rem);
    }
  }

  @media (width <= 760px) {
    .feature-link-list__list {
      grid-template-columns: minmax(0, 1fr);
      grid-auto-rows: auto;
      gap: var(--spacing-sm);
    }

    .feature-link-list__card {
      block-size: auto;
      min-block-size: 7.5rem;
      padding: 1rem;
    }

    .feature-link-list__copy {
      grid-template-rows: auto;
    }

    .feature-link-list__description {
      display: -webkit-box;
      overflow: hidden;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 3;
    }

    .feature-link-list__visual {
      min-inline-size: 5.75rem;
    }

    .feature-link-list__cover-wrap {
      inline-size: 3.6rem;
    }

    .feature-link-list__icon-shell {
      inline-size: 3.6rem;
      block-size: 3.6rem;
    }

    .feature-link-list__icon {
      inline-size: 1.35rem;
      block-size: 1.35rem;
    }
  }

  @media (width <= 520px) {
    .feature-link-list__card {
      gap: 0.85rem;
    }

    .feature-link-list__visual {
      min-inline-size: 4.75rem;
      padding-inline-start: 0;
    }

    .feature-link-list__cover-wrap {
      inline-size: 3.2rem;
    }
  }
</style>
