---
import OptimizedImage from "@components/media/OptimizedImage.astro";
import Icon from "@components/visual/Icon.astro";
import type { CoverImage } from "../home/types";

interface Fact {
  label: string;
  value: string | number;
}

interface Props {
  coverImage: CoverImage;
  coverImageHeight?: number;
  coverImageWidth?: number;
  description: string;
  facts: Fact[];
  id: string;
  title: string;
}

const { coverImage, coverImageHeight, coverImageWidth, description, facts, id, title } =
  Astro.props;

const genreFact = facts.find((fact) => fact.label === "Genre");
const visibleFacts = facts.filter(
  (fact) => fact.label !== "Genre" && fact.label !== "Tracks"
);
const titleId = `album-page-title-${id}`;
const getFactIcon = (label: string) => {
  switch (label) {
    case "Genre":
      return "disc";
    case "Mood":
      return "sparkles";
    case "Language":
      return "globe";
    case "Tracks":
      return "music";
    case "Length":
      return "clock";
    default:
      return "info";
  }
};
---

<section class="album-hero" id={`album-hero-${id}`} aria-labelledby={titleId}>
  <div class="album-hero__lockup">
    <figure class="album-hero__cover-lockup">
      <OptimizedImage
        src={coverImage}
        alt={`Cover art for the album ${title}`}
        class="album-hero__cover-image"
        width={coverImageWidth || 900}
        height={coverImageHeight || 900}
        loading="eager"
        decoding="async"
        widths={[224, 424, 640, 848]}
        sizes="(max-width: 420px) 7rem, (max-width: 760px) 8.6rem, min(46vw, 26.5rem)"
        fetchpriority="high"
        formats={["avif"]}
      />
    </figure>

    <div class="album-hero__title-panel">
      {
        genreFact && (
          <p class="album-hero__eyebrow">
            <Icon name="disc" class="album-hero__eyebrow-icon" aria-hidden="true" />
            {genreFact.value}
          </p>
        )
      }
      <h1 class="album-hero__title" id={titleId}>{title}</h1>
    </div>

    <p class="album-hero__description">{description}</p>

    <ul class="album-hero__facts" aria-label="Album facts">
      {
        visibleFacts.map((fact) => (
          <li class="album-hero__fact" aria-label={`${fact.label}: ${fact.value}`}>
            <Icon
              name={getFactIcon(fact.label)}
              class="album-hero__fact-icon"
              aria-hidden="true"
            />
            <span class="album-hero__fact-value" aria-hidden="true">
              {fact.value}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .album-hero {
    --album-hero-accent: var(--music-album-accent, var(--accent-primary));
    --album-hero-ink: var(--music-album-ink, var(--text-primary));
    --album-hero-muted: var(--music-album-muted, var(--text-secondary));
    --album-hero-line: var(--music-album-line, var(--surface-border-soft));
    --album-hero-cover-radius: var(--radius-md);
    --album-hero-cover-shadow: var(--shadow-xl);
    --album-hero-cover-shadow-mobile: var(--shadow-lg);

    position: relative;
    box-sizing: border-box;
    display: grid;
    inline-size: 100%;
    min-inline-size: 0;
    min-block-size: min(37rem, calc(100svh - 4.5rem));
    padding: max(clamp(1.25rem, 4vw, 3rem), 5.35rem) clamp(1.25rem, 5vw, 4.5rem)
      clamp(1.25rem, 4vw, 3rem);
    overflow: hidden;
    isolation: isolate;
  }

  .album-hero__lockup {
    display: grid;
    gap: clamp(var(--spacing-base), 2.2vw, var(--spacing-xl))
      clamp(var(--spacing-lg), 5vw, calc(var(--spacing-3xl) + var(--spacing-xs)));
    align-items: center;
    inline-size: 100%;
    min-inline-size: 0;
    max-inline-size: 86rem;
    margin-inline: auto;
  }

  .album-hero__cover-lockup {
    position: relative;
    display: grid;
    justify-self: center;
    inline-size: min(100%, 26.5rem);
    min-inline-size: 0;
    margin: 0;
    overflow: hidden;
    background: var(--music-album-paper, var(--surface-panel-bg));
    border: 1px solid color-mix(in srgb, var(--album-hero-accent) 38%, transparent);
    border-radius: var(--album-hero-cover-radius);
    box-shadow:
      var(--album-hero-cover-shadow),
      0 0 4rem color-mix(in srgb, var(--album-hero-accent) 34%, transparent),
      0 1.5rem 5rem color-mix(in srgb, var(--album-hero-accent) 22%, transparent);
  }

  .album-hero__cover-lockup :global(.album-hero__cover-image) {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 1 / 1;
    outline: 1px solid rgb(255 255 255 / 10%);
    outline-offset: -1px;
    object-fit: cover;
  }

  .album-hero__title-panel {
    display: grid;
    gap: clamp(var(--spacing-sm), 1vw, var(--spacing-base));
    align-content: center;
    min-inline-size: 0;
  }

  .album-hero__eyebrow {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    inline-size: fit-content;
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: 800;
    line-height: 1;
    color: var(--album-hero-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .album-hero__eyebrow-icon {
    flex: 0 0 auto;
  }

  .album-hero__title {
    max-inline-size: 13ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2.45rem, 1.9rem + 2.35vw, 4.45rem);
    font-weight: 500;
    line-height: 0.96;
    color: var(--album-hero-ink);
    letter-spacing: 0;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .album-hero__description {
    max-inline-size: 58ch;
    margin: 0;
    font-size: var(--font-size-base);
    line-height: 1.6;
    color: var(--album-hero-muted);
    text-wrap: pretty;
    overflow-wrap: anywhere;
  }

  .album-hero__facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-base) clamp(var(--spacing-base), 2.6vw, var(--spacing-xl));
    align-items: center;
    padding: var(--spacing-base) 0 0;
    margin: 0;
    color: var(--album-hero-muted);
    list-style: none;
    border-block-start: 1px solid
      color-mix(in srgb, var(--album-hero-line) 86%, transparent);
  }

  .album-hero__fact {
    position: relative;
    display: inline-grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--spacing-sm);
    align-items: center;
    min-inline-size: 0;
  }

  .album-hero__fact + .album-hero__fact::before {
    position: absolute;
    inset-block: 0.12rem;
    inset-inline-start: calc(clamp(var(--spacing-base), 2.6vw, var(--spacing-xl)) / -2);
    inline-size: 1px;
    content: "";
    background: color-mix(in srgb, var(--album-hero-line) 74%, transparent);
  }

  .album-hero__fact-icon {
    inline-size: clamp(1rem, 0.96rem + 0.16vw, 1.12rem);
    block-size: clamp(1rem, 0.96rem + 0.16vw, 1.12rem);
    color: var(--album-hero-accent);
  }

  .album-hero__fact-value {
    min-inline-size: 0;
    font-size: var(--font-size-sm);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.18;
    color: var(--album-hero-ink);
    overflow-wrap: anywhere;
  }

  @media (width <= 760px) {
    .album-hero {
      inline-size: 100vw;
      max-inline-size: 100vw;
      min-block-size: auto;
      padding: 5.35rem 1rem 0.8rem;
    }

    .album-hero__lockup {
      grid-template-columns: minmax(6.75rem, 38vw) minmax(0, 1fr);
      gap: var(--spacing-sm);
      place-items: start;
      inline-size: calc(100vw - 2rem);
      max-inline-size: calc(100vw - 2rem);
    }

    .album-hero__cover-lockup {
      grid-row: 1 / span 2;
      justify-self: start;
      inline-size: 100%;
      max-inline-size: 8.6rem;
      border-radius: var(--radius-base);
      box-shadow: var(--album-hero-cover-shadow-mobile);
    }

    .album-hero__title-panel {
      grid-column: 2;
      gap: var(--spacing-sm);
      align-content: start;
      inline-size: 100%;
      min-inline-size: 0;
      max-inline-size: 100%;
      min-block-size: 100%;
    }

    .album-hero__eyebrow {
      font-size: var(--font-size-xs);
    }

    .album-hero__title {
      max-inline-size: 100%;
      font-size: clamp(1.18rem, 5.4vw, 1.55rem);
      font-weight: 600;
      line-height: 1.02;
      text-wrap: balance;
      overflow-wrap: break-word;
      white-space: normal;
    }

    .album-hero__description {
      grid-column: 1 / -1;
      max-inline-size: 100%;
      font-size: var(--font-size-sm);
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .album-hero__facts {
      grid-column: 1 / -1;
      gap: var(--spacing-sm) var(--spacing-base);
      inline-size: 100%;
      max-inline-size: calc(100vw - 2rem);
      padding-block-start: var(--spacing-sm);
      margin-block-start: var(--spacing-2xs);
    }

    .album-hero__fact {
      min-inline-size: 0;
    }

    .album-hero__fact + .album-hero__fact::before {
      content: none;
    }

    .album-hero__fact-icon {
      inline-size: var(--icon-size-xs);
      block-size: var(--icon-size-xs);
    }

    .album-hero__fact-value {
      font-size: var(--font-size-xs);
      overflow-wrap: anywhere;
      white-space: normal;
    }
  }

  @media (width <= 420px) {
    .album-hero__facts {
      gap: var(--spacing-sm);
    }
  }

  @media (480px <= width <= 760px) {
    .album-hero__cover-lockup {
      grid-row: 1 / span 3;
    }

    .album-hero__description {
      grid-column: 2;
    }
  }

  @media (width < 820px) {
    .album-hero__title {
      max-inline-size: 100%;
    }
  }

  @media (width >= 820px) {
    .album-hero__lockup {
      grid-template-columns: minmax(17rem, 0.72fr) minmax(28rem, 1fr);
    }

    .album-hero__cover-lockup {
      grid-row: 1 / span 3;
    }

    .album-hero__title-panel,
    .album-hero__description,
    .album-hero__facts {
      grid-column: 2;
    }
  }

  @media (width >= 1120px) {
    .album-hero__facts {
      flex-wrap: nowrap;
    }
  }
</style>
