---
interface Props {
  pageId: string;
  pageTitle: string;
  pageUrl: string;
}

const { pageId, pageTitle, pageUrl } = Astro.props as Props;
const titleId = `album-comments-${pageId}`;
---

<section class="album-comments" aria-labelledby={titleId} data-album-comments>
  <div class="album-comments__header">
    <p class="album-comments__eyebrow">Community</p>
    <h2 id={titleId} class="album-comments__title">
      Comments
      <span class="album-comments__count" data-album-comments-count hidden>
        <span data-cusdis-count-page-id={pageId}>...</span>
      </span>
    </h2>
    <p class="album-comments__text">
      Read or leave a comment about this album. Comments are provided by Cusdis and load
      only after you allow the comments feature.
    </p>
  </div>

  <div class="album-comments__consent" data-album-comments-consent>
    <p class="album-comments__consent-text">
      Enable comments to load the discussion from Cusdis.
    </p>
    <button class="album-comments__button" type="button" data-album-comments-enable>
      Enable comments
    </button>
    <button class="album-comments__settings-button" type="button" data-cc="manage">
      Privacy settings
    </button>
  </div>

  <div
    id="cusdis_thread"
    class="album-comments__thread"
    data-host="https://cusdis.com"
    data-app-id="dbe92e67-5333-4621-9ffb-959b17de6dc8"
    data-page-id={pageId}
    data-page-url={pageUrl}
    data-page-title={pageTitle}
    data-theme="dark"
    data-cusdis-thread
  >
  </div>

  <script
    is:inline
    type="text/plain"
    data-cc-category="comments"
    data-cc-src="https://cusdis.com/js/cusdis.es.js"
    async
    defer></script>

  <script
    is:inline
    type="text/plain"
    data-cc-category="comments"
    data-cc-src="https://cusdis.com/js/cusdis-count.umd.js"
    data-host="https://cusdis.com"
    data-app-id="dbe92e67-5333-4621-9ffb-959b17de6dc8"
    async
    defer></script>
</section>

<script>
  type ConsentApi = {
    get: () => { categories?: Record<string, boolean> } | null;
    set: (categories: Record<string, boolean>) => void;
  };

  const getConsentApi = (): ConsentApi | undefined =>
    (window as Window & { astroConsent?: ConsentApi }).astroConsent;

  const commentsRoot = document.querySelector("[data-album-comments]");

  if (commentsRoot) {
    const consentPanel = commentsRoot.querySelector("[data-album-comments-consent]");
    const enableButton = commentsRoot.querySelector("[data-album-comments-enable]");
    const commentCount = commentsRoot.querySelector("[data-album-comments-count]");
    const cusdisThread = commentsRoot.querySelector("[data-cusdis-thread]");

    const updateConsentPanel = () => {
      const hasCommentsConsent = getConsentApi()?.get()?.categories?.comments === true;
      consentPanel?.toggleAttribute("hidden", hasCommentsConsent);
      commentCount?.toggleAttribute("hidden", !hasCommentsConsent);
    };

    enableButton?.addEventListener("click", () => {
      getConsentApi()?.set({ comments: true });
      updateConsentPanel();
    });

    document.addEventListener("astro-consent:consent", updateConsentPanel);
    document.addEventListener("astro-consent:change", updateConsentPanel);
    updateConsentPanel();

    window.addEventListener("message", (event) => {
      if (!cusdisThread) {
        return;
      }

      try {
        const message = JSON.parse(event.data) as {
          from?: string;
          event?: string;
          data?: number;
        };

        if (
          message.from !== "cusdis" ||
          message.event !== "resize" ||
          typeof message.data !== "number"
        ) {
          return;
        }

        const resizeHeight = message.data;

        window.requestAnimationFrame(() => {
          const iframe = cusdisThread.querySelector("iframe");
          if (iframe) {
            iframe.style.height = `${resizeHeight + 96}px`;
          }
        });
      } catch {
        // Ignore unrelated postMessage traffic.
      }
    });
  }
</script>

<style>
  .album-comments {
    display: grid;
    gap: clamp(var(--spacing-base), 2vw, var(--spacing-lg));
    padding: clamp(var(--spacing-base), 2vw, var(--spacing-xl)) 0 0;
    color: var(--music-album-ink);
    scroll-margin-block-start: 6rem;
    border-block-start: 1px solid var(--music-album-line);
  }

  .album-comments__header {
    display: grid;
    gap: var(--spacing-xs);
    max-inline-size: 70ch;
  }

  .album-comments__eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    color: var(--music-album-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .album-comments__title {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    align-items: center;
    margin: 0;
    font-size: clamp(var(--font-size-md), 1.5vw, var(--font-size-lg));
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--music-album-ink);
    letter-spacing: var(--letter-spacing-normal);
    text-wrap: balance;
  }

  .album-comments__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 1.75rem;
    min-block-size: 1.5rem;
    padding: 0 var(--spacing-xs);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    color: var(--music-album-muted);
    background: color-mix(in srgb, var(--music-album-paper-soft) 56%, transparent);
    border: 1px solid color-mix(in srgb, var(--music-album-line) 74%, transparent);
    border-radius: var(--radius-base);
  }

  .album-comments__count[hidden] {
    display: none;
  }

  .album-comments__text,
  .album-comments__consent-text {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--music-album-muted);
    text-wrap: pretty;
  }

  .album-comments__consent {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-base);
    background: color-mix(in srgb, var(--music-album-paper-soft) 52%, transparent);
    border: 1px solid color-mix(in srgb, var(--music-album-line) 84%, transparent);
    border-radius: var(--radius-base);
  }

  .album-comments__consent[hidden] {
    display: none;
  }

  .album-comments__button,
  .album-comments__settings-button {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--music-album-ink);
    text-decoration: none;
    cursor: pointer;
    background: color-mix(in srgb, var(--music-album-paper) 78%, transparent);
    border: 1px solid color-mix(in srgb, var(--music-album-accent) 34%, transparent);
    border-radius: var(--radius-base);
  }

  .album-comments__button {
    color: var(--button-text-accent);
    background: var(--music-album-accent);
    border-color: var(--music-album-accent);
  }

  .album-comments__button:hover,
  .album-comments__button:focus-visible,
  .album-comments__settings-button:hover,
  .album-comments__settings-button:focus-visible {
    color: var(--button-text-accent);
    background: var(--accent-primary-hover);
    border-color: var(--accent-primary-hover);
  }

  .album-comments__button:focus-visible,
  .album-comments__settings-button:focus-visible {
    outline: var(--focus-ring-width) solid var(--music-album-accent);
    outline-offset: var(--focus-ring-offset);
  }

  .album-comments__thread {
    min-block-size: 32rem;
    overflow: visible;
  }

  .album-comments__thread :global(iframe) {
    display: block;
    min-block-size: clamp(32rem, 58vh, 46rem);
    color-scheme: dark;
    background: transparent;
  }

  @media screen and (prefers-reduced-motion: no-preference) {
    .album-comments__button,
    .album-comments__settings-button {
      transition:
        color var(--transition-fast),
        background-color var(--transition-fast),
        border-color var(--transition-fast),
        transform var(--transition-fast);
    }

    .album-comments__button:hover,
    .album-comments__button:focus-visible,
    .album-comments__settings-button:hover,
    .album-comments__settings-button:focus-visible {
      transform: translateY(-1px);
    }
  }

  @media (width <= 520px) {
    .album-comments__consent,
    .album-comments__button,
    .album-comments__settings-button {
      inline-size: 100%;
    }
  }
</style>
