---
import ShareSection from "@components/actions/ShareSection.astro";
import Icon from "@components/visual/Icon.astro";

interface Props {
  contentDescription: string;
  contentTitle: string;
  hasAlbumContent: boolean;
  /** Visually hides the first Markdown heading when page content already labels it. */
  hideFirstHeading?: boolean;
  shareUrl: string;
  zipUrl?: string | undefined;
}

const {
  contentDescription,
  contentTitle,
  hasAlbumContent,
  hideFirstHeading = false,
  shareUrl,
  zipUrl,
} = Astro.props;

const hasValidShareUrl = /^https?:\/\//i.test(shareUrl);
const shouldRenderDetails = hasAlbumContent || hasValidShareUrl;
---

{
  shouldRenderDetails && (
    <div class="album-detail-sections">
      {hasAlbumContent && (
        <article
          class:list={[
            "album-detail-sections__details",
            { "album-detail-sections__details--no-first-heading": hideFirstHeading },
          ]}
          aria-labelledby="album-content-heading"
        >
          <h2 id="album-content-heading" class="album-detail-sections__title">
            Liner Notes
          </h2>
          <p class="album-detail-sections__deck">
            A short editorial read on the album world, sound, and standout moments.
          </p>
          <div class="album-detail-sections__prose">
            <slot />
          </div>
        </article>
      )}

      {hasValidShareUrl && (
        <div class="album-detail-sections__share">
          <ShareSection
            id="album-share"
            shareUrl={shareUrl}
            contentTitle={contentTitle}
            contentDescription={contentDescription}
            title="Share this album"
            note="Copy the link or share it by email."
            copyAriaLabel="Copy link to this album"
          />
        </div>
      )}

      {zipUrl && (
        <section
          class="album-detail-sections__download"
          aria-labelledby="album-download-title"
        >
          <div class="album-detail-sections__download-copy">
            <p class="album-detail-sections__download-eyebrow">Full album download</p>
            <h2 id="album-download-title" class="album-detail-sections__download-title">
              Download the complete album
            </h2>
            <p class="album-detail-sections__download-text">
              Get the full ZIP package with tagged audio files, cover artwork, and album
              metadata.
            </p>
          </div>
          <div class="album-detail-sections__download-actions">
            <a
              href={zipUrl}
              download
              class="album-detail-sections__download-button"
              data-fathom-event={`Album Download: ${contentTitle}`}
              aria-label={`Download ${contentTitle} as a tagged album ZIP`}
            >
              <Icon
                name="download"
                class="album-detail-sections__download-icon"
                aria-hidden="true"
              />
              <span>Download album ZIP</span>
            </a>
          </div>
        </section>
      )}
    </div>
  )
}

<style>
  .album-detail-sections {
    --album-details-gap: clamp(var(--spacing-base), 2.5vw, var(--spacing-lg));
    --album-details-mobile-gap: clamp(var(--spacing-sm), 2vw, var(--spacing-base));
    --album-details-panel-padding: clamp(var(--spacing-base), 3vw, var(--spacing-lg));
    --album-details-mobile-inline-padding: var(--spacing-base);
    --album-details-prose-flow: calc(var(--spacing-base) + var(--spacing-2xs));
    --album-details-list-indent: calc(var(--spacing-lg) - var(--spacing-2xs));
    --album-details-radius: var(--radius-md);
    --album-details-panel-shadow:
      0 0 0 1px color-mix(in srgb, var(--music-album-ink) 8%, transparent),
      0 1rem 2rem oklch(5% 0.02 255deg / 0.28);
    --album-details-prose-color: color-mix(
      in srgb,
      var(--music-album-ink) 76%,
      var(--music-album-muted)
    );

    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--album-details-gap);
    align-items: start;
  }

  .album-detail-sections__details {
    min-block-size: 0;
    padding: clamp(var(--spacing-base), 2vw, var(--spacing-xl)) 0 0;
    background: transparent;
    border-block-start: 1px solid var(--music-album-line);
    border-radius: 0;
    box-shadow: none;
  }

  .album-detail-sections__title {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--music-album-ink);
    letter-spacing: var(--letter-spacing-normal);
    text-wrap: balance;
  }

  .album-detail-sections__deck {
    max-inline-size: 70ch;
    margin: var(--spacing-xs) 0 var(--spacing-base);
    font-size: var(--font-size-xs);
    line-height: 1.55;
    color: var(--music-album-muted);
    text-wrap: pretty;
  }

  .album-detail-sections__prose {
    max-inline-size: 86ch;
    font-size: clamp(var(--font-size-base), 1vw, var(--font-size-lg));
    line-height: var(--line-height-loose);
    color: var(--album-details-prose-color);
    text-wrap: pretty;
    overflow-wrap: break-word;
  }

  .album-detail-sections__prose :global(h2) {
    margin: 2rem 0 0.75rem;
    font-size: var(--font-size-md);
    line-height: var(--line-height-tight);
    color: var(--music-album-ink);
    text-wrap: balance;
  }

  .album-detail-sections__details--no-first-heading
    .album-detail-sections__prose
    :global(h2:first-child) {
    position: var(--sr-only, absolute);
    inline-size: var(--sr-only-width, 1px);
    block-size: var(--sr-only-height, 1px);
    padding: var(--sr-only-padding, 0);
    margin: var(--sr-only-margin, -1px);
    overflow: var(--sr-only-overflow, hidden);
    white-space: var(--sr-only-white-space, nowrap);
    border: var(--sr-only-border, 0);
    clip-path: var(--sr-only-clip-path, inset(50%));
  }

  .album-detail-sections__prose :global(p) {
    margin: 0 0 var(--album-details-prose-flow);
  }

  .album-detail-sections__prose :global(p:last-child) {
    margin-block-end: 0;
  }

  .album-detail-sections__prose :global(ul),
  .album-detail-sections__prose :global(ol) {
    padding-inline-start: var(--album-details-list-indent);
    margin: 0 0 var(--album-details-prose-flow);
  }

  .album-detail-sections__prose :global(li) {
    margin-block: 0.35rem;
  }

  .album-detail-sections__prose :global(blockquote) {
    padding: var(--spacing-sm) 0 var(--spacing-sm) var(--spacing-base);
    margin: var(--spacing-lg) 0;
    color: var(--music-album-ink);
    background: color-mix(in srgb, var(--music-album-paper-soft) 42%, transparent);
    border-inline-start: var(--spacing-2xs) solid var(--music-album-accent);
    border-radius: 0 var(--radius-base) var(--radius-base) 0;
  }

  .album-detail-sections__prose :global(blockquote > :last-child) {
    margin-block-end: 0;
  }

  .album-detail-sections__prose :global(code) {
    padding: var(--spacing-2xs) var(--spacing-xs);
    font-family: var(--font-mono);
    font-size: 1em;
    color: var(--music-album-ink);
    background: color-mix(in srgb, var(--music-album-paper-soft) 72%, transparent);
    border: 1px solid var(--music-album-line);
    border-radius: var(--radius-sm);
  }

  .album-detail-sections__prose :global(pre) {
    max-inline-size: 100%;
    padding: var(--spacing-base);
    margin: var(--spacing-lg) 0;
    overflow-x: auto;
    color: var(--music-album-ink);
    background: color-mix(in srgb, var(--music-album-paper-soft) 78%, transparent);
    border: 1px solid var(--music-album-line);
    border-radius: var(--radius-base);
  }

  .album-detail-sections__prose :global(pre code) {
    padding: 0;
    background: transparent;
    border: 0;
  }

  .album-detail-sections__prose :global(hr) {
    block-size: 1px;
    margin: var(--spacing-xl) 0;
    background: var(--music-album-line);
    border: 0;
  }

  .album-detail-sections__prose :global(a) {
    color: var(--music-album-accent);
    text-underline-offset: 0.16em;
  }

  .album-detail-sections__prose :global(a:focus-visible) {
    outline: var(--focus-ring-width) solid var(--music-album-accent);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  .album-detail-sections__share {
    align-self: start;
    color: var(--music-album-ink);
    scroll-margin-block-start: 6rem;
  }

  .album-detail-sections__share :global(.share-section) {
    padding-block: clamp(var(--spacing-base), 2vw, var(--spacing-xl)) 0;
    border-block-start: 1px solid var(--music-album-line);
  }

  .album-detail-sections__download {
    display: grid;
    gap: clamp(var(--spacing-base), 2vw, var(--spacing-lg));
    align-items: center;
    padding-block: clamp(var(--spacing-base), 2vw, var(--spacing-xl)) 0;
    color: var(--music-album-ink);
    scroll-margin-block-start: 6rem;
    border-block-start: 1px solid var(--music-album-line);
  }

  .album-detail-sections__download-copy {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .album-detail-sections__download-eyebrow {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    color: var(--music-album-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .album-detail-sections__download-title {
    margin: 0;
    font-size: clamp(var(--font-size-md), 1.5vw, var(--font-size-lg));
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    color: var(--music-album-ink);
    letter-spacing: var(--letter-spacing-normal);
    text-wrap: balance;
  }

  .album-detail-sections__download-text {
    max-inline-size: 62ch;
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--music-album-muted);
    text-wrap: pretty;
  }

  .album-detail-sections__download-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .album-detail-sections__download-button {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    justify-content: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--button-text-accent);
    text-decoration: none;
    background: var(--music-album-accent);
    border: 1px solid var(--music-album-accent);
    border-radius: var(--radius-base);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .album-detail-sections__download-button:hover,
  .album-detail-sections__download-button:focus-visible {
    background: var(--accent-primary-hover);
    border-color: var(--accent-primary-hover);
    transform: translateY(-1px);
  }

  .album-detail-sections__download-button:focus-visible {
    outline: var(--focus-ring-width) solid var(--music-album-accent);
    outline-offset: var(--focus-ring-offset);
  }

  .album-detail-sections__download-icon {
    flex: 0 0 auto;
    inline-size: var(--icon-size-sm);
    block-size: var(--icon-size-sm);
  }

  @media (width >= 880px) {
    .album-detail-sections__share :global(.share-section),
    .album-detail-sections__download {
      grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1fr);
      gap: clamp(var(--spacing-lg), 3vw, var(--spacing-2xl));
      align-items: end;
    }

    .album-detail-sections__share :global(.share-section__actions),
    .album-detail-sections__download-actions {
      justify-content: flex-end;
    }
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .album-detail-sections__download-button {
      transition: none;
    }

    .album-detail-sections__download-button:hover,
    .album-detail-sections__download-button:focus-visible {
      transform: none;
    }
  }

  @media (width <= 760px) {
    .album-detail-sections {
      gap: var(--album-details-mobile-gap);
    }

    .album-detail-sections__details {
      padding: 0;
      background: transparent;
      border-block-start: 0;
      border-radius: 0;
    }

    .album-detail-sections__title {
      padding: var(--album-details-mobile-inline-padding)
        var(--album-details-mobile-inline-padding) 0;
    }

    .album-detail-sections__deck {
      padding: 0 var(--album-details-mobile-inline-padding);
    }

    .album-detail-sections__prose {
      display: block;
      max-inline-size: 100%;
      padding: 0 var(--album-details-mobile-inline-padding) 0.85rem;
    }
  }
</style>
