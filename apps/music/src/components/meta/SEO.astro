---
import type {
  OpenGraphMeta,
  OpenGraphMusicMeta,
  StructuredDataObject,
  StructuredDataExtra,
  TwitterMeta,
} from "./seo.types";

interface AlternateLocaleLink {
  locale: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  imageAlt?: string;
  type?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  ogMusic?: OpenGraphMusicMeta;
  audioSrc?: string;
  audioType?: string;
  episodeNumber?: number;
  seriesName?: string;
  seriesUrl?: string;
  canonical?: string;
  robots?: string;
  noIndex?: boolean;
  noFollow?: boolean;
  prevUrl?: string;
  nextUrl?: string;
  disableAlternateLanguages?: boolean;
  structuredDataExtra?: StructuredDataExtra;
  authorName?: string;
  articleAuthor?: string;
  openGraph?: OpenGraphMeta;
  alternateLocales?: AlternateLocaleLink[];
  ogSiteName?: string;
  twitter?: TwitterMeta;
  twitterSite?: string;
  twitterUrl?: string;
}

const {
  title,
  description,
  keywords,
  image,
  imageWidth,
  imageHeight,
  imageType,
  imageAlt,
  type,
  ogMusic,
  audioSrc,
  audioType = "audio/mpeg",
  episodeNumber,
  seriesName,
  seriesUrl,
  canonical,
  robots,
  noIndex,
  noFollow,
  prevUrl,
  nextUrl,
  disableAlternateLanguages,
  publishDate,
  modifiedDate,
  structuredDataExtra,
  authorName,
  articleAuthor,
  openGraph,
  alternateLocales,
  ogSiteName,
  twitter,
  twitterSite,
  twitterUrl,
} = Astro.props as Props;

const isValidDate = (date: Date | undefined): date is Date =>
  date instanceof Date && !Number.isNaN(date.valueOf());

const isStructuredDataObject = (value: unknown): value is StructuredDataObject =>
  typeof value === "object" && value !== null && !Array.isArray(value);

const toOpenGraphType = (value: string | undefined): string | undefined => {
  switch (value) {
    case "podcastEpisode":
      return "article";
    case "musicPlaylist":
      return "music.playlist";
    default:
      return value;
  }
};

const escapeJsonForInlineScript = (json: string): string =>
  json
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026")
    .replace(/\u2028/g, "\\u2028")
    .replace(/\u2029/g, "\\u2029");

const toStructuredDataArray = (
  data: StructuredDataExtra | undefined
): StructuredDataObject[] => {
  if (!data) {
    return [];
  }

  return (Array.isArray(data) ? data : [data]).filter(isStructuredDataObject);
};

const hasStructuredDataType = (
  data: StructuredDataObject[],
  expectedType: string
): boolean =>
  data.some(function containsStructuredDataType(item): boolean {
    const type = item["@type"];
    if (Array.isArray(type) ? type.includes(expectedType) : type === expectedType) {
      return true;
    }

    const graph = item["@graph"];
    return Array.isArray(graph)
      ? graph.some(
          (entry) => isStructuredDataObject(entry) && containsStructuredDataType(entry)
        )
      : false;
  });

const publishedIso = isValidDate(publishDate) ? publishDate.toISOString() : undefined;
const modifiedIso = isValidDate(modifiedDate) ? modifiedDate.toISOString() : undefined;
const structuredDataObjects = toStructuredDataArray(structuredDataExtra);
const hasPodcastEpisodeStructuredData = hasStructuredDataType(
  structuredDataObjects,
  "PodcastEpisode"
);
const ogImageType = openGraph?.imageType || imageType;
const ogType = toOpenGraphType(openGraph?.type || type);
const shouldEmitAlternateLanguages = !disableAlternateLanguages;
const alternateLocaleLinks =
  shouldEmitAlternateLanguages && Array.isArray(alternateLocales)
    ? alternateLocales.filter((alternate): alternate is AlternateLocaleLink =>
        Boolean(alternate?.locale && alternate.href)
      )
    : [];
const podcastStructuredData =
  !hasPodcastEpisodeStructuredData &&
  title &&
  description &&
  canonical &&
  seriesName &&
  seriesUrl
    ? {
        "@context": "https://schema.org",
        "@type": "PodcastEpisode",
        name: title,
        description,
        url: canonical,
        partOfSeries: {
          "@type": "PodcastSeries",
          name: seriesName,
          url: seriesUrl,
        },
        ...(typeof episodeNumber === "number" ? { episodeNumber } : {}),
        ...(publishedIso ? { datePublished: publishedIso } : {}),
        ...(modifiedIso ? { dateModified: modifiedIso } : {}),
        ...(image ? { image } : {}),
        ...(audioSrc
          ? {
              audio: {
                "@type": "AudioObject",
                url: audioSrc,
                encodingFormat: audioType,
              },
            }
          : {}),
      }
    : undefined;
const fallbackRobots =
  noIndex || noFollow
    ? `${noIndex ? "noindex" : "index"},${noFollow ? "nofollow" : "follow"}`
    : undefined;
const robotsContent = robots || fallbackRobots;
---

{title && <title>{title}</title>}
{description && <meta name="description" content={description} />}
{
  Array.isArray(keywords) && keywords.length > 0 && (
    <meta name="keywords" content={keywords.join(", ")} />
  )
}

{authorName && <meta name="author" content={authorName} />}
{articleAuthor && <meta property="article:author" content={articleAuthor} />}
{canonical && <link rel="canonical" href={canonical} />}
{prevUrl && <link rel="prev" href={prevUrl} />}
{nextUrl && <link rel="next" href={nextUrl} />}

{robotsContent && <meta name="robots" content={robotsContent} />}

{publishedIso && <meta name="article:published_time" content={publishedIso} />}
{modifiedIso && <meta name="article:modified_time" content={modifiedIso} />}

{openGraph?.title && <meta property="og:title" content={openGraph.title} />}
{
  openGraph?.description && (
    <meta property="og:description" content={openGraph.description} />
  )
}
{ogType && <meta property="og:type" content={ogType} />}
{openGraph?.url && <meta property="og:url" content={openGraph.url} />}
{openGraph?.image && <meta property="og:image" content={openGraph.image} />}
{
  openGraph?.image && ogImageType && (
    <meta property="og:image:type" content={ogImageType} />
  )
}
{
  openGraph?.image && imageWidth && (
    <meta property="og:image:width" content={String(imageWidth)} />
  )
}
{
  openGraph?.image && imageHeight && (
    <meta property="og:image:height" content={String(imageHeight)} />
  )
}
{openGraph?.locale && <meta property="og:locale" content={openGraph.locale} />}
{
  alternateLocaleLinks.map(({ locale }) => (
    <meta property="og:locale:alternate" content={locale} />
  ))
}
{ogSiteName && <meta property="og:site_name" content={ogSiteName} />}
{openGraph?.image && imageAlt && <meta property="og:image:alt" content={imageAlt} />}
{audioSrc && <meta property="og:audio" content={audioSrc} />}
{audioSrc && <meta property="og:audio:secure_url" content={audioSrc} />}
{audioSrc && <meta property="og:audio:type" content={audioType} />}
{ogMusic?.creator && <meta property="music:creator" content={ogMusic.creator} />}
{ogMusic?.album && <meta property="music:album" content={ogMusic.album} />}
{ogMusic?.musician && <meta property="music:musician" content={ogMusic.musician} />}
{
  ogMusic?.releaseDate && (
    <meta property="music:release_date" content={ogMusic.releaseDate} />
  )
}
{ogMusic?.firstTrack && <meta property="music:song" content={ogMusic.firstTrack} />}
{
  typeof episodeNumber === "number" && (
    <meta name="episode:number" content={String(episodeNumber)} />
  )
}
{seriesName && <meta name="series:name" content={seriesName} />}
{seriesUrl && <meta name="series:url" content={seriesUrl} />}
{twitter?.card && <meta name="twitter:card" content={twitter.card} />}
{twitterUrl && <meta name="twitter:url" content={twitterUrl} />}
{twitter?.title && <meta name="twitter:title" content={twitter.title} />}
{
  twitter?.description && (
    <meta name="twitter:description" content={twitter.description} />
  )
}
{twitter?.image && <meta name="twitter:image" content={twitter.image} />}
{twitter?.image && imageAlt && <meta name="twitter:image:alt" content={imageAlt} />}
{twitter?.creator && <meta name="twitter:creator" content={twitter.creator} />}
{twitterSite && <meta name="twitter:site" content={twitterSite} />}

{
  alternateLocaleLinks.length > 0 && (
    <>
      {alternateLocaleLinks.map(({ locale, href }) => (
        <link rel="alternate" hreflang={locale} {href} />
      ))}
      {canonical && <link rel="alternate" hreflang="x-default" href={canonical} />}
    </>
  )
}

{
  (() => {
    const all = [
      ...structuredDataObjects,
      ...(podcastStructuredData ? [podcastStructuredData] : []),
    ];

    if (all.length === 0) {
      return null;
    }

    try {
      const cleaned = all.map((obj) => {
        const replacer = (_key: string, value: unknown) =>
          value instanceof Date && !Number.isNaN(value.valueOf())
            ? value.toISOString()
            : value;
        return escapeJsonForInlineScript(JSON.stringify(obj, replacer, 2));
      });

      return cleaned.map((jsonString) => (
        <script is:inline type="application/ld+json" set:html={jsonString} />
      ));
    } catch (e) {
      console.warn("[SEO] Failed to serialize structured data:", e);
      return null;
    }
  })()
}
