---
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { IconName } from "@shared-ui/components/visual/Icon.astro";

import melodyMindLogo from "../../assets/melody-mind-logo.webp";
import HeaderMobileExtras from "./HeaderMobileExtras.astro";
import HeaderNav from "./HeaderNav.astro";
import type { HeaderNavItem } from "./HeaderNav.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { getAvailableAlbums } from "../../utils/albums";
import { musicAppShellConfig } from "../../utils/appShellConfig";

const shellConfig = musicAppShellConfig;
const currentPath = `${Astro.url.pathname}${Astro.url.search}`;

const homeNavItem: HeaderNavItem = {
  href: "/",
  label: "Home",
  icon: "home",
};
const albumsNavItem: HeaderNavItem = {
  href: "/#albums-list",
  label: "Albums",
  icon: "music",
};
const genresNavItem: HeaderNavItem = {
  href: "/#genre-heading",
  label: "Genres",
  icon: "sparkles",
};
const latestReleasesNavItem: HeaderNavItem = {
  href: "/#latest-releases",
  label: "Latest Releases",
  icon: "sparkles",
};
const searchNavItem: HeaderNavItem = {
  href: "/?search=1",
  label: "Search",
  icon: "search",
};
const headerNavItems: HeaderNavItem[] = [
  homeNavItem,
  albumsNavItem,
  genresNavItem,
  ...shellConfig.header.navItems.map((item) => ({
    href: item.href,
    label: item.label,
    icon: item.icon as IconName,
    ...(item.target ? { target: item.target } : {}),
    ...(item.rel ? { rel: item.rel } : {}),
  })),
  searchNavItem,
  latestReleasesNavItem,
];

const availableAlbums = await getAvailableAlbums();
const mobileGenreLinks = Array.from(
  new Set(
    availableAlbums
      .map((album) => album.genre)
      .filter((genre): genre is string => Boolean(genre))
  )
)
  .sort((a, b) => a.localeCompare(b, "en", { sensitivity: "base" }))
  .slice(0, 4)
  .map((genre) => ({
    href: `/?genre=${encodeURIComponent(genre)}#albums-list`,
    label: genre,
  }));
---

<header class="music-site-header" data-music-site-header>
  <button
    class="music-site-header__backdrop"
    type="button"
    aria-label="Close main menu"
    aria-hidden="true"
    data-music-menu-close
  >
  </button>

  <div class="music-site-header__inner">
    <a class="music-site-header__brand" href="/" aria-label="Go to MelodyMind Music">
      <img
        class="music-site-header__logo"
        src={melodyMindLogo.src}
        width={melodyMindLogo.width}
        height={melodyMindLogo.height}
        alt="Melody Mind"
        loading="eager"
        decoding="async"
      />
    </a>

    <button
      class="music-site-header__toggle"
      type="button"
      aria-label="Open main menu"
      aria-expanded="false"
      data-music-menu-toggle
    >
      <Icon name="menu" class="music-site-header__toggle-icon" aria-hidden="true" />
      <span class="music-site-header__toggle-text">Menu</span>
    </button>

    <nav class="music-site-header__nav" aria-label="Music navigation" data-music-menu-nav>
      <HeaderNav
        items={headerNavItems}
        searchHref={searchNavItem.href}
        currentPath={currentPath}
      />

      <div class="music-site-header__actions">
        <span class="music-site-header__actions-label">Theme</span>
        <ThemeToggle />
      </div>

      <HeaderMobileExtras genreLinks={mobileGenreLinks} />
    </nav>
  </div>
</header>

<script>
  const headers = Array.from(
    document.querySelectorAll<HTMLElement>("[data-music-site-header]")
  ).filter((header) => header.dataset.bound !== "true");

  headers.forEach((header) => {
    header.dataset.bound = "true";

    const toggle = header.querySelector<HTMLButtonElement>("[data-music-menu-toggle]");
    const closeButtons = header.querySelectorAll<HTMLButtonElement>(
      "[data-music-menu-close]"
    );
    const drawer = header.querySelector<HTMLElement>(".music-site-header__inner");
    const nav = header.querySelector<HTMLElement>("[data-music-menu-nav]");
    const desktopQuery = window.matchMedia("(min-width: 1024px)");
    const focusableSelector =
      'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

    if (!toggle || !drawer || !nav) {
      return;
    }

    const getPageSiblings = (): HTMLElement[] =>
      Array.from(document.body.children).filter(
        (element): element is HTMLElement =>
          element instanceof HTMLElement && !element.contains(header)
      );

    const getFocusableElements = (): HTMLElement[] =>
      [
        toggle,
        ...Array.from(nav.querySelectorAll<HTMLElement>(focusableSelector)),
      ].filter((element) => element.offsetParent !== null);

    const setPageSiblingsInert = (inert: boolean) => {
      getPageSiblings().forEach((element) => {
        element.inert = inert;
      });
    };

    // The mobile drawer behaves as a modal menu: trap focus and inert page content.
    const setOpen = (open: boolean, restoreFocus = true) => {
      header.dataset.open = String(open);
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close main menu" : "Open main menu");
      document.body.classList.toggle("music-site-header-open", open);
      setPageSiblingsInert(open);
      drawer.toggleAttribute("role", open);
      drawer.toggleAttribute("aria-modal", open);
      drawer.toggleAttribute("aria-label", open);

      if (open) {
        drawer.setAttribute("role", "dialog");
        drawer.setAttribute("aria-modal", "true");
        drawer.setAttribute("aria-label", "Main menu");
      }

      closeButtons.forEach((button) => {
        button.setAttribute("aria-hidden", String(!open));
      });

      if (open) {
        requestAnimationFrame(() => {
          getFocusableElements()[1]?.focus();
        });
      } else if (restoreFocus) {
        toggle.focus();
      }
    };

    toggle.addEventListener("click", () => {
      setOpen(header.dataset.open !== "true");
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => setOpen(false));
    });

    nav.querySelectorAll("a[href]").forEach((link) => {
      link.addEventListener("click", () => setOpen(false, false));
    });

    window.addEventListener("keydown", (event) => {
      if (header.dataset.open === "true" && event.key === "Tab") {
        const focusableElements = getFocusableElements();
        const firstElement = focusableElements[0];
        const lastElement = focusableElements.at(-1);

        if (!firstElement || !lastElement) {
          return;
        }

        if (!header.contains(document.activeElement)) {
          event.preventDefault();
          firstElement.focus();
          return;
        }

        if (event.shiftKey && document.activeElement === firstElement) {
          event.preventDefault();
          lastElement.focus();
          return;
        }

        if (!event.shiftKey && document.activeElement === lastElement) {
          event.preventDefault();
          firstElement.focus();
        }
      }

      if (header.dataset.open === "true" && event.key === "Escape") {
        setOpen(false);
      }
    });

    desktopQuery.addEventListener("change", (event) => {
      if (event.matches) {
        setOpen(false, false);
      }
    });

    window.addEventListener("pagehide", () => {
      setOpen(false, false);
    });
  });
</script>

<style>
  .music-site-header {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 90;
    padding-inline: clamp(0.75rem, 3vw, 2rem);
  }

  .music-site-header--contrast,
  .music-site-header[data-header-contrast="scrim"] {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, oklch(0% 0 0deg) 42%, transparent),
      color-mix(in srgb, oklch(0% 0 0deg) 18%, transparent) 68%,
      transparent
    );
  }

  .music-site-header__inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.25rem, 3vw, 3rem);
    align-items: center;
    max-inline-size: 90rem;
    min-block-size: 4.25rem;
    margin-inline: auto;
  }

  .music-site-header__brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    min-block-size: 2.75rem;
    color: inherit;
    text-decoration: none;
  }

  .music-site-header__logo {
    display: block;
    inline-size: clamp(10rem, 14vw, 15rem);
    block-size: auto;
    aspect-ratio: 700 / 232;
    object-fit: contain;
    object-position: left center;
  }

  .music-site-header__toggle,
  .music-site-header__backdrop {
    display: none;
  }

  .music-site-header__nav {
    display: flex;
    gap: clamp(1.25rem, 3vw, 3rem);
    align-items: center;
    justify-content: flex-end;
    min-inline-size: 0;
  }

  .music-site-header__brand:focus-visible,
  .music-site-header__toggle:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .music-site-header__actions {
    flex: 0 0 auto;
  }

  .music-site-header__actions-label {
    display: none;
  }

  @media (width <= 1023.98px) {
    .music-site-header {
      --music-menu-panel-width: min(22.5rem, calc(100dvw - 2rem));
      --music-menu-bg-start: oklch(13% 0.048 258deg);
      --music-menu-bg-end: oklch(9% 0.034 252deg);
      --music-menu-bg-glow: oklch(47% 0.18 286deg / 0.34);
      --music-menu-text: oklch(96% 0.012 74deg);
      --music-menu-muted: oklch(76% 0.042 254deg);
      --music-menu-line: oklch(42% 0.067 252deg / 0.72);
      --music-menu-accent: oklch(69% 0.19 286deg);
      --music-menu-active-text: oklch(91% 0.072 296deg);
      --music-menu-active-bg: linear-gradient(
        90deg,
        oklch(34% 0.13 286deg / 0.72),
        oklch(28% 0.105 252deg / 0.7)
      );
      --music-menu-chip-bg: oklch(18% 0.052 252deg / 0.74);
      --music-menu-chip-border: oklch(48% 0.11 258deg / 0.72);
      --music-menu-cta-bg: linear-gradient(
        100deg,
        oklch(45% 0.16 292deg),
        oklch(44% 0.14 252deg)
      );
      --music-menu-cta-text: oklch(98% 0.014 75deg);
      --music-menu-cta-shadow: color-mix(
        in srgb,
        var(--music-menu-accent) 28%,
        transparent
      );

      padding-inline: 0;
    }

    :global([data-theme="light"]) .music-site-header {
      --music-menu-bg-start: oklch(98% 0.014 74deg);
      --music-menu-bg-end: oklch(95% 0.025 74deg);
      --music-menu-bg-glow: oklch(77% 0.11 24deg / 0.18);
      --music-menu-text: oklch(19% 0.026 42deg);
      --music-menu-muted: oklch(45% 0.032 43deg);
      --music-menu-line: oklch(83% 0.041 62deg);
      --music-menu-accent: oklch(46% 0.15 22deg);
      --music-menu-active-text: oklch(38% 0.14 18deg);
      --music-menu-active-bg: linear-gradient(
        90deg,
        oklch(91% 0.047 25deg),
        oklch(96% 0.022 62deg)
      );
      --music-menu-chip-bg: oklch(97% 0.014 72deg);
      --music-menu-chip-border: oklch(86% 0.042 44deg);
      --music-menu-cta-bg: linear-gradient(
        100deg,
        oklch(45% 0.17 18deg),
        oklch(45% 0.15 12deg)
      );
      --music-menu-cta-text: oklch(98% 0.014 75deg);
      --music-menu-cta-shadow: color-mix(
        in srgb,
        var(--music-menu-accent) 28%,
        transparent
      );
    }

    .music-site-header__inner {
      grid-template-columns: auto 1fr auto;
      min-block-size: 4.75rem;
      padding: 1rem 1.25rem;
    }

    .music-site-header__logo {
      inline-size: clamp(7.15rem, 31vw, 8.9rem);
    }

    .music-site-header__toggle {
      position: relative;
      z-index: 4;
      display: grid;
      grid-column: 3 / 4;
      place-items: center;
      inline-size: 2.75rem;
      block-size: 2.75rem;
      padding: 0;
      color: oklch(96% 0.012 72deg);
      cursor: pointer;
      background: oklch(10% 0.034 255deg / 0.52);
      border: 1px solid oklch(96% 0.012 72deg / 0.22);
      border-radius: 999px;
    }

    :global([data-theme="light"]) .music-site-header__toggle {
      color: oklch(39% 0.145 18deg);
      background: oklch(98% 0.014 74deg / 0.62);
      border-color: oklch(58% 0.08 32deg / 0.28);
    }

    .music-site-header__toggle-text {
      position: absolute;
      inline-size: 1px;
      block-size: 1px;
      overflow: hidden;
      white-space: nowrap;
      clip-path: inset(50%);
    }

    .music-site-header__toggle-icon {
      inline-size: 1.45rem;
      block-size: 1.45rem;
    }

    .music-site-header__backdrop {
      position: fixed;
      inset: 0;
      z-index: 1;
      display: block;
      visibility: hidden;
      inline-size: 100%;
      block-size: 100%;
      padding: 0;
      pointer-events: none;
      cursor: default;
      background: color-mix(in srgb, oklch(0% 0 0deg) 68%, transparent);
      border: 0;
      opacity: 0;
    }

    .music-site-header[data-open="true"] .music-site-header__backdrop {
      visibility: visible;
      pointer-events: auto;
      opacity: 0.58;
    }

    .music-site-header[data-open="true"] .music-site-header__inner {
      position: fixed;
      inset-block: 0;
      inset-inline: 0 auto;
      z-index: 2;
      box-sizing: border-box;
      display: block;
      inline-size: var(--music-menu-panel-width);
      max-block-size: 100dvh;
      padding: max(0.95rem, calc(env(safe-area-inset-top) + 0.8rem)) 1.05rem
        max(1.35rem, env(safe-area-inset-bottom));
      overflow-y: auto;
      overscroll-behavior: contain;
      background:
        radial-gradient(circle at 72% 91%, var(--music-menu-bg-glow), transparent 13rem),
        linear-gradient(180deg, var(--music-menu-bg-start), var(--music-menu-bg-end));
      border-inline-end: 1px solid var(--music-menu-line);
      box-shadow: 1.25rem 0 3.25rem oklch(0% 0 0deg / 0.3);
    }

    :global([data-theme="light"])
      .music-site-header[data-open="true"]
      .music-site-header__inner {
      background:
        radial-gradient(circle at 84% 84%, var(--music-menu-bg-glow), transparent 12rem),
        linear-gradient(180deg, var(--music-menu-bg-start), var(--music-menu-bg-end));
    }

    .music-site-header[data-open="true"] .music-site-header__brand {
      max-inline-size: min(10.5rem, calc(100% - 4.4rem));
    }

    .music-site-header[data-open="true"] .music-site-header__logo {
      inline-size: clamp(7.45rem, 32vw, 8.95rem);
    }

    .music-site-header[data-open="true"] .music-site-header__toggle {
      position: absolute;
      inset-block-start: max(0.95rem, calc(env(safe-area-inset-top) + 0.8rem));
      inset-inline: auto 1.05rem;
      color: var(--music-menu-text);
      background: transparent;
      border-color: transparent;
    }

    .music-site-header[data-open="true"] .music-site-header__toggle-icon {
      opacity: 0;
    }

    .music-site-header[data-open="true"] .music-site-header__toggle::before,
    .music-site-header[data-open="true"] .music-site-header__toggle::after {
      position: absolute;
      inline-size: 1.15rem;
      block-size: 0.11rem;
      content: "";
      background: currentcolor;
      border-radius: 999px;
    }

    .music-site-header[data-open="true"] .music-site-header__toggle::before {
      transform: rotate(45deg);
    }

    .music-site-header[data-open="true"] .music-site-header__toggle::after {
      transform: rotate(-45deg);
    }

    .music-site-header__nav {
      display: none;
    }

    .music-site-header[data-open="true"] .music-site-header__nav {
      display: grid;
      gap: 0.72rem;
      align-content: start;
      inline-size: 100%;
      min-inline-size: 0;
      padding-block-start: 1.35rem;
    }

    .music-site-header__actions {
      box-sizing: border-box;
      display: flex;
      align-items: center;
      justify-content: space-between;
      inline-size: 100%;
      min-inline-size: 0;
      min-block-size: 2.5rem;
      padding: 0.45rem 0.72rem;
      margin-block-start: 0.2rem;
      font-size: 1rem;
      color: var(--music-menu-text);
      border-radius: 0.55rem;
    }

    .music-site-header__actions-label {
      display: inline;
      font-size: 0.72rem;
      font-weight: 800;
      line-height: 1;
      color: var(--music-menu-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
  }

  @media (height <= 720px) and (width <= 1023.98px) {
    .music-site-header[data-open="true"] .music-site-header__nav {
      gap: 0.78rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .music-site-header__toggle {
      transition:
        background var(--motion-duration-fast) ease-out,
        border-color var(--motion-duration-fast) ease-out,
        color var(--motion-duration-fast) ease-out,
        transform var(--motion-duration-fast) ease-out;
    }

    .music-site-header__toggle:active {
      transform: scale(0.97);
    }

    .music-site-header__backdrop {
      transition: opacity 180ms ease-out;
    }
  }

  :global(body.music-site-header-open) {
    overflow: hidden;
  }
</style>
