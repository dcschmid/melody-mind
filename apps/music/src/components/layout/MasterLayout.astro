---
import SkipLink from "@components/navigation/SkipLink.astro";
import { ClientRouter } from "astro:transitions";
import "../../styles/master-theme.css";
import "../../styles/animations.css";

interface Props {
  lang?: string;
  dir?: string;
  bodyClass?: string;
  mainClass?: string;
  mainId?: string;
  contentShellClass?: string;
  showSkipLink?: boolean;
  enableAmbientMainBackground?: boolean;
  themeColor?: string;
  appTitle?: string;
  manifestPath?: string;
  faviconVersion?: string;
  faviconSvgPath?: string;
  googleSiteVerification?: string;
  appleMobileWebAppCapable?: boolean;
  appleMobileWebAppStatusBarStyle?: string;
}

const {
  lang = "en",
  dir = "ltr",
  bodyClass = "",
  mainClass = "",
  mainId = "main-content",
  contentShellClass = "",
  showSkipLink = true,
  enableAmbientMainBackground = false,
  themeColor = "#00050f",
  appTitle = "MelodyMind",
  manifestPath = "/site.webmanifest",
  faviconVersion,
  faviconSvgPath,
  googleSiteVerification = import.meta.env.GOOGLE_SITE_VERIFICATION || "",
  appleMobileWebAppCapable = true,
  appleMobileWebAppStatusBarStyle = "black-translucent",
} = Astro.props as Props;

const bodyClasses = ["app__body", bodyClass].filter(Boolean).join(" ");
const mainClasses = [
  "app__main",
  enableAmbientMainBackground ? "app__main--ambient" : "",
  mainClass,
]
  .filter(Boolean)
  .join(" ");
const contentShellClasses = (contentShellClass ?? "").trim();
const versionAssetPath = (path: string): string =>
  faviconVersion ? `${path}?v=${encodeURIComponent(faviconVersion)}` : path;
---

<!doctype html>
<html lang={lang} class="app" dir={dir} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content={themeColor} />
    {
      appleMobileWebAppCapable && (
        <meta name="apple-mobile-web-app-capable" content="yes" />
      )
    }
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content={appleMobileWebAppStatusBarStyle}
    />
    <link
      rel="icon"
      type="image/png"
      href={versionAssetPath("/favicon-96x96.png")}
      sizes="96x96"
    />
    {
      faviconSvgPath && (
        <link rel="icon" type="image/svg+xml" href={versionAssetPath(faviconSvgPath)} />
      )
    }
    <link
      rel="preload"
      href="/fonts/atkinson-hyperlegible-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/atkinson-hyperlegible-bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link rel="shortcut icon" href={versionAssetPath("/favicon.ico")} />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href={versionAssetPath("/apple-touch-icon.png")}
    />
    <meta name="apple-mobile-web-app-title" content={appTitle} />
    <meta name="google-site-verification" content={googleSiteVerification} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="x-content-type-options" content="nosniff" />
    <meta http-equiv="x-frame-options" content="SAMEORIGIN" />
    <meta http-equiv="x-xss-protection" content="1; mode=block" />
    <meta
      http-equiv="Permissions-Policy"
      content="camera=(), microphone=(), geolocation=()"
    />
    <link rel="manifest" href={manifestPath} />
    <ClientRouter fallback="swap" />
    <slot name="head" />
  </head>
  <body class={bodyClasses} transition:animate="none">
    {showSkipLink && <SkipLink targetId={mainId} />}
    <div class={contentShellClasses || undefined}>
      <slot name="body-start" />
      <slot name="before-main" />
      <main id={mainId} tabindex="-1" role="main" class={mainClasses}>
        <slot />
      </main>
      <slot name="after-main" />
      <slot name="body-end" />
    </div>
  </body>
</html>

<style>
  .app {
    color: var(--text-primary);
  }

  .app__body {
    position: relative;
    min-block-size: 100vb;
    margin: 0;
    overflow-x: clip;
    color: var(--text-primary);
    background: var(--page-background);
    background-color: var(--bg-primary);
  }

  .app__main {
    position: relative;
    min-block-size: 0;
    isolation: isolate;
  }

  .app__main--ambient::before {
    content: none;
  }

  .app__main--ambient::after {
    content: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .app__main--ambient::before,
    .app__main--ambient::after {
      opacity: 0;
    }
  }
</style>
