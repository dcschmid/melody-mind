---
import Paragraph from "@components/typography/Paragraph.astro";

// EmptyState stays intentionally small: callers pass copy and optional ARIA behavior.
interface Props extends astroHTML.JSX.HTMLAttributes {
  title?: string;
  description?: string;
  role?: "status" | "note" | "alert";
  live?: "off" | "polite" | "assertive";
  atomic?: boolean;
  className?: string;
  class?: string;
}

const {
  title,
  description,
  role = "note",
  live = "off",
  atomic = true,
  className = "",
  class: classProp = "",
  ...rest
} = Astro.props as Props;

// Preserve the shared block class while still allowing local extension hooks.
const classes = ["empty-state", className, classProp].filter(Boolean).join(" ");
const liveRegionAttributes =
  live === "off" ? {} : { "aria-live": live, "aria-atomic": atomic };
---

<div {...rest} {...liveRegionAttributes} class={classes} role={role}>
  {
    title ? (
      <Paragraph textSize="lg" class="empty-state__title">
        {title}
      </Paragraph>
    ) : null
  }
  {
    description ? (
      <Paragraph textSize="sm" class="empty-state__description">
        {description}
      </Paragraph>
    ) : null
  }
</div>

<style>
  .empty-state[hidden] {
    display: none;
  }

  .empty-state {
    padding: var(--spacing-2xl) var(--spacing-xl);
    color: var(--text-secondary);
    text-align: start;
    background: color-mix(in srgb, var(--accent-primary) 4%, var(--surface-panel-raised));
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
  }

  @media (width <= 480px) {
    .empty-state {
      padding: var(--spacing-xl) var(--spacing-lg);
    }
  }

  .empty-state:focus-visible,
  .empty-state:focus-within {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .empty-state__title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--accent-primary);
    letter-spacing: var(--letter-spacing-tight);
  }

  .empty-state__description {
    max-inline-size: var(--measure-readable);
    margin: var(--spacing-md) 0 0;
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .empty-state__description:first-child {
    margin-block-start: 0;
  }
</style>
