---
import Layout from "../layouts/Layout.astro";
import { resolvePageUrl } from "@utils/siteUrls";
import { getCollection, getEntry, render } from "astro:content";
import { getAlbumCoverImage, getAlbumCoverImageUrl } from "../utils/musicImages";
import { getAlbumDiscoveryMeta, getRelatedAlbums } from "../utils/albumDiscovery";
import { buildMusicAlbumSchema } from "../utils/musicSeo";
import type { Song } from "../types/album";
import type { CollectionEntry } from "astro:content";
import RelatedContentSection from "@components/cards/RelatedContentSection.astro";
import AlbumComments from "@components/music/album/AlbumComments.astro";
import AlbumWebmentions from "@components/music/album/AlbumWebmentions.astro";
import AlbumSupportSection from "@components/music/album/AlbumSupportSection.astro";
import Details from "@components/music/album/Details.astro";
import Hero from "@components/music/album/Hero.astro";
import Surface from "@components/music/album/Surface.astro";
import PlaylistPlayer from "@components/music/album/PlaylistPlayer.astro";
import type { RelatedContentCardItem } from "@components/cards/relatedContent";

type AlbumEntry = CollectionEntry<"albums">;

export async function getStaticPaths() {
  const collection = await getCollection(
    "albums",
    (entry: AlbumEntry) => entry.data.isAvailable
  );
  return collection.map((entry: AlbumEntry) => ({
    params: { album: entry.id },
  }));
}

const { album: albumId } = Astro.params;
const entry = albumId ? await getEntry("albums", albumId) : undefined;

if (!entry || !entry.data.isAvailable) {
  return Astro.redirect("/404");
}

const currentAlbum = entry.data;
const currentAlbumId = entry.id;
const canonical = resolvePageUrl(Astro.site, `/${albumId}/`);
const breadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: currentAlbum.title, url: canonical },
];

const songs = currentAlbum.songs as Song[];
const firstTrackAudioUrl = songs[0]?.audioUrl;
const totalDuration = songs.reduce(
  (acc: number, song: Song) => acc + (song.durationSeconds || 0),
  0
);
const pageDescription = `${currentAlbum.description} ${songs.length} tracks, ${Math.round(
  totalDuration / 60
)} minutes.`;

const albumCoverImage = getAlbumCoverImage(currentAlbum.coverImage);
const albumCoverImageUrl = getAlbumCoverImageUrl(currentAlbum.coverImage);
const albumCoverPlayerImageUrl =
  typeof albumCoverImage === "string" ? albumCoverImage : albumCoverImage.src;
const discoveryMeta = getAlbumDiscoveryMeta({
  id: currentAlbumId,
  ...currentAlbum,
  body: entry.body,
});
const albumFacts = [
  ...(currentAlbum.genre ? [{ label: "Genre", value: currentAlbum.genre }] : []),
  ...(discoveryMeta.moods.length
    ? [{ label: "Mood", value: discoveryMeta.moods.slice(0, 2).join(" · ") }]
    : []),
  ...(discoveryMeta.language
    ? [{ label: "Language", value: discoveryMeta.language }]
    : []),
  { label: "Tracks", value: songs.length },
  ...(totalDuration > 0
    ? [{ label: "Length", value: `${Math.round(totalDuration / 60)} min` }]
    : []),
];

const rawBody = entry.body || "";
const hasAlbumContent = rawBody.trim().length > 0;
const { Content } = await render(entry);
const structuredData = [
  buildMusicAlbumSchema({
    album: currentAlbum,
    canonical,
    coverImageUrl: albumCoverImageUrl,
    songs,
    totalDurationSeconds: totalDuration,
  }),
];

const allAlbums = await getCollection(
  "albums",
  (albumEntry: AlbumEntry) => albumEntry.data.isAvailable
);
const availableAlbums = allAlbums.map((albumEntry: AlbumEntry) => ({
  id: albumEntry.id,
  ...albumEntry.data,
  body: albumEntry.body,
}));
const relatedAlbums: RelatedContentCardItem[] = getRelatedAlbums(
  {
    id: currentAlbumId,
    ...currentAlbum,
    body: entry.body,
  },
  availableAlbums
).map((album) => {
  const imageSrc = getAlbumCoverImage(album.coverImage);
  const totalDurationSeconds = album.songs.reduce(
    (acc: number, song: Song) => acc + (song.durationSeconds || 0),
    0
  );

  return {
    id: album.id,
    href: `/${album.id}/`,
    title: album.title,
    description: album.description,
    imageSrc,
    imageAlt: `Cover art for the album ${album.title}`,
    metaItems: [
      ...(album.genre ? [{ iconName: "disc" as const, label: album.genre }] : []),
      { iconName: "music" as const, label: `${album.songs.length} tracks` },
      ...(totalDurationSeconds
        ? [
            {
              iconName: "clock" as const,
              label: `${Math.round(totalDurationSeconds / 60)} min`,
            },
          ]
        : []),
    ],
    ctaSrText: "Opens album",
  };
});
---

<Layout
  title={currentAlbum.title}
  description={pageDescription}
  type="musicAlbum"
  publishedTime={currentAlbum.publishedAt}
  modifiedTime={currentAlbum.publishedAt}
  image={albumCoverImageUrl}
  imageWidth={currentAlbum.coverImageWidth}
  imageHeight={currentAlbum.coverImageHeight}
  imageType="image/webp"
  ogMusic={{
    album: canonical,
    creator: currentAlbum.artist || "MelodyMind",
    musician: currentAlbum.artist || "MelodyMind",
    releaseDate: currentAlbum.publishedAt.toISOString(),
    ...(songs[0] ? { firstTrack: `${canonical}#track-${songs[0].trackNumber}` } : {}),
  }}
  {...firstTrackAudioUrl ? { audioSrc: firstTrackAudioUrl } : {}}
  language="en"
  locale="en-US"
  keywords={[
    currentAlbum.title.toLowerCase(),
    "ai music",
    "album",
    currentAlbum.genre?.toLowerCase() || "",
    "melodymind",
  ].filter(Boolean)}
  canonical={canonical}
  {breadcrumbs}
  {structuredData}
  mainClass="music-layout__main--album"
  contentShellClass="music-layout__container--album"
>
  <Surface>
    <Hero
      slot="hero"
      id={currentAlbumId}
      title={currentAlbum.title}
      description={currentAlbum.description}
      coverImage={albumCoverImage}
      coverImageWidth={currentAlbum.coverImageWidth}
      coverImageHeight={currentAlbum.coverImageHeight}
      facts={albumFacts}
    />

    <PlaylistPlayer
      id={`album-playlist-${currentAlbumId}`}
      albumId={currentAlbumId}
      albumUrl={`/${currentAlbumId}/`}
      albumTitle={currentAlbum.title}
      songs={songs}
      albumArtworkUrl={albumCoverPlayerImageUrl}
    />

    <Details
      hasAlbumContent={hasAlbumContent}
      hideFirstHeading
      shareUrl={canonical}
      contentTitle={currentAlbum.title}
      contentDescription={currentAlbum.description}
      zipUrl={currentAlbum.zipUrl}
    >
      <Content />
    </Details>

    <RelatedContentSection
      id="related-albums"
      eyebrow="Keep listening"
      title="Similar Albums"
      copy="Continue with albums that share mood, genre, or listening context."
      listAriaLabel="Similar albums"
      items={relatedAlbums}
      mediaObjectFit="cover"
    />

    <AlbumSupportSection albumTitle={currentAlbum.title} />

    <AlbumWebmentions pageUrl={canonical} />

    <AlbumComments
      pageId={currentAlbumId}
      pageUrl={canonical}
      pageTitle={currentAlbum.title}
    />
  </Surface>
</Layout>
