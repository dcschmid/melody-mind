---
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const pages = (await getCollection("genres")) as CollectionEntry<"genres">[];

  return pages.map((page) => ({
    params: { genre: page.id },
  }));
}

return Astro.redirect(`/genre/${Astro.params.genre}/`);
---
