---
import { resolvePageUrl } from "@utils/siteUrls";
import { buildOrganizationSchema } from "@utils/seo/seoSchema";
import { toAbsoluteAssetUrl } from "@utils/imageAssets";
import ContinueListening from "@components/music/home/ContinueListening.astro";
import GridSection from "@components/music/home/GridSection.astro";
import GenreFilterControls from "@components/music/home/GenreFilterControls.astro";
import LatestSection from "@components/music/home/LatestSection.astro";
import Hero from "@components/music/home/Hero.astro";
import Icon from "@components/visual/Icon.astro";
import { genreLandingPages } from "@data/genreLandingPages";
import type { CoverImage, Entry } from "@components/music/home/types";
import type { IconName } from "@components/visual/Icon.astro";
import Layout from "../layouts/Layout.astro";
import type { AlbumData } from "../types/album";

import { formatDuration } from "../utils/albumPresentation";
import { getAvailableAlbums } from "../utils/albums";
import {
  getAlbumCoverImage,
  getAlbumCoverImageUrl,
  musicDefaultOgImageUrl,
} from "../utils/musicImages";
import { buildMusicAlbumListSchema } from "../utils/musicSeo";
import melodyMindLogo from "../assets/melody-mind-logo.webp";

const albums: AlbumData[] = await getAvailableAlbums();
const albumTitleCollator = new Intl.Collator("en", {
  numeric: true,
  sensitivity: "base",
});
const compareAlbumsByTitle = (a: AlbumData, b: AlbumData) =>
  albumTitleCollator.compare(a.title, b.title) || albumTitleCollator.compare(a.id, b.id);
const compareAlbumsByDate = (a: AlbumData, b: AlbumData) =>
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime() ||
  compareAlbumsByTitle(a, b);
const DEFAULT_SORT_VALUE = "date";
const sortParamValue = Astro.url.searchParams.get("sort");
const hasFilterParams = Boolean(sortParamValue);
const initialSortValue = sortParamValue === "title" ? sortParamValue : DEFAULT_SORT_VALUE;
const initialGenreValue = "";
const sortedAlbumsByDate = [...albums].sort(compareAlbumsByDate);
const sortedAlbums =
  initialSortValue === "title"
    ? [...albums].sort(compareAlbumsByTitle)
    : sortedAlbumsByDate;

const isAlbumVisibleForGenre = (mainGenre?: string) =>
  !initialGenreValue || mainGenre === initialGenreValue;

const getImageSource = (image: CoverImage): string =>
  typeof image === "string" ? image : image.src;
const getImageWidth = (image: CoverImage): number | undefined =>
  typeof image === "string" ? undefined : image.width;
const getImageHeight = (image: CoverImage): number | undefined =>
  typeof image === "string" ? undefined : image.height;

const getFeaturedAlbums = (items: AlbumData[], featuredCount: number): AlbumData[] =>
  [...items]
    .sort((a, b) => {
      const aScore = Array.from(a.id).reduce(
        (score, char) => score + char.charCodeAt(0),
        0
      );
      const bScore = Array.from(b.id).reduce(
        (score, char) => score + char.charCodeAt(0),
        0
      );

      return aScore - bScore || compareAlbumsByDate(a, b);
    })
    .slice(0, featuredCount);

const albumEntries: Entry[] = sortedAlbums.map((album) => {
  const totalDurationSeconds = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  const imageSrc = getAlbumCoverImage(album.coverImage);

  return {
    id: album.id,
    title: album.title,
    description: album.description,
    imageSrc,
    imageUrl: getImageSource(imageSrc),
    imageWidth: getImageWidth(imageSrc),
    imageHeight: getImageHeight(imageSrc),
    publishedAt: album.publishedAt,
    publishedAtTime: new Date(album.publishedAt).getTime(),
    genre: album.genre,
    mainGenre: album.mainGenre,
    trackCount: album.songs.length,
    totalDurationSeconds,
    totalDurationLabel: totalDurationSeconds ? formatDuration(totalDurationSeconds) : "",
    isVisible: isAlbumVisibleForGenre(album.mainGenre),
  };
});
const albumEntriesById = new Map(albumEntries.map((album) => [album.id, album]));
const initialVisibleAlbumCount = albumEntries.filter((album) => album.isVisible).length;
const heroAlbums = getFeaturedAlbums(sortedAlbumsByDate, 5).map((album) => {
  const imageSrc = getAlbumCoverImage(album.coverImage);
  return {
    id: album.id,
    title: album.title,
    imageSrc,
    imageUrl: getImageSource(imageSrc),
    imageWidth: getImageWidth(imageSrc),
    imageHeight: getImageHeight(imageSrc),
  };
});
const latestReleaseShelf = sortedAlbumsByDate
  .map((album) => albumEntriesById.get(album.id))
  .filter((album): album is Entry => Boolean(album))
  .slice(0, 3);

const mainGenreIconBySlug: Record<string, IconName> = {
  rock: "guitar",
  metal: "zap",
  pop: "sparkles",
  punk: "flag",
  gothic: "moon",
  "hip-hop": "mic",
  folk: "leaf",
  latin: "sun",
  jazz: "music",
  soundtrack: "tv",
  classical: "book-open",
};

const canonical = resolvePageUrl(Astro.site, "/");
const breadcrumbs = [{ name: "Home", url: canonical }];

const t = {
  title: "MelodyMind Music",
  seoTitle: "MelodyMind Music | AI-Generated Albums",
  subtitle: "Curated albums for deep listening",
  description:
    "MelodyMind Music is a growing archive of full AI-assisted concept albums across rock, metal, punk, pop, gothic, cinematic and experimental genres.",
  editorialDeck:
    "Each album is built around a complete story, original lyrics, cover artwork and a distinct sound world — from political punk records and gothic rock journeys to cinematic metal operas and emotional pop concepts.",
  albums: "Album Shelf",
  albumControls: "Album controls",
  featured: "Featured Albums",
  latest: "From the New Shelf",
  continueListening: "Continue Listening",
  genre: "Browse the Archive",
  newestFirst: "Newest arrivals",
  sortAlphabetically: "A-Z",
  sortBy: "Order",
  exploreAlbums: "Browse Albums",
  latestReleases: "New Shelf",
  viewAll: "Full shelf",
  keywords: [
    "ai music",
    "generated music",
    "melodymind",
    "albums",
    "instrumental",
    "ambient",
  ],
};

const structuredData = [
  buildOrganizationSchema({
    siteUrl: canonical,
    siteName: "MelodyMind Music",
    description: t.description,
    logoUrl: toAbsoluteAssetUrl(melodyMindLogo, new URL(canonical).origin),
  }),
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${canonical.replace(/\/$/, "")}#website`,
    url: canonical.replace(/\/$/, ""),
    name: "MelodyMind Music",
    description: t.description,
    publisher: {
      "@id": `${canonical.replace(/\/$/, "")}#organization`,
    },
  },
  buildMusicAlbumListSchema({
    albums: sortedAlbumsByDate,
    canonical,
    description: t.description,
    site: Astro.site,
    getCoverImageUrl: getAlbumCoverImageUrl,
  }),
];
---

<Layout
  title={t.seoTitle}
  description={t.description}
  keywords={t.keywords}
  type="website"
  image={musicDefaultOgImageUrl}
  language="en"
  locale="en-US"
  canonical={canonical}
  index={!hasFilterParams}
  {breadcrumbs}
  {structuredData}
  contentShellClass="music-layout__container--home"
>
  <div class="music-home">
    <Hero
      albums={heroAlbums}
      eyebrow={t.subtitle}
      title={t.title}
      description={t.description}
      editorialDeck={t.editorialDeck}
      exploreAlbumsLabel={t.exploreAlbums}
      latestReleasesLabel={t.latestReleases}
    />

    <div class="music-home__content" data-home-reveal-root>
      <div data-home-reveal>
        <ContinueListening albums={albumEntries} title={t.continueListening} />
      </div>

      <div data-home-reveal>
        <LatestSection
          albums={latestReleaseShelf}
          title={t.latest}
          viewAllLabel={t.viewAll}
        />
      </div>

      <section
        class="music-home__main-genres"
        aria-labelledby="main-genres-title"
        data-home-reveal
      >
        <div class="music-home__main-genres-copy">
          <p class="music-home__main-genres-kicker">Main Genres</p>
          <h2 id="main-genres-title" class="music-home__main-genres-title">
            Browse the main shelves
          </h2>
        </div>
        <nav class="music-home__main-genres-list" aria-label="Main genre landing pages">
          {
            genreLandingPages.map((page) => (
              <a class="music-home__main-genre-link" href={`/genre/${page.slug}/`}>
                <Icon
                  name={mainGenreIconBySlug[page.slug] || "disc"}
                  class="music-home__main-genre-icon"
                  aria-hidden="true"
                />
                <span>{page.mainGenre}</span>
              </a>
            ))
          }
        </nav>
      </section>

      {
        albums.length > 0 && (
          <div data-home-reveal>
            <GenreFilterControls
              title={t.genre}
              controlsLabel={t.albumControls}
              idPrefix="genre"
              initialGenreValue={initialGenreValue}
              initialSortValue={initialSortValue}
              initialVisibleAlbumCount={initialVisibleAlbumCount}
              newestFirstLabel={t.newestFirst}
              sortAlphabeticallyLabel={t.sortAlphabetically}
              sortByLabel={t.sortBy}
            />
          </div>
        )
      }

      <div data-home-reveal>
        <GridSection
          albums={albumEntries}
          title={t.albums}
          emptyDescription="No albums are on the shelf yet. Check back soon for new listening notes and releases."
          headingId="genre-heading"
          initialVisibleAlbumCount={initialVisibleAlbumCount}
          initialGenreValue={initialGenreValue}
          showHeader={false}
        />
      </div>
    </div>
  </div>
</Layout>

<script>
  const revealTargets = Array.from(
    document.querySelectorAll<HTMLElement>("[data-home-reveal]")
  );
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (revealTargets.length > 0) {
    if (prefersReducedMotion || !("IntersectionObserver" in window)) {
      for (const target of revealTargets) {
        target.classList.add("is-revealed");
      }
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-revealed");
              obs.unobserve(entry.target);
            }
          }
        },
        { rootMargin: "0px 0px -12% 0px", threshold: 0.08 }
      );

      for (const target of revealTargets) {
        observer.observe(target);
      }
    }
  }
</script>

<style>
  :global(.music-layout__container) {
    max-inline-size: none;
    padding: 0;
    overflow-x: clip;
  }

  :global(.music-layout__main)::before {
    display: none;
  }

  .music-home {
    --music-home-accent: oklch(78% 0.16 286deg);
    --music-home-accent-strong: oklch(80% 0.13 252deg);
    --music-home-accent-warm: oklch(80% 0.13 32deg);
    --music-home-paper: oklch(18% 0.037 255deg);
    --music-home-paper-soft: oklch(22% 0.041 252deg);
    --music-home-ink: oklch(96% 0.012 72deg);
    --music-home-muted: oklch(76% 0.036 252deg);
    --music-home-line: oklch(36% 0.055 252deg);

    position: relative;
    inline-size: min(100%, 100vw);
    max-inline-size: 100vw;
    min-block-size: 100svh;
    overflow-x: clip;
    color: var(--music-home-ink);
    isolation: isolate;
  }

  /* Ambient glow fixed to the viewport so it never creates a seam mid-page. */
  .music-home::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background: radial-gradient(
      140vw 90vh at 50% -25%,
      oklch(78% 0.16 286deg / 0.14),
      oklch(80% 0.13 252deg / 0.05) 45%,
      transparent 80%
    );
  }

  .music-home,
  .music-home *,
  .music-home *::before,
  .music-home *::after {
    box-sizing: border-box;
  }

  .music-home__content {
    position: relative;
    display: grid;
    gap: clamp(1.35rem, 3vw, 2.35rem);
    max-inline-size: 90rem;
    padding: clamp(0.55rem, 1.4vw, 1.2rem) clamp(1rem, 4vw, 4rem) clamp(2rem, 6vw, 5rem);
    margin-inline: auto;
  }

  .music-home__content :global(#latest-releases) {
    margin-block: clamp(0.25rem, 1.2vw, 1rem) clamp(0.1rem, 0.8vw, 0.65rem);
  }

  @media (prefers-reduced-motion: no-preference) {
    .music-home__content :global([data-home-reveal]) {
      opacity: 0;
      transform: translateY(1.25rem);
      transition:
        opacity 620ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
      will-change: opacity, transform;
    }

    .music-home__content :global([data-home-reveal].is-revealed) {
      opacity: 1;
      transform: none;
    }
  }

  .music-home__main-genres {
    display: grid;
    gap: clamp(0.85rem, 1.8vw, 1.25rem);
    padding-block: clamp(0.85rem, 2vw, 1.25rem);
    border-block-end: 1px solid var(--music-home-line);
  }

  .music-home__main-genres-copy {
    display: grid;
    gap: 0.25rem;
  }

  .music-home__main-genres-kicker {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: 800;
    line-height: 1.2;
    color: var(--music-home-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .music-home__main-genres-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1.3rem, 1.08rem + 0.8vw, 1.9rem);
    font-weight: 650;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .music-home__main-genres-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.72rem clamp(1rem, 2.2vw, 1.65rem);
    justify-content: flex-start;
  }

  .music-home__main-genre-link {
    position: relative;
    display: inline-flex;
    gap: 0.42rem;
    align-items: center;
    min-block-size: 1.85rem;
    padding-block: 0.18rem 0.42rem;
    font-size: var(--font-size-xs);
    font-weight: 720;
    line-height: 1.1;
    color: var(--music-home-muted);
    text-decoration: none;
  }

  .music-home__main-genre-link::after {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 2px;
    content: "";
    background: var(--music-home-accent);
    opacity: 0.62;
    transform: scaleX(0.22);
    transform-origin: left;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .music-home__main-genre-icon {
    flex: 0 0 auto;
    inline-size: 0.95em;
    block-size: 0.95em;
    color: var(--music-home-accent);
  }

  .music-home__main-genre-link:hover,
  .music-home__main-genre-link:focus-visible {
    color: var(--music-home-ink);
  }

  .music-home__main-genre-link:hover::after,
  .music-home__main-genre-link:focus-visible::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .music-home__main-genre-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: 0.28rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .music-home__main-genre-link::after {
      transition: none;
    }
  }

  @media (width <= 760px) {
    .music-home {
      inline-size: 100%;
      max-inline-size: 100vw;
    }

    .music-home__content {
      gap: 1.2rem;
      inline-size: 100%;
      padding: 0.55rem 1rem clamp(2rem, 6vw, 5rem);
      overflow-x: clip;
    }

    .music-home__main-genres {
      gap: 0.85rem;
    }

    .music-home__main-genres-list {
      gap: 0.55rem 1rem;
    }
  }
</style>
