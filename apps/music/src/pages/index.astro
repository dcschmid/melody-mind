---
import MusicLayout from "../layouts/MusicLayout.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import DetailPill from "@shared-ui/components/data-display/DetailPill.astro";
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import SectionSurface from "@shared-ui/components/layout/SectionSurface.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";
import type { AlbumData } from "../types/album";

import { getAvailableAlbums } from "../utils/albums";
import {
  getAlbumCoverImage,
  getAlbumCoverImageUrl,
  musicHeroImage,
  musicHeroImageUrl,
} from "../utils/musicImages";
import { buildAlbumMetaItems } from "../utils/albumPresentation";
import { buildMusicAlbumListSchema } from "../utils/musicSeo";

const albums: AlbumData[] = await getAvailableAlbums();
const albumTitleCollator = new Intl.Collator("en", {
  numeric: true,
  sensitivity: "base",
});
const compareAlbumsByTitle = (a: AlbumData, b: AlbumData) =>
  albumTitleCollator.compare(a.title, b.title) || albumTitleCollator.compare(a.id, b.id);
const compareAlbumsByDate = (a: AlbumData, b: AlbumData) =>
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime() ||
  compareAlbumsByTitle(a, b);
const genreOptions = Array.from(
  new Set(
    albums.map((album) => album.genre).filter((genre): genre is string => Boolean(genre))
  )
).sort((a, b) => albumTitleCollator.compare(a, b));

const DEFAULT_SORT_VALUE = "date";
const sortParamValue = Astro.url.searchParams.get("sort");
const genreParamValue =
  Astro.url.searchParams.get("genre") ?? Astro.url.searchParams.get("album-genre");
const initialSortValue = sortParamValue === "title" ? sortParamValue : DEFAULT_SORT_VALUE;
const initialGenreValue =
  genreParamValue && genreOptions.includes(genreParamValue) ? genreParamValue : "";
const sortedAlbumsByDate = [...albums].sort(compareAlbumsByDate);
const sortedAlbums =
  initialSortValue === "title"
    ? [...albums].sort(compareAlbumsByTitle)
    : sortedAlbumsByDate;

const getVisibleCountLabel = (count: number, genre = "") => {
  if (count === 0) {
    return genre ? `No albums match ${genre}.` : "No albums match the current filters.";
  }

  return `${count} ${count === 1 ? "album" : "albums"}`;
};
const isAlbumVisibleForGenre = (genre?: string) =>
  !initialGenreValue || genre === initialGenreValue;

const albumEntries = sortedAlbums.map((album) => {
  const totalDuration = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  return {
    id: album.id,
    title: album.title,
    description: album.description,
    imageSrc: getAlbumCoverImage(album.coverImage),
    publishedAt: album.publishedAt,
    publishedAtTime: new Date(album.publishedAt).getTime(),
    metaItems: buildAlbumMetaItems(album.publishedAt, totalDuration),
    genre: album.genre,
    isVisible: isAlbumVisibleForGenre(album.genre),
  };
});
const initialVisibleAlbumCount = albumEntries.filter((album) => album.isVisible).length;

const canonical = resolvePageUrl(Astro.site, "/");
const breadcrumbs = [{ name: "Home", url: canonical }];

const t = {
  title: "MelodyMind Music",
  seoTitle: "MelodyMind Music | AI-Generated Albums",
  subtitle: "AI-Generated Music",
  description:
    "Explore original AI-generated music albums from MelodyMind. Each album features unique compositions across genres, with lyrics available for every track.",
  albums: "Albums",
  allGenres: "All genres",
  genre: "Genre",
  newestFirst: "Newest first",
  sortAlphabetically: "Alphabetical",
  sortBy: "Sort by",
  keywords: [
    "ai music",
    "generated music",
    "melodymind",
    "albums",
    "instrumental",
    "ambient",
  ],
};

const structuredData = [
  buildMusicAlbumListSchema({
    albums: sortedAlbumsByDate,
    canonical,
    description: t.description,
    site: Astro.site,
    getCoverImageUrl: getAlbumCoverImageUrl,
  }),
];
---

<MusicLayout
  title={t.seoTitle}
  description={t.description}
  keywords={t.keywords}
  type="website"
  image={musicHeroImageUrl}
  language="en"
  locale="en-US"
  canonical={canonical}
  {breadcrumbs}
  {structuredData}
>
  <PageShell>
    <Stack gap="xl">
      <HeroTeaser
        id="music-home-hero"
        class="home__hero"
        eyebrow={t.subtitle}
        title="MelodyMind Music"
        description={t.description}
        imageSrc={musicHeroImage}
        imageAlt="MelodyMind Music cover image"
        imageWidth={1200}
        imageHeight={800}
        imageLoading="eager"
        imageDecoding="sync"
        mediaAspectRatio="3 / 2"
        titleLevel="h1"
        titleMaxWidth="10ch"
        descriptionMaxWidth="38rem"
      />

      <SectionSurface as="section" variant="plain" aria-labelledby="albums-heading">
        <div class="home__albums-header">
          <div class="home__albums-title">
            <Headline id="albums-heading" level="h2" textSize="xl">
              {t.albums}
            </Headline>
            <p class="home__albums-deck">
              Recent MelodyMind releases, ordered for listening and browsing.
            </p>
          </div>

          {
            albums.length > 0 && (
              <p
                class="home__results"
                aria-live="polite"
                aria-atomic="true"
                data-album-results
              >
                {getVisibleCountLabel(initialVisibleAlbumCount, initialGenreValue)}
              </p>
            )
          }
        </div>

        {
          albums.length > 0 && (
            <form class="home__controls" aria-label="Album controls" data-album-controls>
              <label class="home__control">
                <span class="home__control-label">{t.sortBy}</span>
                <span class="home__select-wrap">
                  <Icon name="filter" class="home__control-icon" aria-hidden="true" />
                  <select
                    class="home__select"
                    name="album-sort"
                    aria-controls="albums-list"
                    data-album-sort
                  >
                    <option value="date" selected={initialSortValue === "date"}>
                      {t.newestFirst}
                    </option>
                    <option value="title" selected={initialSortValue === "title"}>
                      {t.sortAlphabetically}
                    </option>
                  </select>
                </span>
              </label>

              <label class="home__control">
                <span class="home__control-label">{t.genre}</span>
                <span class="home__select-wrap">
                  <Icon name="tag" class="home__control-icon" aria-hidden="true" />
                  <select
                    class="home__select"
                    name="album-genre"
                    aria-controls="albums-list"
                    data-album-genre
                  >
                    <option value="" selected={initialGenreValue === ""}>
                      {t.allGenres}
                    </option>
                    {genreOptions.map((genre) => (
                      <option value={genre} selected={initialGenreValue === genre}>
                        {genre}
                      </option>
                    ))}
                  </select>
                </span>
              </label>
            </form>
          )
        }

        <AutoGrid preset="fill" min="lg" gap="lg" role="list" id="albums-list">
          {
            albumEntries.map((album) => (
              <ContentCard
                id={`album-card-${album.id}`}
                data-album
                data-album-card
                data-album-title={album.title}
                data-album-published-at={album.publishedAtTime}
                data-album-card-genre={album.genre || ""}
                hidden={!album.isVisible}
                aria-hidden={album.isVisible ? "false" : "true"}
                role="listitem"
                href={`/${album.id}`}
                variant="feature"
                chrome="minimal"
                size="spacious"
                mediaAspectRatio="1 / 1"
                mediaObjectFit="cover"
                imageSrc={album.imageSrc}
                imageAlt={`Cover art for the album ${album.title}`}
                imageWidth={1200}
                imageHeight={1200}
                imageSizes="(max-width: 639px) calc(100vw - 2rem), (max-width: 1023px) calc((100vw - 5rem) / 2), (max-width: 1279px) calc((100vw - 8rem) / 3), 24rem"
                title={album.title}
                description={album.description}
                metaItems={album.metaItems}
                descriptionLineClamp={3}
                ctaLabel="Listen Now"
              >
                <Fragment slot="badge">
                  {album.genre && <DetailPill tone="neutral">{album.genre}</DetailPill>}
                </Fragment>
              </ContentCard>
            ))
          }
        </AutoGrid>
        {
          albums.length === 0 && (
            <EmptyState description="No albums available yet. Check back soon for new AI-generated music!" />
          )
        }
      </SectionSurface>
    </Stack>
  </PageShell>
</MusicLayout>

<script>
  const albumControls = document.querySelector("[data-album-controls]");
  const albumList = document.querySelector("#albums-list");

  if (albumControls instanceof HTMLFormElement && albumList instanceof HTMLElement) {
    const sortSelect = albumControls.querySelector("[data-album-sort]");
    const genreSelect = albumControls.querySelector("[data-album-genre]");
    const results = document.querySelector("[data-album-results]");
    const collator = new Intl.Collator("en", {
      numeric: true,
      sensitivity: "base",
    });
    const defaultSortValue = "date";
    const sortParamName = "sort";
    const genreParamName = "genre";

    const cards = Array.from(
      albumList.querySelectorAll("[data-album-card]")
    ) as HTMLElement[];

    const getVisibleCountLabel = (count: number, genreValue = "") => {
      if (count === 0) {
        return genreValue
          ? `No albums match ${genreValue}.`
          : "No albums match the current filters.";
      }

      return `${count} ${count === 1 ? "album" : "albums"}`;
    };

    const isValidSortValue = (value: string | null) =>
      value === "date" || value === "title";

    const isValidGenreValue = (value: string) => {
      if (!(genreSelect instanceof HTMLSelectElement)) {
        return false;
      }

      return Array.from(genreSelect.options).some((option) => option.value === value);
    };

    const applyControlsFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const sortValue = params.get(sortParamName);
      const genreValue = params.get(genreParamName) ?? params.get("album-genre");

      if (sortSelect instanceof HTMLSelectElement) {
        sortSelect.value = isValidSortValue(sortValue) ? sortValue : defaultSortValue;
      }

      if (genreSelect instanceof HTMLSelectElement) {
        const normalizedGenreValue = genreValue ?? "";
        genreSelect.value = isValidGenreValue(normalizedGenreValue)
          ? normalizedGenreValue
          : "";
      }
    };

    const syncUrlToControls = (sortValue: string, genreValue: string) => {
      const url = new URL(window.location.href);

      if (sortValue === defaultSortValue) {
        url.searchParams.delete(sortParamName);
      } else {
        url.searchParams.set(sortParamName, sortValue);
      }

      if (genreValue) {
        url.searchParams.set(genreParamName, genreValue);
      } else {
        url.searchParams.delete(genreParamName);
      }
      url.searchParams.delete("album-genre");

      window.history.replaceState(null, "", `${url.pathname}${url.search}${url.hash}`);
    };

    const updateAlbums = ({ syncUrl = false } = {}) => {
      const sortValue =
        sortSelect instanceof HTMLSelectElement ? sortSelect.value : defaultSortValue;
      const genreValue =
        genreSelect instanceof HTMLSelectElement ? genreSelect.value : "";

      const sortedCards = [...cards].sort((a, b) => {
        if (sortValue === "date") {
          const aDate = Number(a.dataset.albumPublishedAt || 0);
          const bDate = Number(b.dataset.albumPublishedAt || 0);
          return (
            bDate - aDate ||
            collator.compare(a.dataset.albumTitle || "", b.dataset.albumTitle || "")
          );
        }

        return collator.compare(a.dataset.albumTitle || "", b.dataset.albumTitle || "");
      });

      let visibleCount = 0;

      for (const card of sortedCards) {
        const isVisible = !genreValue || card.dataset.albumCardGenre === genreValue;
        card.toggleAttribute("hidden", !isVisible);
        card.setAttribute("aria-hidden", String(!isVisible));
        if (isVisible) {
          visibleCount += 1;
        }
        albumList.append(card);
      }

      if (results instanceof HTMLElement) {
        results.textContent = getVisibleCountLabel(visibleCount, genreValue);
      }

      if (syncUrl) {
        syncUrlToControls(sortValue, genreValue);
      }
    };

    albumControls.addEventListener("change", () => updateAlbums({ syncUrl: true }));
    window.addEventListener("popstate", () => {
      applyControlsFromUrl();
      updateAlbums();
    });
    applyControlsFromUrl();
    updateAlbums();
  }
</script>

<style>
  .home__hero {
    gap: clamp(var(--spacing-lg), 3vw, var(--spacing-2xl));
  }

  :global([data-album-card][hidden]) {
    display: none;
  }

  .home__albums-header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-base) var(--spacing-xl);
    align-items: end;
    justify-content: space-between;
  }

  .home__albums-title {
    display: grid;
    gap: var(--spacing-xs);
    max-inline-size: 42rem;
  }

  .home__albums-deck {
    max-inline-size: 58ch;
    margin: 0;
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .home__controls {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: end;
    justify-content: flex-start;
    inline-size: 100%;
  }

  .home__control {
    display: grid;
    flex: 1 1 13rem;
    gap: var(--spacing-xs);
    min-inline-size: min(100%, 13rem);
  }

  .home__control-label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .home__select-wrap {
    position: relative;
    display: grid;
    align-items: center;
  }

  .home__control-icon {
    position: absolute;
    inset-inline-start: var(--spacing-sm);
    color: var(--accent-primary);
    pointer-events: none;
  }

  .home__select {
    inline-size: 100%;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-sm) calc(var(--spacing-xl) + var(--spacing-xs))
      var(--spacing-sm) calc(var(--control-min-inline-size) + var(--spacing-xs));
    font: inherit;
    font-size: var(--font-size-base);
    color: var(--text-primary);
    cursor: pointer;
    background: var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  .home__select:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--accent-primary);
  }

  .home__results {
    flex: 0 0 auto;
    padding-block: var(--spacing-xs);
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
  }

  @media (width <= 640px) {
    .home__controls {
      align-items: stretch;
    }

    .home__control {
      flex-basis: 100%;
    }

    .home__albums-header {
      align-items: stretch;
    }

    .home__results {
      padding-block-end: 0;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .home__select {
      transition: border-color var(--motion-duration-fast) var(--motion-ease-standard);
    }
  }
</style>
