---
import MusicLayout from "../layouts/MusicLayout.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import DetailPill from "@shared-ui/components/data-display/DetailPill.astro";
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import SectionSurface from "@shared-ui/components/layout/SectionSurface.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";
import type { AlbumData } from "../types/album";

import { getAvailableAlbums } from "../utils/albums";
import {
  getAlbumCoverImage,
  musicHeroImage,
  musicHeroImageUrl,
} from "../utils/musicImages";
import { buildAlbumMetaItems } from "../utils/albumPresentation";

const albums: AlbumData[] = await getAvailableAlbums();
const sortedAlbums = [...albums].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);

const albumEntries = sortedAlbums.map((album, index) => {
  const totalDuration = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  return {
    id: album.id,
    title: album.title,
    description: album.description,
    imageSrc: getAlbumCoverImage(album.coverImage),
    publishedAt: album.publishedAt,
    isLatest: index === 0,
    metaItems: buildAlbumMetaItems(album.publishedAt, totalDuration),
    genre: album.genre,
  };
});

const canonical = resolvePageUrl(Astro.site, "/");
const breadcrumbs = [{ name: "Home", url: canonical }];

const t = {
  title: "MelodyMind Music",
  seoTitle: "MelodyMind Music | AI-Generated Albums",
  subtitle: "AI-Generated Music",
  description:
    "Explore original AI-generated music albums from MelodyMind. Each album features unique compositions across genres, with lyrics available for every track.",
  albums: "Albums",
  keywords: [
    "ai music",
    "generated music",
    "melodymind",
    "albums",
    "instrumental",
    "ambient",
  ],
};
---

<MusicLayout
  title={t.seoTitle}
  description={t.description}
  keywords={t.keywords}
  type="website"
  image={musicHeroImageUrl}
  language="en"
  locale="en-US"
  canonical={canonical}
  {breadcrumbs}
>
  <PageShell className="page-shell--aurora">
    <Stack gap="xl">
      <HeroTeaser
        id="music-home-hero"
        class="home__hero"
        eyebrow={t.subtitle}
        title="MelodyMind Music"
        description={t.description}
        imageSrc={musicHeroImage}
        imageAlt="MelodyMind Music cover image"
        imageWidth={1200}
        imageHeight={800}
        imageLoading="eager"
        imageDecoding="sync"
        mediaAspectRatio="3 / 2"
        titleLevel="h1"
        titleMaxWidth="10ch"
        descriptionMaxWidth="38rem"
      />

      <SectionSurface as="section" variant="plain" aria-labelledby="albums-heading">
        <Headline id="albums-heading" level="h2" textSize="xl">
          {t.albums}
        </Headline>

        <AutoGrid preset="fill" min="lg" gap="lg" role="list" id="albums-list">
          {
            albumEntries.map((album) => (
              <ContentCard
                id={`album-card-${album.id}`}
                data-album
                role="listitem"
                href={`/${album.id}`}
                variant="feature"
                chrome="minimal"
                size="spacious"
                mediaAspectRatio="1 / 1"
                mediaObjectFit="cover"
                imageSrc={album.imageSrc}
                imageAlt={`Cover art for the album ${album.title}`}
                imageWidth={1200}
                imageHeight={1200}
                title={album.title}
                description={album.description}
                metaItems={album.metaItems}
                descriptionLineClamp={3}
                ctaLabel="Listen Now"
              >
                <Fragment slot="badge">
                  {album.isLatest && <DetailPill tone="accent">Latest</DetailPill>}
                  {album.genre && <DetailPill tone="neutral">{album.genre}</DetailPill>}
                </Fragment>
              </ContentCard>
            ))
          }
        </AutoGrid>
        {
          albums.length === 0 && (
            <EmptyState description="No albums available yet. Check back soon for new AI-generated music!" />
          )
        }
      </SectionSurface>
    </Stack>
  </PageShell>
</MusicLayout>

<style>
  .home__hero {
    gap: clamp(var(--spacing-lg), 3vw, var(--spacing-2xl));
  }
</style>
