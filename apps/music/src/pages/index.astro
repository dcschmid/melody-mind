---
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";
import { buildOrganizationSchema } from "@shared-utils/utils/seo/seoSchema";
import { toAbsoluteAssetUrl } from "@shared-utils/utils/imageAssets";
import ContinueListening from "../components/home/ContinueListening.astro";
import GridSection from "../components/home/GridSection.astro";
import GenreFilterControls from "../components/home/GenreFilterControls.astro";
import LatestSection from "../components/home/LatestSection.astro";
import Hero from "../components/home/Hero.astro";
import type { CoverImage, Entry } from "../components/home/types";
import Layout from "../layouts/Layout.astro";
import type { AlbumData } from "../types/album";

import { formatDuration } from "../utils/albumPresentation";
import { getAvailableAlbums } from "../utils/albums";
import {
  getAlbumCoverImage,
  getAlbumCoverImageUrl,
  musicDefaultOgImageUrl,
} from "../utils/musicImages";
import { buildMusicAlbumListSchema } from "../utils/musicSeo";
import melodyMindLogo from "../assets/melody-mind-logo.webp";

const albums: AlbumData[] = await getAvailableAlbums();
const albumTitleCollator = new Intl.Collator("en", {
  numeric: true,
  sensitivity: "base",
});
const compareAlbumsByTitle = (a: AlbumData, b: AlbumData) =>
  albumTitleCollator.compare(a.title, b.title) || albumTitleCollator.compare(a.id, b.id);
const compareAlbumsByDate = (a: AlbumData, b: AlbumData) =>
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime() ||
  compareAlbumsByTitle(a, b);
const genreOptions = Array.from(
  new Set(
    albums.map((album) => album.genre).filter((genre): genre is string => Boolean(genre))
  )
).sort((a, b) => albumTitleCollator.compare(a, b));
const genreCounts = albums.reduce<Record<string, number>>((counts, album) => {
  if (album.genre) {
    counts[album.genre] = (counts[album.genre] || 0) + 1;
  }

  return counts;
}, {});
const totalGenreCount = albums.length;

const DEFAULT_SORT_VALUE = "date";
const FEATURED_RELEASE_ID = "blacktop-saints";
const sortParamValue = Astro.url.searchParams.get("sort");
const genreParamValue =
  Astro.url.searchParams.get("genre") ?? Astro.url.searchParams.get("album-genre");
const hasFilterParams = Boolean(sortParamValue || genreParamValue);
const initialSortValue = sortParamValue === "title" ? sortParamValue : DEFAULT_SORT_VALUE;
const initialGenreValue =
  genreParamValue && genreOptions.includes(genreParamValue) ? genreParamValue : "";
const sortedAlbumsByDate = [...albums].sort(compareAlbumsByDate);
const sortedAlbums =
  initialSortValue === "title"
    ? [...albums].sort(compareAlbumsByTitle)
    : sortedAlbumsByDate;

const isAlbumVisibleForGenre = (genre?: string) =>
  !initialGenreValue || genre === initialGenreValue;

const getImageSource = (image: CoverImage): string =>
  typeof image === "string" ? image : image.src;
const getImageWidth = (image: CoverImage): number | undefined =>
  typeof image === "string" ? undefined : image.width;
const getImageHeight = (image: CoverImage): number | undefined =>
  typeof image === "string" ? undefined : image.height;

const getFeaturedAlbums = (items: AlbumData[], featuredCount: number): AlbumData[] =>
  [...items]
    .sort((a, b) => {
      const aScore = Array.from(a.id).reduce(
        (score, char) => score + char.charCodeAt(0),
        0
      );
      const bScore = Array.from(b.id).reduce(
        (score, char) => score + char.charCodeAt(0),
        0
      );

      return aScore - bScore || compareAlbumsByDate(a, b);
    })
    .slice(0, featuredCount);

const albumEntries: Entry[] = sortedAlbums.map((album) => {
  const totalDurationSeconds = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  const imageSrc = getAlbumCoverImage(album.coverImage);

  return {
    id: album.id,
    title: album.title,
    description: album.description,
    imageSrc,
    imageUrl: getImageSource(imageSrc),
    imageWidth: getImageWidth(imageSrc),
    imageHeight: getImageHeight(imageSrc),
    publishedAt: album.publishedAt,
    publishedAtTime: new Date(album.publishedAt).getTime(),
    genre: album.genre,
    moodSummary: album.moods.slice(0, 2).join(" · "),
    trackCount: album.songs.length,
    totalDurationSeconds,
    totalDurationLabel: totalDurationSeconds ? formatDuration(totalDurationSeconds) : "",
    isVisible: isAlbumVisibleForGenre(album.genre),
  };
});
const initialVisibleAlbumCount = albumEntries.filter((album) => album.isVisible).length;
const heroAlbums = getFeaturedAlbums(sortedAlbumsByDate, 5).map((album) => {
  const imageSrc = getAlbumCoverImage(album.coverImage);
  return {
    id: album.id,
    title: album.title,
    imageSrc,
    imageUrl: getImageSource(imageSrc),
    imageWidth: getImageWidth(imageSrc),
    imageHeight: getImageHeight(imageSrc),
  };
});
const featuredRelease =
  albumEntries.find((album) => album.id === FEATURED_RELEASE_ID) || albumEntries[0];
const latestReleaseShelf = [
  ...(featuredRelease ? [featuredRelease] : []),
  ...albumEntries.filter((album) => album.id !== featuredRelease?.id),
].slice(0, 3);

const canonical = resolvePageUrl(Astro.site, "/");
const breadcrumbs = [{ name: "Home", url: canonical }];

const t = {
  title: "MelodyMind Music",
  seoTitle: "MelodyMind Music | AI-Generated Albums",
  subtitle: "Curated albums for deep listening",
  description:
    "A listening room for original albums with a strong sense of place: neon pop, storm-lit rock, folk ballads, club rhythms, and late-night instrumentals.",
  editorialDeck:
    "Browse by mood, genre, and cover art. Each release is framed like a small record review, with lyrics or track notes close at hand.",
  albums: "Album Shelf",
  allGenres: "Full Shelf",
  albumControls: "Album controls",
  featured: "Featured Albums",
  latest: "From the New Shelf",
  continueListening: "Continue Listening",
  genre: "Browse the Archive",
  genreFilterLabel: "Filter albums by genre",
  lessGenres: "Show fewer",
  moreGenres: "More genres",
  newestFirst: "Newest arrivals",
  selectedGenre: "Showing:",
  sortAlphabetically: "A-Z",
  sortBy: "Order",
  exploreAlbums: "Browse Albums",
  latestReleases: "New Shelf",
  listenNow: "Read & Listen",
  viewAll: "Full shelf",
  keywords: [
    "ai music",
    "generated music",
    "melodymind",
    "albums",
    "instrumental",
    "ambient",
  ],
};

const structuredData = [
  buildOrganizationSchema({
    siteUrl: canonical,
    siteName: "MelodyMind Music",
    description: t.description,
    logoUrl: toAbsoluteAssetUrl(melodyMindLogo, new URL(canonical).origin),
  }),
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${canonical.replace(/\/$/, "")}#website`,
    url: canonical.replace(/\/$/, ""),
    name: "MelodyMind Music",
    description: t.description,
    publisher: {
      "@id": `${canonical.replace(/\/$/, "")}#organization`,
    },
  },
  buildMusicAlbumListSchema({
    albums: sortedAlbumsByDate,
    canonical,
    description: t.description,
    site: Astro.site,
    getCoverImageUrl: getAlbumCoverImageUrl,
  }),
];
---

<Layout
  title={t.seoTitle}
  description={t.description}
  keywords={t.keywords}
  type="website"
  image={musicDefaultOgImageUrl}
  language="en"
  locale="en-US"
  canonical={canonical}
  index={!hasFilterParams}
  {breadcrumbs}
  {structuredData}
  contentShellClass="music-layout__container--home"
>
  <div class="music-home">
    <Hero
      albums={heroAlbums}
      eyebrow={t.subtitle}
      title={t.title}
      description={t.description}
      editorialDeck={t.editorialDeck}
      exploreAlbumsLabel={t.exploreAlbums}
      latestReleasesLabel={t.latestReleases}
    />

    <div class="music-home__content">
      <LatestSection
        albums={latestReleaseShelf}
        title={t.latest}
        viewAllLabel={t.viewAll}
      />

      <ContinueListening albums={albumEntries} title={t.continueListening} />

      {
        albums.length > 0 && (
          <GenreFilterControls
            title={t.genre}
            allGenresLabel={t.allGenres}
            controlsLabel={t.albumControls}
            genreFilterLabel={t.genreFilterLabel}
            genreOptions={genreOptions}
            genreCounts={genreCounts}
            totalGenreCount={totalGenreCount}
            idPrefix="music-home-genre-filter"
            initialGenreValue={initialGenreValue}
            initialSortValue={initialSortValue}
            lessGenresLabel={t.lessGenres}
            moreGenresLabel={t.moreGenres}
            newestFirstLabel={t.newestFirst}
            selectedGenreLabel={t.selectedGenre}
            sortAlphabeticallyLabel={t.sortAlphabetically}
            sortByLabel={t.sortBy}
          />
        )
      }

      <GridSection
        albums={albumEntries}
        title={t.albums}
        listenNowLabel={t.listenNow}
        emptyDescription="No albums are on the shelf yet. Check back soon for new listening notes and releases."
        initialVisibleAlbumCount={initialVisibleAlbumCount}
        initialGenreValue={initialGenreValue}
      />
    </div>
  </div>
</Layout>

<style>
  :global(.music-layout__container) {
    max-inline-size: none;
    padding: 0;
    overflow-x: clip;
  }

  :global(.music-layout__main)::before {
    display: none;
  }

  .music-home {
    --music-home-accent: oklch(40% 0.13 16deg);
    --music-home-accent-strong: oklch(38% 0.125 16deg);
    --music-home-paper: oklch(98% 0.014 75deg);
    --music-home-paper-soft: oklch(94% 0.032 70deg);
    --music-home-ink: oklch(19% 0.025 52deg);
    --music-home-muted: oklch(39% 0.033 55deg);
    --music-home-line: oklch(83% 0.043 67deg);

    inline-size: min(100%, 100vw);
    max-inline-size: 100vw;
    min-block-size: 100svh;
    overflow-x: clip;
    color: var(--music-home-ink);
    background:
      radial-gradient(circle at 92% 8%, oklch(90% 0.052 61deg / 0.34), transparent 36rem),
      linear-gradient(180deg, oklch(98% 0.016 75deg), oklch(94% 0.031 72deg));
  }

  .music-home,
  .music-home *,
  .music-home *::before,
  .music-home *::after {
    box-sizing: border-box;
  }

  :global([data-theme="dark"]) .music-home {
    --music-home-accent: oklch(78% 0.16 286deg);
    --music-home-accent-strong: oklch(80% 0.13 252deg);
    --music-home-paper: oklch(18% 0.037 255deg);
    --music-home-paper-soft: oklch(22% 0.041 252deg);
    --music-home-ink: oklch(96% 0.012 72deg);
    --music-home-muted: oklch(76% 0.036 252deg);
    --music-home-line: oklch(36% 0.055 252deg);

    background:
      radial-gradient(
        ellipse at 78% 20%,
        oklch(44% 0.179 303deg / 0.38),
        transparent 48rem
      ),
      radial-gradient(
        circle at 24% 12%,
        oklch(36% 0.143 252deg / 0.28),
        transparent 26rem
      ),
      linear-gradient(180deg, oklch(13% 0.038 255deg), oklch(9% 0.028 252deg));
  }

  .music-home__content {
    position: relative;
    display: grid;
    gap: clamp(1.35rem, 3vw, 2.35rem);
    max-inline-size: 90rem;
    padding: clamp(0.55rem, 1.4vw, 1.2rem) clamp(1rem, 4vw, 4rem) clamp(2rem, 6vw, 5rem);
    margin-inline: auto;
  }

  .music-home__content::before {
    position: absolute;
    inset-block-start: -2.5rem;
    inset-inline: 0;
    z-index: -1;
    block-size: 4rem;
    pointer-events: none;
    content: "";
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in srgb, var(--music-home-paper) 56%, transparent) 62%,
      transparent
    );
  }

  .music-home__content :global(#latest-releases) {
    margin-block: clamp(0.25rem, 1.2vw, 1rem) clamp(0.1rem, 0.8vw, 0.65rem);
  }

  :global([data-theme="dark"]) .music-home__content::before {
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in srgb, oklch(10% 0.032 252deg) 62%, transparent) 62%,
      transparent
    );
  }

  @media (width <= 760px) {
    .music-home {
      inline-size: 100%;
      max-inline-size: 100vw;
    }

    .music-home__content {
      gap: 1.2rem;
      inline-size: 100%;
      padding: 0.55rem 1rem clamp(2rem, 6vw, 5rem);
      overflow-x: clip;
    }
  }
</style>
