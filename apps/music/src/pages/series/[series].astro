---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ContentCard from "@components/cards/ContentCard.astro";
import OptimizedImage from "@components/media/OptimizedImage.astro";
import Layout from "../../layouts/Layout.astro";
import { resolvePageUrl } from "@utils/siteUrls";
import { buildCollectionPageSchema } from "@utils/seo/seoSchema";
import { formatDuration } from "../../utils/albumPresentation";
import { getAvailableAlbums } from "../../utils/albums";
import type { AlbumData } from "../../types/album";
import {
  getAlbumCoverImage,
  getAlbumCoverImageUrl,
  musicDefaultOgImageUrl,
} from "../../utils/musicImages";
import { buildMusicAlbumListSchema } from "../../utils/musicSeo";

type SeriesEntry = CollectionEntry<"series">;
interface SeriesPage {
  slug: string;
  order: number;
  title: string;
  eyebrow: string;
  shortDescription: string;
  keywords: string[];
  albumIds: string[];
}

interface SeriesAlbumCard {
  id: string;
  partNumber: number;
  title: string;
  description: string;
  imageSrc: ReturnType<typeof getAlbumCoverImage>;
  publishedAt: string;
  genre: string | undefined;
  trackCount: number;
  totalDurationLabel: string;
}

export async function getStaticPaths() {
  const pages = (await getCollection("series")) as SeriesEntry[];

  return pages.map((entry) => ({
    params: { series: entry.id },
    props: {
      entry,
    },
  }));
}

const { entry } = Astro.props as { entry: SeriesEntry };
const page: SeriesPage = {
  slug: entry.id,
  ...entry.data,
};
const { Content } = await render(entry);

const albums: AlbumData[] = await getAvailableAlbums();
const albumsById = new Map(albums.map((album) => [album.id, album]));
const seriesAlbums = page.albumIds
  .map((albumId) => albumsById.get(albumId))
  .filter((album): album is (typeof albums)[number] => Boolean(album));
const albumCards: SeriesAlbumCard[] = seriesAlbums.map((album, index) => {
  const totalDurationSeconds = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  const imageSrc = getAlbumCoverImage(album.coverImage);

  return {
    id: album.id,
    partNumber: index + 1,
    title: album.title,
    description: album.description,
    imageSrc,
    publishedAt: album.publishedAt,
    genre: album.genre,
    trackCount: album.songs.length,
    totalDurationLabel: totalDurationSeconds ? formatDuration(totalDurationSeconds) : "",
  };
});
const heroAlbums = albumCards.slice(0, 3);
const canonical = resolvePageUrl(Astro.site, `/series/${page.slug}/`);
const pageImage = seriesAlbums[0]?.coverImage
  ? getAlbumCoverImageUrl(seriesAlbums[0].coverImage)
  : musicDefaultOgImageUrl;
const breadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: page.title, url: canonical },
];
const structuredData = [
  buildCollectionPageSchema({
    url: canonical,
    name: page.title,
    description: page.shortDescription,
    lang: "en",
    image: pageImage,
    mainEntityId: `${canonical}#album-list`,
  }),
  buildMusicAlbumListSchema({
    albums: seriesAlbums,
    canonical,
    description: page.shortDescription,
    name: `${page.title} albums`,
    site: Astro.site,
    getCoverImageUrl: getAlbumCoverImageUrl,
  }),
];
const GRID_COVER_IMAGE_SIZES =
  "(max-width: 640px) 7.5rem, (max-width: 760px) 44vw, (max-width: 1180px) 28vw, min(18rem, calc((100vw - 10rem) / 5))";
---

<Layout
  title={`${page.title} | MelodyMind Music`}
  description={page.shortDescription}
  keywords={page.keywords}
  type="website"
  image={pageImage}
  language="en"
  locale="en-US"
  canonical={canonical}
  {breadcrumbs}
  {structuredData}
  contentShellClass="music-layout__container--series"
>
  <main class="series-landing" aria-labelledby="series-landing-title">
    <header class="series-landing__hero">
      <div class="series-landing__copy">
        <p class="series-landing__eyebrow">{page.eyebrow}</p>
        <h1 id="series-landing-title" class="series-landing__title">{page.title}</h1>
        <p class="series-landing__intro">{page.shortDescription}</p>
      </div>

      {
        heroAlbums.length > 0 && (
          <div class="series-landing__covers" aria-label={`${page.title} cover artwork`}>
            {heroAlbums.map((album, index) => (
              <span
                class="series-landing__cover-item"
                style={`--series-cover-index: ${index};`}
              >
                <OptimizedImage
                  src={album.imageSrc}
                  alt={`Cover art for the album ${album.title}`}
                  class="series-landing__cover"
                  width={320}
                  height={320}
                  widths={[180, 240, 320, 480]}
                  sizes="(max-width: 760px) 42vw, 20rem"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </span>
            ))}
          </div>
        )
      }
    </header>

    <section class="series-landing__story" aria-label={`${page.title} story`}>
      <Content />
    </section>

    <section class="series-landing__albums" aria-labelledby="series-albums-title">
      <div class="series-landing__section-header">
        <p class="series-landing__section-kicker">
          {albumCards.length}
          {albumCards.length === 1 ? "album" : "albums"}
        </p>
        <h2 id="series-albums-title" class="series-landing__section-title">
          Albums in this series
        </h2>
      </div>

      <ol class="series-landing__grid">
        {
          albumCards.map((album) => (
            <li class="series-landing__item">
              <ContentCard
                id={`series-album-card-${album.id}`}
                class="series-landing__card"
                href={`/${album.id}/`}
                dataTestId="series-album-card"
                variant="default"
                size="compact"
                mediaAspectRatio="1 / 1"
                mediaObjectFit="cover"
                imageSrc={album.imageSrc}
                imageAlt={`Cover art for the album ${album.title}`}
                imageWidth={1024}
                imageHeight={1024}
                imageSizes={GRID_COVER_IMAGE_SIZES}
                title={album.title}
                description={album.description}
                metaItems={[
                  { iconName: "book-open" as const, label: `Part ${album.partNumber}` },
                  ...(album.genre
                    ? [{ iconName: "disc" as const, label: album.genre }]
                    : []),
                  { iconName: "music" as const, label: `${album.trackCount} tracks` },
                  ...(album.totalDurationLabel
                    ? [{ iconName: "clock" as const, label: album.totalDurationLabel }]
                    : []),
                ]}
                ctaSrText={`Open album ${album.title}`}
              />
            </li>
          ))
        }
      </ol>
    </section>
  </main>
</Layout>

<style>
  :global(.music-layout__container.music-layout__container--series) {
    inline-size: 100%;
    max-inline-size: none;
    padding: 0;
    margin: 0;
    overflow-x: clip;
  }

  :global(.music-layout__container--series) {
    /* Local aliases onto the global palette so high-contrast and
       forced-colors overrides propagate into this page. */
    --series-landing-accent: var(--accent-primary);
    --series-landing-ink: var(--text-primary);
    --series-landing-muted: var(--text-tertiary);
    --series-landing-line: var(--border-default);
  }

  .series-landing {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    min-block-size: 100svh;
    padding: max(clamp(2rem, 5vw, 4rem), 6rem) clamp(1rem, 4vw, 4rem)
      clamp(2.5rem, 6vw, 5rem);
    color: var(--series-landing-ink);
    isolation: isolate;
  }

  .series-landing::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background: radial-gradient(
      140vw 90vh at 50% -25%,
      color-mix(in srgb, var(--accent-primary) 9%, transparent),
      color-mix(in srgb, var(--accent-strong) 4%, transparent) 45%,
      transparent 80%
    );
  }

  .series-landing__hero,
  .series-landing__story,
  .series-landing__albums {
    inline-size: min(100%, 90rem);
    margin-inline: auto;
  }

  .series-landing__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.72fr);
    gap: clamp(1.4rem, 4vw, 4rem);
    align-items: center;
    padding-block-end: clamp(1rem, 2vw, 1.6rem);
    border-block-end: 1px solid var(--series-landing-line);
  }

  .series-landing__copy {
    display: grid;
    gap: clamp(0.9rem, 2vw, 1.25rem);
    min-inline-size: 0;
  }

  .series-landing__eyebrow,
  .series-landing__section-kicker {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    color: var(--series-landing-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .series-landing__title {
    max-inline-size: 14ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2.8rem, 2.1rem + 3vw, 5rem);
    font-weight: var(--font-weight-bold);
    line-height: 0.98;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .series-landing__intro {
    max-inline-size: 72ch;
    margin: 0;
    font-size: var(--font-size-md);
    line-height: 1.62;
    color: var(--series-landing-muted);
    text-wrap: pretty;
  }

  .series-landing__covers {
    position: relative;
    display: grid;
    place-items: center;
    min-block-size: clamp(18rem, 32vw, 29rem);
  }

  .series-landing__cover-item {
    position: absolute;
    inline-size: clamp(10.5rem, 19vw, 20rem);
    color: inherit;
    transform: translateX(calc((var(--series-cover-index) - 1) * 34%))
      translateY(calc((var(--series-cover-index) - 1) * 4%))
      rotate(calc((var(--series-cover-index) - 1) * 5deg));
  }

  .series-landing__cover {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 1 / 1;
    outline: 1px solid var(--border-muted);
    outline-offset: -1px;
    object-fit: cover;
    border-radius: var(--radius-md);
    box-shadow: 0 1.4rem 3.6rem oklch(0% 0 0deg / 0.38);
  }

  .series-landing__albums {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .series-landing__story {
    max-inline-size: 72rem;
    padding-block: clamp(0.25rem, 1vw, 0.75rem);
  }

  .series-landing__section-header {
    display: grid;
    gap: 0.35rem;
  }

  .series-landing__section-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1.6rem, 1.35rem + 1vw, 2.35rem);
    font-weight: var(--font-weight-semibold);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .series-landing__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 1.6vw, 1.4rem);
    align-items: stretch;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .series-landing__item {
    display: grid;
    min-inline-size: 0;
  }

  .series-landing__card {
    block-size: 100%;
  }

  @media (width <= 900px) {
    .series-landing__hero {
      grid-template-columns: minmax(0, 1fr);
    }

    .series-landing__covers {
      order: -1;
      min-block-size: 15rem;
    }
  }

  @media (width <= 760px) {
    .series-landing {
      padding-inline: 1rem;
    }

    .series-landing__intro {
      font-size: var(--font-size-sm);
      line-height: 1.6;
    }

    .series-landing__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width <= 520px) {
    .series-landing__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

<style is:global>
  .series-landing__story > * {
    max-inline-size: 76ch;
  }

  .series-landing__story > *:first-child {
    margin-block-start: 0;
  }

  .series-landing__story > *:last-child {
    margin-block-end: 0;
  }

  .series-landing__story p,
  .series-landing__story li {
    font-size: var(--font-size-md);
    line-height: 1.7;
    color: var(--series-landing-muted);
    text-wrap: pretty;
  }

  .series-landing__story h2,
  .series-landing__story h3 {
    margin-block: clamp(1.5rem, 3vw, 2.25rem) 0.7rem;
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    line-height: 1.12;
    color: var(--series-landing-ink);
    letter-spacing: 0;
    text-wrap: balance;
  }

  .series-landing__story h2 {
    font-size: clamp(1.7rem, 1.45rem + 0.9vw, 2.35rem);
  }

  .series-landing__story h3 {
    font-size: clamp(1.25rem, 1.1rem + 0.55vw, 1.7rem);
  }

  .series-landing__story a {
    color: var(--series-landing-accent);
    text-underline-offset: 0.18em;
  }

  .series-landing__card .content-card__media {
    position: relative;
  }

  .series-landing__card .content-card__media::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    content: "";
    background: radial-gradient(
      120% 90% at 50% 100%,
      color-mix(in srgb, var(--series-landing-accent) 42%, transparent),
      transparent 62%
    );
    mix-blend-mode: screen;
    opacity: 0;
  }

  .series-landing__card.content-card--interactive:hover .content-card__media::before,
  .series-landing__card.content-card--interactive:focus-within
    .content-card__media::before {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .series-landing__card .content-card__media::before {
      transition: opacity 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }
  }
</style>
