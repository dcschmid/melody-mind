---
import { getCollection, render, type CollectionEntry } from "astro:content";
import OptimizedImage from "@components/media/OptimizedImage.astro";
import Icon from "@components/visual/Icon.astro";
import Layout from "../../layouts/Layout.astro";
import { resolvePageUrl } from "@utils/siteUrls";
import { buildCollectionPageSchema } from "@utils/seo/seoSchema";
import { formatDuration } from "../../utils/albumPresentation";
import { getAvailableAlbums } from "../../utils/albums";
import type { AlbumData } from "../../types/album";
import {
  getAlbumCoverImage,
  getAlbumCoverImageUrl,
  musicDefaultOgImageUrl,
} from "../../utils/musicImages";
import { buildMusicAlbumListSchema } from "../../utils/musicSeo";

type SeriesEntry = CollectionEntry<"series">;
interface SeriesPage {
  slug: string;
  order: number;
  title: string;
  eyebrow: string;
  shortDescription: string;
  keywords: string[];
  albumIds: string[];
}

interface SeriesAlbumCard {
  id: string;
  partNumber: number;
  title: string;
  description: string;
  imageSrc: ReturnType<typeof getAlbumCoverImage>;
  genre: string | undefined;
  trackCount: number;
  totalDurationLabel: string;
}

export async function getStaticPaths() {
  const pages = (await getCollection("series")) as SeriesEntry[];

  return pages.map((entry) => ({
    params: { series: entry.id },
    props: {
      entry,
    },
  }));
}

const { entry } = Astro.props as { entry: SeriesEntry };
const page: SeriesPage = {
  slug: entry.id,
  ...entry.data,
};
const { Content } = await render(entry);

const albums: AlbumData[] = await getAvailableAlbums();
const albumsById = new Map(
  albums.map((album) => [album.id.toLocaleLowerCase("en"), album])
);
const seriesAlbums = page.albumIds
  .map((albumId) => albumsById.get(albumId.toLocaleLowerCase("en")))
  .filter((album): album is (typeof albums)[number] => Boolean(album));
const albumCards: SeriesAlbumCard[] = seriesAlbums.map((album, index) => {
  const totalDurationSeconds = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  const imageSrc = getAlbumCoverImage(album.coverImage);

  return {
    id: album.id,
    partNumber: index + 1,
    title: album.title,
    description: album.description,
    imageSrc,
    genre: album.genre,
    trackCount: album.songs.length,
    totalDurationLabel: totalDurationSeconds ? formatDuration(totalDurationSeconds) : "",
  };
});
const canonical = resolvePageUrl(Astro.site, `/series/${page.slug}/`);
const socialImageAlbum = seriesAlbums[0];
const pageImage = socialImageAlbum?.coverImage
  ? getAlbumCoverImageUrl(socialImageAlbum.coverImage)
  : musicDefaultOgImageUrl;
const pageImageAlt = socialImageAlbum
  ? `Cover art for ${socialImageAlbum.title}, Part 1 of ${page.title}`
  : "Cover artwork for MelodyMind Music";
const breadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: "Album Series", url: resolvePageUrl(Astro.site, "/series/") },
  { name: page.title, url: canonical },
];
const structuredData = [
  buildCollectionPageSchema({
    url: canonical,
    name: page.title,
    description: page.shortDescription,
    lang: "en",
    image: pageImage,
    mainEntityId: `${canonical}#album-list`,
  }),
  buildMusicAlbumListSchema({
    albums: seriesAlbums,
    canonical,
    description: page.shortDescription,
    name: `${page.title} albums`,
    site: Astro.site,
    getCoverImageUrl: getAlbumCoverImageUrl,
  }),
];
const SEQUENCE_COVER_IMAGE_SIZES = "(max-width: 520px) 6.5rem, 9rem";
---

<Layout
  title={`${page.title} | MelodyMind Music`}
  description={page.shortDescription}
  keywords={page.keywords}
  type="website"
  image={pageImage}
  {...socialImageAlbum?.coverImageWidth
    ? { imageWidth: socialImageAlbum.coverImageWidth }
    : {}}
  {...socialImageAlbum?.coverImageHeight
    ? { imageHeight: socialImageAlbum.coverImageHeight }
    : {}}
  imageAlt={pageImageAlt}
  language="en"
  locale="en-US"
  canonical={canonical}
  {breadcrumbs}
  {structuredData}
  contentShellClass="music-layout__container--series"
>
  <div class="series-landing" aria-labelledby="series-landing-title">
    <header class="series-landing__hero">
      <div class="series-landing__copy">
        <a class="series-landing__back" href="/series/">
          <Icon name="arrow-left" aria-hidden="true" />
          <span>All album series</span>
        </a>
        <p class="series-landing__eyebrow">{page.eyebrow}</p>
        <h1 id="series-landing-title" class="series-landing__title">{page.title}</h1>
        <div class="series-landing__intro">
          <Content />
        </div>
        <p class="series-landing__order-note">
          <Icon name="book-open" aria-hidden="true" />
          <span>
            {`${albumCards.length}-part listening order, beginning with Part 1`}
          </span>
        </p>
      </div>
    </header>

    <section class="series-landing__albums" aria-labelledby="series-albums-title">
      <div class="series-landing__section-header">
        <p class="series-landing__section-kicker">
          {`${albumCards.length} ${albumCards.length === 1 ? "album" : "albums"}`}
        </p>
        <h2 id="series-albums-title" class="series-landing__section-title">
          Albums in this series
        </h2>
      </div>

      <ol class="series-landing__sequence">
        {
          albumCards.map((album) => (
            <li class="series-landing__item">
              <span class="series-landing__part-number" aria-hidden="true">
                {String(album.partNumber).padStart(2, "0")}
              </span>
              <a
                id={`series-album-${album.id}`}
                class="series-landing__album-link"
                href={`/${album.id}/`}
                data-testid="series-album-card"
              >
                <OptimizedImage
                  src={album.imageSrc}
                  alt={`Cover art for the album ${album.title}`}
                  class="series-landing__album-cover"
                  width={288}
                  height={288}
                  widths={[104, 144, 216, 288]}
                  sizes={SEQUENCE_COVER_IMAGE_SIZES}
                  loading={album.partNumber === 1 ? "eager" : "lazy"}
                  decoding="async"
                />
                <span class="series-landing__album-copy">
                  <span class="series-landing__part-label">
                    Part {album.partNumber}
                    {album.partNumber === 1 && (
                      <span class="series-landing__start">Start here</span>
                    )}
                  </span>
                  <strong class="series-landing__album-title">{album.title}</strong>
                  <span class="series-landing__album-description">
                    {album.description}
                  </span>
                  <span class="series-landing__album-meta">
                    {album.genre && <span>{album.genre}</span>}
                    <span>{`${album.trackCount} tracks`}</span>
                    {album.totalDurationLabel && <span>{album.totalDurationLabel}</span>}
                  </span>
                  <span class="series-landing__album-action">
                    Open album
                    <Icon name="chevron-right" aria-hidden="true" />
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </section>
  </div>
</Layout>

<style>
  :global(.music-layout__container.music-layout__container--series) {
    inline-size: 100%;
    max-inline-size: none;
    padding: 0;
    margin: 0;
    overflow-x: clip;
  }

  :global(.music-layout__container--series) {
    /* Local aliases onto the global palette so high-contrast and
       forced-colors overrides propagate into this page. */
    --series-landing-accent: var(--accent-primary);
    --series-landing-ink: var(--text-primary);
    --series-landing-muted: var(--text-tertiary);
    --series-landing-line: var(--border-default);
  }

  .series-landing {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    min-block-size: 100svh;
    padding: max(clamp(2rem, 5vw, 4rem), 6rem) clamp(1rem, 4vw, 4rem)
      clamp(2.5rem, 6vw, 5rem);
    color: var(--series-landing-ink);
  }

  .series-landing__hero,
  .series-landing__albums {
    inline-size: min(100%, 90rem);
    margin-inline: auto;
  }

  .series-landing__hero {
    padding-block-end: clamp(1.25rem, 3vw, 2.25rem);
    border-block-end: 1px solid var(--series-landing-line);
  }

  .series-landing__copy {
    display: grid;
    gap: clamp(0.9rem, 2vw, 1.25rem);
    min-inline-size: 0;
    max-inline-size: 72ch;
  }

  .series-landing__eyebrow,
  .series-landing__section-kicker {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    color: var(--series-landing-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .series-landing__back {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    inline-size: fit-content;
    min-block-size: var(--control-min-block-size);
    padding-inline: var(--spacing-xs);
    margin-inline-start: calc(-1 * var(--spacing-xs));
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--series-landing-muted);
    text-decoration: none;
    border-radius: var(--radius-base);
  }

  .series-landing__back:hover,
  .series-landing__back:focus-visible {
    color: var(--series-landing-accent);
  }

  .series-landing__back:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .series-landing__back :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .series-landing__title {
    max-inline-size: 18ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2.4rem, 1.9rem + 2.4vw, 4.25rem);
    font-weight: var(--font-weight-bold);
    line-height: 0.98;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .series-landing__intro {
    max-inline-size: 72ch;
    margin: 0;
    font-size: var(--font-size-md);
    line-height: 1.62;
    color: var(--series-landing-muted);
    text-wrap: pretty;
  }

  .series-landing__order-note {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    inline-size: fit-content;
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--series-landing-ink);
  }

  .series-landing__order-note :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
    color: var(--series-landing-accent);
  }

  .series-landing__albums {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .series-landing__section-header {
    display: grid;
    gap: 0.35rem;
  }

  .series-landing__section-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1.6rem, 1.35rem + 1vw, 2.35rem);
    font-weight: var(--font-weight-semibold);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .series-landing__sequence {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
    border-block-start: 1px solid var(--series-landing-line);
  }

  .series-landing__item {
    display: grid;
    grid-template-columns: 3.5rem minmax(0, 1fr);
    gap: clamp(var(--spacing-base), 2vw, var(--spacing-xl));
    align-items: center;
    min-inline-size: 0;
    padding-block: clamp(var(--spacing-lg), 3vw, var(--spacing-2xl));
    border-block-end: 1px solid var(--series-landing-line);
  }

  .series-landing__part-number {
    align-self: start;
    padding-block-start: var(--spacing-sm);
    font-size: clamp(1.4rem, 1.1rem + 1vw, 2rem);
    font-weight: var(--font-weight-bold);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--series-landing-accent);
  }

  .series-landing__album-link {
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr);
    gap: clamp(var(--spacing-base), 2.4vw, var(--spacing-2xl));
    align-items: center;
    min-inline-size: 0;
    padding: var(--spacing-sm);
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-base);
  }

  .series-landing__album-link:hover,
  .series-landing__album-link:focus-visible {
    background: color-mix(in srgb, var(--series-landing-accent) 7%, transparent);
  }

  .series-landing__album-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .series-landing__album-cover {
    display: block;
    inline-size: 9rem;
    block-size: 9rem;
    object-fit: cover;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-sm);
  }

  .series-landing__album-copy {
    display: grid;
    gap: var(--spacing-xs);
    min-inline-size: 0;
  }

  .series-landing__part-label {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: baseline;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--series-landing-muted);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
  }

  .series-landing__start {
    color: var(--series-landing-accent);
  }

  .series-landing__album-title {
    font-size: clamp(1.35rem, 1.15rem + 0.7vw, 1.9rem);
    line-height: 1.12;
  }

  .series-landing__album-description {
    display: -webkit-box;
    max-inline-size: 68ch;
    overflow: hidden;
    -webkit-line-clamp: 2;
    line-height: 1.55;
    color: var(--series-landing-muted);
    text-wrap: pretty;
    -webkit-box-orient: vertical;
  }

  .series-landing__album-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs) var(--spacing-base);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--series-landing-muted);
  }

  .series-landing__album-meta span + span::before {
    margin-inline-end: var(--spacing-base);
    color: var(--series-landing-line);
    content: "•";
  }

  .series-landing__album-action {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    inline-size: fit-content;
    min-block-size: var(--control-min-block-size);
    font-weight: var(--font-weight-bold);
    color: var(--series-landing-accent);
  }

  .series-landing__album-action :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
  }

  @media (width <= 760px) {
    .series-landing {
      padding-inline: 1rem;
    }

    .series-landing__intro {
      font-size: var(--font-size-sm);
      line-height: 1.6;
    }

    .series-landing__item {
      grid-template-columns: 2.75rem minmax(0, 1fr);
    }
  }

  @media (width <= 520px) {
    .series-landing__item {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--spacing-xs);
    }

    .series-landing__part-number {
      padding-block-start: 0;
    }

    .series-landing__album-link {
      grid-template-columns: 6.5rem minmax(0, 1fr);
      gap: var(--spacing-base);
      padding-inline: 0;
    }

    .series-landing__album-cover {
      inline-size: 6.5rem;
      block-size: 6.5rem;
    }

    .series-landing__album-description {
      -webkit-line-clamp: 3;
    }
  }
</style>

<style is:global>
  .series-landing__intro > * {
    max-inline-size: 76ch;
  }

  .series-landing__intro > *:first-child {
    margin-block-start: 0;
  }

  .series-landing__intro > *:last-child {
    margin-block-end: 0;
  }

  .series-landing__intro p,
  .series-landing__intro li {
    font-size: var(--font-size-md);
    line-height: 1.7;
    color: var(--series-landing-muted);
    text-wrap: pretty;
  }

  .series-landing__intro h2,
  .series-landing__intro h3 {
    margin-block: clamp(1.5rem, 3vw, 2.25rem) 0.7rem;
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    line-height: 1.12;
    color: var(--series-landing-ink);
    letter-spacing: 0;
    text-wrap: balance;
  }

  .series-landing__intro h2 {
    font-size: clamp(1.7rem, 1.45rem + 0.9vw, 2.35rem);
  }

  .series-landing__intro h3 {
    font-size: clamp(1.25rem, 1.1rem + 0.55vw, 1.7rem);
  }

  .series-landing__intro a {
    color: var(--series-landing-accent);
    text-underline-offset: 0.18em;
  }
</style>
