---
import Layout from "@layouts/Layout.astro";
import AutoGrid from "@components/layout/AutoGrid.astro";
import LegalDocumentSection from "@components/layout/LegalDocumentSection.astro";
import PageShell from "@components/layout/PageShell.astro";
import DataTable from "@components/policies/DataTable.astro";
import Stack from "@components/layout/Stack.astro";
import StaticPageHero from "@components/layout/StaticPageHero.astro";
import { trustedHtmlList } from "@utils/trustedHtml";

import { buildLegalPageSeo } from "../utils/legal/buildLegalPageSeo";

export const prerender = true;

const title = "Cookie & Storage Policy";
const description =
  "Details about browser storage used on MelodyMind Music for core site features.";
const lastUpdated = "24 July 2026";

const highlights = [
  {
    value: "No analytics",
    label: "We do not load analytics or advertising trackers.",
  },
  {
    value: "Local-first",
    label: "Preferences and music player state use browser local storage.",
  },
] as const;

const policySections = [
  {
    icon: "shield",
    title: "Do we use cookies?",
    trustedHtmlBody: trustedHtmlList([
      "We do not use tracking cookies for advertising or cross-site profiling.",
      "We use browser local storage only for site features such as music player state.",
    ]),
  },
  {
    icon: "settings",
    title: "How we use browser storage",
    trustedHtmlBody: trustedHtmlList([
      "We use local storage to remember the last music player position and related playback state.",
      "MelodyMind Quiz does not use local storage, session storage, IndexedDB, or cookies for quiz progress or results.",
      "You can clear this data at any time in your browser settings.",
    ]),
  },
  {
    icon: "file-text",
    title: "Related privacy information",
    trustedHtmlBody: trustedHtmlList([
      'For full details about personal data processing and your rights, see our <a href="/privacy">Privacy Policy</a>.',
    ]),
  },
  {
    icon: "refresh-ccw",
    title: "Policy updates",
    trustedHtmlBody: trustedHtmlList([
      "We update this page when storage technologies or legal requirements change.",
      `Last updated: ${lastUpdated}.`,
    ]),
  },
] as const;

const storageKeys = [
  {
    keyName: "melodymind:music-player-state:v2",
    purpose: "Restores the last album, track, and playback position in the music player.",
    storageType: "LocalStorage",
    retention: "Until replaced by a newer player state or cleared by you.",
  },
] as const;

const storageKeyColumns = [
  { key: "keyName", label: "Key", renderAsCode: true, isRowHeader: true },
  { key: "purpose", label: "Purpose" },
  { key: "storageType", label: "Type" },
  { key: "retention", label: "Retention" },
] as const;

const pageSeo = buildLegalPageSeo({
  site: Astro.site,
  path: "/cookies/",
  title,
  description,
  imageAlt: "Cookie Policy",
  fallbackKeywords: ["cookies", "localStorage", "privacy", "storage policy"],
  maxDescription: 160,
  modifiedDate: new Date(lastUpdated),
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <Stack className="cookies-page" gap="2xl">
      <StaticPageHero
        eyebrow="Browser Storage"
        title="Cookie & Storage Policy"
        lead="This page explains which browser storage technologies we use, why we use them, and how you can manage them."
        {highlights}
        highlightsAriaLabel="Key cookie policy points"
      />

      <AutoGrid className="cookies-page__content-grid" preset="legal" gap="section">
        {
          policySections.map((section) => (
            <LegalDocumentSection
              icon={section.icon}
              title={section.title}
              trustedHtmlBody={section.trustedHtmlBody}
            />
          ))
        }

        <LegalDocumentSection
          icon="book-open"
          title="Local storage entries we use"
          desktopSpan="full"
        >
          <DataTable
            caption="Browser storage keys used by MelodyMind Music"
            columns={storageKeyColumns}
            rows={storageKeys}
          />
        </LegalDocumentSection>
      </AutoGrid>
    </Stack>
  </PageShell>
</Layout>
