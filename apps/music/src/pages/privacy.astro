---
import Layout from "@layouts/Layout.astro";
import LegalDocumentPage from "@components/layout/LegalDocumentPage.astro";
import PageShell from "@components/layout/PageShell.astro";
import { trustedHtmlList } from "@utils/trustedHtml";

import { buildLegalPageSeo } from "../utils/legal/buildLegalPageSeo";

export const prerender = true;

const title = "Privacy Policy";
const description =
  "How we process personal data on MelodyMind Music, including hosting logs, browser storage, and AI-generated media details.";
const lastUpdated = "24 July 2026";

const highlights = [
  {
    value: "Limited processing",
    label: "We aim to process only the data needed to run the site.",
  },
  {
    value: "No analytics",
    label: "We do not load analytics or advertising trackers.",
  },
  {
    value: "Clear rights",
    label: "Your GDPR rights and complaint options are listed below.",
  },
] as const;

const sections = [
  {
    icon: "user",
    title: "Controller",
    trustedHtmlBody: trustedHtmlList([
      "Daniel Schmid",
      "Hiltenspergerstr. 78, 80796 Munich, Germany",
      'Email: <a href="mailto:dcschmid@murena.io">dcschmid@murena.io</a>',
    ]),
  },
  {
    icon: "shield",
    title: "Hosting & Access Logs",
    trustedHtmlBody: trustedHtmlList([
      "We host this site on Render (render.com). Render processes server logs such as IP address, timestamp, requested URL, and user agent to maintain site stability and security. Legal basis: Art. 6(1)(f) GDPR, legitimate interest in secure operation. Logs are deleted automatically on a rolling basis. Depending on the Render region, data may be processed in the EU or transferred to the United States under appropriate safeguards, such as standard contractual clauses.",
    ]),
  },
  {
    icon: "grid",
    title: "Browser Storage",
    trustedHtmlBody: trustedHtmlList([
      "We use browser storage for site features such as music player state.",
      "MelodyMind Quiz does not store quiz progress, answers, or results. Its active round exists only in memory and resets when the page is left or reloaded.",
      'For a current overview of local storage entries, see our <a href="/cookies">Cookie &amp; Storage Policy</a>.',
    ]),
  },
  {
    icon: "share-2",
    title: "Sharing Quiz Results",
    trustedHtmlBody: trustedHtmlList([
      "MelodyMind Quiz opens your device share sheet only when you choose Share result. If the share sheet is unavailable, the result text can be copied to your clipboard. We do not receive or store the shared result.",
    ]),
  },
  {
    icon: "sparkles",
    title: "AI-Generated Music and Images",
    trustedHtmlBody: trustedHtmlList([
      "Some music, text, and images are generated with assistance from AI services. We do not intentionally send personal data to AI services. If you contact us and share personal information, we do not use that content in AI prompts without your consent.",
    ]),
  },
  {
    icon: "mail",
    title: "Contact",
    trustedHtmlBody: trustedHtmlList([
      "If you email us, we process your message, contact details, and related metadata to respond. Legal basis: Art. 6(1)(b) GDPR, pre-contractual communication, or Art. 6(1)(f) GDPR, legitimate interest in responding to inquiries. We keep this data only as long as necessary.",
    ]),
  },
  {
    icon: "help-circle",
    title: "Your Rights",
    trustedHtmlBody: trustedHtmlList([
      "You have the rights of access, rectification, erasure, restriction, objection, including to processing based on Art. 6(1)(f) GDPR, and data portability. You may also lodge a complaint with your local supervisory authority. In Bavaria, this is the BayLDA, Bayerisches Landesamt fuer Datenschutzaufsicht.",
    ]),
  },
  {
    icon: "clock",
    title: "Data Retention",
    trustedHtmlBody: trustedHtmlList([
      "We retain personal data only as long as necessary for the stated purposes or legal obligations and then delete or anonymize it.",
    ]),
  },
  {
    icon: "refresh-ccw",
    title: "Updates",
    trustedHtmlBody: trustedHtmlList([
      `We may update this policy to reflect legal or technical changes. Last updated: ${lastUpdated}.`,
    ]),
  },
] as const;

const pageSeo = buildLegalPageSeo({
  site: Astro.site,
  path: "/privacy/",
  title,
  description,
  imageAlt: "Privacy Policy",
  fallbackKeywords: ["privacy", "data protection", "browser storage", "AI music"],
  maxDescription: 160,
  modifiedDate: new Date(lastUpdated),
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <LegalDocumentPage
      eyebrow="Data Protection"
      title="Privacy Policy"
      lead="This notice explains how we process personal data on MelodyMind Music in line with EU and German data protection law."
      {highlights}
      highlightsAriaLabel="Key privacy policy points"
      {sections}
    />
  </PageShell>
</Layout>
