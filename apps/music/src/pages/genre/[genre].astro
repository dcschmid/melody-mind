---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ContentCard from "@components/cards/ContentCard.astro";
import AlbumGridFilter from "@components/music/discovery/AlbumGridFilter.astro";
import Icon from "@components/visual/Icon.astro";
import Layout from "../../layouts/Layout.astro";
import { resolvePageUrl } from "@utils/siteUrls";
import { buildCollectionPageSchema } from "@utils/seo/seoSchema";
import { formatDuration } from "../../utils/albumPresentation";
import { getAvailableAlbums } from "../../utils/albums";
import {
  getAlbumCoverImage,
  getAlbumCoverImageUrl,
  musicDefaultOgImageUrl,
} from "../../utils/musicImages";
import { buildMusicAlbumListSchema } from "../../utils/musicSeo";

type GenreEntry = CollectionEntry<"genres">;
interface GenrePage {
  slug: string;
  order: number;
  mainGenre: string;
  title: string;
  eyebrow: string;
  description: string;
  keywords: string[];
}

export async function getStaticPaths() {
  const pages = (await getCollection("genres")) as GenreEntry[];

  return pages.map((entry) => ({
    params: { genre: entry.id },
    props: {
      entry,
    },
  }));
}

const { entry } = Astro.props as { entry: GenreEntry };
const page: GenrePage = {
  slug: entry.id,
  ...entry.data,
};
const { Content } = await render(entry);

const albums = await getAvailableAlbums();
const albumTitleCollator = new Intl.Collator("en", {
  numeric: true,
  sensitivity: "base",
});
const genreAlbums = albums
  .filter((album) => album.mainGenre === page.mainGenre)
  .sort(
    (a, b) =>
      new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime() ||
      albumTitleCollator.compare(a.title, b.title)
  );

const albumCards = genreAlbums.map((album) => {
  const totalDurationSeconds = album.songs.reduce(
    (acc, song) => acc + (song.durationSeconds || 0),
    0
  );
  const imageSrc = getAlbumCoverImage(album.coverImage);

  return {
    id: album.id,
    title: album.title,
    description: album.description,
    imageSrc,
    publishedAt: album.publishedAt,
    genre: album.genre,
    mainGenre: album.mainGenre,
    trackCount: album.songs.length,
    totalDurationLabel: totalDurationSeconds ? formatDuration(totalDurationSeconds) : "",
    searchText: [
      album.title,
      album.genre || "",
      ...(album.moods || []),
      ...(album.tags || []),
    ]
      .filter(Boolean)
      .join(" "),
  };
});
const canonical = resolvePageUrl(Astro.site, `/genre/${page.slug}/`);
const socialImageAlbum = genreAlbums[0];
const pageImage = socialImageAlbum?.coverImage
  ? getAlbumCoverImageUrl(socialImageAlbum.coverImage)
  : musicDefaultOgImageUrl;
const pageImageAlt = socialImageAlbum
  ? `Cover art for ${socialImageAlbum.title}, featured on the ${page.title} page`
  : "Cover artwork for MelodyMind Music";
const breadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: "Genres", url: resolvePageUrl(Astro.site, "/genre/") },
  { name: page.title, url: canonical },
];
const structuredData = [
  buildCollectionPageSchema({
    url: canonical,
    name: page.title,
    description: page.description,
    lang: "en",
    image: pageImage,
    mainEntityId: `${canonical}#album-list`,
  }),
  buildMusicAlbumListSchema({
    albums: genreAlbums,
    canonical,
    description: page.description,
    name: page.title,
    site: Astro.site,
    getCoverImageUrl: getAlbumCoverImageUrl,
  }),
];
const GRID_COVER_IMAGE_SIZES =
  "(max-width: 640px) 7.5rem, (max-width: 760px) 44vw, (max-width: 1180px) 28vw, min(18rem, calc((100vw - 10rem) / 5))";
---

<Layout
  title={`${page.title} | MelodyMind Music`}
  description={page.description}
  keywords={[...page.keywords, "ai music", "concept albums", "MelodyMind"]}
  type="website"
  image={pageImage}
  {...socialImageAlbum?.coverImageWidth
    ? { imageWidth: socialImageAlbum.coverImageWidth }
    : {}}
  {...socialImageAlbum?.coverImageHeight
    ? { imageHeight: socialImageAlbum.coverImageHeight }
    : {}}
  imageAlt={pageImageAlt}
  language="en"
  locale="en-US"
  canonical={canonical}
  {breadcrumbs}
  {structuredData}
  contentShellClass="music-layout__container--genre"
>
  <div class="genre-landing" aria-labelledby="genre-landing-title">
    <header class="genre-landing__hero">
      <div class="genre-landing__copy">
        <a class="genre-landing__back" href="/genre/">
          <Icon name="arrow-left" aria-hidden="true" />
          <span>All genres</span>
        </a>
        <p class="genre-landing__eyebrow">{page.eyebrow}</p>
        <h1 id="genre-landing-title" class="genre-landing__title">{page.title}</h1>
        <div class="genre-landing__intro">
          <Content />
        </div>
        <p class="genre-landing__catalog-note">
          <Icon name="disc" aria-hidden="true" />
          <span>
            {
              `${albumCards.length} ${albumCards.length === 1 ? "album" : "albums"}, newest first`
            }
          </span>
        </p>
      </div>
    </header>

    <section class="genre-landing__albums" aria-labelledby="genre-albums-title">
      <div class="genre-landing__section-header">
        <p class="genre-landing__section-kicker">
          {`${albumCards.length} ${albumCards.length === 1 ? "album" : "albums"}`}
        </p>
        <h2 id="genre-albums-title" class="genre-landing__section-title">
          Albums in this genre
        </h2>
      </div>

      <AlbumGridFilter albumCount={albumCards.length} genreTitle={page.eyebrow}>
        <ul class="genre-landing__grid">
          {
            albumCards.map((album) => (
              <li
                class="genre-landing__item"
                data-album-filter-item
                data-album-filter-text={album.searchText}
              >
                <ContentCard
                  id={`genre-album-card-${album.id}`}
                  class="genre-landing__card"
                  href={`/${album.id}/`}
                  dataTestId="genre-album-card"
                  variant="default"
                  size="compact"
                  mediaAspectRatio="1 / 1"
                  mediaObjectFit="cover"
                  imageSrc={album.imageSrc}
                  imageAlt={`Cover art for the album ${album.title}`}
                  imageWidth={1024}
                  imageHeight={1024}
                  imageSizes={GRID_COVER_IMAGE_SIZES}
                  title={album.title}
                  description={album.description}
                  metaItems={[
                    ...(album.genre
                      ? [{ iconName: "disc" as const, label: album.genre }]
                      : []),
                    { iconName: "music" as const, label: `${album.trackCount} tracks` },
                    ...(album.totalDurationLabel
                      ? [{ iconName: "clock" as const, label: album.totalDurationLabel }]
                      : []),
                  ]}
                  ctaSrText={`Open album ${album.title}`}
                />
              </li>
            ))
          }
        </ul>
      </AlbumGridFilter>
    </section>
  </div>
</Layout>

<style>
  :global(.music-layout__container.music-layout__container--genre) {
    inline-size: 100%;
    max-inline-size: none;
    padding: 0;
    margin: 0;
    overflow-x: clip;
  }

  :global(.music-layout__container--genre) {
    /* Local aliases onto the global palette so high-contrast and
       forced-colors overrides propagate into this page. */
    --genre-landing-accent: var(--accent-primary);
    --genre-landing-ink: var(--text-primary);
    --genre-landing-muted: var(--text-tertiary);
    --genre-landing-line: var(--border-default);
  }

  .genre-landing {
    position: relative;
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    min-block-size: 100svh;
    padding: max(clamp(2rem, 5vw, 4rem), 6rem) clamp(1rem, 4vw, 4rem)
      clamp(2.5rem, 6vw, 5rem);
    color: var(--genre-landing-ink);
  }

  .genre-landing__hero,
  .genre-landing__albums {
    inline-size: min(100%, 90rem);
    margin-inline: auto;
  }

  .genre-landing__hero {
    padding-block-end: clamp(1.25rem, 3vw, 2.25rem);
    border-block-end: 1px solid var(--genre-landing-line);
  }

  .genre-landing__copy {
    display: grid;
    gap: clamp(0.9rem, 2vw, 1.25rem);
    min-inline-size: 0;
    max-inline-size: 72ch;
  }

  .genre-landing__eyebrow,
  .genre-landing__section-kicker {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    color: var(--genre-landing-accent);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
  }

  .genre-landing__back {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    inline-size: fit-content;
    min-block-size: var(--control-min-block-size);
    padding-inline: var(--spacing-xs);
    margin-inline-start: calc(-1 * var(--spacing-xs));
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--genre-landing-muted);
    text-decoration: none;
    border-radius: var(--radius-base);
  }

  .genre-landing__back:hover,
  .genre-landing__back:focus-visible {
    color: var(--genre-landing-accent);
  }

  .genre-landing__back:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .genre-landing__back :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
  }

  .genre-landing__title {
    max-inline-size: 18ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(2.4rem, 1.9rem + 2.4vw, 4.25rem);
    font-weight: var(--font-weight-bold);
    line-height: 0.98;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .genre-landing__intro {
    max-inline-size: 68ch;
    margin: 0;
    font-size: var(--font-size-md);
    line-height: 1.62;
    color: var(--genre-landing-muted);
    text-wrap: pretty;
  }

  .genre-landing__catalog-note {
    display: inline-flex;
    gap: var(--spacing-xs);
    align-items: center;
    inline-size: fit-content;
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--genre-landing-ink);
  }

  .genre-landing__catalog-note :global(svg) {
    inline-size: 1rem;
    block-size: 1rem;
    color: var(--genre-landing-accent);
  }

  .genre-landing__albums {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .genre-landing__section-header {
    display: grid;
    gap: 0.35rem;
  }

  .genre-landing__section-title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: clamp(1.6rem, 1.35rem + 1vw, 2.35rem);
    font-weight: var(--font-weight-semibold);
    line-height: 1.1;
    letter-spacing: 0;
  }

  .genre-landing__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 1.6vw, 1.4rem);
    align-items: stretch;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .genre-landing__item {
    display: grid;
    min-inline-size: 0;
  }

  .genre-landing__card {
    block-size: 100%;
  }

  @media (width <= 1180px) {
    .genre-landing__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (width <= 760px) {
    .genre-landing {
      padding-inline: 1rem;
    }

    .genre-landing__intro {
      font-size: var(--font-size-sm);
      line-height: 1.6;
    }

    .genre-landing__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width <= 520px) {
    .genre-landing__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>

<style is:global>
  .genre-landing__intro > * {
    max-inline-size: 76ch;
  }

  .genre-landing__intro > *:first-child {
    margin-block-start: 0;
  }

  .genre-landing__intro > *:last-child {
    margin-block-end: 0;
  }

  .genre-landing__intro p,
  .genre-landing__intro li {
    font-size: var(--font-size-md);
    line-height: 1.7;
    color: var(--genre-landing-muted);
    text-wrap: pretty;
  }

  .genre-landing__intro h2,
  .genre-landing__intro h3 {
    margin-block: clamp(1.5rem, 3vw, 2.25rem) 0.7rem;
    font-family: var(--font-sans);
    font-weight: var(--font-weight-semibold);
    line-height: 1.12;
    color: var(--genre-landing-ink);
    letter-spacing: 0;
    text-wrap: balance;
  }

  .genre-landing__intro h2 {
    font-size: clamp(1.7rem, 1.45rem + 0.9vw, 2.35rem);
  }

  .genre-landing__intro h3 {
    font-size: clamp(1.25rem, 1.1rem + 0.55vw, 1.7rem);
  }

  .genre-landing__intro a {
    color: var(--genre-landing-accent);
    text-underline-offset: 0.18em;
  }

  .genre-landing__card .content-card__media {
    position: relative;
  }

  /* Soft accent glow that blooms over the cover on hover/focus. */
  .genre-landing__card .content-card__media::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    content: "";
    background: radial-gradient(
      120% 90% at 50% 100%,
      color-mix(in srgb, var(--genre-landing-accent) 42%, transparent),
      transparent 62%
    );
    mix-blend-mode: screen;
    opacity: 0;
  }

  .genre-landing__card.content-card--interactive:hover .content-card__media::before,
  .genre-landing__card.content-card--interactive:focus-within
    .content-card__media::before {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .genre-landing__card .content-card__media::before {
      transition: opacity 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }
  }
</style>
