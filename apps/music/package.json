{
  "name": "music",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:background": "astro dev --background",
    "dev:logs": "astro dev logs",
    "dev:status": "astro dev status",
    "dev:stop": "astro dev stop",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "pnpm format && pnpm exec eslint --config ../../eslint.config.mjs --fix \"src/**/*.{js,ts,jsx,tsx,astro}\" && pnpm stylelint",
    "lint:check": "pnpm exec eslint --config ../../eslint.config.mjs \"src/**/*.{js,ts,jsx,tsx,astro}\" && pnpm stylelint:check",
    "format": "pnpm exec prettier --write \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx}\"",
    "format:check": "pnpm exec prettier --check \"src/**/*.{js,ts,jsx,tsx,astro,md,mdx}\"",
    "stylelint": "pnpm exec stylelint --config ../../stylelint.config.cjs --fix \"src/**/*.{astro,css}\"",
    "stylelint:check": "pnpm exec stylelint --config ../../stylelint.config.cjs \"src/**/*.{astro,css}\" --quiet",
    "indexnow:submit": "node scripts/submit-indexnow.mjs",
    "update:audio-metadata": "node scripts/update-audio-metadata.mjs"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@freshjuice/astro-search-plugin": "^1.0.1",
    "@iconify-json/simple-icons": "^1.2.87",
    "@iconify-json/tabler": "^1.2.35",
    "@zdenekkurecka/astro-consent": "^0.3.2",
    "astro": "^7.0.2",
    "astro-icon": "^1.1.5",
    "astro-minify-html-swc": "^0.1.11",
    "lightningcss": "^1.32.0",
    "music-metadata": "^11.13.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/js-yaml": "^4.0.9",
    "image-size": "^2.0.2",
    "js-yaml": "^5.1.0",
    "typescript": "^6.0.3"
  }
}
