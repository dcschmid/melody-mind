---
import TaxonomyArticleGrid from "@components/TaxonomyArticleGrid.astro";
import TaxonomyBlockHeader from "@components/TaxonomyBlockHeader.astro";
import TaxonomyGroupBlock from "@components/TaxonomyGroupBlock.astro";
import type { TaxonomySubsectionWithArticles } from "@utils/taxonomy/buildTaxonomySectionPageData";

interface Props {
  subsection: TaxonomySubsectionWithArticles;
}

const { subsection } = Astro.props as Props;
const hasGroups = Boolean(subsection.groups && subsection.groups.length > 0);
---

<div id={subsection.id} class="taxonomy-subsection-block">
  <div class="taxonomy-subsection-block__header">
    <TaxonomyBlockHeader
      wrapperClassName="taxonomy-subsection-block__info"
      titleClassName="taxonomy-subsection-block__title"
      level="h2"
      title={subsection.title}
      description={subsection.description}
      countLabel={`${subsection.articleCount} ${subsection.articleCount === 1 ? "article" : "articles"}`}
    />
  </div>

  {
    hasGroups ? (
      <div class="taxonomy-subsection-block__groups">
        {subsection.groupsWithArticles.map((group) => (
          <TaxonomyGroupBlock subsectionId={subsection.id} group={group} />
        ))}
      </div>
    ) : (
      <TaxonomyArticleGrid
        articles={subsection.articles}
        emptyDescription="No articles in this topic yet."
      />
    )
  }
</div>

<style>
  .taxonomy-subsection-block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
    scroll-margin-block-start: var(--spacing-3xl);
  }

  .taxonomy-subsection-block + .taxonomy-subsection-block {
    padding-block-start: clamp(var(--spacing-2xl), 4vw, var(--spacing-3xl));
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .taxonomy-subsection-block__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  @media (width >= 768px) {
    .taxonomy-subsection-block__header {
      flex-direction: row;
      gap: var(--spacing-lg);
      align-items: flex-start;
    }
  }

  .taxonomy-subsection-block__info {
    flex: 1;
  }

  .taxonomy-subsection-block__title {
    padding: 0;
    border: 0;
  }

  .taxonomy-subsection-block__groups {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }
</style>
