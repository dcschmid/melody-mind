---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";

interface JumpTarget {
  anchorId: string;
  title: string;
  articleCount: number;
  parentTitle?: string;
}

interface Props {
  targets: JumpTarget[];
  title?: string;
  navLabel?: string;
  contentId?: string;
}

const {
  targets,
  title = "Jump to a topic",
  navLabel = "Jump to a topic",
  contentId = "taxonomy-toc-content",
} = Astro.props;
---

{
  targets.length >= 1 && (
    <nav class="taxonomy-jump-nav" aria-label={navLabel}>
      <div class="taxonomy-jump-nav__panel">
        <div class="taxonomy-jump-nav__header">
          <Headline level="h2" textSize="xl" className="taxonomy-jump-nav__headline">
            {title}
          </Headline>
          <button
            type="button"
            class="taxonomy-jump-nav__toggle"
            aria-expanded="false"
            aria-controls={contentId}
          >
            <span class="taxonomy-jump-nav__toggle-label">{title}</span>
            <Icon
              name="chevron-down"
              class="taxonomy-jump-nav__chevron"
              aria-hidden="true"
            />
          </button>
        </div>
        <div id={contentId} class="taxonomy-jump-nav__content" hidden>
          <ul class="taxonomy-jump-nav__list">
            {targets.map((target) => (
              <li class="taxonomy-jump-nav__item">
                <a href={`#${target.anchorId}`} class="taxonomy-jump-nav__link">
                  <span class="taxonomy-jump-nav__title">{target.title}</span>
                  <span
                    class="taxonomy-jump-nav__count"
                    aria-label={`${target.articleCount} articles`}
                  >
                    {target.articleCount}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </nav>
  )
}

<script>
  import { bindOverlayDisclosure } from "@shared-ui/scripts/interactive/overlayDisclosure";

  const navRoots = Array.from(
    document.querySelectorAll<HTMLElement>(".taxonomy-jump-nav")
  ).filter((root) => root.dataset.taxonomyJumpNavBound !== "true");

  navRoots.forEach((nav) => {
    nav.dataset.taxonomyJumpNavBound = "true";
    const toggle = nav.querySelector<HTMLButtonElement>(".taxonomy-jump-nav__toggle");
    const content = nav.querySelector<HTMLElement>(".taxonomy-jump-nav__content");
    const mobileMedia = window.matchMedia("(max-width: 39.999rem)");

    if (!(toggle instanceof HTMLButtonElement) || !(content instanceof HTMLElement)) {
      return;
    }

    bindOverlayDisclosure({
      root: nav,
      toggle,
      panel: content,
      mobileMedia,
      bodyClass: "taxonomy-jump-nav-open",
      excludeFromOutsideLock: (element: Element, currentRoot: HTMLElement) =>
        element === currentRoot || element === currentRoot.closest("header"),
      applyDesktopState: () => {
        nav.setAttribute("data-open", "true");
        toggle.setAttribute("aria-expanded", "true");
        content.hidden = false;
      },
      applyMobileClosedState: () => {
        nav.setAttribute("data-open", "false");
        toggle.setAttribute("aria-expanded", "false");
        content.hidden = true;
      },
      closeOnLinkSelector: "a[href^='#']",
    });
  });
</script>

<style>
  :global(body.taxonomy-jump-nav-open) {
    overflow: hidden;
  }

  .taxonomy-jump-nav {
    position: static;
    display: block;
  }

  .taxonomy-jump-nav__panel {
    display: grid;
    gap: var(--spacing-base);
    padding-block: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
  }

  .taxonomy-jump-nav__header {
    display: grid;
    gap: var(--spacing-sm);
  }

  .taxonomy-jump-nav__headline {
    margin: 0;
    color: var(--text-primary);
  }

  @media (width >= 40rem) {
    .taxonomy-jump-nav__header {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--spacing-lg);
      align-items: center;
      justify-content: space-between;
    }
  }

  .taxonomy-jump-nav__toggle {
    display: none;
    gap: var(--spacing-md);
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: var(--spacing-md) var(--spacing-lg);
    font: inherit;
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    text-align: center;
    cursor: pointer;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-subtle);
    border-radius: var(--radius-lg);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  @media (prefers-reduced-motion: reduce) {
    .taxonomy-jump-nav__toggle {
      transition: none;
    }
  }

  .taxonomy-jump-nav__toggle:hover,
  .taxonomy-jump-nav__toggle:focus-visible {
    background: var(--surface-card-hover);
    border-color: var(--surface-border-accent);
    transform: translateY(-1px);
  }

  .taxonomy-jump-nav__toggle:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .taxonomy-jump-nav__toggle-label {
    line-height: var(--line-height-tight);
  }

  .taxonomy-jump-nav__chevron {
    width: var(--spacing-base);
    height: var(--spacing-base);
    color: var(--accent-primary);
    transition: transform var(--transition-fast);
  }

  @media (prefers-reduced-motion: reduce) {
    .taxonomy-jump-nav__chevron {
      transition: none;
    }
  }

  .taxonomy-jump-nav[data-open="true"] .taxonomy-jump-nav__chevron {
    transform: rotate(180deg);
  }

  .taxonomy-jump-nav__content {
    position: static;
    z-index: 1;
    visibility: visible;
    width: 100%;
    min-width: 0;
    max-height: none;
    padding: 0;
    overflow: visible;
    pointer-events: auto;
    background: none;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    opacity: 1;
    transform: none;
    transition: none;
  }

  .taxonomy-jump-nav__content[hidden] {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .taxonomy-jump-nav__content {
      transition: none;
    }
  }

  .taxonomy-jump-nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .taxonomy-jump-nav__item {
    margin: 0;
  }

  .taxonomy-jump-nav__link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    min-block-size: var(--control-min-block-size);
    padding: var(--spacing-xs) var(--spacing-sm);
    color: var(--text-primary);
    text-decoration: none;
    background: none;
    border: 1px solid var(--surface-border-subtle);
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  @media (prefers-reduced-motion: reduce) {
    .taxonomy-jump-nav__link {
      transition: none;
    }
  }

  .taxonomy-jump-nav__link:hover,
  .taxonomy-jump-nav__link:focus-visible {
    color: var(--accent-primary);
    background: color-mix(in srgb, var(--accent-primary) 5%, transparent);
    border-color: var(--surface-border-accent);
  }

  .taxonomy-jump-nav__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .taxonomy-jump-nav__count {
    flex-shrink: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-none);
    color: var(--text-tertiary);
  }

  @media (width < 40rem) {
    .taxonomy-jump-nav__toggle {
      display: inline-flex;
      justify-content: space-between;
      width: 100%;
      text-align: left;
    }

    .taxonomy-jump-nav__content {
      position: absolute;
      top: calc(100% + var(--spacing-md));
      right: 0;
      left: 0;
      z-index: 20;
      visibility: hidden;
      max-height: min(var(--overlay-max-block-size), 60vh);
      padding: var(--spacing-base);
      overflow: auto;
      pointer-events: none;
      background: var(--surface-panel-bg);
      background-image: none;
      border: 1px solid var(--surface-border-soft);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-base);
      opacity: 0;
      transform: translateY(calc((var(--spacing-xs) + var(--spacing-2xs)) * -1));
    }

    .taxonomy-jump-nav[data-open="true"] .taxonomy-jump-nav__content {
      visibility: visible;
      pointer-events: auto;
      opacity: 1;
      transform: translateY(0);
    }

    .taxonomy-jump-nav__list {
      display: grid;
      gap: var(--spacing-sm);
    }

    .taxonomy-jump-nav__link {
      display: flex;
      justify-content: space-between;
      padding: var(--spacing-md) var(--spacing-base);
      border-radius: var(--radius-lg);
    }

    .taxonomy-jump-nav__link:hover,
    .taxonomy-jump-nav__link:focus-visible {
      transform: none;
    }
  }
</style>
