---
/**
 * Lightweight Search Panel
 *
 * Provides the consistent markup needed by `initSearchPanel` without the previous
 * prop explosion. Only the essentials remain: ids/labels and optional text templates
 * for the auto-managed status + no-results helpers.
 */
export interface Props {
  idBase: string;
  label: string;
  placeholder: string;
  ariaControls: string;
  /** Analytics surface key for result-click tracking */
  analyticsSurface?: string;
  /** Text shown when all items visible */
  statusAllText?: string;
  /** Template for results count (use {count}) */
  statusCountTemplate?: string;
  /** Template for no results (use {term}) */
  noResultsTemplate?: string;
}

const {
  idBase,
  label,
  placeholder,
  ariaControls,
  analyticsSurface = "unknown",
  statusAllText = "Showing all results",
  statusCountTemplate = "{count} results",
  noResultsTemplate = 'No results for "{term}"',
} = Astro.props as Props;

const inputId = `${idBase}-input`;
const clearId = `${idBase}-clear`;
const resetId = `${idBase}-reset`;
const statusId = `${idBase}-status`;
const noResultsId = `${idBase}-no-results`;
const inputClasses = "search-panel__input";
---

<div class="search-panel" data-search-root data-search-surface={analyticsSurface}>
  <div class="search-panel__bar">
    <div class="search-panel__field">
      <label for={inputId} class="search-panel__sr">{label}</label>
      <div class="search-panel__icon">
        <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <input
        id={inputId}
        type="search"
        class={inputClasses}
        {placeholder}
        aria-controls={ariaControls}
        aria-describedby={statusId}
        autocomplete="off"
        data-search-input
      />
      <button
        id={clearId}
        class="search-panel__clear"
        type="button"
        aria-label="Clear search input"
        data-search-clear
        hidden
        aria-hidden="true"
        tabindex="-1"
      >
        <svg aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <slot name="controls" />
    <button
      id={resetId}
      class="search-panel__reset"
      type="button"
      aria-label="Reset search"
      aria-controls={ariaControls}
      data-search-reset
    >
      <svg
        class="search-panel__reset-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 4v6h6M20 20v-6h-6"></path>
      </svg>
      <span>Reset search</span>
    </button>
  </div>
  <div class="search-panel__meta">
    <div
      id={statusId}
      data-search-status
      class="search-panel__status"
      role="status"
      aria-live="polite"
      aria-atomic="true"
      data-search-status-all={statusAllText}
      data-search-status-count={statusCountTemplate}
    >
    </div>
    <div
      id={noResultsId}
      data-search-no-results
      hidden
      data-search-no-results-tpl={noResultsTemplate}
      class="search-panel__no-results"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    >
    </div>
    <slot name="status" />
    <slot name="no-results" />
  </div>
</div>
<style>
  /* ========================================
     SEARCH PANEL - MINIMAL DESIGN
     ======================================== */

  .search-panel {
    display: grid;
    gap: 0.9rem;
    inline-size: 100%;
  }

  :global(.search-panel-shell) {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    inline-size: 100%;
    max-inline-size: var(--search-shell-max-inline-size, none);
    min-block-size: var(--search-shell-min-block-size, auto);
    padding: 0.9rem 1.1rem;
    background: var(--gn-bg-muted);
    border: 1px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  @media (width >= 640px) {
    :global(.search-panel-shell) {
      padding: 1.1rem 1.3rem;
    }
  }

  :global(.search-panel-shell .search-panel) {
    gap: 0.6rem;
  }

  .search-panel__bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .search-panel__field {
    position: relative;
    flex: 1 1 18rem;
    min-inline-size: 0;
  }

  .search-panel__sr {
    position: absolute;
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: 0;
    margin: var(--sr-only-margin);
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: var(--sr-only-clip-path);
  }

  .search-panel__icon {
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    display: flex;
    align-items: center;
    padding-inline-start: 1.3rem;
    color: var(--gn-ink-muted);
    pointer-events: none;
  }

  .search-panel__icon svg {
    display: block;
    inline-size: 1.5rem;
    block-size: 1.5rem;
  }

  .search-panel__input {
    inline-size: 100%;
    padding: 0.9rem 3.75rem 0.9rem 3.2rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 2px solid var(--gn-panel-border);
    border-radius: 999px;
  }

  @media (width >= 640px) {
    .search-panel__input {
      padding: 1.05rem 4rem 1.05rem 3.5rem;
      font-size: 1.15rem;
    }
  }

  .search-panel__input::placeholder {
    color: var(--gn-ink-muted);
  }

  .search-panel__input:hover,
  .search-panel__input:focus {
    border-color: var(--gn-accent);
  }

  .search-panel__input:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
    border-color: var(--gn-accent);
  }

  .search-panel__input:focus-visible + .search-panel__icon,
  .search-panel__input:hover + .search-panel__icon {
    color: var(--gn-accent);
  }

  .search-panel__clear {
    position: absolute;
    inset-block: 0;
    inset-inline-end: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-block-size: 44px;
    padding-inline: 0.35rem 0.9rem;
    color: var(--gn-ink-muted);
    cursor: pointer;
    background: transparent;
    border: none;
  }

  .search-panel__clear svg {
    inline-size: 1.2rem;
    block-size: 1.2rem;
    padding: 0.35rem;
    background: var(--gn-bg-muted);
    border-radius: 999px;
  }

  .search-panel__clear:hover,
  .search-panel__clear:focus {
    color: var(--gn-accent);
  }

  .search-panel__clear:focus-visible {
    outline: 2px solid var(--gn-accent);
    outline-offset: 3px;
  }

  .search-panel__reset {
    display: inline-flex;
    gap: 0.75rem;
    align-items: center;
    min-block-size: 44px;
    padding: 0.75rem 1.4rem;
    font-weight: 600;
    color: var(--gn-ink);
    white-space: nowrap;
    cursor: pointer;
    background: var(--gn-bg);
    border: 2px solid var(--gn-accent);
    border-radius: 999px;
  }

  .search-panel__reset:hover,
  .search-panel__reset:focus {
    background: var(--gn-bg-muted);
    border-color: var(--gn-accent);
  }

  .search-panel__reset:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
  }

  .search-panel__reset-icon {
    display: block;
    flex-shrink: 0;
    inline-size: 1.25rem;
    block-size: 1.25rem;
  }

  .search-panel__meta {
    display: grid;
    gap: 0.35rem;
    padding-inline-start: 0.25rem;
  }

  .search-panel__status {
    font-size: 1rem;
    color: var(--gn-ink-muted);
    text-align: start;
  }

  @media (width >= 640px) {
    .search-panel__status {
      font-size: 1.05rem;
    }
  }

  .search-panel__no-results {
    font-size: 1rem;
    color: var(--gn-ink-muted);
    text-align: start;
  }

  :root[data-theme="light"] :global(.search-panel-shell) {
    background: var(--gn-bg-muted);
  }

  :root[data-theme="light"] .search-panel__input {
    background: var(--gn-bg);
  }
</style>
