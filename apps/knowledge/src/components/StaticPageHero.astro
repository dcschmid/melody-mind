---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Highlight {
  label: string;
  value: string;
}

interface Props extends astroHTML.JSX.HTMLAttributes {
  badge?: string;
  eyebrow?: string;
  highlights: readonly Highlight[] | Highlight[];
  highlightsLabel: string;
  lead: string;
  leadClassName?: string;
  leadTextAlign?: "left" | "center" | "right";
  leadTextSize?: "sm" | "base" | "lg" | "xl";
  title: string;
  titleClassName?: string;
  titleLevel?: "h1" | "h2";
  titleTextAlign?: "left" | "center" | "right";
  titleTextSize?: "xl" | "2xl";
  class?: string;
}

const {
  badge,
  eyebrow,
  highlights,
  highlightsLabel,
  lead,
  leadClassName,
  leadTextAlign = "left",
  leadTextSize = "lg",
  title,
  titleClassName,
  titleLevel = "h1",
  titleTextAlign = "left",
  titleTextSize = "2xl",
  class: className,
  ...rest
} = Astro.props;
---

<header {...rest} class:list={["static-page-hero", className]}>
  <div class="static-page-hero__main">
    {
      badge ? (
        <div class="static-page-hero__badge">{badge}</div>
      ) : eyebrow ? (
        <Paragraph textSize="sm" className="static-page-hero__eyebrow">
          {eyebrow}
        </Paragraph>
      ) : null
    }
    <Headline
      level={titleLevel}
      textSize={titleTextSize}
      textAlign={titleTextAlign}
      className={`static-page-hero__title ${titleClassName || ""}`.trim()}
    >
      {title}
    </Headline>
    <Paragraph
      textSize={leadTextSize}
      textAlign={leadTextAlign}
      className={`static-page-hero__lead ${leadClassName || ""}`.trim()}
    >
      {lead}
    </Paragraph>
  </div>

  <div class="static-page-hero__highlights" aria-label={highlightsLabel}>
    {
      highlights.map((highlight) => (
        <div class="static-page-hero__highlight">
          <p class="static-page-hero__highlight-value">{highlight.value}</p>
          <p class="static-page-hero__highlight-label">{highlight.label}</p>
        </div>
      ))
    }
  </div>
</header>

<style>
  .static-page-hero {
    position: relative;
    display: grid;
    gap: var(--spacing-lg);
    padding: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl));
    overflow: hidden;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--card-bg) 96%, transparent),
        color-mix(in srgb, var(--surface-2) 94%, transparent)
      ),
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--accent-primary) 14%, transparent),
        transparent 36%
      );
    border: var(--card-border-width) solid
      color-mix(in srgb, var(--card-border-color) 82%, transparent);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
  }

  .static-page-hero::before {
    position: absolute;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: var(--spacing-2xs);
    content: "";
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-primary) 76%, transparent),
      color-mix(in srgb, var(--accent-strong) 58%, transparent),
      transparent
    );
  }

  .static-page-hero::after {
    position: absolute;
    inset: var(--spacing-xs);
    pointer-events: none;
    content: "";
    border: 1px solid color-mix(in srgb, var(--border-default) 34%, transparent);
    border-radius: calc(var(--radius-2xl) - var(--spacing-xs));
  }

  .static-page-hero__main {
    display: grid;
    gap: var(--spacing-base);
    max-inline-size: var(--measure-wide);
  }

  .static-page-hero__eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--link-default);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-widest);
  }

  .static-page-hero__title {
    margin: 0;
    font-size: var(--font-size-4xl);
    font-weight: var(--heading-font-weight);
    line-height: var(--heading-line-height);
    letter-spacing: var(--heading-letter-spacing);
  }

  .static-page-hero__lead {
    margin: 0;
    color: color-mix(in srgb, var(--text-primary) 82%, transparent);
  }

  .static-page-hero__badge {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-self: start;
    padding: var(--spacing-sm) var(--spacing-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-widest);
    background: var(--surface-pill-bg);
    border: 1px solid var(--surface-border-accent);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
  }

  .static-page-hero__highlights {
    display: grid;
    gap: var(--spacing-md);
  }

  .static-page-hero__highlight {
    position: relative;
    display: grid;
    gap: var(--spacing-sm);
    align-content: start;
    padding: var(--spacing-base);
    background: var(--surface-pill-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--card-radius);
  }

  .static-page-hero__highlight::before {
    inline-size: var(--spacing-base);
    block-size: var(--spacing-2xs);
    content: "";
    background: color-mix(in srgb, var(--accent-primary) 72%, transparent);
    border-radius: var(--radius-full);
  }

  .static-page-hero__highlight-value,
  .static-page-hero__highlight-label {
    margin: 0;
  }

  .static-page-hero__highlight-value {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    letter-spacing: var(--letter-spacing-wide);
  }

  .static-page-hero__highlight-label {
    font-size: var(--font-size-base);
    color: var(--text-secondary);
  }

  @media (width >= 720px) {
    .static-page-hero {
      padding: clamp(var(--spacing-xl), 3vw, var(--spacing-2xl));
    }

    .static-page-hero__highlights {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
