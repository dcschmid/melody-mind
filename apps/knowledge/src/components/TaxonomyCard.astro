---
/**
 * TaxonomyCard Component - Minimal & Accessible
 *
 * Used on the homepage to display taxonomy sections.
 * WCAG AAA compliant with minimal styling.
 */
import Card from "@shared-ui/components/cards/Card.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  id: string;
  title: string;
  description?: string;
  image?: string;
  subsectionCount: number;
  articleCount: number;
  href: string;
  index?: number;
}

const {
  id,
  title,
  description,
  image = "/taxonomy/default.jpg",
  subsectionCount,
  articleCount,
  href,
  index: _index = 0,
} = Astro.props;

const cardId = `taxonomy-card-${id}`;
---

<Card
  data-testid="taxonomy-card"
  data-title={title}
  href={href}
  labelledBy={cardId}
  variant="default"
  mediaObjectFit="contain"
  imageSrc={image}
  imageAlt={`${title} cover`}
  imageClassName="taxonomy-card__image"
  imageWidth={1024}
  imageHeight={683}
>
  <Fragment slot="badge">
    <span class="taxonomy-card__badge">
      {articleCount > 0 ? `${articleCount} articles` : `${subsectionCount} topics`}
    </span>
  </Fragment>

  <div class="taxonomy-card__body">
    <Headline level="h3" textSize="base" className="taxonomy-card__title">
      <span id={cardId}>{title}</span>
    </Headline>
    {
      description && (
        <Paragraph textSize="sm" className="taxonomy-card__description">
          {description}
        </Paragraph>
      )
    }
  </div>
</Card>

<style>
  .taxonomy-card__badge {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    padding: 0.4rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: color-mix(in srgb, var(--surface-1) 96%, transparent);
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: 999px;
  }

  .taxonomy-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
  }

  .taxonomy-card__title {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .taxonomy-card__description {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 3;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    /* stylelint-disable-next-line property-no-deprecated */
    -webkit-box-orient: block-axis;
  }

  @container (max-width: 480px) {
    .taxonomy-card__body {
      gap: 0.5rem;
      padding: 1rem;
    }

    .taxonomy-card__badge {
      padding: 0.3rem 0.7rem;
      font-size: 0.7rem;
    }

    .taxonomy-card__title {
      font-size: 1.1rem;
    }

    .taxonomy-card__description {
      font-size: 0.9rem;
    }
  }
</style>
