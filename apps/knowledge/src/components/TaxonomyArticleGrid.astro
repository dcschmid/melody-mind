---
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import type { TaxonomyArticle } from "@utils/taxonomy/buildTaxonomySectionPageData";

interface Props {
  articles: TaxonomyArticle[];
  emptyDescription: string;
}

const { articles, emptyDescription } = Astro.props as Props;

const articleDateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

{
  articles.length > 0 ? (
    <ul class="taxonomy-article-grid">
      {articles.map((article, index) => {
        const articleSlug = "slug" in article ? article.slug : article.id;
        const createdAt = article.data.createdAt || new Date();

        return (
          <li class="taxonomy-article-grid__item">
            <ContentCard
              id={`card-title-${articleSlug}-${index}`}
              data-testid="knowledge-card"
              data-title={article.data.title}
              data-description={article.data.description}
              href={`/knowledge/${articleSlug}`}
              variant="default"
              size="default"
              mediaObjectFit="contain"
              imageSrc={article.data.image || "/default-cover.jpg"}
              imageAlt={`Cover image for ${article.data.title}`}
              imageWidth={1024}
              imageHeight={683}
              title={article.data.title}
              description={article.data.description}
              metaItems={[
                {
                  iconName: "clock",
                  label: `${article.data.readingTime || 0} min read`,
                },
                {
                  iconName: "calendar",
                  label: articleDateFormatter.format(createdAt),
                  datetime: createdAt.toISOString(),
                },
              ]}
              ctaSrText="Opens article"
            />
          </li>
        );
      })}
    </ul>
  ) : (
    <EmptyState className="taxonomy-article-grid__empty" description={emptyDescription} />
  )
}

<style>
  .taxonomy-article-grid {
    display: grid;
    gap: var(--spacing-lg);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .taxonomy-article-grid__item {
    min-inline-size: 0;
  }

  @media (width >= 640px) {
    .taxonomy-article-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1024px) {
    .taxonomy-article-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .taxonomy-article-grid__empty {
    padding: var(--spacing-lg);
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: var(--radius-lg);
  }
</style>
