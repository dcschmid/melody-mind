---
/**
 * ButtonLink Component - Simple & Clean
 *
 * A versatile anchor-style button with consistent styling.
 */
import { getLangFromUrl, useTranslations } from "@utils/i18n";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(String(lang));

type ButtonVariant = "primary" | "secondary";

interface Props {
  href: string;
  ariaLabel?: string;
  ariaDescribedBy?: string;
  className?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;
  variant?: ButtonVariant;
  icon?: string;
  analyticsPodcastTarget?: "episode" | "series";
}

const rawProps = Astro.props as Props & Record<string, unknown>;

const {
  href,
  ariaLabel,
  ariaDescribedBy,
  className = "",
  target = "_self",
  rel,
  variant = "primary",
  icon,
  analyticsPodcastTarget,
} = rawProps;

const isExternal = target === "_blank";
const finalRel = isExternal ? `noopener noreferrer ${rel || ""}`.trim() : rel;
const externalLinkText = t("nav.openNewWindow");

const baseClasses = "button-link";

const variantClasses: Record<ButtonVariant, string> = {
  primary: "button-link--primary",
  secondary: "button-link--secondary",
};

const classes = [baseClasses, variantClasses[variant], String(className)]
  .filter(Boolean)
  .join(" ");

const iconClasses = "button-link__icon";

const ariaLabelAttr =
  (ariaLabel as string | undefined) ?? (rawProps["aria-label"] as string | undefined);

const ariaDescribedByAttr =
  (ariaDescribedBy as string | undefined) ??
  (rawProps["aria-describedby"] as string | undefined);

const forwardedAttrs = (() => {
  const restAttrs: Record<string, unknown> = { ...rawProps };
  for (const key of [
    "href",
    "ariaLabel",
    "ariaDescribedBy",
    "className",
    "target",
    "rel",
    "variant",
    "icon",
    "analyticsPodcastTarget",
    "aria-describedby",
    "aria-label",
  ]) {
    if (key in restAttrs) {
      delete (restAttrs as Record<string, unknown>)[key];
    }
  }
  return restAttrs;
})();
---

<a
  {href}
  class={classes}
  aria-label={ariaLabelAttr
    ? `${ariaLabelAttr}${isExternal ? ` (${externalLinkText})` : ""}`
    : undefined}
  aria-describedby={ariaDescribedByAttr}
  {target}
  rel={finalRel}
  data-analytics-podcast-target={analyticsPodcastTarget}
  {...forwardedAttrs}
>
  {icon && <Icon name={icon} class={iconClasses} aria-hidden="true" />}
  <slot />
  {isExternal && <span class="button-link__sr"> ({externalLinkText})</span>}
</a>
<style>
  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 48px;
    min-width: 48px;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    border: 2px solid transparent;
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.75);
    line-height: 1.2;
    width: 100%;
    max-width: 100%;
  }

  @media (min-width: 640px) {
    .button-link {
      width: auto;
    }
  }

  .button-link:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--gn-accent) 35%, transparent);
  }

  .button-link:hover {
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.82);
  }

  .button-link:active {
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.85);
  }

  .button-link--primary {
    background: var(--gn-bg-muted);
    border-color: var(--color-gn-amber-500);
    color: var(--gn-ink);
  }

  .button-link--primary:hover {
    background: var(--gn-bg);
  }

  .button-link--secondary {
    background: var(--gn-bg-muted);
    border-color: var(--gn-panel-border);
    color: var(--gn-ink-muted);
  }

  .button-link--secondary:hover {
    background: var(--gn-bg);
    color: var(--gn-ink);
  }

  .button-link--sm {
    min-height: 36px;
    padding: 0.45rem 0.9rem;
    font-size: 1rem;
  }

  .button-link--md {
    min-height: 40px;
    padding: 0.55rem 1rem;
    font-size: 1.125rem;
  }

  .button-link__icon {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  .button-link__sr {
    position: absolute;
    width: var(--sr-only-width);
    height: var(--sr-only-height);
    margin: var(--sr-only-margin);
    overflow: hidden;
    clip-path: var(--sr-only-clip-path);
    white-space: nowrap;
    border: 0;
  }
</style>
