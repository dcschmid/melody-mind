---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { normalizeImageKey } from "@shared-utils/utils/imageAssets";

interface Props {
  imageSrc: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  heading: string;
  headingLevel?: "h2" | "h3" | "h4";
  sizes?: string;
  className?: string;
}

const knowledgeImageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/knowledge/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

const knowledgeImagesByPath = Object.fromEntries(
  Object.entries(knowledgeImageModules).map(([path, module]) => {
    const normalizedPath = path.replace(/^\.\.\/assets\//u, "").replace(/\?.*$/u, "");
    return [normalizedPath, module.default];
  })
) as Record<string, ImageMetadata>;
const knowledgeImagesByKey = Object.fromEntries(
  Object.entries(knowledgeImageModules).map(([path, module]) => {
    const fileName = path.split("/").pop() ?? "";
    return [normalizeImageKey(fileName), module.default];
  })
) as Record<string, ImageMetadata>;

const {
  imageSrc,
  imageAlt = "",
  imageWidth,
  imageHeight,
  heading,
  headingLevel = "h3",
  sizes = "(max-width: 640px) 100vw, (max-width: 1024px) 70vw, 40vw",
  className = "",
} = Astro.props as Props;

const normalizedImageKey = imageSrc.replace(/^\/+/u, "").replace(/\?.*$/u, "");
const resolvedImage =
  knowledgeImagesByPath[normalizedImageKey] ||
  knowledgeImagesByKey[normalizeImageKey(normalizedImageKey)];

if (!resolvedImage) {
  throw new Error(`Unknown knowledge subsection image: ${imageSrc}`);
}

const resolvedImageWidth = imageWidth || resolvedImage.width;
const resolvedImageHeight = imageHeight || resolvedImage.height;
const Tag = headingLevel;
const classes = ["subsection-figure", className].filter(Boolean).join(" ");
---

<figure class={classes}>
  <div class="subsection-figure__media">
    <Image
      class="subsection-figure__image"
      src={resolvedImage}
      alt={imageAlt}
      width={resolvedImageWidth}
      height={resolvedImageHeight}
      sizes={sizes}
      loading="lazy"
      decoding="async"
    />
  </div>
  <figcaption class="subsection-figure__content">
    <Tag class="subsection-figure__title">{heading}</Tag>
  </figcaption>
</figure>

<style>
  .subsection-figure {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-base);
    align-items: center;
    margin: var(--spacing-xl) 0;
  }

  .subsection-figure__media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  .subsection-figure__media::after {
    position: absolute;
    inset: var(--spacing-xs);
    pointer-events: none;
    content: "";
    border: 1px solid var(--surface-border-subtle);
    border-radius: calc(var(--radius-lg) - var(--spacing-xs));
  }

  .subsection-figure__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .subsection-figure__content {
    position: relative;
    display: flex;
    align-items: center;
    min-block-size: 100%;
    padding-inline-start: var(--spacing-lg);
  }

  .subsection-figure__content::before {
    position: absolute;
    inset-block: var(--spacing-xs);
    inset-inline-start: 0;
    inline-size: 3px;
    content: "";
    background: var(--accent-primary);
    border-radius: var(--radius-full);
  }

  .subsection-figure__title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--font-size-xl);
    line-height: var(--line-height-tight);
    color: var(--heading-color);
    letter-spacing: var(--letter-spacing-tight);
    text-wrap: balance;
  }

  @media (width >= 900px) {
    .subsection-figure {
      grid-template-columns: minmax(0, 40%) minmax(0, 60%);
      gap: var(--spacing-xl);
    }
  }

  @media (width <= 899px) {
    .subsection-figure__content {
      padding-block-start: var(--spacing-base);
      padding-inline-start: 0;
    }

    .subsection-figure__content::before {
      inset-block: 0 auto;
      inline-size: 2.75rem;
      block-size: 3px;
    }
  }
</style>
