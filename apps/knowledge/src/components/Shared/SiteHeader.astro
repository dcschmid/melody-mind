---
import SharedSiteHeader from "@shared-ui/components/Shared/SiteHeader.astro";

interface NavItem {
  href: string;
  label: string;
  icon?: string;
  badgeType?: "bookmarkCount";
  badgeBaseLabel?: string;
}

interface Props {
  showIcons?: boolean;
}

const { showIcons = true } = Astro.props as Props;

const navItems: NavItem[] = [
  {
    href: "/bookmarks",
    label: "Bookmarks",
    icon: "bookmark",
    badgeType: "bookmarkCount",
    badgeBaseLabel: "Saved articles",
  },
  { href: "/quiz", label: "Quizzes", icon: "grid" },
];
---

<SharedSiteHeader
  {showIcons}
  {navItems}
  brandHref="/"
  brandText="Melody Mind"
  brandMark="MM"
  brandAriaLabel="Go to the Melody Mind homepage"
  searchAction="/search"
  searchInputName="q"
  searchInputLabel="Search Melody Mind"
  searchInputPlaceholder="Search titles or descriptions..."
  searchSubmitLabel="Search"
  menuOpenLabel="Open main menu"
  menuCloseLabel="Close main menu"
  menuText="Menu"
  navAriaLabel="Primary navigation"
/>
