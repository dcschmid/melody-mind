---
/**
 * KnowledgeCard Component - Minimal & Accessible
 *
 * A simple card for displaying music knowledge articles.
 * WCAG AAA compliant with essential hover feedback for links only.
 */
import { format } from "date-fns";
import { enUS as en } from "date-fns/locale";
import Icon from "@shared-ui/components/Icon.astro";
import Card from "@shared-ui/components/Card.astro";
import Headline from "@shared-ui/components/Headline.astro";

export const prerender = true;

interface Props {
  title: string;
  description: string;
  image?: string;
  createdAt: Date;
  slug: string;
  readingTime?: number;
  articleUrl?: string;
  keywords?: string;
  index?: number;
}

const {
  title,
  description,
  image = "/default-cover.jpg",
  createdAt,
  slug,
  readingTime = 0,
  articleUrl,
  keywords,
  index = 0,
} = Astro.props;

const locale = en;
const formattedDate = format(createdAt, "MMMM d, yyyy", { locale });
const hasOwnLink = Boolean(articleUrl);
const cardId = `card-title-${slug}-${index}`;
const metaId = `${cardId}-meta`;
const descId = `${cardId}-desc`;
const imageAltText = title ? `Cover image for ${title}` : "";
---

<Card
  data-testid="knowledge-card"
  data-title={title}
  data-description={description}
  data-keywords={keywords}
  labelledBy={cardId}
  describedBy={`${descId} ${metaId}`}
  href={articleUrl}
  variant="default"
  mediaObjectFit="contain"
  imageSrc={image}
  imageAlt={imageAltText}
  imageClassName="knowledge-card__image"
  imageWidth={1024}
  imageHeight={683}
>
  <div class="knowledge-card__body">
    <Headline
      level="h3"
      textSize="base"
      class:list={[
        "knowledge-card__title",
        !hasOwnLink && "knowledge-card__title--centered",
      ]}
    >
      <span id={cardId}>{title}</span>
    </Headline>

    <div id={descId}>
      <p
        class:list={[
          "knowledge-card__description",
          !hasOwnLink && "knowledge-card__description--centered",
        ]}
      >
        {description}
      </p>
    </div>

    <div class="knowledge-card__meta" id={metaId}>
      <div class="knowledge-card__meta-item">
        <Icon name="clock" class="knowledge-card__meta-icon" aria-hidden="true" />
        <span>
          {readingTime} min read
        </span>
      </div>
      <time
        datetime={createdAt.toISOString()}
        class="knowledge-card__meta-item"
        aria-label={`Published: ${formattedDate}`}
      >
        <Icon name="calendar" class="knowledge-card__meta-icon" aria-hidden="true" />
        {formattedDate}
      </time>
    </div>
  </div>

  {hasOwnLink && <Fragment slot="sr">Opens article</Fragment>}
</Card>

<style>
  .knowledge-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
  }

  .knowledge-card__title {
    margin: 0;
    font-size: var(--font-size-lg);
    color: var(--gn-ink);
  }

  .knowledge-card__title--centered {
    text-align: center;
  }

  .knowledge-card__description {
    margin: 0;
    line-height: 1.65;
    color: var(--gn-ink-muted);
  }

  .knowledge-card__description--centered {
    text-align: center;
  }

  .knowledge-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    padding-block-start: 1.25rem;
    margin-block-start: auto;
    font-size: var(--font-size-sm);
    color: var(--gn-ink-muted);
    border-block-start: 1px solid var(--gn-panel-border);
  }

  .knowledge-card__meta-item {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    font-weight: 500;
    white-space: nowrap;
  }

  .knowledge-card__meta-icon {
    display: block;
    flex-shrink: 0;
    inline-size: 1.125rem;
    block-size: 1.125rem;
    color: var(--color-gn-amber-300);
  }

  @container (max-width: 480px) {
    .knowledge-card__body {
      gap: 0.875rem;
      padding: 1.25rem;
    }

    .knowledge-card__meta {
      gap: 0.5rem;
      padding-block-start: 1rem;
    }

    .knowledge-card__title {
      font-size: var(--font-size-base);
    }
  }
</style>
