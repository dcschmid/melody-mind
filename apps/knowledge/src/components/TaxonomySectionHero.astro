---
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import { Image } from "astro:assets";
import type { TaxonomySection } from "../types/taxonomy";

interface Props {
  section: TaxonomySection;
  subsectionCount: number;
  articleCount: number;
}

const { section, subsectionCount, articleCount } = Astro.props as Props;
---

<header class="taxonomy-section-hero">
  <HeroTeaser
    id={`taxonomy-hero-${section.id}`}
    title={section.title}
    titleLevel="h1"
    description={section.description ||
      "Explore the connected topics and articles in this section."}
    mediaPosition="start"
    mediaAspectRatio="4 / 3"
  >
    {
      section.image ? (
        <Fragment slot="media">
          <Image
            src={section.image}
            alt={section.title}
            loading="eager"
            class="taxonomy-section-hero__image"
            width="1200"
            height="900"
          />
        </Fragment>
      ) : null
    }
    <div slot="meta" class="taxonomy-section-hero__stats" aria-label="Section statistics">
      <span class="taxonomy-section-hero__stat">{subsectionCount} topics</span>
      <span class="taxonomy-section-hero__stat">{articleCount} articles</span>
    </div>
  </HeroTeaser>
</header>

<style>
  .taxonomy-section-hero {
    padding-block-end: var(--spacing-xl);
    border-block-end: 1px solid color-mix(in srgb, var(--border-default) 72%, transparent);
  }

  .taxonomy-section-hero__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .taxonomy-section-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-base);
  }

  .taxonomy-section-hero__stat {
    display: inline-flex;
    align-items: center;
    min-block-size: var(--spacing-2xl);
    padding: var(--spacing-md) var(--spacing-base);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--accent-strong);
    letter-spacing: var(--letter-spacing-wide);
    background: var(--surface-pill-bg);
    border: 1px solid var(--surface-border-accent);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
  }
</style>
