---
import LegalDocumentSection from "./LegalDocumentSection.astro";
import StaticPageHero from "./StaticPageHero.astro";

interface Highlight {
  label: string;
  value: string;
}

interface Section {
  body: readonly string[] | string[];
  icon: string;
  title: string;
}

interface Props {
  eyebrow: string;
  highlights: readonly Highlight[] | Highlight[];
  highlightsLabel: string;
  lead: string;
  sections: readonly Section[] | Section[];
  title: string;
}

const { eyebrow, highlights, highlightsLabel, lead, sections, title } = Astro.props;
---

<div class="legal-document">
  <StaticPageHero
    eyebrow={eyebrow}
    {highlights}
    {highlightsLabel}
    lead={lead}
    title={title}
  />

  <div class="legal-document__content-grid">
    {
      sections.map((section) => (
        <LegalDocumentSection
          icon={section.icon}
          title={section.title}
          body={section.body}
        />
      ))
    }
  </div>
</div>

<style>
  .legal-document {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .legal-document__content-grid {
    display: grid;
    gap: var(--section-gap);
  }

  @media (width >= 720px) {
    .legal-document__content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1100px) {
    .legal-document__content-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--spacing-lg);
    }
  }
</style>
