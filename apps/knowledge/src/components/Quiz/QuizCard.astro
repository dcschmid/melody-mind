---
import SharedQuizCard from "@shared-ui/components/QuizCard.astro";

export const prerender = true;

interface Props {
  title: string;
  description: string;
  slug: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, slug, image, imageAlt } = Astro.props as Props;
---

<SharedQuizCard
  title={title}
  description={description}
  href={`/quiz/${slug}`}
  image={image}
  imageAlt={imageAlt}
  id={`quiz-card-${slug}`}
/>
