---
import { Icon } from "astro-icon/components";
import ReadingModeToggle from "@components/ReadingModeToggle.astro";
---

<section class="panel panel--compact reading-controls" aria-label="Reading settings">
  <button
    id="reading-controls-toggle"
    aria-expanded="false"
    aria-controls="reading-controls-content"
    class="reading-controls__toggle"
  >
    <span class="reading-controls__toggle-label">
      <Icon name="menu" class="reading-controls__toggle-icon" aria-hidden="true" />
      <span>Reading settings</span>
    </span>
    <span
      class="reading-controls__sr"
      data-expanded="Hide reading settings"
      data-collapsed="Show reading settings"
    >
      Show reading settings
    </span>
    <Icon
      name="chevron-down"
      id="reading-controls-chevron"
      class="reading-controls__toggle-chevron"
      aria-hidden="true"
    />
  </button>

  <div
    id="reading-controls-content"
    aria-labelledby="reading-controls-toggle"
    class="reading-controls__content"
  >
    <div class="reading-controls__row" role="group" aria-label="Font size">
      <span class="reading-controls__label">Text size</span>
      <div class="reading-controls__actions">
        <button
          type="button"
          class="reading-controls__button"
          data-reading-font-size="small"
          data-active="false"
          aria-pressed="false"
        >
          A-
        </button>
        <button
          type="button"
          class="reading-controls__button"
          data-reading-font-size="medium"
          data-active="true"
          aria-pressed="true"
        >
          A
        </button>
        <button
          type="button"
          class="reading-controls__button"
          data-reading-font-size="large"
          data-active="false"
          aria-pressed="false"
        >
          A+
        </button>
      </div>
    </div>

    <div class="reading-controls__row" role="group" aria-label="Line height">
      <span class="reading-controls__label">Line spacing</span>
      <div class="reading-controls__actions">
        <button
          type="button"
          class="reading-controls__button"
          data-reading-line-height="compact"
          data-active="false"
          aria-pressed="false"
        >
          Compact
        </button>
        <button
          type="button"
          class="reading-controls__button"
          data-reading-line-height="normal"
          data-active="true"
          aria-pressed="true"
        >
          Normal
        </button>
        <button
          type="button"
          class="reading-controls__button"
          data-reading-line-height="relaxed"
          data-active="false"
          aria-pressed="false"
        >
          Relaxed
        </button>
      </div>
    </div>

    <div class="reading-controls__row reading-controls__row--mode">
      <span class="reading-controls__label">Reading mode</span>
      <ReadingModeToggle />
    </div>
  </div>
</section>

<script>
  (() => {
    const toggle = document.getElementById("reading-controls-toggle");
    const content = document.getElementById("reading-controls-content");
    const stateText = toggle?.querySelector("[data-expanded]") as HTMLElement | null;

    if (!toggle || !content) {
      return;
    }

    let isOpen = false;

    const setExpanded = (expanded: boolean): void => {
      toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      content.setAttribute("aria-hidden", expanded ? "false" : "true");
      toggle.parentElement?.classList.toggle("reading-controls--open", expanded);
      if (stateText) {
        stateText.textContent = expanded
          ? stateText.getAttribute("data-expanded") || ""
          : stateText.getAttribute("data-collapsed") || "";
      }
    };

    const toggleContent = (): void => {
      isOpen = !isOpen;
      setExpanded(isOpen);
    };

    toggle.addEventListener("click", (e): void => {
      e.preventDefault();
      toggleContent();
    });

    toggle.addEventListener("keydown", (e): void => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggleContent();
      }
    });

    document.addEventListener("click", (e): void => {
      if (!isOpen) return;
      const target = e.target as Node;
      if (target && !toggle.contains(target) && !content.contains(target)) {
        isOpen = false;
        setExpanded(false);
      }
    });

    setExpanded(isOpen);
  })();
</script>

<style>
  .reading-controls {
    display: grid;
    gap: 1rem;
    margin-block: 0.75rem 1rem;
    border: 2px solid var(--gn-panel-border);
    background: var(--gn-bg-muted);
    padding: 0;
    border-radius: 1rem;
    overflow: hidden;
  }

  .reading-controls__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    min-height: 48px;
    padding: 0.75rem 1.25rem;
    border-radius: 0;
    border: none;
    border-bottom: 2px solid transparent;
    background: var(--gn-bg);
    color: var(--gn-ink);
    font-size: 1.125rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
  }

  .reading-controls__toggle:hover {
    background: var(--gn-bg-muted);
    border-bottom-color: var(--gn-accent);
  }

  .reading-controls__toggle:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: -3px;
  }

  .reading-controls__toggle-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .reading-controls__toggle-icon {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--gn-ink-muted);
  }

  .reading-controls__toggle-chevron {
    display: block;
    width: 1.1rem;
    height: 1.1rem;
    color: var(--gn-ink-muted);
  }

  .reading-controls--open .reading-controls__toggle-chevron {
    transform: rotate(180deg);
  }

  .reading-controls__sr {
    position: absolute;
    width: var(--sr-only-width);
    height: var(--sr-only-height);
    margin: var(--sr-only-margin);
    overflow: hidden;
    clip-path: var(--sr-only-clip-path);
    white-space: nowrap;
    border: 0;
  }

  .reading-controls__content {
    display: none;
    padding: 1.25rem;
    border-top: 2px solid var(--gn-panel-border);
    background: var(--gn-bg);
  }

  .reading-controls--open .reading-controls__content {
    display: block;
  }

  .reading-controls__row {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 0.95rem;
    border-radius: 0.75rem;
    border: 1px solid var(--gn-panel-border);
    background: var(--gn-bg-muted);
  }

  .reading-controls__row--mode {
    align-items: flex-start;
  }

  .reading-controls__label {
    margin: 0;
    font-size: 1.15rem;
    color: var(--gn-ink-muted);
    font-weight: 600;
  }

  .reading-controls__actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    width: fit-content;
    padding: 0.3rem;
    border-radius: 999px;
    border: 1px solid var(--gn-panel-border);
    background: var(--gn-bg);
  }

  .reading-controls__button {
    min-height: 2.4rem;
    min-width: 3.35rem;
    border-radius: 999px;
    border: 2px solid transparent;
    background: transparent;
    color: var(--gn-ink);
    padding: 0.35rem 0.85rem;
    font-size: 1.025rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
  }

  .reading-controls__button:hover {
    border-color: var(--gn-accent);
    background: var(--gn-bg-muted);
  }

  .reading-controls__button[data-active="true"] {
    border-color: var(--gn-accent);
    background: var(--gn-accent);
    color: var(--gn-bg);
  }

  .reading-controls__button:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
  }

  @media (min-width: 900px) {
    .reading-controls {
      margin-block: 0.9rem 1.1rem;
    }

    .reading-controls__row {
      grid-template-columns: minmax(10rem, 12rem) minmax(0, 1fr);
      align-items: center;
      column-gap: 1rem;
      display: grid;
    }

    .reading-controls__row--mode {
      align-items: center;
    }
  }
</style>
