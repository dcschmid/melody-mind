---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import AIContentBadge from "@shared-ui/components/badges/AIContentBadge.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import type { KnowledgeArticleLike } from "@utils/knowledge/articlePage";

interface Props {
  entry: KnowledgeArticleLike & {
    data: NonNullable<KnowledgeArticleLike["data"]> & {
      title: string;
      description: string;
    };
  };
  imageSource?: ImageMetadata;
  publishedDate: Date;
  publishedDateLabel: string;
  readingText: string;
  slugKey: string;
  taxonomyPillLabel: string;
}

const {
  entry,
  imageSource,
  publishedDate,
  publishedDateLabel,
  readingText,
  slugKey,
  taxonomyPillLabel,
} = Astro.props as Props;
---

<div class="knowledge__hero">
  <HeroTeaser
    id={`knowledge-article-hero-${slugKey || "entry"}`}
    title={entry.data.title}
    titleLevel="h1"
    description={entry.data.description}
    mediaAspectRatio="3 / 2"
    class="knowledge__hero-teaser"
  >
    <div slot="meta" class="knowledge__meta">
      <p class="knowledge__meta-label">In-depth guide</p>
      <ul class="knowledge__meta-list" aria-label="Article details">
        {
          entry.data.aiGenerated ? (
            <li class="knowledge__meta-item">
              <AIContentBadge
                aiTools={entry.data.aiTools}
                size="md"
                className="knowledge__ai-badge"
              />
            </li>
          ) : null
        }
        <li class="knowledge__meta-item">
          <Icon name="calendar" class="knowledge__pill-icon" aria-hidden="true" />
          <time datetime={publishedDate.toISOString()}>{publishedDateLabel}</time>
        </li>
        <li class="knowledge__meta-item">
          <Icon name="clock" class="knowledge__pill-icon" aria-hidden="true" />
          <span>{readingText}</span>
        </li>
        {
          taxonomyPillLabel ? (
            <li class="knowledge__meta-item">
              <Icon
                name="tag"
                class="knowledge__pill-icon knowledge__pill-icon--teal"
                aria-hidden="true"
              />
              <span>{taxonomyPillLabel}</span>
            </li>
          ) : null
        }
      </ul>
    </div>
    <Fragment slot="media">
      {
        imageSource ? (
          <div class="knowledge__media-frame">
            <Image
              class="knowledge__media-image"
              src={imageSource}
              alt={entry.data.title}
              loading="eager"
              fetchpriority="high"
              width={imageSource.width}
              height={imageSource.height}
              decoding="async"
            />
          </div>
        ) : (
          <div
            class="knowledge__media-placeholder"
            role="img"
            aria-label="No image available"
          >
            <div class="knowledge__media-placeholder-content">
              <Icon
                name="image"
                class="knowledge__media-placeholder-icon"
                aria-hidden="true"
              />
              <span>No image available</span>
            </div>
          </div>
        )
      }
    </Fragment>
  </HeroTeaser>
</div>

<style>
  .knowledge__hero {
    margin-bottom: 0;
  }

  .knowledge__hero-teaser {
    inline-size: 100%;
  }

  .knowledge__hero-teaser :global(.hero-teaser__title) {
    max-inline-size: 12ch;
    font-size: clamp(2.2rem, 1.9rem + 1.35vw, 4rem);
    line-height: 0.96;
  }

  .knowledge__hero-teaser :global(.hero-teaser__description) {
    max-inline-size: 38ch;
    font-size: clamp(1rem, 0.97rem + 0.18vw, 1.14rem);
  }

  .knowledge__hero-teaser :global(.knowledge__meta) {
    display: grid;
    gap: var(--spacing-xs);
    padding-block-start: 0;
  }

  .knowledge__hero-teaser :global(.knowledge__meta-label) {
    margin: 0;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .knowledge__hero-teaser :global(.knowledge__meta-list) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem var(--spacing-lg);
    align-items: center;
    padding: 0;
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    list-style: none;
  }

  .knowledge__hero-teaser :global(.knowledge__meta-item) {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    font-weight: var(--font-weight-medium);
    line-height: 1.3;
    color: var(--text-secondary);
  }

  .knowledge__hero-teaser :global(.knowledge__meta-item .ai-badge) {
    min-block-size: auto;
  }

  .knowledge__pill-icon {
    flex-shrink: 0;
    inline-size: 1rem;
    block-size: 1rem;
    color: var(--accent-primary);
  }

  .knowledge__pill-icon--teal {
    color: var(--accent-primary);
  }

  .knowledge__hero-teaser :global(.knowledge__meta-item time),
  .knowledge__hero-teaser :global(.knowledge__meta-item span) {
    display: inline-block;
  }

  .knowledge__media-frame {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .knowledge__media-image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .knowledge__media-image img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .knowledge__media-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 3 / 2;
    padding: var(--spacing-xl);
    color: var(--text-secondary);
    text-align: center;
    background: var(--surface-panel-bg);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
  }

  .knowledge__media-placeholder-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    align-items: center;
  }

  .knowledge__media-placeholder-icon {
    inline-size: var(--spacing-3xl);
    block-size: var(--spacing-3xl);
  }

  @media (width >= 1024px) {
    .knowledge__hero-teaser :global(.hero-teaser__grid) {
      grid-template-columns: minmax(0, 0.9fr) minmax(24rem, 1.1fr);
      gap: clamp(var(--spacing-lg), 2vw, var(--spacing-2xl));
      align-items: center;
    }

    .knowledge__hero-teaser :global(.hero-teaser__copy) {
      order: 1;
      padding-inline: 0 clamp(0rem, 1.5vw, var(--spacing-base)) 0 0;
    }

    .knowledge__hero-teaser :global(.hero-teaser__media) {
      align-self: center;
      order: 2;
    }

    .knowledge__hero-teaser :global(.hero-teaser__footer) {
      padding-block-start: var(--spacing-md);
      margin-block-start: var(--spacing-lg);
    }

    .knowledge__hero-teaser :global(.knowledge__meta) {
      gap: 0.375rem;
    }

    .knowledge__hero-teaser :global(.knowledge__meta-list) {
      gap: var(--spacing-sm) var(--spacing-lg);
    }

    .knowledge__hero-teaser :global(.knowledge__meta-item) {
      position: relative;
    }

    .knowledge__hero-teaser
      :global(.knowledge__meta-item + .knowledge__meta-item::before) {
      position: absolute;
      inset-block: 0.2rem;
      inset-inline-start: calc(var(--spacing-sm) * -1);
      inline-size: 1px;
      content: "";
      background: var(--surface-border-soft);
    }

    .knowledge__media-placeholder-icon {
      inline-size: calc(var(--spacing-3xl) + var(--spacing-base));
      block-size: calc(var(--spacing-3xl) + var(--spacing-base));
    }
  }
</style>
