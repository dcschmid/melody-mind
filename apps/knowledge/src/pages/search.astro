---
import PagefindSearch from "astro-pagefind/components/Search";

import Layout from "@layouts/Layout.astro";
import Headline from "@shared-ui/components/Headline.astro";
import PageShell from "@shared-ui/components/Shared/PageShell.astro";
import { buildPageSeo, type StructuredData } from "@utils/seo/buildPageSeo";
import { resolvePageUrl } from "@utils/siteUrls";

export const prerender = true;

const title = "Search Melody Mind";
const description =
  "Search Melody Mind articles, category pages, and music history guides.";
const currentUrl = resolvePageUrl(Astro.site, "/search");
const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  contentKind: "generic",
  structuredData: [] as StructuredData[],
  enrichedParts: [title, description, "site search music genres history guides"],
  fallbackKeywords: ["search", "music knowledge", "genre guides", "music history"],
  keywordLimit: 24,
  maxDescription: 155,
  image: "/melody-mind.jpg",
  imageAlt: "Search Melody Mind Knowledge",
  index: false,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell className="page-shell--aurora page-shell--grid">
    <section class="search-page">
      <header class="search-page__header">
        <div class="search-page__hero">
          <div class="search-page__hero-copy">
            <p class="search-page__eyebrow">Library Search</p>
            <Headline level="h1" textSize="3xl" className="search-page__title">
              Search Melody Mind
            </Headline>
            <p class="search-page__lead">
              Search across guides, timelines, and taxonomy pages with a fast, built-in
              index tailored to Melody Mind.
            </p>
            <div class="search-page__feature-list" aria-hidden="true">
              <span class="search-page__feature-badge">Full-site search</span>
              <span class="search-page__feature-badge">Fast static results</span>
              <span class="search-page__feature-badge">Shareable query links</span>
            </div>
          </div>
          <div class="search-page__hero-panel">
            <p class="search-page__hero-kicker">Search tips</p>
            <ul class="search-page__hero-list">
              <li class="search-page__hero-item">
                Try genres like dub, grime, or neo-soul.
              </li>
              <li class="search-page__hero-item">Search decades, cities, or scenes.</li>
              <li class="search-page__hero-item">
                Press <kbd>/</kbd> in the header to jump to search.
              </li>
            </ul>
          </div>
        </div>
      </header>

      <section class="search-page__panel" aria-labelledby="search-page-results-title">
        <div class="search-page__panel-head">
          <div class="search-page__panel-copy">
            <p class="search-page__panel-eyebrow">Search the site</p>
            <Headline level="h2" textSize="lg" className="search-page__panel-title">
              <span id="search-page-results-title">Results</span>
            </Headline>
          </div>
          <p class="search-page__panel-help">
            Enter at least two characters. Results update while you type.
          </p>
        </div>

        <div class="search-page__search-ui">
          <PagefindSearch
            id="search-page-ui"
            className="search-page__pagefind"
            uiOptions={{
              showImages: false,
              excerptLength: 24,
              resetStyles: false,
              autofocus: false,
              translations: {
                placeholder: "Search artists, genres, eras, or movements",
                clear_search: "Clear",
                load_more: "Show more",
                search_label: "Search Melody Mind",
                zero_results: "No pages match that query",
                many_results: "[COUNT] results for [SEARCH_TERM]",
                one_result: "[COUNT] result for [SEARCH_TERM]",
                searching: "Searching…",
              },
            }}
          />
        </div>
      </section>
    </section>
  </PageShell>
</Layout>

<script>
  const syncSearchQueryFromUrl = (): void => {
    const query = new URL(window.location.href).searchParams.get("q")?.trim() || "";
    if (!query) {
      return;
    }

    let attempts = 0;

    const applyQuery = (): void => {
      const input = document.querySelector<HTMLInputElement>(
        "#search-page-ui input.pagefind-ui__search-input"
      );

      if (!input) {
        attempts += 1;
        if (attempts < 20) {
          window.requestAnimationFrame(applyQuery);
        }
        return;
      }

      if (input.value === query) {
        return;
      }

      input.focus();
      input.value = query;
      input.dispatchEvent(new Event("input", { bubbles: true }));
    };

    applyQuery();
  };

  document.addEventListener("astro:page-load", syncSearchQueryFromUrl);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", syncSearchQueryFromUrl, {
      once: true,
    });
  } else {
    syncSearchQueryFromUrl();
  }
</script>

<style>
  .search-page {
    display: grid;
    gap: 1.75rem;
  }

  .search-page__header {
    display: grid;
    gap: 1rem;
  }

  .search-page__hero {
    display: grid;
    gap: 1.15rem;
    align-items: start;
  }

  .search-page__hero-copy,
  .search-page__hero-panel,
  .search-page__panel {
    position: relative;
    display: grid;
    gap: 0.8rem;
    padding: 1.35rem;
    overflow: hidden;
    background: var(--gn-bg-muted);
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  .search-page__eyebrow,
  .search-page__hero-kicker,
  .search-page__panel-eyebrow {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gn-accent);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .search-page__title {
    max-inline-size: 11ch;
    margin: 0;
    font-size: clamp(2.8rem, 8vi, 5rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .search-page__lead {
    max-inline-size: 56ch;
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--gn-ink-muted);
  }

  .search-page__feature-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .search-page__feature-badge {
    display: inline-flex;
    align-items: center;
    min-block-size: 2.25rem;
    padding: 0.45rem 0.85rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 1px solid var(--gn-accent);
    border-radius: 999px;
  }

  .search-page__hero-list {
    display: grid;
    gap: 0.75rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .search-page__hero-item {
    position: relative;
    padding-inline-start: 1rem;
    line-height: 1.6;
    color: var(--gn-ink-muted);
  }

  .search-page__hero-item::before {
    position: absolute;
    inset-block-start: 0.7rem;
    inset-inline-start: 0;
    inline-size: 0.45rem;
    block-size: 0.45rem;
    content: "";
    background: var(--gn-accent);
    border-radius: 999px;
  }

  .search-page__hero-item kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 1.6rem;
    min-block-size: 1.6rem;
    padding: 0 0.35rem;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 1px solid var(--gn-panel-border);
    border-radius: 0.35rem;
  }

  .search-page__panel {
    gap: 1.2rem;
  }

  .search-page__panel-head {
    display: grid;
    gap: 0.65rem;
  }

  .search-page__panel-copy {
    display: grid;
    gap: 0.35rem;
  }

  .search-page__panel-title,
  :global(.search-page__pagefind .pagefind-ui__message) {
    margin: 0;
    color: var(--gn-ink);
  }

  .search-page__panel-title {
    font-size: clamp(1.7rem, 4vi, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .search-page__panel-help {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--gn-ink-muted);
  }

  .search-page__search-ui {
    position: relative;
    z-index: 1;
  }

  :global(.search-page__pagefind.pagefind-ui) {
    --pagefind-ui-primary: var(--gn-accent);
    --pagefind-ui-text: var(--gn-ink);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--gn-panel-border);
    --pagefind-ui-tag: rgba(var(--gn-accent-rgb, 139, 92, 246), 0.16);
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: 1rem;

    font-family: inherit;
    color: var(--gn-ink);
  }

  :global(.search-page__pagefind .pagefind-ui__search-input) {
    min-block-size: 3.5rem;
    font-size: 1.125rem;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 2px solid var(--gn-panel-border);
    border-radius: 999px;
  }

  :global(.search-page__pagefind .pagefind-ui__search-input:hover), :global(.search-page__pagefind .pagefind-ui__search-input:focus) {
    border-color: var(--gn-accent);
  }

  :global(.search-page__pagefind .pagefind-ui__search-input:focus-visible) {
    outline: 3px solid var(--gn-accent);
    outline-offset: 3px;
    border-color: var(--gn-accent);
  }

  :global(.search-page__pagefind .pagefind-ui__search-clear),
  :global(.search-page__pagefind .pagefind-ui__button) {
    font: inherit;
    border-radius: 999px;
  }

  :global(.search-page__pagefind .pagefind-ui__search-clear) {
    inset-block-start: 0.4rem;
    inset-inline-end: 0.4rem;
    min-inline-size: 4.5rem;
    block-size: 2.7rem;
    padding: 0 1rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 2px solid var(--gn-accent);
  }

  :global(.search-page__pagefind .pagefind-ui__search-clear:hover), :global(.search-page__pagefind .pagefind-ui__search-clear:focus) {
    background: var(--gn-bg-muted);
  }

  :global(.search-page__pagefind .pagefind-ui__drawer) {
    margin-block-start: 1.2rem;
    background: transparent;
  }

  :global(.search-page__pagefind .pagefind-ui__message) {
    padding: 0.25rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.5;
    color: var(--gn-ink-muted);
  }

  :global(.search-page__pagefind .pagefind-ui__results) {
    display: grid;
    gap: 0;
    padding: 0;
  }

  :global(.search-page__pagefind .pagefind-ui__result) {
    position: relative;
    display: block;
    padding: 1.7rem 0.2rem 1.55rem 1.1rem;
    overflow: hidden;
    font-size: 1.125rem;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  :global(.search-page__pagefind .pagefind-ui__result::before) {
    position: absolute;
    inset: 0 auto 0 0;
    inline-size: 0.28rem;
    content: "";
  }

  :global(.search-page__pagefind .pagefind-ui__result::after) {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    block-size: 1px;
    pointer-events: none;
    content: "";
  }

  :global(.search-page__pagefind .pagefind-ui__result-link) {
    color: var(--gn-ink);
    text-decoration: none;
  }

  :global(.search-page__pagefind .pagefind-ui__result-link:focus-visible) {
    outline: 3px solid var(--gn-accent);
    outline-offset: 3px;
    border-radius: 1rem;
  }

  :global(.search-page__pagefind .pagefind-ui__result-inner) {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.2rem;
    align-items: start;
    inline-size: 100%;
    min-inline-size: 0;
    margin-block-start: 0;
  }

  :global(.search-page__pagefind .pagefind-ui__result-nested) {
    display: none;
  }

  :global(.search-page__pagefind .pagefind-ui__result-title) {
    display: block;
    inline-size: 100%;
    min-inline-size: 0;
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.18;
    color: var(--gn-ink);
    letter-spacing: -0.02em;
  }

  :global(.search-page__pagefind .pagefind-ui__result-title .pagefind-ui__result-link) {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    align-items: flex-start;
    inline-size: 100%;
    min-inline-size: 0;
    color: var(--gn-ink);
    text-decoration: none;
    -webkit-text-fill-color: var(--gn-ink);
  }

  :global(
    .search-page__pagefind .pagefind-ui__result-title .pagefind-ui__result-link:hover
  ), :global(
    .search-page__pagefind .pagefind-ui__result-title .pagefind-ui__result-link:focus
  ) {
    color: var(--gn-accent);
    -webkit-text-fill-color: var(--gn-accent);
  }

  :global(
    .search-page__pagefind .pagefind-ui__result-title .pagefind-ui__result-link:visited
  ) {
    color: var(--gn-ink);
    -webkit-text-fill-color: var(--gn-ink);
  }

  :global(
    .search-page__pagefind
      .pagefind-ui__result-title
      .pagefind-ui__result-link[href*="/knowledge/"]::before
  ) {
    content: "Knowledge Guide";
  }

  :global(
    .search-page__pagefind
      .pagefind-ui__result-title
      .pagefind-ui__result-link[href*="/taxonomy/"]::before
  ) {
    content: "Taxonomy";
  }

  :global(
    .search-page__pagefind
      .pagefind-ui__result-title
      .pagefind-ui__result-link[href*="/categories/"]::before
  ) {
    content: "Category";
  }

  :global(
    .search-page__pagefind .pagefind-ui__result-title .pagefind-ui__result-link::before
  ) {
    display: inline-flex;
    align-items: center;
    inline-size: fit-content;
    min-block-size: 1.9rem;
    padding: 0.2rem 0.65rem;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1;
    color: var(--gn-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    background: var(--gn-bg);
    border: 1px solid var(--gn-accent);
    border-radius: 999px;
  }

  :global(.search-page__pagefind .pagefind-ui__result-excerpt) {
    display: block;
    display: -webkit-box;
    inline-size: 100%;
    min-inline-size: 0;
    max-inline-size: none;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 3;
    font-size: 1.125rem;
    line-height: 1.84;
    color: var(--gn-ink-muted);
    text-wrap: pretty;
    /* stylelint-disable-next-line property-no-deprecated */
    -webkit-box-orient: block-axis;
  }

  :global(.search-page__pagefind .pagefind-ui__result-excerpt mark) {
    padding: 0 0.16em;
    color: var(--gn-ink);
    background: rgba(251, 191, 36, 0.36);
    border-radius: 0.2rem;
  }

  :global(.search-page__pagefind .pagefind-ui__result-thumb) {
    display: none;
  }

  :global(.search-page__pagefind .pagefind-ui__result-tags) {
    gap: 0.45rem;
    margin-block-start: 0.45rem;
  }

  :global(.search-page__pagefind .pagefind-ui__result-tag) {
    display: inline-flex;
    align-items: center;
    min-block-size: 1.85rem;
    padding: 0.2rem 0.6rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--gn-ink-muted);
    background: var(--gn-bg);
    border: 1px solid var(--gn-accent);
    border-radius: 999px;
  }

  :global(.search-page__pagefind .pagefind-ui__result *) {
    font-size: inherit;
  }

  :global(.search-page__pagefind .pagefind-ui__result-link),
  :global(.search-page__pagefind .pagefind-ui__result-title),
  :global(.search-page__pagefind .pagefind-ui__result-inner),
  :global(.search-page__pagefind .pagefind-ui__result-excerpt),
  :global(.search-page__pagefind .pagefind-ui__result-excerpt *) {
    inline-size: 100%;
    min-inline-size: 0;
  }

  :global(.search-page__pagefind .pagefind-ui__result-title),
  :global(.search-page__pagefind .pagefind-ui__result-title *) {
    font-size: 1.5rem;
  }

  :global(.search-page__pagefind .pagefind-ui__result-excerpt),
  :global(.search-page__pagefind .pagefind-ui__result-excerpt *) {
    font-size: 1.125rem;
  }

  :global(.search-page__pagefind .pagefind-ui__result + .pagefind-ui__result) {
    margin-block-start: 0;
  }

  :global(.search-page__pagefind .pagefind-ui__button) {
    min-block-size: 2.7rem;
    padding: 0.65rem 1rem;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 2px solid var(--gn-accent);
  }

  :global(.search-page__pagefind .pagefind-ui__button:hover), :global(.search-page__pagefind .pagefind-ui__button:focus) {
    background: var(--gn-bg-muted);
  }

  @media (width >= 640px) {
    .search-page {
      gap: 2.2rem;
    }

    .search-page__hero {
      grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.9fr);
    }

    .search-page__panel {
      padding: 1.6rem;
    }

    :global(.search-page__pagefind .pagefind-ui__result) {
      padding: 1.95rem 0.25rem 1.8rem 1.35rem;
    }

    :global(.search-page__pagefind .pagefind-ui__result-title) {
      font-size: 1.625rem;
    }

    :global(.search-page__pagefind .pagefind-ui__result-title *) {
      font-size: 1.625rem;
    }
  }
</style>
