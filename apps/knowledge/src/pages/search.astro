---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import OramaSearchSection from "../components/OramaSearchSection.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import { knowledgeHeroImageUrl } from "@utils/knowledgeImages";

export const prerender = true;

const initialQuery = Astro.url.searchParams.get("q")?.trim() ?? "";

const title = "Search Melody Mind";
const description =
  "Search Melody Mind articles by title, description, taxonomy, takeaways, and article text.";
const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, "/search");
const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  contentKind: "generic",
  structuredData: [] as StructuredData[],
  enrichedParts: [title, description, "site search music knowledge articles"],
  fallbackKeywords: ["search", "music knowledge", "article search", "genre guides"],
  keywordLimit: 24,
  maxDescription: 155,
  image: knowledgeHeroImageUrl(baseUrl),
  imageAlt: "Search Melody Mind Knowledge",
  index: false,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});

const searchIndexUrl = "/search-index.json";
---

<Layout {pageSeo}>
  <PageShell className="page-shell--night page-shell--grid">
    <OramaSearchSection
      searchIndexUrl={searchIndexUrl}
      initialQuery={initialQuery}
      title={title}
      lead={description}
      placeholder="Search articles, genres, eras, or concepts..."
      emptyText="Type a title, genre, era, or keyword."
      noResultsText="No matching articles found."
      resultLimit={24}
    />
  </PageShell>
</Layout>
