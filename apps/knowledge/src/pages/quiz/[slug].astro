---
/**
 * Quiz Detail Page
 *
 * Renders an individual quiz with questions and interactive quiz logic.
 */
import Layout from "@layouts/Layout.astro";
import KnowledgeCard from "@components/KnowledgeCard.astro";
import PageShell from "@components/Shared/PageShell.astro";
import BackToTop from "@components/Shared/BackToTop.astro";
import { buildPageSeo, type StructuredData } from "@utils/seo/buildPageSeo";
import { resolvePageUrl } from "@utils/siteUrls";
import { getCollection } from "astro:content";
import { getCollectionCached } from "@utils/content/getCollectionCached";
import { normalizeDate } from "@utils/content/dateUtils";
import { getReadingTime } from "@utils/readingTime";
import { loggers } from "@utils/logging";
import type { QuizData, QuizQuestion } from "../../content.config";

export const prerender = true;

interface Props {
  quiz: {
    id: string;
    data: QuizData;
  };
}

export async function getStaticPaths() {
  const quizzes = await getCollection("quizzes");
  return quizzes.map((quiz) => ({
    params: { slug: quiz.id },
    props: { quiz: { id: quiz.id, data: quiz.data } },
  }));
}

const { quiz } = Astro.props as Props;
let relatedKnowledgeArticles: Array<{
  slug: string;
  title: string;
  description: string;
  image?: string;
  createdAt: Date;
  readingTime: number;
}> = [];

const currentUrl = resolvePageUrl(Astro.site, `/quiz/${quiz.id}`);

const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: "Quizzes", url: resolvePageUrl(Astro.site, "/quiz") },
  { name: quiz.data.title, url: currentUrl },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: seoBreadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.name,
    item: crumb.url,
  })),
};

const quizSeoTitle = quiz.data.seoTitle || `${quiz.data.title} Music Quiz`;
const quizSeoDescription = quiz.data.seoDescription || quiz.data.description;
const quizFeaturedTopics = quiz.data.featuredTopics.length
  ? quiz.data.featuredTopics
  : [quiz.data.category.replace(/-/g, " "), ...quiz.data.relatedArticles];

const quizSchema = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  name: quiz.data.title,
  description: quizSeoDescription,
  url: currentUrl,
  numberOfQuestions: quiz.data.questionsPerSession,
  about: quizFeaturedTopics.map((topic: string) => ({
    "@type": "Thing",
    name: topic,
  })),
  keywords: quizFeaturedTopics.join(", "),
  isPartOf: {
    "@type": "CollectionPage",
    name: "Music History Quizzes And Trivia",
    url: resolvePageUrl(Astro.site, "/quiz"),
  },
};

const pageSeo = buildPageSeo({
  title: quizSeoTitle,
  description: quizSeoDescription,
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: [breadcrumbSchema, quizSchema] as StructuredData[],
  fallbackKeywords: [
    "music quiz",
    quiz.data.title,
    quiz.data.category,
    ...quizFeaturedTopics,
  ],
  index: true,
  follow: true,
});

const questionsData = quiz.data.questions.map((q: QuizQuestion) => ({
  question: q.question,
  type: q.type,
  difficulty: q.difficulty,
  options: q.options,
  correct: q.correct,
  explanation: q.explanation,
  source: q.source,
  sourceLine: q.sourceLine,
}));

const passingScore = quiz.data.passingScore;
const questionsPerSession = quiz.data.questionsPerSession;
const totalPoolSize = quiz.data.questions.length;

try {
  const knowledgeEntries: any[] = await getCollectionCached("knowledge-en").catch(
    () => []
  );
  const knowledgeBySlug = new Map(
    knowledgeEntries.map((entry) => [String(entry.slug || entry.id || ""), entry])
  );

  relatedKnowledgeArticles = quiz.data.relatedArticles
    .map((articleSlug: string) => knowledgeBySlug.get(articleSlug))
    .filter(Boolean)
    .map((article: any) => {
      const createdAt = normalizeDate(article?.data?.createdAt) || new Date();
      return {
        slug: String(article?.slug || article?.id || ""),
        title: String(article?.data?.title || ""),
        description: String(article?.data?.description || ""),
        image: typeof article?.data?.image === "string" ? article.data.image : undefined,
        createdAt,
        readingTime:
          typeof article?.data?.readingTime === "number"
            ? article.data.readingTime
            : getReadingTime(article?.body || "", { languageCode: "en" }).minutes,
      };
    })
    .filter((article: { slug: string; title: string }) => article.slug && article.title);
} catch (e) {
  loggers.pages.warn("quiz detail: related article load issue", {
    error: (e as any)?.message || e,
  });
}
---

<Layout {pageSeo}>
  <PageShell className="page-shell--aurora page-shell--grid">
    <div class="quiz-detail">
      <header class="quiz-detail__header">
        <div class="quiz-detail__hero">
          <div class="quiz-detail__hero-main">
            <nav aria-label="Breadcrumb" class="quiz-detail__breadcrumb">
              <a href="/quiz">← All Quizzes</a>
            </nav>

            <h1 class="quiz-detail__title">{quiz.data.title}</h1>
            <p class="quiz-detail__description">{quiz.data.description}</p>

            <div class="quiz-detail__meta">
              <span class="quiz-detail__badge"
                >{quiz.data.category.replace(/-/g, " ")}</span
              >
              <span class="quiz-detail__badge">{questionsPerSession} questions</span>
              <span class="quiz-detail__badge">{passingScore}% to pass</span>
            </div>
          </div>
        </div>
      </header>

      <div class="quiz-detail__content">
        <aside class="quiz-detail__sidebar">
          <div class="quiz-detail__sidebar-card">
            <div id="quiz-progress-container"></div>
          </div>
        </aside>

        <main class="quiz-detail__main">
          <section class="quiz-detail__panel" aria-labelledby="quiz-play-heading">
            <div class="quiz-detail__panel-header">
              <h2 id="quiz-play-heading" class="quiz-detail__panel-title">
                Answer the question
              </h2>
            </div>

            <div id="quiz-question-container"></div>
            <div id="quiz-result-container"></div>
          </section>

          <div class="quiz-detail__nav" id="quiz-nav">
            <button
              type="button"
              id="quiz-nav-prev"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--prev"
              hidden
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M15 18l-6-6 6-6"></path>
              </svg>
              Previous
            </button>

            <button
              type="button"
              id="quiz-check-answer"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--check"
            >
              Check Answer
            </button>

            <button
              type="button"
              id="quiz-nav-next"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--next"
            >
              Next
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M9 18l6-6-6-6"></path>
              </svg>
            </button>

            <button
              type="button"
              id="quiz-nav-submit"
              class="quiz-detail__nav-btn quiz-detail__nav-btn--submit"
              hidden
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              Show Results
            </button>
          </div>
        </main>
      </div>

      <footer class="quiz-detail__footer">
        <div class="quiz-detail__footer-head">
          <h2 class="quiz-detail__footer-title">Read the source guides</h2>
          <p class="quiz-detail__source">
            Every question in this quiz is grounded in the related Melody Mind articles.
          </p>
        </div>
        {
          relatedKnowledgeArticles.length ? (
            <ul class="quiz-detail__related-grid" aria-label="Related articles">
              {relatedKnowledgeArticles.map((article, index) => (
                <li class="quiz-detail__related-item">
                  <KnowledgeCard
                    title={article.title}
                    description={article.description}
                    image={article.image}
                    createdAt={article.createdAt}
                    slug={article.slug}
                    lang="en"
                    readingTime={article.readingTime}
                    articleUrl={`/knowledge/${article.slug}`}
                    index={index}
                  />
                </li>
              ))}
            </ul>
          ) : (
            <p class="quiz-detail__source">
              Questions based on:
              {quiz.data.relatedArticles.map((slug: string, i: number) => (
                <>
                  {i > 0 && ", "}
                  <a href={`/knowledge/${slug}`}>{slug.replace(/-/g, " ")}</a>
                </>
              ))}
            </p>
          )
        }
      </footer>
    </div>
  </PageShell>

  <BackToTop lang="en" />

  <script
    is:inline
    type="application/json"
    id="quiz-questions-data"
    set:html={JSON.stringify(questionsData)}
  />
  <span id="quiz-passing-score" data-value={passingScore} hidden></span>
  <span id="quiz-questions-per-session" data-value={questionsPerSession} hidden></span>
  <span id="quiz-total-pool-size" data-value={totalPoolSize} hidden></span>
</Layout>

<script>
  import { initQuiz, type QuizQuestion } from "../../scripts/quiz/quizClient";

  document.addEventListener("DOMContentLoaded", () => {
    const questionsEl = document.getElementById("quiz-questions-data");
    const passingScoreEl = document.getElementById("quiz-passing-score");
    const questionsPerSessionEl = document.getElementById("quiz-questions-per-session");

    if (!questionsEl || !passingScoreEl || !questionsPerSessionEl) return;

    const questions: QuizQuestion[] = JSON.parse(questionsEl.textContent || "[]");
    const passingScore: number = parseInt(passingScoreEl.dataset.value || "70", 10);
    const questionsPerSession: number = parseInt(
      questionsPerSessionEl.dataset.value || "20",
      10
    );

    initQuiz(questions, passingScore, questionsPerSession);
  });
</script>

<style>
  .quiz-detail {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .quiz-detail__header {
    position: relative;
  }

  .quiz-detail__hero {
    display: block;
    padding: 1.25rem;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--gn-accent) 20%, var(--gn-panel-border));
    background:
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--gn-accent) 18%, transparent),
        transparent 34%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--gn-bg) 94%, transparent),
        var(--gn-bg-muted)
      );
    box-shadow:
      0 24px 52px color-mix(in srgb, var(--gn-accent) 8%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 24%, transparent);
  }

  @media (min-width: 960px) {
    .quiz-detail__hero {
      padding: 1.75rem;
    }
  }

  .quiz-detail__hero-main {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .quiz-detail__breadcrumb {
    margin-bottom: 0.15rem;
  }

  .quiz-detail__breadcrumb a {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--gn-panel-border);
    background: color-mix(in srgb, var(--gn-bg) 88%, transparent);
    font-size: 0.86rem;
    color: var(--gn-ink-muted);
    text-decoration: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .quiz-detail__breadcrumb a:hover {
    color: var(--gn-accent);
    border-color: color-mix(in srgb, var(--gn-accent) 32%, var(--gn-panel-border));
    background: color-mix(in srgb, var(--gn-accent) 8%, var(--gn-bg));
  }

  .quiz-detail__title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.08;
    color: var(--gn-ink);
    letter-spacing: -0.04em;
  }

  @media (min-width: 640px) {
    .quiz-detail__title {
      font-size: 3rem;
    }
  }

  .quiz-detail__description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--gn-ink-muted);
    max-width: 62ch;
  }

  .quiz-detail__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.15rem;
  }

  .quiz-detail__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--gn-panel-border);
    background: color-mix(in srgb, var(--gn-bg) 84%, transparent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gn-ink-muted);
  }

  .quiz-detail__content {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 1024px) {
    .quiz-detail__content {
      grid-template-columns: 240px 1fr;
      gap: 1.25rem;
    }
  }

  .quiz-detail__sidebar {
    position: static;
    height: fit-content;
  }

  @media (min-width: 1024px) {
    .quiz-detail__sidebar {
      position: sticky;
      top: 1rem;
    }
  }

  .quiz-detail__sidebar-card,
  .quiz-detail__panel {
    border-radius: 1.1rem;
    border: 1px solid var(--gn-panel-border);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--gn-bg) 94%, transparent),
      var(--gn-bg-muted)
    );
    box-shadow: 0 18px 36px color-mix(in srgb, var(--gn-ink) 4%, transparent);
  }

  .quiz-detail__sidebar-card {
    padding: 0.85rem;
  }

  .quiz-detail__main {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .quiz-detail__panel {
    padding: 1rem;
  }

  .quiz-detail__panel-header {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.85rem;
  }

  .quiz-detail__panel-title {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--gn-ink);
  }

  .quiz-detail__nav {
    display: grid;
    gap: 0.75rem;
    padding: 0;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .quiz-detail__nav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease,
      box-shadow 0.15s ease;
    border: 1px solid var(--gn-panel-border);
    background: linear-gradient(180deg, var(--gn-bg) 0%, var(--gn-bg-muted) 100%);
    color: var(--gn-ink);
  }

  .quiz-detail__nav-btn svg {
    width: 1rem;
    height: 1rem;
  }

  .quiz-detail__nav-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    border-color: var(--gn-accent);
    background: color-mix(in srgb, var(--gn-accent) 8%, var(--gn-bg));
    box-shadow: 0 10px 20px color-mix(in srgb, var(--gn-accent) 10%, transparent);
  }

  .quiz-detail__nav-btn:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
  }

  .quiz-detail__nav-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .quiz-detail__nav-btn--check,
  .quiz-detail__nav-btn--submit {
    background: var(--gn-accent);
    border-color: var(--gn-accent);
    color: var(--gn-bg);
  }

  .quiz-detail__nav-btn--submit {
    grid-column: 1 / -1;
  }

  .quiz-detail__nav-btn--check {
    grid-column: 1 / -1;
  }

  .quiz-detail__nav-btn--check:hover,
  .quiz-detail__nav-btn--submit:hover {
    background: color-mix(in srgb, var(--gn-accent) 85%, black);
    border-color: color-mix(in srgb, var(--gn-accent) 85%, black);
  }

  .quiz-detail__footer {
    display: grid;
    gap: 1.25rem;
    padding: 1rem 1.1rem;
    border-radius: 1.1rem;
    border: 1px solid var(--gn-panel-border);
    background: color-mix(in srgb, var(--gn-bg) 86%, transparent);
  }

  .quiz-detail__footer-head {
    display: grid;
    gap: 0.5rem;
  }

  .quiz-detail__footer-title {
    margin: 0;
    font-size: clamp(1.25rem, 1.1rem + 0.6vw, 1.7rem);
    color: var(--gn-ink);
  }

  .quiz-detail__source {
    margin: 0;
    font-size: 0.9rem;
    color: var(--gn-ink-muted);
    line-height: 1.6;
  }

  .quiz-detail__source a {
    color: var(--gn-accent);
    text-decoration: none;
  }

  .quiz-detail__source a:hover {
    text-decoration: underline;
  }

  .quiz-detail__related-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  .quiz-detail__related-item {
    min-width: 0;
  }

  :global(.quiz-progress) {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  :global(.quiz-progress__eyebrow) {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gn-ink-muted);
    font-weight: 700;
  }

  :global(.quiz-progress__headline) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.quiz-progress__index) {
    font-size: 1rem;
    line-height: 1.25;
    color: var(--gn-ink);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  :global(.quiz-progress__target) {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--gn-ink-muted);
  }

  :global(.quiz-progress__header) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  :global(.quiz-progress__counter) {
    font-size: 0.9rem;
    color: var(--gn-ink-muted);
    font-weight: 500;
  }

  :global(.quiz-progress__counter strong) {
    color: var(--gn-ink);
    font-weight: 700;
  }

  :global(.quiz-progress__score) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gn-ink-muted);
  }

  :global(.quiz-progress__score-correct) {
    color: var(--color-gn-green-400);
    font-weight: 700;
  }

  :global(.quiz-progress__bar) {
    height: 0.55rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--gn-ink) 10%, var(--gn-panel-border));
    overflow: hidden;
  }

  :global(.quiz-progress__fill) {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--gn-accent) 0%,
      color-mix(in srgb, white 24%, var(--gn-accent)) 100%
    );
    transition: width 0.3s ease;
  }

  :global(.quiz-progress__stats) {
    display: grid;
    gap: 0.55rem;
  }

  :global(.quiz-progress__stat) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0.8rem;
    border-radius: 0.8rem;
    border: 1px solid var(--gn-panel-border);
    background: color-mix(in srgb, var(--gn-bg) 82%, transparent);
  }

  :global(.quiz-progress__stat-label) {
    font-size: 0.82rem;
    color: var(--gn-ink-muted);
    font-weight: 600;
  }

  :global(.quiz-progress__stat-value) {
    font-size: 1rem;
    color: var(--gn-ink);
    font-weight: 700;
  }

  :global(.quiz-question) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.quiz-question__topline) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  :global(.quiz-question__card) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid var(--gn-panel-border);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--gn-bg) 94%, transparent),
      var(--gn-bg-muted)
    );
  }

  :global(.quiz-question__number) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.2rem;
    height: 2.2rem;
    padding: 0 0.65rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    background: var(--gn-accent);
    color: var(--gn-bg);
  }

  :global(.quiz-question__type) {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--gn-panel-border);
    background: color-mix(in srgb, var(--gn-bg) 88%, transparent);
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--gn-ink-muted);
  }

  :global(.quiz-question__badge) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  :global(.quiz-question__badge svg) {
    width: 1rem;
    height: 1rem;
  }

  :global(.quiz-question__badge--correct) {
    background: color-mix(in srgb, var(--color-gn-green-400) 15%, transparent);
    color: var(--color-gn-green-400);
    border: 1px solid color-mix(in srgb, var(--color-gn-green-400) 30%, transparent);
