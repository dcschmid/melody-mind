---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import LegalDocumentPage from "../components/LegalDocumentPage.astro";
import { buildLegalPageSeo } from "../utils/legal/buildLegalPageSeo";

const title = "Privacy Policy";
const description =
  "How we process personal data on Melody Mind Knowledge, including analytics with Fathom and AI-generated media details.";
const lastUpdated = "15 March 2026";

const highlights = [
  {
    value: "Consent first",
    label: "Analytics only activates after explicit opt-in.",
  },
  {
    value: "Minimal data",
    label: "We aim to process only the data necessary to operate the site.",
  },
  {
    value: "Clear rights",
    label: "Your GDPR rights and complaint options are listed below.",
  },
] as const;

const sections = [
  {
    icon: "user",
    title: "Controller",
    body: [
      "Daniel Schmid",
      "Hiltenspergerstr. 78, 80796 Munich, Germany",
      'Email: <a href="mailto:dcschmid@murena.io">dcschmid@murena.io</a>',
    ],
  },
  {
    icon: "shield",
    title: "Hosting & Access Logs",
    body: [
      "We host this site on Render (render.com). Render processes server logs such as IP address, timestamp, requested URL, and user agent to maintain site stability and security. Legal basis: Art. 6(1)(f) GDPR (legitimate interest in secure operation). Logs are deleted automatically on a rolling basis. Depending on the Render region, data may be processed in the EU or transferred to the United States under appropriate safeguards, such as standard contractual clauses.",
    ],
  },
  {
    icon: "grid",
    title: "Analytics with Fathom",
    body: [
      "We use Fathom Analytics only after you give explicit consent through our cookie banner. Until you opt in, no analytics script is loaded. Your choice is stored in your browser's local storage (`cookie_consent`) with separate settings for essential and analytics preferences. Legal basis: Art. 6(1)(a) GDPR (consent) and the ePrivacy Directive. If your browser sends a Do Not Track (DNT) signal, analytics remain disabled.",
      'You can change or withdraw your choice at any time via "Cookie settings" in the footer. Withdrawal applies from that moment onward and does not affect prior lawful processing. For a detailed list of storage technologies, see our <a href="/cookies">Cookie &amp; Storage Policy</a>.',
    ],
  },
  {
    icon: "sparkles",
    title: "AI-Generated Content",
    body: [
      "Some text and images are generated with assistance from OpenAI services. We do not intentionally send personal data to OpenAI. If you contact us and share personal information, we do not use that content in AI prompts without your consent.",
    ],
  },
  {
    icon: "mail",
    title: "Contact",
    body: [
      "If you email us, we process your message, contact details, and related metadata to respond. Legal basis: Art. 6(1)(b) GDPR (pre-contractual communication) or Art. 6(1)(f) GDPR (legitimate interest in responding to inquiries). We keep this data only as long as necessary.",
    ],
  },
  {
    icon: "help-circle",
    title: "Your Rights",
    body: [
      "You have the rights of access, rectification, erasure, restriction, objection (including to processing based on Art. 6(1)(f) GDPR), and data portability. You may also lodge a complaint with your local supervisory authority. In Bavaria, this is the BayLDA (Bayerisches Landesamt für Datenschutzaufsicht).",
    ],
  },
  {
    icon: "clock",
    title: "Data Retention",
    body: [
      "We retain personal data only as long as necessary for the stated purposes or legal obligations and then delete or anonymize it.",
    ],
  },
  {
    icon: "refresh-ccw",
    title: "Updates",
    body: [
      `We may update this policy to reflect legal or technical changes. Last updated: ${lastUpdated}.`,
    ],
  },
] as const;

const pageSeo = buildLegalPageSeo({
  site: Astro.site,
  path: "/privacy",
  title,
  description,
  imageAlt: "Privacy Policy",
  fallbackKeywords: ["privacy", "data protection", "fathom analytics", "openai media"],
  maxDescription: 160,
  modifiedDate: new Date(lastUpdated),
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <LegalDocumentPage
      eyebrow="Privacy"
      title="Privacy Policy"
      lead="This notice explains how we process personal data on Melody Mind Knowledge in line with EU and German data protection law."
      {highlights}
      highlightsLabel="Key privacy policy points"
      {sections}
    />
  </PageShell>
</Layout>
