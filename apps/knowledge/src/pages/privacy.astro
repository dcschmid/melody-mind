---
import Layout from "@layouts/Layout.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

const title = "Privacy Policy";
const description =
  "How we process personal data on Melody Mind Knowledge, including analytics with Fathom and AI-generated media details.";
const currentUrl = resolvePageUrl(Astro.site, "/privacy");
const lastUpdated = "15 March 2026";

const breadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: title, url: currentUrl },
];

const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs,
  structuredData: [] as StructuredData[],
  enrichedParts: [title, description],
  fallbackKeywords: ["privacy", "data protection", "fathom analytics", "openai media"],
  keywordLimit: 24,
  maxDescription: 160,
  image: "/knowledge.png",
  imageAlt: "Privacy Policy",
  modifiedDate: new Date(lastUpdated),
  index: false,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--spacious">
    <div class="legal-page">
      <header class="legal-page__header static-page-header">
        <Paragraph textSize="sm" className="legal-page__eyebrow static-page-eyebrow">
          Privacy
        </Paragraph>
        <Headline
          level="h1"
          textSize="2xl"
          className="legal-page__title static-page-title"
        >
          Privacy Policy
        </Headline>
        <Paragraph textSize="lg" className="legal-page__lead static-page-lead">
          This notice explains how we process personal data on Melody Mind Knowledge in
          line with EU and German data protection law.
        </Paragraph>
      </header>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          1. Controller
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">Daniel Schmid</Paragraph>
        <Paragraph textSize="sm" className="legal-page__text">
          Hiltenspergerstr. 78, 80796 Munich, Germany
        </Paragraph>
        <Paragraph textSize="sm" className="legal-page__text">
          Email:
          <a class="legal-page__link" href="mailto:dcschmid@murena.io">
            dcschmid@murena.io
          </a>
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          2. Hosting & Access Logs
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          We host this site on Render (render.com). Render processes server logs such as
          IP address, timestamp, requested URL, and user agent to maintain site stability
          and security. Legal basis: Art. 6(1)(f) GDPR (legitimate interest in secure
          operation). Logs are deleted automatically on a rolling basis. Depending on the
          Render region, data may be processed in the EU or transferred to the United
          States under appropriate safeguards, such as standard contractual clauses.
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          3. Analytics with Fathom
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          We use Fathom Analytics only after you give explicit consent through our cookie
          banner. Until you opt in, no analytics script is loaded. Your choice is stored
          in your browser's local storage (`cookie_consent`) with separate settings for
          essential and analytics preferences. Legal basis: Art. 6(1)(a) GDPR (consent)
          and the ePrivacy Directive. If your browser sends a Do Not Track (DNT) signal,
          analytics remain disabled.
        </Paragraph>
        <Paragraph textSize="sm" className="legal-page__text">
          You can change or withdraw your choice at any time via "Cookie settings" in the
          footer. Withdrawal applies from that moment onward and does not affect prior
          lawful processing. For a detailed list of storage technologies, see our
          <a class="legal-page__link" href="/cookies"> Cookie &amp; Storage Policy</a>.
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          4. AI-Generated Content
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          Some text and images are generated with assistance from OpenAI services. We do
          not intentionally send personal data to OpenAI. If you contact us and share
          personal information, we do not use that content in AI prompts without your
          consent.
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          5. Contact
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          If you email us, we process your message, contact details, and related metadata
          to respond. Legal basis: Art. 6(1)(b) GDPR (pre-contractual communication) or
          Art. 6(1)(f) GDPR (legitimate interest in responding to inquiries). We keep this
          data only as long as necessary.
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          6. Your Rights
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          You have the rights of access, rectification, erasure, restriction, objection
          (including to processing based on Art. 6(1)(f) GDPR), and data portability. You
          may also lodge a complaint with your local supervisory authority. In Bavaria,
          this is the BayLDA (Bayerisches Landesamt für Datenschutzaufsicht).
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          7. Data Retention
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          We retain personal data only as long as necessary for the stated purposes or
          legal obligations and then delete or anonymize it.
        </Paragraph>
      </section>

      <section class="legal-panel legal-page__section">
        <Headline level="h2" textSize="base" className="legal-page__section-title">
          8. Updates
        </Headline>
        <Paragraph textSize="sm" className="legal-page__text">
          We may update this policy to reflect legal or technical changes. Last updated:
          {lastUpdated}.
        </Paragraph>
      </section>
    </div>
  </PageShell>
</Layout>

<style>
  .legal-page {
    display: flex;
    flex-direction: column;
    gap: var(--static-page-gap);
  }

  .legal-page__section {
    display: flex;
    flex-direction: column;
    gap: var(--static-page-section-gap);
  }

  .legal-page__section-title {
    margin: 0;
    font-size: 1.225rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .legal-page__text {
    margin: 0;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .legal-page__link {
    color: var(--link-default);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-page__link:hover,
  .legal-page__link:focus-visible {
    color: var(--link-hover);
  }

  .legal-page__list {
    padding-inline-start: 1.5rem;
    margin: 0;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .legal-page__list li {
    margin-block-end: 0.5rem;
  }
</style>
