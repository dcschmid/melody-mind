---
/**
 * Knowledge Article Page (English only)
 */
import { render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import ButtonLink from "@shared-ui/components/buttons/ButtonLink.astro";
import ShareSection from "@shared-ui/components/actions/ShareSection.astro";
import ArticleHero from "@shared-ui/components/cards/ArticleHero.astro";
import RelatedKnowledgeArticles from "@components/RelatedKnowledgeArticles.astro";
import ReadingProgress from "@shared-ui/components/navigation/ReadingProgress.astro";
import Prose from "@shared-ui/components/typography/Prose.astro";
import TableOfContents from "@shared-ui/components/navigation/TableOfContents.astro";
import RecentItemsTracker from "@shared-ui/components/init/RecentItemsTracker.astro";

import KnowledgeTakeaways from "@shared-ui/components/cards/KnowledgeTakeaways.astro";
import { VERSIONED_KEYS } from "@constants/storageVersions";
import {
  buildKnowledgeArticleStorageMeta,
  buildKnowledgeArticlePageData,
  getKnowledgeArticleStaticPaths,
  resolveKnowledgeArticleEntry,
  resolveKnowledgeSlug,
} from "@utils/knowledge/articlePage";

export const prerender = true;

/**
 * Prebuilds one static route per knowledge article.
 * We pass the full entry through `props` so the page can render without re-fetching during build.
 */
export async function getStaticPaths() {
  return getKnowledgeArticleStaticPaths();
}

const lang = "en";
const initialEntry: any = (Astro.props as { entry?: any }).entry;

// `[...slug]` can arrive either as an array or as a flat string depending on the route shape.
const resolvedSlug = resolveKnowledgeSlug((Astro as any).params?.slug);
const entry = await resolveKnowledgeArticleEntry({
  entry: initialEntry,
  slug: resolvedSlug,
  lang,
});

if (!entry) {
  return new Response("Not found", { status: 404 });
}

const slugKey = resolvedSlug || entry?.slug || entry?.id || "";
const { headings, Content } = await render(entry);
const mergedHeadings = headings;
const takeaways = entry.data.takeaways || [];
const {
  articleLinks,
  canonical,
  currentKeywords,
  currentTaxonomySubsection,
  currentTaxonomyGroup,
  description,
  imageSource,
  pageSeo,
  publishedDate,
  publishedDateLabel,
  readingResult,
  title,
} = buildKnowledgeArticlePageData({
  site: Astro.site,
  entry,
  lang,
  slugKey,
});
const { storageSlug, storageUpdatedAt, storageImage } = buildKnowledgeArticleStorageMeta(
  entry,
  slugKey
);
---

<Layout {pageSeo}>
  <Fragment slot="head"></Fragment>

  <ReadingProgress storageKey={VERSIONED_KEYS.READ_PROGRESS} />

  <div
    class="knowledge"
    data-analytics-article="true"
    data-analytics-article-slug={slugKey}
    data-analytics-article-category={currentTaxonomyGroup ||
      currentTaxonomySubsection ||
      "uncategorized"}
  >
    <div class="knowledge__container">
      <ArticleHero
        title={entry.data.title}
        description={entry.data.description}
        imageSource={imageSource}
        imageAlt={entry.data.title}
        publishedDate={publishedDate}
        publishedDateLabel={publishedDateLabel}
        readingText={readingResult.text}
        idBase={`knowledge-article-hero-${slugKey || "entry"}`}
        aiGenerated={entry.data.aiGenerated}
        aiTools={entry.data.aiTools}
        links={articleLinks}
      />

      <div class="knowledge__body">
        <div class="knowledge__content-grid">
          <aside class="knowledge__rail" aria-label="Article navigation and summary">
            <div class="knowledge__rail-stack">
              <TableOfContents headings={mergedHeadings} className="knowledge__toc" />

              {
                takeaways.length ? (
                  <div class="knowledge__rail-panel knowledge__rail-panel--takeaways">
                    <KnowledgeTakeaways items={takeaways} />
                  </div>
                ) : null
              }
            </div>
          </aside>

          <div class="knowledge__main">
            <section class="knowledge__article-shell" data-animate="rise-in">
              <article id="article-content" class="knowledge-article">
                <div id="article-title" class="knowledge__title-sr">
                  {entry.data.title}
                </div>
                <div
                  role="region"
                  aria-labelledby="article-title"
                  aria-label="Main content"
                >
                  <Prose className="knowledge-article__prose">
                    <Content />
                  </Prose>
                </div>
              </article>
            </section>

            <section class="knowledge__section-shell knowledge__section-shell--share">
              <ShareSection
                id="knowledge-share"
                shareUrl={canonical}
                contentTitle={title}
                contentDescription={description}
              />
            </section>

            <section class="knowledge__section-shell knowledge__section-shell--related">
              <RelatedKnowledgeArticles
                currentKeywords={currentKeywords}
                currentTaxonomyGroup={currentTaxonomyGroup}
                currentTaxonomySubsection={currentTaxonomySubsection}
                currentSlug={slugKey}
                lang={lang}
              />
            </section>

            <div class="knowledge__back">
              <ButtonLink href="/" icon="arrow-left" aria-label="Back to knowledge list">
                <span>Back to knowledge list</span>
              </ButtonLink>
            </div>

            <RecentItemsTracker
              item={{
                slug: storageSlug,
                title,
                updatedAt: storageUpdatedAt,
                image: storageImage,
              }}
              storageKey={VERSIONED_KEYS.RECENT_READS}
            />
          </div>
        </div>
      </div>

      <!-- DOM hooks for lightweight client features. Data is passed via attributes to avoid inline scripts. -->
    </div>
  </div>
</Layout>

<style>
  .knowledge {
    position: relative;
    min-height: 100vh;
    overflow-x: hidden;
    font-family: var(--font-sans);
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
    background: var(--page-background);
  }

  .knowledge__container {
    position: relative;
    z-index: 2;
    display: grid;
    gap: clamp(var(--spacing-lg), 2.2vw, var(--spacing-2xl));
    max-width: var(--content-max-width);
    padding: calc(var(--spacing-xl) + var(--spacing-sm)) var(--spacing-base)
      var(--spacing-3xl);
    margin: 0 auto;
  }

  .knowledge__body,
  .knowledge__content-grid,
  .knowledge__main,
  .knowledge__rail-stack {
    display: grid;
    gap: var(--spacing-xl);
  }

  .knowledge__support-panel,
  .knowledge__section-shell,
  .knowledge__rail-panel {
    position: relative;
    padding: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-panel-raised) 92%, transparent),
      color-mix(in srgb, var(--surface-panel-bg) 96%, transparent)
    );
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-xl);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 78%, transparent),
      var(--shadow-lg);
  }

  .knowledge__support-panel {
    padding-block: clamp(var(--spacing-base), 1.75vw, var(--spacing-lg));
  }

  .knowledge__support-panel::before,
  .knowledge__section-shell::before,
  .knowledge__rail-panel::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    border-radius: inherit;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--surface-1) 12%, transparent);
  }

  .knowledge__article-shell {
    padding: 0;
    overflow: visible;
    background: none;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .knowledge__article-shell::before {
    display: none;
  }

  .knowledge__support-panel :global(.link-panel) {
    padding-block: 0;
    border-block: 0;
  }

  .knowledge__rail {
    min-inline-size: 0;
  }

  .knowledge__rail-panel {
    padding: clamp(var(--spacing-base), 1.8vw, var(--spacing-lg));
  }

  .knowledge__toc {
    display: grid;
    gap: var(--spacing-base);
  }

  .knowledge__toc :global(.toc[data-toc-root]),
  .knowledge__rail-panel--takeaways :global(.knowledge-takeaways) {
    gap: var(--spacing-base);
  }

  .knowledge__toc :global(.toc__content) {
    background: color-mix(in srgb, var(--section-surface-bg) 94%, transparent);
  }

  .knowledge__toc :global(.toc__link) {
    font-size: var(--font-size-sm);
  }

  .knowledge__rail-panel--takeaways :global(.knowledge-takeaways) {
    border-block-start: 0;
  }

  .knowledge__rail-panel--takeaways {
    padding: 0;
    background: none;
    border: 0;
    box-shadow: none;
  }

  .knowledge__rail-panel--takeaways::before {
    display: none;
  }

  .knowledge-article {
    padding: 0;
    margin: 0;
    background: none;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .knowledge-article__prose {
    max-inline-size: min(100%, var(--measure-readable));
    margin-inline: auto;
  }

  .knowledge-article__prose :global(> h2) {
    position: relative;
    padding-block-start: var(--spacing-base);
  }

  .knowledge-article__prose :global(> h2::before) {
    display: block;
    inline-size: clamp(2.5rem, 8vw, 4rem);
    block-size: 1px;
    margin-block-end: var(--spacing-base);
    content: "";
    background: color-mix(in srgb, var(--accent-primary) 44%, var(--surface-border-soft));
  }

  .knowledge-article__prose :global(> p) {
    max-inline-size: 60ch;
  }

  .knowledge-article__prose :global(> blockquote) {
    margin-inline: 0;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--surface-1) 32%, transparent);
  }

  .knowledge-article__prose :global(> :first-child) {
    margin-block-start: 0;
  }

  .knowledge-article__prose :global(> :last-child) {
    margin-block-end: 0;
  }

  .knowledge__section-shell {
    padding-block: clamp(var(--spacing-base), 1.8vw, var(--spacing-lg));
  }

  .knowledge__section-shell--share :global(.share-section),
  .knowledge__section-shell--related :global(.related-content-section) {
    padding-block: 0;
    margin-block-start: 0;
    border-block-start: 0;
  }

  .knowledge__section-shell--share {
    padding: 0;
    background: none;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .knowledge__section-shell--share::before {
    display: none;
  }

  .knowledge__section-shell--share :global(.share-section__copy),
  .knowledge__section-shell--related :global(.related-content-section__header) {
    gap: var(--spacing-sm);
  }

  .knowledge__section-shell--share :global(.share-section) {
    gap: clamp(0.8rem, 1.4vw, 1rem);
  }

  .knowledge__section-shell--share :global(.share-section__actions) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: flex-end;
  }

  .knowledge__section-shell--share :global(.share-section__button) {
    flex: 0 0 auto;
    justify-content: center;
    background: color-mix(in srgb, var(--surface-1) 68%, transparent);
  }

  .knowledge__section-shell--share :global(.share-section__button--primary) {
    justify-content: center;
    background: linear-gradient(
      135deg,
      var(--accent-primary),
      color-mix(in srgb, var(--accent-primary) 72%, var(--accent-strong))
    );
  }

  .knowledge__section-shell--related :global(.related-content-section) {
    gap: clamp(var(--spacing-lg), 2vw, var(--spacing-xl));
  }

  .knowledge__section-shell--related {
    padding: 0;
    background: none;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .knowledge__section-shell--related::before {
    display: none;
  }

  .knowledge__section-shell--related :global(.related-content-section__header) {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
  }

  .knowledge__section-shell--related :global(.related-content-section__copy) {
    max-inline-size: 48ch;
  }

  .knowledge__section-shell--related :global(.related-content-section__grid) {
    gap: clamp(var(--spacing-base), 1.8vw, var(--spacing-lg));
  }

  .knowledge__section-shell--related :global(.content-card) {
    border-radius: calc(var(--radius-xl) - 0.1rem);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--surface-1) 68%, transparent),
      var(--shadow-sm);
  }

  .knowledge__section-shell--related :global(.content-card__media) {
    aspect-ratio: 4 / 3;
  }

  .knowledge__section-shell--related :global(.content-card__body) {
    gap: 0.72rem;
  }

  .knowledge__section-shell--related :global(.content-card__title) {
    font-size: var(--font-size-sm);
    line-height: 1.2;
  }

  .knowledge__section-shell--related :global(.content-card__description) {
    font-size: var(--font-size-xs);
    line-height: 1.55;
  }

  .knowledge__section-shell--related :global(.content-card__meta) {
    gap: 0.55rem 0.85rem;
    padding-block-start: 0.7rem;
  }

  .knowledge__back {
    display: flex;
    justify-content: center;
    padding-block-start: var(--spacing-base);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .knowledge__title-sr {
    position: absolute;
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    margin: var(--sr-only-margin);
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: var(--sr-only-clip-path);
  }

  @media (width >= 640px) {
    .knowledge__container {
      padding: var(--spacing-2xl) var(--spacing-lg)
        calc(var(--spacing-2xl) + var(--spacing-lg));
    }

    .knowledge__support-panel,
    .knowledge__section-shell,
    .knowledge__rail-panel {
      border-radius: calc(var(--radius-xl) + var(--spacing-xs));
    }

    .knowledge__section-shell--share :global(.share-section__copy) {
      max-inline-size: 22rem;
    }
  }

  @media (width >= 1024px) {
    .knowledge__container {
      padding: calc(var(--spacing-2xl) + var(--spacing-sm)) var(--spacing-xl)
        calc(var(--spacing-2xl) + var(--spacing-xl));
    }

    .knowledge__main {
      gap: clamp(var(--spacing-lg), 2vw, var(--spacing-2xl));
    }

    .knowledge__section-shell--related :global(.related-content-section__header) {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }

    .knowledge__section-shell--related :global(.related-content-section__grid) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
