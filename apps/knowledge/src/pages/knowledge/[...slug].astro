---
/**
 * Knowledge Article Page (English only)
 */
import { render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import ButtonLink from "@shared-ui/components/buttons/ButtonLink.astro";
import ArticleHero from "@shared-ui/components/cards/ArticleHero.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import ReadingProgress from "@shared-ui/components/navigation/ReadingProgress.astro";
import Prose from "@shared-ui/components/typography/Prose.astro";
import VisuallyHidden from "@shared-ui/components/utilities/VisuallyHidden.astro";
import ShareSection from "@shared-ui/components/actions/ShareSection.astro";
import RelatedContentSection from "@shared-ui/components/cards/RelatedContentSection.astro";
import TableOfContents from "@shared-ui/components/navigation/TableOfContents.astro";
import RecentItemsTracker from "@shared-ui/components/init/RecentItemsTracker.astro";
import KnowledgeTakeaways from "@shared-ui/components/cards/KnowledgeTakeaways.astro";
import { VERSIONED_KEYS } from "@constants/storageVersions";
import {
  buildKnowledgeArticleStorageMeta,
  buildKnowledgeArticlePageData,
  resolveKnowledgeSlug,
} from "@utils/knowledge/articlePageMeta";
import type { ResolvedKnowledgeEntry } from "@utils/knowledge/articlePageTypes";
import {
  getKnowledgeArticleStaticPaths,
  resolveKnowledgeArticleEntry,
} from "@utils/knowledge/articlePageContent";
import { loadRelatedKnowledgeArticleCardItems } from "@utils/knowledge/articlePageRelated";

export const prerender = true;

/**
 * Prebuilds one static route per knowledge article.
 * We pass the full entry through `props` so the page can render without re-fetching during build.
 */
export async function getStaticPaths() {
  return getKnowledgeArticleStaticPaths();
}

const lang = "en";
const initialEntry = (Astro.props as { entry?: ResolvedKnowledgeEntry }).entry;

// `[...slug]` can arrive either as an array or as a flat string depending on the route shape.
const resolvedSlug = resolveKnowledgeSlug(Astro.params.slug);
const entry = await resolveKnowledgeArticleEntry({
  entry: initialEntry,
  slug: resolvedSlug,
  lang,
});

if (!entry) {
  return Astro.redirect("/404");
}

const slugKey = resolvedSlug || entry?.id || "";
const { headings, Content } = await render(entry);
const mergedHeadings = headings;
const takeaways = entry.data.takeaways || [];
const {
  articleLinks,
  canonical,
  currentKeywords,
  currentTaxonomySubsection,
  currentTaxonomyGroup,
  description,
  imageSource,
  pageSeo,
  publishedDate,
  publishedDateLabel,
  readingResult,
  title,
} = buildKnowledgeArticlePageData({
  site: Astro.site,
  entry,
  lang,
  slugKey,
});
const { storageSlug, storageUpdatedAt, storageImage } = buildKnowledgeArticleStorageMeta(
  entry,
  slugKey
);
const recentReadDataId = `recent-read-data-${storageSlug
  .replace(/[^A-Za-z0-9_-]+/g, "-")
  .replace(/^-+|-+$/g, "")}`;
const relatedArticleItems = await loadRelatedKnowledgeArticleCardItems({
  currentKeywords,
  currentTaxonomyGroup,
  currentTaxonomySubsection,
  currentSlug: slugKey,
  lang,
});
---

<Layout {pageSeo}>
  <Fragment slot="head"></Fragment>

  <ReadingProgress
    storageKey={VERSIONED_KEYS.READ_PROGRESS}
    progressDataId={recentReadDataId}
  />

  <PageShell
    className="knowledge-article-shell"
    containerClass="page-shell__container--wide knowledge-article-shell__container"
  >
    <Stack className="knowledge" gap="2xl">
      <ArticleHero
        title={entry.data.title}
        description={entry.data.description}
        imageSource={imageSource}
        imageAlt={entry.data.imageAlt ?? ""}
        publishedDate={publishedDate}
        publishedDateLabel={publishedDateLabel}
        readingText={readingResult.text}
        idBase={`knowledge-article-hero-${slugKey || "entry"}`}
        aiGenerated={entry.data.aiGenerated}
        aiTools={entry.data.aiTools}
        links={articleLinks}
      />

      {
        takeaways.length ? (
          <KnowledgeTakeaways
            items={takeaways}
            idBase={`knowledge-takeaways-${slugKey || "entry"}`}
          />
        ) : null
      }

      <div class="knowledge__toc-surface">
        <TableOfContents headings={mergedHeadings} surface="minimal" />
      </div>

      <Stack className="knowledge__main" gap="xl">
        <article id="article-content" data-animate="rise-in">
          <VisuallyHidden id="article-title">{entry.data.title}</VisuallyHidden>
          <div role="region" aria-labelledby="article-title" aria-label="Main content">
            <Prose variant="article" className="knowledge__prose">
              <Content />
            </Prose>
          </div>
        </article>

        <ShareSection
          id="knowledge-share"
          shareUrl={canonical}
          contentTitle={title}
          contentDescription={description}
        />

        <RelatedContentSection
          id="related-knowledge-articles"
          eyebrow="Continue reading"
          title="Related articles"
          copy="Continue with guides from the same taxonomy branch or closely related keywords."
          listAriaLabel="Related articles"
          items={relatedArticleItems}
        />

        <div class="knowledge__back">
          <ButtonLink href="/" icon="arrow-left" aria-label="Back to knowledge list">
            <span>Back to knowledge list</span>
          </ButtonLink>
        </div>

        <RecentItemsTracker
          item={{
            slug: storageSlug,
            title,
            updatedAt: storageUpdatedAt,
            image: storageImage,
          }}
          storageKey={VERSIONED_KEYS.RECENT_READS}
          dataId={recentReadDataId}
        />
      </Stack>
    </Stack>
  </PageShell>
</Layout>

<style>
  :global(.page-shell__container.knowledge-article-shell__container) {
    padding-block-start: clamp(6rem, 8vw, 7.5rem);
  }

  .knowledge__back {
    display: flex;
    justify-content: center;
  }

  .knowledge :global(.article-hero) {
    scroll-margin-block-start: calc(var(--site-header-height) + var(--spacing-lg));
  }

  .knowledge__toc-surface {
    inline-size: min(100%, 76rem);
    margin-inline: auto;
  }

  :global(.knowledge__prose.prose--article) {
    max-inline-size: min(100%, 78rem);
  }

  @media (width >= 1024px) {
    :global(.page-shell__container.knowledge-article-shell__container) {
      padding-block-start: clamp(7rem, 7vw, 8.75rem);
    }

    .knowledge__main {
      gap: clamp(var(--spacing-lg), 2vw, var(--spacing-2xl));
    }
  }
</style>
