---
import Layout from "@layouts/Layout.astro";
import LegalDocumentPage from "@shared-ui/components/layout/LegalDocumentPage.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import { buildLegalPageSeo } from "../utils/legal/buildLegalPageSeo";

const title = "Legal Notice";
const description =
  "Legal notice for Melody Mind Knowledge in accordance with German law.";

const highlights = [
  {
    value: "German legal notice",
    label: "Required provider information for a Germany-based website.",
  },
  {
    value: "Private project",
    label: "Melody Mind Knowledge is presented here as a non-commercial project.",
  },
  {
    value: "Direct contact",
    label: "A contact address and dispute-resolution information are included below.",
  },
] as const;

const sections = [
  {
    icon: "user",
    title: "Service Provider",
    body: [
      "Daniel Schmid",
      "Hiltenspergerstr. 78",
      "80796 Munich",
      "Germany",
      "This website is a non-commercial private project.",
    ],
  },
  {
    icon: "mail",
    title: "Contact",
    body: ['Email: <a href="mailto:dcschmid@murena.io">dcschmid@murena.io</a>'],
  },
  {
    icon: "book-open",
    title: "Responsible for Editorial Content (§ 18 Abs. 2 MStV)",
    body: [
      "Daniel Schmid, Hiltenspergerstr. 78, 80796 Munich, Germany",
      "(Previously referenced in older legal notices as § 55 RStV.)",
    ],
  },
  {
    icon: "shield",
    title: "Register Entry",
    body: [
      "No commercial register entry exists for this private, non-commercial project.",
    ],
  },
  {
    icon: "tag",
    title: "VAT Identification Number",
    body: [
      "No VAT identification number (USt-IdNr.) is available, as this is not a commercial activity.",
    ],
  },
  {
    icon: "help-circle",
    title: "Dispute Resolution",
    body: [
      'The European Commission provides a platform for online dispute resolution: <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noreferrer">https://ec.europa.eu/consumers/odr</a>',
      "We are neither willing nor obliged to participate in dispute resolution proceedings before a consumer arbitration board.",
    ],
  },
  {
    icon: "info",
    title: "Liability for Own Content",
    body: [
      "We prepare our content with care. However, we cannot guarantee that all information is complete, accurate, or current at all times. You use the information on this website at your own risk.",
      "As a service provider, we are responsible for our own content on these pages in accordance with general laws (§ 5 TMG). Mandatory legal obligations remain unaffected.",
    ],
  },
  {
    icon: "external-link",
    title: "Liability for External Links (§ 8 TMG)",
    body: [
      "This website contains links to external third-party websites. We have no influence over the content of those websites and therefore cannot accept any liability for third-party content.",
      "Linked pages were checked for possible legal violations at the time of linking. Permanent monitoring of linked content is not reasonable without concrete evidence of a violation. If we become aware of legal infringements, such links will be removed promptly.",
    ],
  },
] as const;

const pageSeo = buildLegalPageSeo({
  site: Astro.site,
  path: "/imprint",
  title,
  description,
  imageAlt: "Legal Notice",
  fallbackKeywords: ["legal notice", "imprint", "impressum"],
  maxDescription: 150,
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <LegalDocumentPage
      eyebrow="Legal"
      title="Legal Notice"
      lead="Required legal information for a website operated from Germany."
      {highlights}
      highlightsLabel="Key legal notice points"
      {sections}
    />
  </PageShell>
</Layout>
