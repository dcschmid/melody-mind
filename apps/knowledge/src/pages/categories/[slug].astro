---
import Layout from "@layouts/Layout.astro";
import KnowledgeCard from "@components/KnowledgeCard.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import BackToTop from "@shared-ui/components/navigation/BackToTop.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import {
  buildCollectionPageSchema,
  buildKnowledgeArticlesItemList,
} from "@shared-utils/utils/seo/seoSchema";
import { getCollectionEntries } from "@shared-utils/utils/content/getCollectionEntries";
import { sortEntries } from "@shared-utils/utils/content/sortEntries";
import {
  normalizeDate,
  derivePublishModified,
} from "@shared-utils/utils/content/dateUtils";
import { calculateReadingTime } from "@shared-utils/utils/readingTime";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import { loggers } from "@shared-utils/utils/logging";
import categories from "../../data/categories.json";
import { Image } from "astro:assets";
import SearchPanel from "@shared-ui/components/search/SearchPanel.astro";

export const prerender = true;

type CategoryDef = {
  slug: string;
  name: string;
  description: string;
  image: string;
};

export async function getStaticPaths() {
  return (categories as CategoryDef[]).map((cat) => ({
    params: { slug: cat.slug },
  }));
}

const allCategories = categories as CategoryDef[];
const slug = (Astro.params?.slug as string) || "";
const category = allCategories.find((c) => c.slug === slug);

if (!category) {
  return new Response("Not found", { status: 404 });
}

let baseArticles: any[] = [];
try {
  baseArticles = await getCollectionEntries("knowledge-en");
} catch (e) {
  loggers.pages.warn("category page: collection load issue", {
    error: (e as any)?.message || e,
  });
}

const articlesWithReadingTime = baseArticles.map((article: any) => {
  const createdAtRaw = article?.data?.createdAt;
  const updatedAtRaw = article?.data?.updatedAt;
  const createdAt = normalizeDate(createdAtRaw);
  const updatedAt = normalizeDate(updatedAtRaw);
  const readingTime =
    article.data.readingTime || calculateReadingTime(article.body || "");
  return {
    ...article,
    data: { ...article.data, createdAt, updatedAt, readingTime },
  };
});

const filteredArticles = sortEntries(
  articlesWithReadingTime.filter((a) => a.data.category === slug)
);

const keywordPool = filteredArticles.flatMap((article) => article.data.keywords || []);
const metaKeywords = keywordPool.slice(0, 10).join(", ");

let earliestCreated: Date | null = null;
let latestUpdated: Date | null = null;
for (const a of filteredArticles) {
  const c = normalizeDate(a.data.createdAt);
  if (c && (!earliestCreated || c.getTime() < earliestCreated.getTime()))
    earliestCreated = c;
  const u = normalizeDate(a.data.updatedAt);
  if (u && (!latestUpdated || u.getTime() > latestUpdated.getTime())) latestUpdated = u;
}
const collectionDates = derivePublishModified(earliestCreated, latestUpdated);

const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, `/categories/${category.slug}`);
const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: category.name, url: currentUrl },
];
const articleItemListId = `${currentUrl}#article-itemlist`;

const breadcrumbSchema = seoBreadcrumbs.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: seoBreadcrumbs.map((crumb, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: crumb.name,
        item: crumb.url,
      })),
    }
  : undefined;

const itemListSchema = buildKnowledgeArticlesItemList({
  articles: filteredArticles.map((article: any) => ({
    slug: "slug" in article ? article.slug : article.id,
    data: {
      title: article.data.title,
      description: article.data.description,
      createdAt: article.data.createdAt,
      updatedAt: article.data.updatedAt,
      keywords: article.data.keywords,
      image: article.data.image,
    },
  })),
  baseUrl,
  lang: "en",
  listName: `${category.name} articles`,
  itemListId: articleItemListId,
});
const collectionPageSchema = buildCollectionPageSchema({
  url: currentUrl,
  name: category.name,
  description: category.description,
  lang: "en",
  image: `${baseUrl}${category.image}`,
  mainEntityId: articleItemListId,
});

const pageSeo = buildPageSeo({
  title: `${category.name} Guides`,
  description: category.description,
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: [collectionPageSchema, breadcrumbSchema, itemListSchema].filter(
    Boolean
  ) as StructuredData[],
  enrichedParts: [category.name, category.description],
  fallbackKeywords: metaKeywords
    .split(",")
    .map((k) => k.trim())
    .filter(Boolean),
  keywordLimit: 24,
  maxDescription: 150,
  image: category.image,
  imageAlt: `${category.name} - Music Knowledge`,
  publishDate: collectionDates.publishDate || undefined,
  modifiedDate: collectionDates.modifiedDate || undefined,
  index: true,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell
    className="page-shell--aurora page-shell--grid"
    containerClass="page-shell__container--wide"
  >
    <div class="category-page">
      <header class="category-hero">
        <div class="category-hero__headline">
          <div class="category-hero__eyebrow">
            <span class="category-hero__dot"></span>
            Explore this category
          </div>
          <Headline level="h1" textSize="2xl" className="category-hero__title">
            <span id="category-heading">{category.name}</span>
          </Headline>
        </div>
        <div class="category-hero__media">
          <div class="category-hero__background">
            <Image
              src={category.image}
              alt={`${category.name} hero`}
              loading="lazy"
              decoding="async"
              class="category-hero__image"
              width="1920"
              height="1280"
            />
            <div class="category-hero__overlay" aria-hidden="true"></div>
          </div>
          <div class="category-hero__body">
            <div class="category-hero__content">
              <Paragraph textSize="base" className="category-hero__description">
                {category.description}
              </Paragraph>
              <div class="category-hero__stats">
                <span class="category-hero__stat">
                  <span class="category-hero__dot"></span>
                  {filteredArticles.length} articles
                </span>
              </div>
            </div>
          </div>
        </div>
      </header>

      <section
        class="category-page__section"
        aria-labelledby="category-heading"
        aria-describedby="category-helper-text"
      >
        <div class="category-page__tools">
          <Paragraph
            id="category-helper-text"
            textSize="sm"
            className="category-page__helper"
          >
            Each article card includes the title, description, publish date, and estimated
            reading time.
          </Paragraph>
          <div class="category-page__search search-panel-shell">
            <SearchPanel
              idBase="category-search"
              label="Search articles"
              placeholder="Search by title, summary, or keyword"
              ariaControls="category-articles-list"
              analyticsSurface="category-articles"
              statusAllText="Showing all articles"
              statusCountTemplate="{count} articles found"
              noResultsTemplate='No results for "{term}"'
            />
          </div>
        </div>
        {
          filteredArticles.length > 0 ? (
            <>
              <ul
                class="category-page__grid"
                id="category-articles-list"
                aria-label={`${category.name} articles`}
              >
                {filteredArticles.map((article, index: number) => {
                  const createdAt =
                    article.data.createdAt instanceof Date
                      ? article.data.createdAt
                      : normalizeDate(article.data.createdAt) || new Date();
                  const articleSlug = "slug" in article ? article.slug : article.id;

                  return (
                    <li
                      data-search-text={`${article.data.title} ${article.data.description} ${article.data.keywords?.join(" ") || ""}`}
                    >
                      <KnowledgeCard
                        title={article.data.title}
                        description={article.data.description}
                        image={article.data.image as string}
                        createdAt={createdAt}
                        slug={articleSlug}
                        readingTime={article.data.readingTime}
                        articleUrl={`/knowledge/${articleSlug}`}
                        keywords={article.data.keywords?.join(", ")}
                        index={index}
                      />
                    </li>
                  );
                })}
              </ul>
              <div
                id="category-search-empty"
                class="category-page__empty"
                aria-live="polite"
                hidden
              >
                No results match your search. Try another keyword.
              </div>
            </>
          ) : (
            <div
              class="category-page__empty"
              role="status"
              aria-live="polite"
              id="category-search-no-results"
            >
              <Paragraph textSize="lg" className="category-page__empty-title">
                No articles in this category yet.
              </Paragraph>
              <Paragraph textSize="sm" className="category-page__empty-text">
                Check back soon for new additions.
              </Paragraph>
            </div>
          )
        }
      </section>
    </div>
  </PageShell>

  <BackToTop />
</Layout>
<style>
  .panel {
    --panel-radius: 1rem;
    --panel-padding: 1.5rem;

    position: relative;
    padding: var(--panel-padding);
    background: var(--gn-bg-muted);
    border: 2px solid var(--gn-panel-border);
    border-radius: var(--panel-radius);
  }

  .panel--compact {
    --panel-padding: 1rem;
  }

  .panel--tight {
    --panel-padding: 1.25rem;
  }

  .panel--card {
    --panel-radius: 1rem;
    --panel-padding: 1.25rem;
  }

  .category-page {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .category-page__section {
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 2.4vi, 2.5rem);
  }

  .category-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  @media (width >= 768px) {
    .category-hero {
      gap: 2rem;
    }
  }

  .category-hero__headline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .category-hero__media {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  @media (width >= 768px) {
    .category-hero__media {
      flex-direction: row;
      gap: 2rem;
      align-items: stretch;
    }
  }

  .category-hero__background {
    position: relative;
    inline-size: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  .category-hero__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
  }

  .category-hero__overlay {
    position: absolute;
    inset: 0;
    display: none;
  }

  .category-hero__body {
    display: flex;
    justify-content: center;
    inline-size: 100%;
  }

  @media (width >= 768px) {
    .category-hero__background,
    .category-hero__body {
      inline-size: 50%;
    }

    .category-hero__body {
      align-items: center;
    }
  }

  @media (width >= 1024px) {
    .category-hero__background {
      inline-size: 58%;
    }

    .category-hero__body {
      inline-size: 42%;
    }
  }

  .category-hero__content {
    inline-size: min(820px, 100%);
    padding: 2rem 2.25rem;
    background: var(--gn-bg-muted);
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  .category-hero__eyebrow {
    display: inline-flex;
    gap: 0.625rem;
    align-items: center;
    padding: 0.4rem 0.9rem;
    margin-block-end: 1.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--gn-ink);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    background: var(--gn-bg);
    border: 1px solid var(--gn-panel-border);
    border-radius: 999px;
  }

  @media (width >= 640px) {
    .category-hero__eyebrow {
      font-size: 0.875rem;
    }
  }

  .category-hero__dot {
    inline-size: 0.5rem;
    block-size: 0.5rem;
    background: var(--gn-accent);
    border-radius: 999px;
  }

  .category-hero__title {
    margin: 0;
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--gn-ink);
    letter-spacing: -0.02em;
  }

  @media (width >= 640px) {
    .category-hero__title {
      font-size: 3.25rem;
    }
  }

  @media (width >= 1024px) {
    .category-hero__title {
      font-size: 4rem;
    }
  }

  .category-hero__description {
    max-inline-size: 60ch;
    margin: 0 0 2rem;
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.75;
    color: var(--gn-ink-muted);
  }

  @media (width >= 640px) {
    .category-hero__description {
      font-size: 1.125rem;
      line-height: 1.75;
    }
  }

  @media (width >= 1024px) {
    .category-hero__description {
      margin-block-end: 2.25rem;
      font-size: 1.2rem;
    }
  }

  .category-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .category-hero__stat {
    display: inline-flex;
    gap: 0.625rem;
    align-items: center;
    padding: 0.7rem 1.4rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 2px solid var(--gn-panel-border);
    border-radius: 999px;
  }

  .category-page__tools {
    display: grid;
    gap: 1.25rem;
  }

  @media (width >= 960px) {
    .category-page__tools {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: stretch;
    }
  }

  .category-page__helper {
    padding: 1.25rem 1.5rem;
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--gn-ink-muted);
    background: var(--gn-bg-muted);
    border: 1px solid var(--gn-panel-border);
    border-radius: 0.75rem;
  }

  @media (width >= 640px) {
    .category-page__helper {
      padding: 1rem 1.2rem;
      font-size: 1.0625rem;
    }
  }

  .category-page__search {
    padding: 1.25rem 1.5rem;
    background: var(--gn-bg-muted);
    border: 1px solid var(--gn-panel-border);
    border-radius: 0.75rem;
  }

  .category-page__search :global(.search-panel__input) {
    font-size: 1.05rem;
    background: var(--gn-bg);
    border: 2px solid var(--gn-panel-border);
    border-radius: 0.75rem;
  }

  @media (width >= 640px) {
    .category-page__search :global(.search-panel__input) {
      font-size: 1.15rem;
    }
  }

  .category-page__search :global(.search-panel__input:hover),
  .category-page__search :global(.search-panel__input:focus) {
    border-color: var(--gn-accent);
  }

  .category-page__search :global(.search-panel__input:focus-visible) {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
  }

  .category-page__search :global(.search-panel__reset) {
    color: var(--gn-ink);
    background: var(--gn-bg);
    border: 2px solid var(--gn-accent);
    border-radius: 999px;
  }

  .category-page__search :global(.search-panel__reset:hover),
  .category-page__search :global(.search-panel__reset:focus) {
    background: var(--gn-bg-muted);
  }

  .category-page__grid {
    display: grid;
    gap: 2rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (width >= 640px) {
    .category-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.75rem;
    }
  }

  @media (width >= 1024px) {
    .category-page__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem;
    }
  }

  .category-page__empty {
    padding: 3rem 2rem;
    color: var(--gn-ink-muted);
    text-align: center;
    background: var(--gn-bg-muted);
    border: 2px solid var(--gn-panel-border);
    border-radius: 0.75rem;
  }

  .category-page__empty-title {
    margin: 0;
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--gn-ink);
    letter-spacing: -0.01em;
  }

  .category-page__empty-text {
    margin-block-start: 0.75rem;
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--gn-ink-muted);
  }
</style>
