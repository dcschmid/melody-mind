---
/**
 * Taxonomy Section Page - Display subsections and articles for a taxonomy section
 */
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import TaxonomyJumpNav from "@shared-ui/components/taxonomy/TaxonomyJumpNav.astro";
import TaxonomySectionHero from "@shared-ui/components/taxonomy/TaxonomySectionHero.astro";
import TaxonomySubsectionBlock from "@shared-ui/components/taxonomy/TaxonomySubsectionBlock.astro";
import { getCollectionCached } from "@shared-utils/utils/content/getCollectionCached";
import { loggers } from "@shared-utils/utils/logging";
import { buildTaxonomySectionSeo } from "@utils/taxonomy/taxonomyPage";
import {
  buildTaxonomySectionPageData,
  type TaxonomyArticle,
} from "@utils/taxonomy/buildTaxonomySectionPageData";
import {
  getKnowledgeCategoryImage,
  getKnowledgeTaxonomyImage,
} from "@utils/knowledgeImages";
import { musicTaxonomy } from "../../data/musicTaxonomy";

export const prerender = true;

export async function getStaticPaths() {
  return musicTaxonomy.map((section) => ({
    params: { section: section.id },
  }));
}

type KnowledgeEntry = CollectionEntry<"knowledge-en">;

const getErrorMessage = (error: unknown): string =>
  error instanceof Error ? error.message : String(error);

const sectionId = Astro.params.section || "";
const section = musicTaxonomy.find((s) => s.id === sectionId);

if (!section) {
  return Astro.redirect("/404");
}

// Load articles
let baseArticles: KnowledgeEntry[] = [];
try {
  baseArticles = (await getCollectionCached("knowledge-en", {
    getCollection,
  })) as KnowledgeEntry[];
} catch (e) {
  loggers.pages.warn("taxonomy section: collection load issue", {
    error: getErrorMessage(e),
  });
}

const { sectionArticles, subsectionsData, jumpTargets } = buildTaxonomySectionPageData({
  baseArticles,
  section,
});
const toTaxonomyCard = (article: TaxonomyArticle) => ({
  id: article.id,
  title: article.data.title,
  description: article.data.description,
  href: `/knowledge/${article.id}`,
  imageSrc: getKnowledgeCategoryImage(article.data.image),
  imageAlt: `Cover image for ${article.data.title}`,
  readingTime: article.data.readingTime,
  createdAt: article.data.createdAt,
});
const sharedSubsectionsData = subsectionsData.map((subsection) => ({
  ...subsection,
  articles: subsection.articles.map(toTaxonomyCard),
  groupsWithArticles: subsection.groupsWithArticles.map((group) => ({
    ...group,
    articles: group.articles.map(toTaxonomyCard),
  })),
}));
const sectionImage = getKnowledgeTaxonomyImage(section.image) || undefined;

const pageSeo = buildTaxonomySectionSeo({
  site: Astro.site,
  sectionId,
  section,
  sectionArticles,
});
---

<Layout {pageSeo}>
  <PageShell className="page-shell--night page-shell--grid">
    <Stack className="taxonomy-section" gap="2xl">
      <TaxonomySectionHero
        id={section.id}
        title={section.title}
        description={section.description}
        imageSrc={sectionImage}
        imageAlt={section.title}
      />

      {jumpTargets.length >= 1 && <TaxonomyJumpNav targets={jumpTargets} />}

      <Stack as="section" className="taxonomy-section__content" gap="2xl">
        {
          sharedSubsectionsData.map((subsection) => (
            <TaxonomySubsectionBlock subsection={subsection} />
          ))
        }
      </Stack>
    </Stack>
  </PageShell>
</Layout>
