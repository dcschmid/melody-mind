---
/**
 * Taxonomy Section Page - Display subsections and articles for a taxonomy section
 */
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/Shared/PageShell.astro";
import KnowledgeCard from "@components/KnowledgeCard.astro";
import Headline from "@shared-ui/components/Headline.astro";
import BackToTop from "@shared-ui/components/Shared/BackToTop.astro";
import { buildPageSeo, type StructuredData } from "@utils/seo/buildPageSeo";
import {
  buildCollectionPageSchema,
  buildKnowledgeArticlesItemList,
} from "@utils/seo/seoSchema";
import { getCollectionCached } from "@utils/content/getCollectionCached";
import { sortKnowledgeEntries } from "@utils/content/sortKnowledgeEntries";
import { derivePublishModified, normalizeDate } from "@utils/content/dateUtils";
import { calculateReadingTime } from "@utils/readingTime";
import { resolveBaseUrl, resolvePageUrl } from "@utils/siteUrls";
import { loggers } from "@shared-utils/utils/logging";
import { musicTaxonomy } from "../../data/musicTaxonomy";
import type { TaxonomySubsection } from "../../types/taxonomy";
import { Image } from "astro:assets";

export const prerender = true;

export async function getStaticPaths() {
  return musicTaxonomy.map((section) => ({
    params: { section: section.id },
  }));
}

const sectionId = Astro.params.section as string;
const section = musicTaxonomy.find((s) => s.id === sectionId);
const seoDescriptionOverrides: Record<string, string> = {
  "canon-key-artists":
    "Discover the artists who shaped music history across genres, eras, and major cultural movements.",
  "countries-regional-traditions":
    "Explore traditional and contemporary music shaped by regional identity, local history, and cultural exchange around the world.",
  "electronic-club-nightlife":
    "Trace electronic music from house and techno to global club culture through the DJs, scenes, and communities that shaped it.",
  "folk-regional-expressions":
    "Explore folk and regional music through storytelling, place, tradition, and evolving cultural identity across communities.",
  "hiphop-rap-culture":
    "Trace hip hop from Bronx origins to global influence through lyrical storytelling, scenes, production, and cultural change.",
  "latin-caribbean-afro-roots":
    "Discover Latin, Caribbean, and Afro-rooted music through rhythm, migration, heritage, and cross-cultural exchange.",
  "live-performance-stagecraft":
    "Explore live performance through stage presence, touring, sound, lighting, and the craft of connecting with audiences.",
  "mainstream-pop-global-hits":
    "Explore chart pop, breakout stars, and global hits through the artists, sounds, and moments that shaped mass audiences.",
  "music-media-technology-industry":
    "Explore the business, media, and technology systems that shape music, from streaming and radio to platforms and AI.",
  "music-theory-composition":
    "Discover harmony, melody, rhythm, form, and composition ideas that shape musical meaning across traditions.",
  "music-therapy-wellness-healing":
    "Explore how music supports wellbeing, recovery, and mental health through therapy, self-care, and research.",
};

const seoTitleOverrides: Record<string, string> = {
  "emotional-seasonal-situational": "Emotional, Seasonal & Situational Music",
};

if (!section) {
  return new Response("Not found", { status: 404 });
}

// Load articles
let baseArticles: any[] = [];
try {
  baseArticles = await getCollectionCached("knowledge-en").catch(() => []);
} catch (e) {
  loggers.pages.warn("taxonomy section: collection load issue", {
    error: (e as any)?.message || e,
  });
}

// Process articles
const articlesWithReadingTime = baseArticles.map((article: any) => {
  const createdAt = normalizeDate(article?.data?.createdAt);
  const updatedAt = normalizeDate(article?.data?.updatedAt);
  const readingTime =
    article.data.readingTime || calculateReadingTime(article.body || "");
  return {
    ...article,
    data: { ...article.data, createdAt, updatedAt, readingTime },
  };
});

// Get subsection IDs for this section
const subsectionIds = section.subsections.map((s) => s.id);

// Filter articles for this section
const sectionArticles = sortKnowledgeEntries(
  articlesWithReadingTime.filter((a: any) =>
    subsectionIds.includes(a.data?.taxonomySubsection)
  )
);

// Build subsection data with article counts and groups
const subsectionsData = section.subsections.map((subsection: TaxonomySubsection) => {
  const articles = sortKnowledgeEntries(
    articlesWithReadingTime.filter(
      (a: any) => a.data?.taxonomySubsection === subsection.id
    )
  );

  // Build groups with article counts
  const groupsWithArticles = (subsection.groups || []).map((group) => {
    const groupArticles = sortKnowledgeEntries(
      articlesWithReadingTime.filter(
        (a: any) =>
          a.data?.taxonomySubsection === subsection.id &&
          a.data?.taxonomyGroup === group.id
      )
    );
    return {
      ...group,
      anchorId: `${subsection.id}--${group.id}`,
      articleCount: groupArticles.length,
    };
  });

  return {
    ...subsection,
    articleCount: articles.length,
    articles,
    groupsWithArticles,
  };
});

// Build flat list of jump targets (groups with articles, or subsections without groups)
interface JumpTarget {
  anchorId: string;
  title: string;
  articleCount: number;
  parentTitle?: string;
}

const jumpTargets: JumpTarget[] = subsectionsData.flatMap((subsection) => {
  const groupsWithContent = subsection.groupsWithArticles.filter(
    (g) => g.articleCount > 0
  );

  if (groupsWithContent.length > 0) {
    // Has groups with articles → list groups
    return groupsWithContent.map((group) => ({
      anchorId: group.anchorId,
      title: group.title,
      articleCount: group.articleCount,
      parentTitle: subsection.title,
    }));
  } else if (subsection.articleCount > 0) {
    // No groups but has articles → list subsection
    return [
      {
        anchorId: subsection.id,
        title: subsection.title,
        articleCount: subsection.articleCount,
      },
    ];
  }
  return [];
});

// SEO
const currentUrl = resolvePageUrl(Astro.site, `/taxonomy/${sectionId}`);
const baseUrl = resolveBaseUrl(Astro.site);
const seoDescription =
  seoDescriptionOverrides[sectionId] ||
  section.description ||
  `Explore ${section.title} - music knowledge and guides.`;
const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: section.title, url: currentUrl },
];
const articleItemListId = `${currentUrl}#article-itemlist`;
let earliestCreated: Date | null = null;
let latestUpdated: Date | null = null;

for (const article of sectionArticles) {
  const createdAt = normalizeDate(article.data.createdAt);
  const updatedAt = normalizeDate(article.data.updatedAt);
  if (
    createdAt &&
    (!earliestCreated || createdAt.getTime() < earliestCreated.getTime())
  ) {
    earliestCreated = createdAt;
  }
  if (updatedAt && (!latestUpdated || updatedAt.getTime() > latestUpdated.getTime())) {
    latestUpdated = updatedAt;
  }
}

const sectionDates = derivePublishModified(earliestCreated, latestUpdated);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: seoBreadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.name,
    item: crumb.url,
  })),
};
const itemListSchema = buildKnowledgeArticlesItemList({
  articles: sectionArticles.map((article: any) => ({
    slug: "slug" in article ? article.slug : article.id,
    data: {
      title: article.data.title,
      description: article.data.description,
      createdAt: article.data.createdAt,
      updatedAt: article.data.updatedAt,
      keywords: article.data.keywords,
      image: article.data.image,
    },
  })),
  baseUrl,
  lang: "en",
  listName: `${section.title} articles`,
  itemListId: articleItemListId,
});
const collectionPageSchema = buildCollectionPageSchema({
  url: currentUrl,
  name: section.title,
  description: seoDescription,
  lang: "en",
  image: section.image ? `${baseUrl}${section.image}` : undefined,
  mainEntityId: articleItemListId,
});

const pageSeo = buildPageSeo({
  title: seoTitleOverrides[sectionId] || `${section.title} Topics`,
  description: seoDescription,
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: [collectionPageSchema, breadcrumbSchema, itemListSchema].filter(
    Boolean
  ) as StructuredData[],
  enrichedParts: [section.title, section.description || ""],
  fallbackKeywords: [],
  keywordLimit: 28,
  maxDescription: 160,
  image: section.image,
  imageAlt: `${section.title} - Melody Mind`,
  publishDate: sectionDates.publishDate || undefined,
  modifiedDate: sectionDates.modifiedDate || undefined,
  index: true,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell className="page-shell--aurora page-shell--grid">
    <div class="taxonomy-section">
      <header class="taxonomy-section__header">
        <div class="taxonomy-section__hero">
          {
            section.image && (
              <div class="taxonomy-section__media">
                <Image
                  src={section.image}
                  alt={section.title}
                  loading="eager"
                  class="taxonomy-section__image"
                  width="1200"
                  height="400"
                />
                <div class="taxonomy-section__overlay" aria-hidden="true" />
              </div>
            )
          }
          <div class="taxonomy-section__intro">
            <Headline level="h1" textSize="2xl" className="taxonomy-section__title">
              {section.title}
            </Headline>
            {
              section.description && (
                <p class="taxonomy-section__description">{section.description}</p>
              )
            }
            <div class="taxonomy-section__stats">
              <span class="taxonomy-section__stat">
                {subsectionsData.length} topics
              </span>
              <span class="taxonomy-section__stat">
                {sectionArticles.length} articles
              </span>
            </div>

            {
              jumpTargets.length >= 1 && (
                <nav class="taxonomy-section__toc" aria-label="Jump to a topic">
                  <button
                    type="button"
                    class="taxonomy-section__toc-toggle"
                    aria-expanded="false"
                    aria-controls="taxonomy-toc-content"
                  >
                    <span class="taxonomy-section__toc-toggle-label">
                      Jump to a topic
                    </span>
                    <svg
                      class="taxonomy-section__toc-chevron"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </button>
                  <div id="taxonomy-toc-content" class="taxonomy-section__toc-content">
                    <ul class="taxonomy-section__toc-list">
                      {jumpTargets.map((target) => (
                        <li class="taxonomy-section__toc-item">
                          <a
                            href={`#${target.anchorId}`}
                            class="taxonomy-section__toc-link"
                          >
                            <span class="taxonomy-section__toc-title">
                              {target.title}
                            </span>
                            <span class="taxonomy-section__toc-count">
                              {target.articleCount}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </nav>
              )
            }
          </div>
        </div>
      </header>

      <section class="taxonomy-section__content">
        {
          subsectionsData.map((subsection) => (
            <div id={subsection.id} class="taxonomy-section__subsection">
              <div class="taxonomy-section__subsection-header">
                <div class="taxonomy-section__subsection-info">
                  <Headline
                    level="h2"
                    textSize="lg"
                    className="taxonomy-section__subsection-title"
                  >
                    {subsection.title}
                  </Headline>
                  {subsection.description && (
                    <p class="taxonomy-section__subsection-description">
                      {subsection.description}
                    </p>
                  )}
                  <span class="taxonomy-section__subsection-count">
                    {subsection.articleCount}{" "}
                    {subsection.articleCount === 1 ? "article" : "articles"}
                  </span>
                </div>
              </div>

              {subsection.groups && subsection.groups.length > 0 && (
                <div class="taxonomy-section__groups">
                  {subsection.groups.map((group) => {
                    const groupArticles = sortKnowledgeEntries(
                      articlesWithReadingTime.filter(
                        (a: any) =>
                          a.data?.taxonomySubsection === subsection.id &&
                          a.data?.taxonomyGroup === group.id
                      )
                    );

                    return (
                      <div
                        id={`${subsection.id}--${group.id}`}
                        class="taxonomy-section__group"
                      >
                        <div class="taxonomy-section__group-header">
                          <div class="taxonomy-section__group-info">
                            <Headline
                              level="h3"
                              textSize="base"
                              className="taxonomy-section__group-title"
                            >
                              {group.title}
                            </Headline>
                            {group.description && (
                              <p class="taxonomy-section__group-description">
                                {group.description}
                              </p>
                            )}
                            <span class="taxonomy-section__group-count">
                              {groupArticles.length}{" "}
                              {groupArticles.length === 1 ? "article" : "articles"}
                            </span>
                          </div>
                        </div>
                        {groupArticles.length > 0 ? (
                          <ul class="taxonomy-section__articles">
                            {groupArticles.map((article: any, index: number) => {
                              const articleSlug =
                                "slug" in article ? article.slug : article.id;
                              return (
                                <li>
                                  <KnowledgeCard
                                    title={article.data.title}
                                    description={article.data.description}
                                    image={article.data.image}
                                    createdAt={article.data.createdAt || new Date()}
                                    slug={articleSlug}
                                    readingTime={article.data.readingTime}
                                    articleUrl={`/knowledge/${articleSlug}`}
                                    index={index}
                                  />
                                </li>
                              );
                            })}
                          </ul>
                        ) : (
                          <p class="taxonomy-section__empty">No articles yet.</p>
                        )}
                      </div>
                    );
                  })}
                </div>
              )}

              {(!subsection.groups || subsection.groups.length === 0) && (
                <>
                  {subsection.articles.length > 0 ? (
                    <ul class="taxonomy-section__articles">
                      {subsection.articles.map((article: any, index: number) => {
                        const articleSlug = "slug" in article ? article.slug : article.id;
                        return (
                          <li>
                            <KnowledgeCard
                              title={article.data.title}
                              description={article.data.description}
                              image={article.data.image}
                              createdAt={article.data.createdAt || new Date()}
                              slug={articleSlug}
                              readingTime={article.data.readingTime}
                              articleUrl={`/knowledge/${articleSlug}`}
                              index={index}
                            />
                          </li>
                        );
                      })}
                    </ul>
                  ) : (
                    <p class="taxonomy-section__empty">No articles in this topic yet.</p>
                  )}
                </>
              )}
            </div>
          ))
        }
      </section>
    </div>
  </PageShell>

  <BackToTop />
</Layout>

<style>
  .taxonomy-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .taxonomy-section__header {
    padding-block-end: 2rem;
    border-block-end: 1px solid var(--gn-panel-border);
  }

  .taxonomy-section__hero {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (width >= 768px) {
    .taxonomy-section__hero {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .taxonomy-section__media {
    position: relative;
    inline-size: 100%;
    aspect-ratio: 3 / 1;
    overflow: hidden;
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  @media (width >= 768px) {
    .taxonomy-section__media {
      inline-size: 40%;
      aspect-ratio: 4 / 3;
    }
  }

  .taxonomy-section__image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .taxonomy-section__overlay {
    position: absolute;
    inset: 0;
  }

  .taxonomy-section__intro {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.75rem;
  }

  .taxonomy-section__title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--gn-ink);
  }

  @media (width >= 768px) {
    .taxonomy-section__title {
      font-size: 2.5rem;
    }
  }

  .taxonomy-section__description {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--gn-ink-muted);
  }

  .taxonomy-section__stats {
    display: flex;
    gap: 1rem;
    margin-block-start: 0.5rem;
  }

  .taxonomy-section__stat {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.9rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gn-ink-muted);
    background: var(--gn-bg-muted);
    border: 1px solid var(--gn-panel-border);
    border-radius: 999px;
  }

  .taxonomy-section__content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .taxonomy-section__subsection {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .taxonomy-section__subsection-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (width >= 768px) {
    .taxonomy-section__subsection-header {
      flex-direction: row;
      gap: 1.5rem;
      align-items: flex-start;
    }
  }

  .taxonomy-section__subsection-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.5rem;
  }

  .taxonomy-section__subsection-title {
    padding-block-end: 0.5rem;
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--gn-ink);
    border-block-end: 2px solid var(--gn-panel-border);
  }

  .taxonomy-section__subsection-description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--gn-ink-muted);
  }

  .taxonomy-section__subsection-count {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--gn-accent);
  }

  .taxonomy-section__subsection-image {
    flex-shrink: 0;
    inline-size: 100%;
    max-inline-size: 300px;
    overflow: hidden;
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  .taxonomy-section__subsection-img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .taxonomy-section__groups {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .taxonomy-section__group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--gn-bg-muted);
    border: 1px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  .taxonomy-section__group-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (width >= 640px) {
    .taxonomy-section__group-header {
      flex-direction: row;
      gap: 1rem;
      align-items: flex-start;
    }
  }

  .taxonomy-section__group-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.35rem;
  }

  .taxonomy-section__group-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gn-ink);
  }

  .taxonomy-section__group-description {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--gn-ink-muted);
  }

  .taxonomy-section__group-count {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--gn-accent);
  }

  .taxonomy-section__group-image {
    flex-shrink: 0;
    inline-size: 100%;
    max-inline-size: 180px;
    overflow: hidden;
    border: 1px solid var(--gn-panel-border);
    border-radius: 0.75rem;
  }

  .taxonomy-section__group-img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .taxonomy-section__articles {
    display: grid;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (width >= 640px) {
    .taxonomy-section__articles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1024px) {
    .taxonomy-section__articles {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .taxonomy-section__empty {
    padding: 1.5rem;
    margin: 0;
    color: var(--gn-ink-muted);
    text-align: center;
    background: var(--gn-bg-muted);
    border: 1px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  /* Jump Navigation TOC */
  .taxonomy-section__toc {
    position: relative;
    margin-block-end: 1rem;
  }

  .taxonomy-section__toc-toggle {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    inline-size: 100%;
    min-block-size: 48px;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--gn-ink);
    text-align: start;
    cursor: pointer;
    background: var(--gn-bg-muted);
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
  }

  .taxonomy-section__toc-toggle:hover, .taxonomy-section__toc-toggle:focus {
    background: var(--gn-bg);
    border-color: var(--gn-accent);
  }

  .taxonomy-section__toc-toggle:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
  }

  .taxonomy-section__toc-toggle-label {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
  }

  .taxonomy-section__toc-chevron {
    flex-shrink: 0;
    color: var(--gn-ink-muted);
  }

  .taxonomy-section__toc[data-open="true"] .taxonomy-section__toc-chevron {
    transform: rotate(180deg);
  }

  .taxonomy-section__toc-content {
    position: absolute;
    inset-block-start: calc(100% + 0.5rem);
    inset-inline: 0;
    z-index: 20;
    display: none;
    max-block-size: 50vb;
    padding: 1rem;
    overflow-block: auto;
    background: var(--gn-bg-muted);
    border: 2px solid var(--gn-panel-border);
    border-radius: 1rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .taxonomy-section__toc[data-open="true"] .taxonomy-section__toc-content {
    display: block;
  }

  .taxonomy-section__toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .taxonomy-section__toc-item {
    margin: 0;
  }

  .taxonomy-section__toc-link {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--gn-ink);
    text-decoration: none;
    border-radius: 0.75rem;
  }

  .taxonomy-section__toc-link:hover, .taxonomy-section__toc-link:focus {
    background: var(--gn-bg);
  }

  .taxonomy-section__toc-link:focus-visible {
    outline: 2px solid var(--gn-accent);
    outline-offset: 2px;
  }

  .taxonomy-section__toc-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-inline-size: 2rem;
    min-block-size: 2rem;
    padding: 0 0.625rem;
    font-size: 0.8125rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    color: var(--gn-bg);
    background: var(--gn-accent);
    border-radius: 999px;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--gn-ink) 10%, transparent);
  }

  :global(:root[data-theme="light"]) .taxonomy-section__toc-count {
    color: var(--gn-bg-primary);
    background: var(--gn-accent-strong);
  }

  :global(:root[data-theme="dark"]) .taxonomy-section__toc-count {
    color: var(--gn-bg-primary);
    background: var(--gn-accent);
  }

  .taxonomy-section__toc-link:hover .taxonomy-section__toc-count, .taxonomy-section__toc-link:focus .taxonomy-section__toc-count {
    color: var(--gn-bg);
    background: var(--gn-accent-strong);
  }

  :global(:root[data-theme="light"])
    .taxonomy-section__toc-link:hover
    .taxonomy-section__toc-count, :global(:root[data-theme="light"])
    .taxonomy-section__toc-link:focus
    .taxonomy-section__toc-count {
    color: var(--gn-bg-primary);
    background: var(--gn-accent);
  }

  :global(:root[data-theme="dark"])
    .taxonomy-section__toc-link:hover
    .taxonomy-section__toc-count, :global(:root[data-theme="dark"])
    .taxonomy-section__toc-link:focus
    .taxonomy-section__toc-count {
    color: var(--gn-bg-primary);
    background: var(--gn-accent-strong);
  }

  /* Desktop: Show as pill list */
  @media (width >= 640px) {
    .taxonomy-section__toc-toggle {
      display: none;
    }

    .taxonomy-section__toc-content {
      position: static;
      display: block;
      max-block-size: none;
      padding: 0;
      overflow: visible;
      background: transparent;
      border: none;
      box-shadow: none;
    }

    .taxonomy-section__toc-list {
      flex-flow: row wrap;
      gap: 0.5rem;
    }

    .taxonomy-section__toc-link {
      padding: 0.5rem 0.875rem;
      font-size: 0.875rem;
      background: var(--gn-bg-muted);
      border: 1px solid var(--gn-panel-border);
      border-radius: 999px;
    }

    .taxonomy-section__toc-link:hover, .taxonomy-section__toc-link:focus {
      background: var(--gn-bg);
      border-color: var(--gn-accent);
    }
  }

  /* Scroll margin for anchored sections */
  .taxonomy-section__subsection,
  .taxonomy-section__group {
    scroll-margin-block-start: 80px;
  }
</style>

<script>
  const tocNav = document.querySelector<HTMLElement>(".taxonomy-section__toc");
  const tocToggle = document.querySelector<HTMLButtonElement>(
    ".taxonomy-section__toc-toggle"
  );
  const tocContent = document.getElementById("taxonomy-toc-content");

  if (tocNav && tocToggle && tocContent) {
    const setOpen = (open: boolean): void => {
      tocNav.setAttribute("data-open", open ? "true" : "false");
      tocToggle.setAttribute("aria-expanded", open ? "true" : "false");
    };

    tocToggle.addEventListener("click", () => {
      const isOpen = tocToggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (tocNav.getAttribute("data-open") === "true" && !tocNav.contains(target)) {
        setOpen(false);
      }
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && tocNav.getAttribute("data-open") === "true") {
        setOpen(false);
        tocToggle.focus();
      }
    });

    // Close on link click (mobile)
    tocContent.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const link = target.closest<HTMLAnchorElement>("a[href^='#']");
      if (link && window.innerWidth < 640) {
        setOpen(false);
      }
    });
  }
</script>
