---
/**
 * Taxonomy Section Page - Display subsections and articles for a taxonomy section
 */
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import KnowledgeCard from "@components/KnowledgeCard.astro";
import TaxonomyJumpNav from "@components/TaxonomyJumpNav.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import BackToTop from "@shared-ui/components/navigation/BackToTop.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import {
  buildCollectionPageSchema,
  buildKnowledgeArticlesItemList,
} from "@shared-utils/utils/seo/seoSchema";
import { getCollectionEntries } from "@shared-utils/utils/content/getCollectionEntries";
import { sortEntries } from "@shared-utils/utils/content/sortEntries";
import {
  derivePublishModified,
  normalizeDate,
} from "@shared-utils/utils/content/dateUtils";
import { calculateReadingTime } from "@shared-utils/utils/readingTime";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import { loggers } from "@shared-utils/utils/logging";
import {
  getTaxonomySectionSeoDescription,
  getTaxonomySectionSeoTitle,
} from "@utils/knowledge/taxonomyPage";
import { musicTaxonomy } from "../../data/musicTaxonomy";
import type { TaxonomySubsection } from "../../types/taxonomy";
import { Image } from "astro:assets";

export const prerender = true;

export async function getStaticPaths() {
  return musicTaxonomy.map((section) => ({
    params: { section: section.id },
  }));
}

const sectionId = Astro.params.section as string;
const section = musicTaxonomy.find((s) => s.id === sectionId);

if (!section) {
  return new Response("Not found", { status: 404 });
}

// Load articles
let baseArticles: any[] = [];
try {
  baseArticles = await getCollectionEntries("knowledge-en");
} catch (e) {
  loggers.pages.warn("taxonomy section: collection load issue", {
    error: (e as any)?.message || e,
  });
}

// Process articles
const articlesWithReadingTime = baseArticles.map((article: any) => {
  const createdAt = normalizeDate(article?.data?.createdAt);
  const updatedAt = normalizeDate(article?.data?.updatedAt);
  const readingTime =
    article.data.readingTime || calculateReadingTime(article.body || "");
  return {
    ...article,
    data: { ...article.data, createdAt, updatedAt, readingTime },
  };
});

// Get subsection IDs for this section
const subsectionIds = section.subsections.map((s) => s.id);

// Filter articles for this section
const sectionArticles = sortEntries(
  articlesWithReadingTime.filter((a: any) =>
    subsectionIds.includes(a.data?.taxonomySubsection)
  )
);

// Build subsection data with article counts and groups
const subsectionsData = section.subsections.map((subsection: TaxonomySubsection) => {
  const articles = sortEntries(
    articlesWithReadingTime.filter(
      (a: any) => a.data?.taxonomySubsection === subsection.id
    )
  );

  // Build groups with article counts
  const groupsWithArticles = (subsection.groups || []).map((group) => {
    const groupArticles = sortEntries(
      articlesWithReadingTime.filter(
        (a: any) =>
          a.data?.taxonomySubsection === subsection.id &&
          a.data?.taxonomyGroup === group.id
      )
    );
    return {
      ...group,
      anchorId: `${subsection.id}--${group.id}`,
      articleCount: groupArticles.length,
    };
  });

  return {
    ...subsection,
    articleCount: articles.length,
    articles,
    groupsWithArticles,
  };
});

// Build flat list of jump targets (groups with articles, or subsections without groups)
interface JumpTarget {
  anchorId: string;
  title: string;
  articleCount: number;
  parentTitle?: string;
}

const jumpTargets: JumpTarget[] = subsectionsData.flatMap((subsection) => {
  const groupsWithContent = subsection.groupsWithArticles.filter(
    (g) => g.articleCount > 0
  );

  if (groupsWithContent.length > 0) {
    // Has groups with articles → list groups
    return groupsWithContent.map((group) => ({
      anchorId: group.anchorId,
      title: group.title,
      articleCount: group.articleCount,
      parentTitle: subsection.title,
    }));
  } else if (subsection.articleCount > 0) {
    // No groups but has articles → list subsection
    return [
      {
        anchorId: subsection.id,
        title: subsection.title,
        articleCount: subsection.articleCount,
      },
    ];
  }
  return [];
});

// SEO
const currentUrl = resolvePageUrl(Astro.site, `/taxonomy/${sectionId}`);
const baseUrl = resolveBaseUrl(Astro.site);
const seoDescription = getTaxonomySectionSeoDescription({
  sectionId,
  sectionTitle: section.title,
  sectionDescription: section.description,
});
const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: section.title, url: currentUrl },
];
const articleItemListId = `${currentUrl}#article-itemlist`;
let earliestCreated: Date | null = null;
let latestUpdated: Date | null = null;

for (const article of sectionArticles) {
  const createdAt = normalizeDate(article.data.createdAt);
  const updatedAt = normalizeDate(article.data.updatedAt);
  if (
    createdAt &&
    (!earliestCreated || createdAt.getTime() < earliestCreated.getTime())
  ) {
    earliestCreated = createdAt;
  }
  if (updatedAt && (!latestUpdated || updatedAt.getTime() > latestUpdated.getTime())) {
    latestUpdated = updatedAt;
  }
}

const sectionDates = derivePublishModified(earliestCreated, latestUpdated);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: seoBreadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.name,
    item: crumb.url,
  })),
};
const itemListSchema = buildKnowledgeArticlesItemList({
  articles: sectionArticles.map((article: any) => ({
    slug: "slug" in article ? article.slug : article.id,
    data: {
      title: article.data.title,
      description: article.data.description,
      createdAt: article.data.createdAt,
      updatedAt: article.data.updatedAt,
      keywords: article.data.keywords,
      image: article.data.image,
    },
  })),
  baseUrl,
  lang: "en",
  listName: `${section.title} articles`,
  itemListId: articleItemListId,
});
const collectionPageSchema = buildCollectionPageSchema({
  url: currentUrl,
  name: section.title,
  description: seoDescription,
  lang: "en",
  image: section.image ? `${baseUrl}${section.image}` : undefined,
  mainEntityId: articleItemListId,
});

const pageSeo = buildPageSeo({
  title: getTaxonomySectionSeoTitle(sectionId, section.title),
  description: seoDescription,
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: [collectionPageSchema, breadcrumbSchema, itemListSchema].filter(
    Boolean
  ) as StructuredData[],
  enrichedParts: [section.title, section.description || ""],
  fallbackKeywords: [],
  keywordLimit: 28,
  maxDescription: 160,
  image: section.image,
  imageAlt: `${section.title} - Melody Mind`,
  publishDate: sectionDates.publishDate || undefined,
  modifiedDate: sectionDates.modifiedDate || undefined,
  index: true,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell className="page-shell--aurora page-shell--grid">
    <div class="taxonomy-section">
      <header class="taxonomy-section__header">
        <div class="taxonomy-section__hero">
          {
            section.image && (
              <div class="taxonomy-section__media">
                <Image
                  src={section.image}
                  alt={section.title}
                  loading="eager"
                  class="taxonomy-section__image"
                  width="1200"
                  height="400"
                />
                <div class="taxonomy-section__overlay" aria-hidden="true" />
              </div>
            )
          }
          <div class="taxonomy-section__intro">
            <Headline level="h1" textSize="2xl" className="taxonomy-section__title">
              {section.title}
            </Headline>
            {
              section.description && (
                <Paragraph textSize="base" className="taxonomy-section__description">
                  {section.description}
                </Paragraph>
              )
            }
            <div class="taxonomy-section__stats">
              <span class="taxonomy-section__stat">
                {subsectionsData.length} topics
              </span>
              <span class="taxonomy-section__stat">
                {sectionArticles.length} articles
              </span>
            </div>

            {jumpTargets.length >= 1 && <TaxonomyJumpNav targets={jumpTargets} />}
          </div>
        </div>
      </header>

      <section class="taxonomy-section__content">
        {
          subsectionsData.map((subsection) => (
            <div id={subsection.id} class="taxonomy-section__subsection">
              <div class="taxonomy-section__subsection-header">
                <div class="taxonomy-section__subsection-info">
                  <Headline
                    level="h2"
                    textSize="lg"
                    className="taxonomy-section__subsection-title"
                  >
                    {subsection.title}
                  </Headline>
                  {subsection.description && (
                    <Paragraph
                      textSize="sm"
                      className="taxonomy-section__subsection-description"
                    >
                      {subsection.description}
                    </Paragraph>
                  )}
                  <span class="taxonomy-section__subsection-count">
                    {subsection.articleCount}{" "}
                    {subsection.articleCount === 1 ? "article" : "articles"}
                  </span>
                </div>
              </div>

              {subsection.groups && subsection.groups.length > 0 && (
                <div class="taxonomy-section__groups">
                  {subsection.groups.map((group) => {
                    const groupArticles = sortEntries(
                      articlesWithReadingTime.filter(
                        (a: any) =>
                          a.data?.taxonomySubsection === subsection.id &&
                          a.data?.taxonomyGroup === group.id
                      )
                    );

                    return (
                      <div
                        id={`${subsection.id}--${group.id}`}
                        class="taxonomy-section__group"
                      >
                        <div class="taxonomy-section__group-header">
                          <div class="taxonomy-section__group-info">
                            <Headline
                              level="h3"
                              textSize="base"
                              className="taxonomy-section__group-title"
                            >
                              {group.title}
                            </Headline>
                            {group.description && (
                              <Paragraph
                                textSize="sm"
                                className="taxonomy-section__group-description"
                              >
                                {group.description}
                              </Paragraph>
                            )}
                            <span class="taxonomy-section__group-count">
                              {groupArticles.length}{" "}
                              {groupArticles.length === 1 ? "article" : "articles"}
                            </span>
                          </div>
                        </div>
                        {groupArticles.length > 0 ? (
                          <ul class="taxonomy-section__articles">
                            {groupArticles.map((article: any, index: number) => {
                              const articleSlug =
                                "slug" in article ? article.slug : article.id;
                              return (
                                <li>
                                  <KnowledgeCard
                                    title={article.data.title}
                                    description={article.data.description}
                                    image={article.data.image}
                                    createdAt={article.data.createdAt || new Date()}
                                    slug={articleSlug}
                                    readingTime={article.data.readingTime}
                                    articleUrl={`/knowledge/${articleSlug}`}
                                    index={index}
                                  />
                                </li>
                              );
                            })}
                          </ul>
                        ) : (
                          <EmptyState
                            className="taxonomy-section__empty"
                            description="No articles yet."
                          />
                        )}
                      </div>
                    );
                  })}
                </div>
              )}

              {(!subsection.groups || subsection.groups.length === 0) && (
                <>
                  {subsection.articles.length > 0 ? (
                    <ul class="taxonomy-section__articles">
                      {subsection.articles.map((article: any, index: number) => {
                        const articleSlug = "slug" in article ? article.slug : article.id;
                        return (
                          <li>
                            <KnowledgeCard
                              title={article.data.title}
                              description={article.data.description}
                              image={article.data.image}
                              createdAt={article.data.createdAt || new Date()}
                              slug={articleSlug}
                              readingTime={article.data.readingTime}
                              articleUrl={`/knowledge/${articleSlug}`}
                              index={index}
                            />
                          </li>
                        );
                      })}
                    </ul>
                  ) : (
                    <EmptyState
                      className="taxonomy-section__empty"
                      description="No articles in this topic yet."
                    />
                  )}
                </>
              )}
            </div>
          ))
        }
      </section>
    </div>
  </PageShell>

  <BackToTop />
</Layout>

<style>
  .taxonomy-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .taxonomy-section__header {
    padding-block-end: 2rem;
    border-block-end: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
  }

  .taxonomy-section__hero {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (width >= 768px) {
    .taxonomy-section__hero {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .taxonomy-section__media {
    position: relative;
    inline-size: 100%;
    aspect-ratio: 3 / 1;
    overflow: hidden;
    border: 1px solid var(--border-default);
    border-radius: 1rem;
  }

  @media (width >= 768px) {
    .taxonomy-section__media {
      inline-size: 40%;
      aspect-ratio: 4 / 3;
    }
  }

  .taxonomy-section__image {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .taxonomy-section__overlay {
    position: absolute;
    inset: 0;
  }

  .taxonomy-section__intro {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.75rem;
  }

  .taxonomy-section__title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
  }

  @media (width >= 768px) {
    .taxonomy-section__title {
      font-size: 2.5rem;
    }
  }

  .taxonomy-section__description {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .taxonomy-section__stats {
    display: flex;
    gap: 1rem;
    margin-block-start: 0.5rem;
  }

  .taxonomy-section__stat {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.9rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: 999px;
  }

  .taxonomy-section__content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .taxonomy-section__subsection {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .taxonomy-section__subsection-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (width >= 768px) {
    .taxonomy-section__subsection-header {
      flex-direction: row;
      gap: 1.5rem;
      align-items: flex-start;
    }
  }

  .taxonomy-section__subsection-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.5rem;
  }

  .taxonomy-section__subsection-title {
    padding-block-end: 0.5rem;
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    border-block-end: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
  }

  .taxonomy-section__subsection-description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .taxonomy-section__subsection-count {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent-primary);
  }

  .taxonomy-section__subsection-image {
    flex-shrink: 0;
    inline-size: 100%;
    max-inline-size: 300px;
    overflow: hidden;
    border: 1px solid var(--border-default);
    border-radius: 1rem;
  }

  .taxonomy-section__subsection-img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .taxonomy-section__groups {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .taxonomy-section__group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: 1rem;
  }

  .taxonomy-section__group-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (width >= 640px) {
    .taxonomy-section__group-header {
      flex-direction: row;
      gap: 1rem;
      align-items: flex-start;
    }
  }

  .taxonomy-section__group-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.35rem;
  }

  .taxonomy-section__group-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .taxonomy-section__group-description {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .taxonomy-section__group-count {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent-primary);
  }

  .taxonomy-section__group-image {
    flex-shrink: 0;
    inline-size: 100%;
    max-inline-size: 180px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: 0.75rem;
  }

  .taxonomy-section__group-img {
    display: block;
    inline-size: 100%;
    block-size: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .taxonomy-section__articles {
    display: grid;
    gap: 1.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (width >= 640px) {
    .taxonomy-section__articles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1024px) {
    .taxonomy-section__articles {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .taxonomy-section__empty {
    padding: var(--spacing-lg);
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: var(--radius-lg);
  }

  /* Scroll margin for anchored sections */
  .taxonomy-section__subsection,
  .taxonomy-section__group {
    scroll-margin-block-start: 80px;
  }
</style>
