---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import LegalDocumentSection from "../components/LegalDocumentSection.astro";
import StaticPageHero from "../components/StaticPageHero.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

const title = "Cookie & Storage Policy";
const description =
  "Details about cookies and local storage used on Melody Mind Knowledge, including analytics consent preferences.";
const currentUrl = resolvePageUrl(Astro.site, "/cookies");
const lastUpdated = "06 February 2026";

const breadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: title, url: currentUrl },
];

const highlights = [
  {
    value: "Consent-based",
    label: "Analytics only turns on after you explicitly opt in.",
  },
  {
    value: "Local-first",
    label: "Most entries are browser storage keys for reading features.",
  },
  {
    value: "Always manageable",
    label: "You can update consent or clear storage at any time.",
  },
] as const;

const policySections = [
  {
    icon: "shield",
    title: "Do we use cookies?",
    body: [
      "We currently do not place non-essential tracking cookies ourselves. For analytics, we use Fathom only after you give explicit consent through the cookie banner.",
    ],
  },
  {
    icon: "shield",
    title: "Analytics consent and legal basis",
    body: [
      "Non-essential analytics turns on only after you explicitly opt in through the cookie banner. Legal basis: Art. 6(1)(a) GDPR (consent) and the ePrivacy Directive.",
      "If your browser sends a Do Not Track (DNT) signal, analytics remains disabled.",
    ],
  },
  {
    icon: "settings",
    title: "How to change or withdraw consent",
    body: [
      "Open <strong>Cookie settings</strong> in the footer at any time to review or update your choice. You can also clear site storage in your browser settings.",
    ],
  },
  {
    icon: "file-text",
    title: "Related privacy information",
    body: [
      'For full details about personal data processing and your rights, see our <a href="/privacy">Privacy Policy</a>.',
    ],
  },
  {
    icon: "refresh-ccw",
    title: "Policy updates",
    body: [
      "We update this page when storage technologies, analytics settings, or legal requirements change.",
      `Last updated: ${lastUpdated}.`,
    ],
  },
] as const;

const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs,
  structuredData: [] as StructuredData[],
  enrichedParts: [title, description],
  fallbackKeywords: ["cookies", "localStorage", "privacy", "consent", "fathom"],
  keywordLimit: 24,
  maxDescription: 160,
  image: "/knowledge.png",
  imageAlt: "Cookie Policy",
  modifiedDate: new Date(lastUpdated),
  index: false,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <div class="cookies-page">
      <StaticPageHero
        eyebrow="Privacy"
        title="Cookie & Storage Policy"
        lead="This page explains which cookies and browser storage technologies we use, why we use them, and how you can manage your preferences."
        {highlights}
        highlightsLabel="Key cookie policy points"
      />

      <div class="cookies-page__content-grid">
        {
          policySections.map((section) => (
            <LegalDocumentSection
              icon={section.icon}
              title={section.title}
              body={section.body}
            />
          ))
        }

        <LegalDocumentSection
          icon="book-open"
          title="Local storage entries we use"
          class="cookies-page__section--table"
        >
          <div class="cookies-page__table-wrap">
            <table class="cookies-page__table">
              <caption class="cookies-page__sr-only">
                Browser storage keys used by Melody Mind Knowledge
              </caption>
              <thead>
                <tr>
                  <th scope="col">Key</th>
                  <th scope="col">Purpose</th>
                  <th scope="col">Type</th>
                  <th scope="col">Retention</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>cookie_consent</code></td>
                  <td
                    >Stores your consent preferences for essential and analytics
                    processing.</td
                  >
                  <td>LocalStorage</td>
                  <td>Until you change or delete it.</td>
                </tr>
                <tr>
                  <td><code>mm_recent_reads</code></td>
                  <td>Shows your recently opened articles on the home page.</td>
                  <td>LocalStorage</td>
                  <td>Until it is replaced or cleared by you.</td>
                </tr>
                <tr>
                  <td><code>mm_read_progress</code></td>
                  <td>Stores your reading progress for each article.</td>
                  <td>LocalStorage</td>
                  <td>Until it is replaced or cleared by you.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </LegalDocumentSection>
      </div>
    </div>
  </PageShell>
</Layout>

<style>
  .cookies-page {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .cookies-page__content-grid {
    display: grid;
    gap: var(--section-gap);
  }

  .cookies-page__table-wrap {
    padding: var(--spacing-sm);
    overflow-inline: auto;
    background: color-mix(in srgb, var(--surface-1) 82%, transparent);
    border: 1px solid color-mix(in srgb, var(--border-default) 68%, transparent);
    border-radius: var(--card-radius);
  }

  .cookies-page__table {
    inline-size: 100%;
    min-inline-size: min(var(--measure-standard), 100%);
    border-collapse: collapse;
  }

  .cookies-page__table th,
  .cookies-page__table td {
    padding: var(--spacing-md) var(--spacing-sm);
    vertical-align: top;
    color: var(--text-secondary);
    text-align: start;
  }

  .cookies-page__table th {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .cookies-page__table code {
    font-family: var(--font-mono);
    font-size: var(--font-size-base);
    color: var(--link-default);
  }

  .cookies-page__sr-only {
    position: var(--sr-only);
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    padding: var(--sr-only-padding);
    margin: var(--sr-only-margin);
    overflow: var(--sr-only-overflow);
    white-space: var(--sr-only-white-space);
    border: var(--sr-only-border);
    clip-path: inset(50%);
  }

  @media (width >= 720px) {
    .cookies-page {
      padding: var(--spacing-xl);
    }

    .cookies-page__content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1100px) {
    .cookies-page__content-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--spacing-lg);
    }

    .cookies-page__section--table {
      grid-column: 1 / -1;
    }
  }
</style>
