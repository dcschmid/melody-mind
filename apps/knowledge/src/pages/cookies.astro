---
import Layout from "@layouts/Layout.astro";
import LegalDocumentSection from "@shared-ui/components/layout/LegalDocumentSection.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import DataTable from "@shared-ui/components/policies/DataTable.astro";
import StaticPageHero from "@shared-ui/components/layout/StaticPageHero.astro";
import { buildLegalPageSeo } from "../utils/legal/buildLegalPageSeo";

const title = "Cookie & Storage Policy";
const description =
  "Details about cookies and local storage used on Melody Mind Knowledge for core site features.";
const lastUpdated = "06 February 2026";

const highlights = [
  {
    value: "Storage only",
    label: "We currently rely on browser storage for site features, not analytics.",
  },
  {
    value: "Local-first",
    label: "Most entries are browser storage keys for reading features.",
  },
  {
    value: "Always manageable",
    label: "You can clear browser storage at any time in your browser settings.",
  },
] as const;

const policySections = [
  {
    icon: "shield",
    title: "Do we use cookies?",
    body: [
      "We currently do not rely on a cookie-based analytics or consent system. Most client-side persistence on this site uses local storage for functional features.",
    ],
  },
  {
    icon: "settings",
    title: "How we use browser storage",
    body: [
      "We use local storage to remember feature-level preferences and site state, such as reading progress and recently opened content.",
      "You can clear this storage at any time through your browser settings.",
    ],
  },
  {
    icon: "file-text",
    title: "Related privacy information",
    body: [
      'For full details about personal data processing and your rights, see our <a href="/privacy">Privacy Policy</a>.',
    ],
  },
  {
    icon: "refresh-ccw",
    title: "Policy updates",
    body: [
      "We update this page when storage technologies or legal requirements change.",
      `Last updated: ${lastUpdated}.`,
    ],
  },
] as const;

const storageKeys = [
  {
    keyName: "mm_recent_reads",
    purpose: "Shows your recently opened articles on the home page.",
    storageType: "LocalStorage",
    retention: "Until it is replaced or cleared by you.",
  },
  {
    keyName: "mm_read_progress",
    purpose: "Stores your reading progress for each article.",
    storageType: "LocalStorage",
    retention: "Until it is replaced or cleared by you.",
  },
] as const;

const storageKeyColumns = [
  { key: "keyName", label: "Key", renderAsCode: true },
  { key: "purpose", label: "Purpose" },
  { key: "storageType", label: "Type" },
  { key: "retention", label: "Retention" },
] as const;

const pageSeo = buildLegalPageSeo({
  site: Astro.site,
  path: "/cookies",
  title,
  description,
  imageAlt: "Cookie Policy",
  fallbackKeywords: ["cookies", "localStorage", "privacy", "storage policy"],
  maxDescription: 160,
  modifiedDate: new Date(lastUpdated),
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <div class="cookies-page">
      <StaticPageHero
        eyebrow="Privacy"
        title="Cookie & Storage Policy"
        lead="This page explains which browser storage technologies we use, why we use them, and how you can manage them."
        {highlights}
        highlightsLabel="Key cookie policy points"
      />

      <div class="cookies-page__content-grid">
        {
          policySections.map((section) => (
            <LegalDocumentSection
              icon={section.icon}
              title={section.title}
              body={section.body}
            />
          ))
        }

        <LegalDocumentSection
          icon="book-open"
          title="Local storage entries we use"
          class="cookies-page__section--table"
        >
          <DataTable
            caption="Browser storage keys used by Melody Mind Knowledge"
            columns={storageKeyColumns}
            rows={storageKeys}
          />
        </LegalDocumentSection>
      </div>
    </div>
  </PageShell>
</Layout>

<style>
  .cookies-page {
    position: relative;
    display: grid;
    gap: var(--spacing-2xl);
  }

  .cookies-page__content-grid {
    position: relative;
    display: grid;
    gap: var(--section-gap);
    padding-block-start: var(--spacing-xl);
    border-block-start: 1px solid var(--surface-border-soft);
  }

  .cookies-page__content-grid::before {
    position: absolute;
    top: 0;
    left: 0;
    width: min(8rem, 22%);
    height: 1px;
    content: "";
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-primary) 52%, transparent),
      transparent
    );
  }

  @media (width >= 720px) {
    .cookies-page {
      padding: var(--spacing-xl);
    }

    .cookies-page__content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1100px) {
    .cookies-page__content-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--spacing-lg);
    }

    .cookies-page__section--table {
      grid-column: 1 / -1;
    }
  }
</style>
