---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import Prose from "@shared-ui/components/typography/Prose.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import StaticPageHero from "../components/StaticPageHero.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

export const prerender = true;

const canonical = resolvePageUrl(Astro.site, "/ai-content");

const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: "AI Content Policy", url: canonical },
];

const structuredDataExtra = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "AI Content Policy",
    name: "AI Content Policy",
    description:
      "How we use AI tools at Melody Mind and ensure content quality, transparency, and compliance with copyright law.",
    url: canonical,
    author: { "@type": "Organization", name: "Melody Mind" },
    publisher: {
      "@type": "Organization",
      name: "Melody Mind",
      logo: {
        "@type": "ImageObject",
        url: "https://melody-mind.de/melody-mind.png",
      },
    },
    datePublished: new Date().toISOString(),
    dateModified: new Date().toISOString(),
    mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
    inLanguage: "en",
    articleSection: "About",
  },
];

const highlights = [
  { value: "Human-reviewed", label: "Every AI-assisted piece is checked by editors" },
  { value: "Clearly labeled", label: "AI-supported content is marked transparently" },
  {
    value: "Legally aligned",
    label: "Processes follow copyright and EU transparency rules",
  },
] as const;

const policySections = [
  {
    icon: "sparkles",
    title: "What AI Tools We Use",
    sectionClass: "ai-policy__section--tools",
    body: [
      "At Melody Mind, we use AI tools to support content creation, research, and optimization. The main tools we use include:",
    ],
    items: [
      "<strong>ChatGPT (OpenAI)</strong> - Content drafting, research support, and idea development",
      "<strong>Claude (Anthropic)</strong> - Technical writing, code explanation, and content refinement",
      "<strong>Other AI tools</strong> - Image generation, translation, and SEO support",
    ],
  },
  {
    icon: "shield",
    title: "Human Oversight & Quality Assurance",
    sectionClass: "ai-policy__section--oversight",
    body: [
      "AI-generated content is never published without human review. Our editorial process includes:",
      "The AI-Generated badge shown on some articles indicates that AI tools contributed to the creation process. It is there to make that use clear and transparent.",
    ],
    items: [
      "Fact-checking all information against reliable sources",
      "Ensuring historical and musical accuracy",
      "Reviewing for clarity, tone, and style consistency",
      "Verifying compliance with copyright laws",
      "Adding human insights and expertise",
    ],
  },
  {
    icon: "file-text",
    title: "Copyright & Legal Compliance",
    sectionClass: "ai-policy__section--copyright",
    body: [
      "We take copyright law seriously. Our AI content practices align with:",
      "AI does not replace human judgment or creativity. It is a tool that helps us work more efficiently, while our editorial review maintains quality, accuracy, and originality.",
    ],
    items: [
      "<strong>German Copyright Act (UrhG)</strong> - We respect intellectual property rights and do not intentionally create content that infringes existing copyrights",
      "<strong>EU AI Act transparency requirements</strong> - AI-generated content is clearly labeled in line with EU rules",
      "<strong>Transparency principle</strong> - Users can identify AI-generated content and understand how we use AI tools",
    ],
  },
] as const;

const faqItems = [
  {
    question: "Does AI write all your content?",
    answer:
      "No. AI assists with drafting, research, and optimization, but human editors review, refine, and verify all content before publication.",
  },
  {
    question: "Is AI-generated content reliable?",
    answer:
      "Yes. Human oversight helps ensure that AI-generated content meets our standards for accuracy, clarity, and musical expertise. We fact-check information and verify sources.",
  },
  {
    question: "Can I trust AI-generated articles?",
    answer:
      "Yes. Our editorial process ensures that all content, whether AI-assisted or not, goes through review for accuracy and quality.",
  },
  {
    question: "What about images and media?",
    answer:
      "We use AI tools for image generation when appropriate, while following copyright and licensing requirements. AI-generated images are also clearly labeled.",
  },
] as const;

const principles = [
  "Transparency about where AI supports our workflow",
  "Human review before anything is published",
  "Source checks for factual, historical, and musical claims",
  "Clear legal and copyright boundaries",
] as const;

const pageSeo = buildPageSeo({
  title: "AI Content Policy | Melody Mind",
  description:
    "How we use AI tools at Melody Mind and ensure content quality, transparency, and compliance with copyright law.",
  url: canonical,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: structuredDataExtra,
  enrichedParts: [
    "AI Content Policy",
    "How we use AI tools",
    "Content quality",
    "Transparency",
  ],
  fallbackKeywords: [
    "AI",
    "artificial intelligence",
    "content policy",
    "transparency",
    "copyright",
    "UrhG",
    "ChatGPT",
    "Claude",
  ],
  keywordLimit: 24,
  maxDescription: 155,
  image: "/knowledge.png",
  imageAlt: "AI Content Policy",
  publishDate: new Date(),
  modifiedDate: new Date(),
  index: true,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide page-shell__container--spacious">
    <div class="ai-policy">
      <div class="ai-policy__container">
        <StaticPageHero
          class="ai-policy__hero"
          badge="AI Content Policy"
          title="Transparency About AI-Generated Content"
          titleTextSize="xl"
          lead="We use AI tools to enhance our content creation process while maintaining quality, accuracy, and legal compliance."
          {highlights}
          highlightsLabel="Key policy points"
        />

        <div class="ai-policy__content-grid">
          {
            policySections.map((section) => (
              <section class={`legal-panel ai-policy__section ${section.sectionClass}`}>
                <div class="ai-policy__section-header">
                  <Icon name={section.icon} class="ai-policy__icon" aria-hidden="true" />
                  <Headline level="h2" textSize="lg" textAlign="left">
                    {section.title}
                  </Headline>
                </div>
                <Prose className="ai-policy__prose">
                  <p set:html={section.body[0]} />
                  <ul>
                    {section.items.map((item) => (
                      <li set:html={item} />
                    ))}
                  </ul>
                  {section.body[1] && <p set:html={section.body[1]} />}
                </Prose>
              </section>
            ))
          }

          <section class="legal-panel ai-policy__section ai-policy__section--principles">
            <div class="ai-policy__section-header">
              <Icon name="shield" class="ai-policy__icon" aria-hidden="true" />
              <Headline level="h2" textSize="lg" textAlign="left">
                Core Principles
              </Headline>
            </div>
            <ul class="ai-policy__principles">
              {
                principles.map((principle) => (
                  <li class="ai-policy__principle">{principle}</li>
                ))
              }
            </ul>
          </section>

          <section class="legal-panel ai-policy__section ai-policy__section--contact">
            <div class="ai-policy__section-header">
              <Icon name="mail" class="ai-policy__icon" aria-hidden="true" />
              <Headline level="h2" textSize="lg" textAlign="left">
                Questions or Feedback?
              </Headline>
            </div>
            <Prose>
              <p>
                If you have questions about our AI content policy or would like to share
                feedback, please contact us. We are committed to transparency and ongoing
                improvement.
              </p>
            </Prose>
          </section>

          <section class="legal-panel ai-policy__section ai-policy__section--faq">
            <div class="ai-policy__section-header">
              <Icon name="help-circle" class="ai-policy__icon" aria-hidden="true" />
              <Headline level="h2" textSize="lg" textAlign="left">
                Frequently Asked Questions
              </Headline>
            </div>
            <div class="ai-policy__faq-list">
              {
                faqItems.map((item) => (
                  <article class="ai-policy__faq-item">
                    <h3 class="ai-policy__faq-question">{item.question}</h3>
                    <Paragraph
                      textSize="base"
                      textAlign="left"
                      className="ai-policy__faq-answer"
                    >
                      {item.answer}
                    </Paragraph>
                  </article>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </div>
  </PageShell>
</Layout>

<style>
  .ai-policy__container {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .ai-policy__hero {
    overflow: hidden;
  }

  .ai-policy__content-grid {
    display: grid;
    gap: var(--section-gap);
  }

  .ai-policy__section {
    position: relative;
    display: grid;
    gap: var(--spacing-xl);
    min-width: 0;
    padding: clamp(var(--spacing-xl), 2.5vw, var(--spacing-2xl));
    overflow: hidden;
    border: var(--card-border-width) solid
      color-mix(in srgb, var(--card-border-color) 82%, transparent);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-base);
  }

  .ai-policy__section::after {
    position: absolute;
    inset: var(--spacing-xs);
    pointer-events: none;
    content: "";
    border: 1px solid color-mix(in srgb, var(--border-default) 34%, transparent);
    border-radius: calc(var(--card-radius) - var(--spacing-xs));
  }

  .ai-policy__section--contact {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 96%, transparent),
        color-mix(in srgb, var(--surface-2) 92%, transparent)
      ),
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--accent-primary) 11%, transparent),
        transparent 38%
      );
  }

  .ai-policy__section--principles {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--accent-primary) 12%, var(--surface-1)),
      color-mix(in srgb, var(--surface-1) 98%, transparent)
    );
  }

  .ai-policy__section--faq {
    grid-column: 1 / -1;
  }

  .ai-policy__section-header {
    display: flex;
    gap: var(--spacing-md);
    align-items: center;
    padding-block-end: var(--spacing-base);
    border-block-end: 1px solid color-mix(in srgb, var(--border-default) 72%, transparent);
  }

  .ai-policy__icon {
    flex-shrink: 0;
    inline-size: var(--spacing-xl);
    block-size: var(--spacing-xl);
    margin-block-start: 0;
    color: var(--accent-primary);
  }

  .ai-policy__prose {
    max-inline-size: none;
  }

  .ai-policy__faq-list {
    display: grid;
    gap: var(--spacing-base);
  }

  .ai-policy__faq-item {
    padding: var(--spacing-base);
    background: color-mix(in srgb, var(--surface-1) 88%, transparent);
    border: 1px solid color-mix(in srgb, var(--border-default) 68%, transparent);
    border-radius: var(--card-radius);
  }

  .ai-policy__faq-question {
    margin: 0 0 var(--spacing-sm);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
  }

  .ai-policy__faq-answer {
    margin: 0;
  }

  .ai-policy__principles {
    display: grid;
    gap: var(--spacing-base);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .ai-policy__principle {
    position: relative;
    padding-inline-start: calc(var(--spacing-base) + var(--spacing-sm));
    font-size: var(--font-size-base);
    color: var(--text-secondary);
  }

  .ai-policy__principle::before {
    position: absolute;
    inset-block-start: var(--spacing-sm);
    inset-inline-start: 0;
    inline-size: var(--spacing-sm);
    block-size: var(--spacing-sm);
    content: "";
    background: var(--accent-primary);
    border-radius: var(--radius-full);
    box-shadow: 0 0 0 var(--spacing-sm)
      color-mix(in srgb, var(--accent-primary) 14%, transparent);
  }

  @media (width >= 720px) {
    .ai-policy {
      padding: var(--spacing-xl);
    }

    .ai-policy__section {
      padding: clamp(var(--spacing-xl), 2.5vw, var(--spacing-2xl));
    }

    .ai-policy__content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-policy__faq-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (width >= 1100px) {
    .ai-policy__content-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .ai-policy__prose {
      font-size: var(--font-size-base);
    }

    .ai-policy__prose p:first-child {
      margin-block-start: 0;
    }

    .ai-policy__prose p:last-child {
      margin-block-end: 0;
    }

    .ai-policy__prose ul {
      columns: 2;
      column-gap: calc(var(--spacing-xl) + var(--spacing-sm));
    }

    .ai-policy__prose li {
      break-inside: avoid;
    }

    .ai-policy__section--tools {
      grid-column: 1 / -1;
    }

    .ai-policy__section--oversight {
      grid-column: 1 / -1;
    }

    .ai-policy__section--principles {
      grid-column: 1 / -1;
    }

    .ai-policy__section--copyright {
      grid-column: 1 / -1;
    }

    .ai-policy__section--contact {
      grid-column: 1 / -1;
      align-self: stretch;
    }

    .ai-policy__section--faq .ai-policy__section-header {
      max-inline-size: 38rem;
    }
  }
</style>
