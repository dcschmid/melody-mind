---
import Layout from "@layouts/Layout.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import NotFoundContent from "@shared-ui/components/layout/NotFoundContent.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

export const prerender = true;

const canonical = resolvePageUrl(Astro.site, "/404");

const pageSeo = buildPageSeo({
  title: "Page not found",
  description:
    "The page you're looking for doesn't exist. Browse articles, taxonomy, or search to find what you need.",
  url: canonical,
  brandSuffix: " - MelodyMind",
  index: false,
  follow: false,
});
---

<Layout {pageSeo}>
  <PageShell>
    <main>
      <NotFoundContent
        title="Page not found"
        description="The article you're looking for isn't here. It may have moved, or the link might be wrong. Explore our articles or search for what you need."
        buttons={[
          { href: "/knowledge/", label: "Explore articles", variant: "primary" },
          { href: "/taxonomy/", label: "Browse topics", variant: "secondary" },
          { href: "/", label: "Go home", variant: "ghost" },
        ]}
      />
    </main>
  </PageShell>
</Layout>
