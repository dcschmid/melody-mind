---
/**
 * Knowledge Index Page - Professional Dark Mode with WCAG AAA
 */
import Layout from "@layouts/Layout.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import { buildPageSeo, type StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import {
  buildCollectionPageSchema,
  buildKnowledgeArticlesItemList,
} from "@shared-utils/utils/seo/seoSchema";
import { calculateReadingTime } from "@shared-utils/utils/readingTime";
import BackToTop from "@shared-ui/components/navigation/BackToTop.astro";
import { sortEntries } from "@shared-utils/utils/content/sortEntries";
import { getCollectionEntries } from "@shared-utils/utils/content/getCollectionEntries";
import {
  normalizeDate,
  derivePublishModified,
} from "@shared-utils/utils/content/dateUtils";
import { resolveBaseUrl, resolvePageUrl } from "@shared-utils/utils/siteUrls";
import { musicTaxonomy } from "../data/musicTaxonomy";
import { countArticlesPerSubsection } from "../utils/taxonomy/taxonomyUtils";
import { Image } from "astro:assets";
import { loggers } from "@shared-utils/utils/logging";

export const prerender = true;

const lang = "en";

// Load English knowledge collection
let baseArticles: any[] = [];
try {
  baseArticles = await getCollectionEntries("knowledge-en");
} catch (e) {
  loggers.pages.warn("knowledge index: collection load issue", {
    error: (e as any)?.message || e,
  });
}

// Process articles
const articlesWithReadingTime = baseArticles.map((article: any) => {
  const createdAtRaw = article?.data?.createdAt;
  const updatedAtRaw = article?.data?.updatedAt;
  const createdAt = normalizeDate(createdAtRaw);
  const updatedAt = normalizeDate(updatedAtRaw);
  const readingTime =
    article.data.readingTime || calculateReadingTime(article.body || "");
  return {
    ...article,
    data: { ...article.data, createdAt, updatedAt, readingTime },
  };
});

const sortedArticles = sortEntries(articlesWithReadingTime);
const recentReadImageMap = Object.fromEntries(
  sortedArticles.map((article: any) => {
    const articleSlug =
      typeof article?.slug === "string" && article.slug
        ? article.slug.replace(/^\/+/, "")
        : typeof article?.id === "string"
          ? article.id.replace(/^\/+/, "")
          : "";
    const articleImage =
      typeof article?.data?.image === "string" ? article.data.image.trim() : "";

    return [articleSlug, articleImage];
  })
);

// SEO
const title = "Music Knowledge";
const description =
  "Curated genre deep dives from roots to today's sounds, with stories, listening cues, and playlists that help you explore faster and hear music with more context.";
const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, "/");

let earliestCreated: Date | null = null;
let latestUpdated: Date | null = null;
for (const a of articlesWithReadingTime) {
  const c = normalizeDate(a.data.createdAt);
  if (c && (!earliestCreated || c.getTime() < earliestCreated.getTime()))
    earliestCreated = c;
  const u = normalizeDate(a.data.updatedAt);
  if (u && (!latestUpdated || u.getTime() > latestUpdated.getTime())) latestUpdated = u;
}
const collectionDates = derivePublishModified(earliestCreated, latestUpdated);
const articleCollectionId = `${currentUrl}#knowledge-itemlist`;

const articleCollectionSchema = buildKnowledgeArticlesItemList({
  articles: sortedArticles.map((a: any) => ({
    slug: "slug" in a ? a.slug : a.id,
    data: {
      title: a.data.title,
      description: a.data.description,
      createdAt: a.data.createdAt,
      updatedAt: a.data.updatedAt,
      keywords: a.data.keywords,
      image: a.data.image,
    },
  })),
  baseUrl,
  lang,
  listName: "Knowledge Articles",
  itemListId: articleCollectionId,
});
const collectionPageSchema = buildCollectionPageSchema({
  url: currentUrl,
  name: title,
  description,
  lang,
  image: `${baseUrl}/melody-mind.jpg`,
  mainEntityId: articleCollectionId,
});

const keywordPool = sortedArticles.flatMap((article) => article.data.keywords || []);
const metaKeywords = keywordPool.slice(0, 10).join(", ");

// Count articles per taxonomy subsection
const subsectionArticleCounts = countArticlesPerSubsection(sortedArticles);

// Build taxonomy sections with article counts
const taxonomySections = musicTaxonomy.map((section) => {
  const subsectionCount = section.subsections.length;
  const articleCount = section.subsections.reduce((acc: number, sub: { id: string }) => {
    return acc + (subsectionArticleCounts[sub.id] || 0);
  }, 0);

  return {
    ...section,
    subsectionCount,
    articleCount,
  };
});

const pageSeo = buildPageSeo({
  title,
  description,
  url: currentUrl,
  contentKind: "generic",
  structuredData: [collectionPageSchema, articleCollectionSchema].filter(
    Boolean
  ) as StructuredData[],
  enrichedParts: [title, description, keywordPool.slice(0, 25).join(" ")],
  fallbackKeywords: metaKeywords
    .split(",")
    .map((k) => k.trim())
    .filter(Boolean),
  keywordLimit: 28,
  maxDescription: 150,
  image: "/melody-mind.jpg",
  imageAlt: "Melody Mind - Music Knowledge Platform",
  publishDate: collectionDates.publishDate || undefined,
  modifiedDate: collectionDates.modifiedDate || undefined,
  index: true,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell>
    <div class="knowledge-index">
      <header class="knowledge-index__intro">
        <HeroTeaser
          id="knowledge-home-hero"
          eyebrow="Melody Mind Knowledge"
          title="Trace how music evolves"
          titleLevel="h1"
          description="From genre roots to current sounds, explore the cultural stories, key artists, and sonic shifts that shape each style."
          mediaPosition="start"
          mediaAspectRatio="3 / 2"
        >
          <Fragment slot="media">
            <Image
              class="knowledge-index__hero-image"
              src="/melody-mind.jpg"
              width="1080"
              height="720"
              alt="Melody Mind collage artwork representing music history and genre connections"
              loading="eager"
              fetchpriority="high"
            />
          </Fragment>
          <div
            slot="meta"
            class="knowledge-index__feature-list"
            aria-label="Knowledge features"
          >
            <span class="knowledge-index__feature-item">
              <Icon
                name="book-open"
                class="knowledge-index__feature-icon"
                aria-hidden="true"
              />
              <span>Curated guides</span>
            </span>
            <span class="knowledge-index__feature-item">
              <Icon
                name="music"
                class="knowledge-index__feature-icon"
                aria-hidden="true"
              />
              <span>Key listening picks</span>
            </span>
            <span class="knowledge-index__feature-item">
              <Icon
                name="globe"
                class="knowledge-index__feature-icon"
                aria-hidden="true"
              />
              <span>Genre connections</span>
            </span>
            <span class="knowledge-index__feature-item">
              <Icon
                name="sparkles"
                class="knowledge-index__feature-icon"
                aria-hidden="true"
              />
              <span>Listening notes</span>
            </span>
          </div>
        </HeroTeaser>
      </header>

      <section
        class="knowledge-index__section knowledge-index__section--recent"
        aria-labelledby="recent-reads-title"
      >
        <div class="knowledge-index__section-head">
          <div class="knowledge-index__section-copy">
            <Headline level="h2" textSize="lg" className="knowledge-index__section-title">
              <span id="recent-reads-title">Recently read</span>
            </Headline>
            <Paragraph textSize="sm" className="knowledge-index__section-help">
              Return to the guides you opened most recently.
            </Paragraph>
          </div>
        </div>
        <div class="recent-reads" id="recent-reads" hidden>
          <ul class="recent-reads__list" id="recent-reads-list"></ul>
        </div>
        <script
          is:inline
          id="recent-read-images"
          type="application/json"
          set:html={JSON.stringify(recentReadImageMap)}
        />
        <p
          id="recent-reads-status"
          class="knowledge-index__sr"
          role="status"
          aria-live="polite"
          aria-atomic="true"
        >
        </p>
        <EmptyState
          className="recent-reads recent-reads--empty"
          id="recent-reads-empty"
          description="No recent guides yet. Open an article and it will appear here."
        />
      </section>

      <section
        class="knowledge-index__section"
        aria-labelledby="knowledge-categories-title"
        aria-describedby="knowledge-categories-help"
      >
        <div class="knowledge-index__section-head">
          <div class="knowledge-index__section-copy">
            <Headline level="h2" textSize="lg" className="knowledge-index__section-title">
              <span id="knowledge-categories-title">Explore categories</span>
            </Headline>
            <Paragraph
              textSize="sm"
              className="knowledge-index__section-help"
              id="knowledge-categories-help"
            >
              Browse genre sections. Each card includes the number of available articles.
            </Paragraph>
          </div>
        </div>
        <ul
          class="knowledge-index__grid"
          aria-label="Knowledge categories"
          id="knowledge-categories-list"
        >
          {
            taxonomySections.map((section) => (
              <li data-search-text={`${section.title} ${section.description || ""}`}>
                <ContentCard
                  id={`taxonomy-card-${section.id}`}
                  data-testid="taxonomy-card"
                  data-title={section.title}
                  href={`/taxonomy/${section.id}`}
                  variant="default"
                  size="default"
                  mediaObjectFit="contain"
                  imageSrc={section.image}
                  imageAlt={`${section.title} cover`}
                  imageWidth={1024}
                  imageHeight={683}
                  title={section.title}
                  description={section.description}
                  descriptionLineClamp={3}
                >
                  <Fragment slot="badge">
                    <span class="taxonomy-card__badge">
                      {section.articleCount > 0
                        ? `${section.articleCount} articles`
                        : `${section.subsectionCount} topics`}
                    </span>
                  </Fragment>
                </ContentCard>
              </li>
            ))
          }
        </ul>
        <div
          id="knowledge-search-empty"
          class="knowledge-index__empty"
          role="status"
          aria-live="polite"
          aria-atomic="true"
          hidden
        >
          No categories match your search. Try another search term.
        </div>
      </section>
    </div>
  </PageShell>

  <BackToTop />
</Layout>
<script>
  // Recent Reads Script
  // NOTE: STORAGE_KEY_RECENT_READS must match VERSIONED_KEYS.RECENT_READS in
  // src/constants/storageVersions.ts
  const STORAGE_KEY_RECENT_READS = "mm_recent_reads_v1";
  const RECENT_READS_FALLBACK_IMAGE = "/melody-mind.jpg";
  (() => {
    const storageKey = STORAGE_KEY_RECENT_READS;
    const container = document.getElementById("recent-reads");
    const list = document.getElementById("recent-reads-list");
    const emptyState = document.getElementById("recent-reads-empty");
    const status = document.getElementById("recent-reads-status");
    const imageMapEl = document.getElementById("recent-read-images");
    if (!container || !list || !emptyState || !status || !imageMapEl) {
      return;
    }

    let imageMap: Record<string, string> = {};
    try {
      imageMap = JSON.parse(imageMapEl.textContent || "{}");
    } catch {
      imageMap = {};
    }

    let items = [];
    try {
      const raw = window.localStorage?.getItem(storageKey);
      if (raw) {
        items = JSON.parse(raw);
      }
    } catch {
      items = [];
    }

    const sanitized = Array.isArray(items)
      ? items.filter(
          (item) =>
            item && typeof item.slug === "string" && typeof item.title === "string"
        )
      : [];

    if (!sanitized.length) {
      container.hidden = true;
      emptyState.hidden = false;
      status.textContent = "No recent guides available.";
      return;
    }

    emptyState.hidden = true;
    container.hidden = false;
    status.textContent = `Showing ${Math.min(sanitized.length, 3)} recent guides.`;

    sanitized.slice(0, 3).forEach((item) => {
      const li = document.createElement("li");
      li.className = "recent-reads__item";

      const link = document.createElement("a");
      link.className = "recent-reads__link";
      const normalizedSlug = item.slug.replace(/^\/+/, "");
      link.href = `/knowledge/${normalizedSlug}`;

      const media = document.createElement("div");
      media.className = "recent-reads__media";

      const image = document.createElement("img");
      image.className = "recent-reads__image";
      image.loading = "lazy";
      image.decoding = "async";
      image.alt = item.title ? `Cover image for ${item.title}` : "Article cover image";
      const articleImage =
        typeof imageMap[normalizedSlug] === "string"
          ? imageMap[normalizedSlug].trim()
          : "";
      image.src =
        articleImage ||
        (typeof item.image === "string" && item.image.trim() ? item.image : "") ||
        RECENT_READS_FALLBACK_IMAGE;
      image.src =
        typeof image.src === "string" && image.src
          ? image.src
          : RECENT_READS_FALLBACK_IMAGE;
      image.onerror = () => {
        if (image.src.endsWith(RECENT_READS_FALLBACK_IMAGE)) {
          return;
        }
        image.src = RECENT_READS_FALLBACK_IMAGE;
      };

      const title = document.createElement("span");
      title.className = "recent-reads__title";
      title.textContent = item.title;

      const overlay = document.createElement("span");
      overlay.className = "recent-reads__overlay";
      overlay.append(title);

      media.append(image, overlay);
      link.append(media);
      li.append(link);

      list.append(li);
    });
  })();
</script>
<style>
  /* ========================================
     KNOWLEDGE INDEX - MINIMAL LAYOUT
     ======================================== */

  .knowledge-index {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .knowledge-index__intro {
    padding-block-end: 2.5rem;
    border-block-end: 1px solid var(--border-default);
  }

  /* ========================================
     HERO
     ======================================== */

  .knowledge-index__hero-image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .taxonomy-card__badge {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    padding: 0.4rem 0.8rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: color-mix(in srgb, var(--surface-1) 96%, transparent);
    border: 1px solid color-mix(in srgb, var(--border-default) 88%, transparent);
    border-radius: var(--radius-full);
  }

  .knowledge-index__feature-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .knowledge-index__feature-item {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    min-block-size: 48px;
    padding: 0.65rem 1rem;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-1) 92%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-primary) 40%, var(--border-default));
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
  }

  .knowledge-index__feature-icon {
    display: block;
    flex-shrink: 0;
    inline-size: 1.1rem;
    block-size: 1.1rem;
    color: var(--accent-primary);
  }

  /* ========================================
     SECTIONS
     ======================================== */

  .knowledge-index__section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .knowledge-index__section-head {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  @media (width >= 640px) {
    .knowledge-index__section-head {
      flex-direction: row;
      align-items: end;
      justify-content: space-between;
    }
  }

  .knowledge-index__section-copy {
    display: grid;
    gap: 0.4rem;
    max-inline-size: 42rem;
  }

  .knowledge-index__search {
    margin-inline-start: auto;

    --search-shell-max-inline-size: 30rem;
  }

  .knowledge-index__section-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .knowledge-index__section-help {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  /* ========================================
     RESPONSIVE GRID
     ======================================== */

  .knowledge-index__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (width >= 500px) {
    .knowledge-index__grid {
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    }
  }

  @media (width >= 1024px) {
    .knowledge-index__grid {
      grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    }
  }

  /* ========================================
     EMPTY STATE
     ======================================== */

  .knowledge-index__empty {
    padding: 2rem;
    margin-block-start: 1.5rem;
    color: var(--text-secondary);
    text-align: center;
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid var(--border-default);
    border-radius: 1rem;
  }

  .knowledge-index__section--recent {
    margin-block-start: 0.5rem;
  }

  /* ========================================
     RECENT READS
     ======================================== */

  :global(.recent-reads) {
    padding: 1.25rem;
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid var(--border-default);
    border-radius: 1rem;
  }

  :global(.recent-reads--empty) {
    padding: var(--spacing-lg);
    background: linear-gradient(160deg, var(--surface-2), var(--surface-1));
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  :global(.recent-reads--empty .empty-state__description) {
    font-size: var(--font-size-base);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  :global(.recent-reads__list) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  @media (width >= 600px) {
    :global(.recent-reads__list) {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    }
  }

  /* ========================================
     RECENT READ ITEMS
     ======================================== */

  :global(.recent-reads__item) {
    min-inline-size: 0;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    :global(.recent-reads__link) {
      display: block;
      overflow: hidden;
      color: var(--text-primary);
      text-decoration: none;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--accent-primary) 18%, transparent),
          transparent
        ),
        var(--surface-1);
      border: 1px solid var(--border-default);
      border-radius: 0.75rem;
      transition: none;
    }
  }

  :global(.recent-reads__link) {
    display: block;
    overflow: hidden;
    color: var(--text-primary);
    text-decoration: none;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--accent-primary) 18%, transparent),
        transparent
      ),
      var(--surface-1);
    border: 1px solid var(--border-default);
    border-radius: 0.75rem;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  :global(.recent-reads__link:hover),
  :global(.recent-reads__link:focus) {
    border-color: color-mix(in srgb, var(--accent-primary) 45%, var(--border-default));
    box-shadow: var(--interactive-shadow-focus);
    transform: translateY(-2px);
  }

  :global(.recent-reads__link):focus-visible {
    outline: 3px solid var(--accent-primary);
    outline-offset: 2px;
    box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent-primary) 35%, transparent);
  }

  :global(.recent-reads__media) {
    position: relative;
    aspect-ratio: 16 / 10;
    background:
      linear-gradient(
        145deg,
        var(--surface-2),
        color-mix(in srgb, var(--accent-primary) 20%, var(--surface-1))
      ),
      var(--surface-1);
  }

  :global(.recent-reads__image) {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  :global(.recent-reads__overlay) {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    display: flex;
    align-items: flex-end;
    min-block-size: 40%;
    padding: 1rem 0.95rem 0.9rem;
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--surface-1) 15%, transparent) 30%,
      color-mix(in srgb, var(--surface-1) 92%, transparent) 100%
    );
    border-radius: 0.75rem;
  }

  :global(.recent-reads__title) {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-white);
    text-shadow: var(--effect-title-shadow-soft);
    /* stylelint-disable-next-line property-no-deprecated */
    -webkit-box-orient: block-axis;
  }

  /* ========================================
     SCREEN READER ONLY
     ======================================== */

  .knowledge-index__sr {
    position: absolute;
    inline-size: var(--sr-only-width);
    block-size: var(--sr-only-height);
    margin: var(--sr-only-margin);
    overflow: hidden;
    white-space: nowrap;
    border: 0;
    clip-path: var(--sr-only-clip-path);
  }
</style>
