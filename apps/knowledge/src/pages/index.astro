---
import Layout from "@layouts/Layout.astro";
import RecentReadsPanel from "@shared-ui/components/init/RecentReadsPanel.astro";
import DetailPill from "@shared-ui/components/data-display/DetailPill.astro";
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import Stack from "@shared-ui/components/layout/Stack.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import HeroTeaser from "@shared-ui/components/cards/HeroTeaser.astro";
import { buildKnowledgeIndexPageData } from "@utils/knowledge/buildKnowledgeIndexPageData";
import {
  getKnowledgeTaxonomyImage,
  knowledgeHeroImage,
  knowledgeHeroImageSrc,
} from "@utils/knowledgeImages";

export const prerender = true;

const { pageSeo, taxonomySections } = await buildKnowledgeIndexPageData(Astro.site);
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--wide">
    <Stack gap="2xl">
      <div class="knowledge-index__intro">
        <HeroTeaser
          id="knowledge-home-hero"
          class="knowledge-index__hero"
          eyebrow="Melody Mind Knowledge"
          title="Trace how music evolves"
          titleLevel="h1"
          description="From genre roots to current sounds, explore the cultural stories, key artists, and sonic shifts that shape each style."
          imageSrc={knowledgeHeroImage}
          imageAlt="Melody Mind collage artwork representing music history and genre connections"
          imageWidth={1024}
          imageHeight={683}
          imageLoading="eager"
          mediaAspectRatio="3 / 2"
        />
      </div>

      <Stack as="section" gap="lg">
        <RecentReadsPanel
          storageKey="mm_recent_reads_v1"
          fallbackImage={knowledgeHeroImageSrc}
          className="knowledge-index__recent"
        />
      </Stack>

      <Stack
        as="section"
        aria-labelledby="knowledge-taxonomy-title"
        aria-describedby="knowledge-taxonomy-help"
        gap="lg"
      >
        <div class="section-header knowledge-index__section-header">
          <div class="section-header__copy">
            <h2 id="knowledge-taxonomy-title" class="section-header__title">
              Explore the taxonomy
            </h2>
            <p class="section-header__description" id="knowledge-taxonomy-help">
              Browse taxonomy sections. Each card includes the number of available
              articles.
            </p>
          </div>
        </div>
        <AutoGrid
          as="ul"
          class="knowledge-index__grid"
          preset="fill"
          min="lg"
          gap="lg"
          aria-label="Knowledge taxonomy sections"
          id="knowledge-taxonomy-list"
        >
          {
            taxonomySections.map((section) => (
              <li data-search-text={`${section.title} ${section.description || ""}`}>
                <ContentCard
                  id={`taxonomy-card-${section.id}`}
                  dataTestId="taxonomy-card"
                  data-title={section.title}
                  href={`/taxonomy/${section.id}`}
                  variant="default"
                  size="default"
                  mediaObjectFit="contain"
                  imageSrc={getKnowledgeTaxonomyImage(section.image) || section.image}
                  imageAlt={`${section.title} cover`}
                  imageWidth={1024}
                  imageHeight={683}
                  title={section.title}
                  description={section.description}
                  descriptionLineClamp={4}
                >
                  <Fragment slot="badge">
                    <DetailPill tone="accent">
                      {section.articleCount > 0
                        ? `${section.articleCount} articles`
                        : `${section.subsectionCount} topics`}
                    </DetailPill>
                  </Fragment>
                </ContentCard>
              </li>
            ))
          }
        </AutoGrid>
      </Stack>
    </Stack>
  </PageShell>
</Layout>
<style>
  .section-header {
    position: relative;
    padding-block-end: var(--spacing-sm);
    border-block-end: 1px solid var(--surface-border-soft);
  }

  .section-header__title {
    margin: 0;
    color: var(--accent-primary);
  }

  .section-header__description {
    margin: 0;
    color: var(--text-secondary);
  }

  .knowledge-index__intro {
    max-inline-size: 82rem;
    margin-inline: auto;
  }

  .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__copy) {
    padding-inline: 0;
  }

  .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__title) {
    max-inline-size: 11ch;
    line-height: 1.04;
  }

  .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__description) {
    max-inline-size: 35rem;
    line-height: 1.55;
  }

  .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__media) {
    border-radius: var(--radius-lg);
  }

  .knowledge-index__grid {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .knowledge-index__section-header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-base);
    align-items: flex-start;
  }

  @media (width >= 640px) {
    .knowledge-index__section-header {
      flex-direction: row;
      align-items: end;
      justify-content: space-between;
    }
  }

  @media (width >= 960px) {
    .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__grid) {
      grid-template-columns: minmax(20rem, 0.72fr) minmax(26rem, 1fr);
      gap: clamp(var(--spacing-2xl), 5vw, var(--spacing-4xl));
    }

    .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__copy) {
      order: 1;
      padding-block: clamp(var(--spacing-xl), 5vw, var(--spacing-4xl));
    }

    .knowledge-index__intro :global(.knowledge-index__hero .hero-teaser__media) {
      align-self: center;
      order: 2;
      max-block-size: clamp(24rem, 36vw, 32rem);
    }
  }
</style>
