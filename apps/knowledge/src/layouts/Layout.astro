---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import SiteHeader from "@shared-ui/components/navigation/SiteHeader.astro";
import SharedFooter from "@shared-ui/components/layout/Footer.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";

import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import {
  buildOrganizationSchema,
  buildWebSiteSchema,
} from "@shared-utils/utils/seo/seoSchema";
import { resolveBaseUrl } from "@shared-utils/utils/siteUrls";
import type { NavItem } from "@shared-ui/components/navigation/types";

/**
 * Normalized SEO payload expected by the shared `<SEO />` component.
 * Knowledge pages build this upstream and Layout only merges in global defaults.
 */
interface PageSeo {
  title: string;
  description: string;
  keywords: string;
  canonical: string;
  image?: string;
  type: "website" | "article" | "music" | "game" | "podcastEpisode";
  robots: string;
  openGraph: {
    title: string;
    description: string;
    type: string;
    url: string;
    image?: string;
    locale?: string;
  };
  twitter: {
    card: string;
    title: string;
    description: string;
    image?: string;
    creator?: string;
  };
  structuredData: StructuredData[];
  publishDate?: Date;
  modifiedDate?: Date;
  ogLocale?: string;
  alternateLocales?: string[];
  authorName?: string;
  imageAlt?: string;
}

/**
 * Shared layout contract for all knowledge pages.
 * Keep this surface narrow: page-specific SEO should be prepared before reaching the layout.
 */
interface Props {
  imageWidth?: number;
  imageHeight?: number;
  pageSeo: PageSeo;
  ogMusic?: {
    creator?: string;
    album?: string;
    musician?: string;
  };
  audioSrc?: string;
  episodeNumber?: number;
  seriesName?: string;
  seriesUrl?: string;
  prevUrl?: string;
  nextUrl?: string;
  disableAlternateLanguages?: boolean;
  structuredDataExtra?: any | any[];
  authorName?: string;
}

const {
  pageSeo,
  imageWidth,
  imageHeight,
  ogMusic,
  audioSrc,
  episodeNumber,
  seriesName,
  seriesUrl,
  prevUrl,
  nextUrl,
  disableAlternateLanguages,
  authorName,
} = Astro.props;

/**
 * The layout currently treats incoming SEO as the source of truth and only appends
 * global fallbacks such as default images and baseline structured data.
 */
const constructedPageSeo = pageSeo;
const mergedTitle = constructedPageSeo.title;
const mergedDescription = constructedPageSeo.description;
const mergedKeywords = constructedPageSeo.keywords;
const mergedType = constructedPageSeo.type;
const mergedCanonical = constructedPageSeo.canonical;
const mergedImage = constructedPageSeo.image || "/melody-mind.png";
const mergedPublishDate = constructedPageSeo.publishDate;
const mergedModifiedDate = constructedPageSeo.modifiedDate;
const mergedStructuredData = constructedPageSeo.structuredData;
const robotsTag = constructedPageSeo.robots;
const siteUrl = resolveBaseUrl(Astro.site);
const globalStructuredData: StructuredData[] = [];
const siteName = "Melody Mind";
const siteDescription =
  "Music knowledge platform for genres, timelines, and guided listening.";

// Ensure every page ships the site-level schemas even if the page config omitted them.
if (!mergedStructuredData.some((entry) => entry["@type"] === "Organization")) {
  globalStructuredData.push(
    buildOrganizationSchema({
      siteUrl,
      siteName,
      description: siteDescription,
    })
  );
}

if (!mergedStructuredData.some((entry) => entry["@type"] === "WebSite")) {
  globalStructuredData.push(
    buildWebSiteSchema({
      siteUrl,
      siteName,
      description: siteDescription,
    })
  );
}

const finalStructuredData = [...globalStructuredData, ...mergedStructuredData];
const lang = "en";

/**
 * Maps a simple locale code to the Open Graph locale format expected by social platforms.
 * The fallback keeps the language prefix and guesses a region where no explicit mapping exists.
 */
function mapOgLocale(locale: string): string {
  if (!locale) {
    return "en_US";
  }

  const base = locale.toLowerCase();
  switch (base) {
    case "en":
      return "en_US";
    case "de":
      return "de_DE";
    case "fr":
      return "fr_FR";
    case "es":
      return "es_ES";
    default:
      return base.replace(/-.+$/, "").concat("_", base.toUpperCase().slice(-2) || "US");
  }
}

const autoOgLocale = mapOgLocale(lang);
/**
 * Kept as typed arrays so future performance optimizations can be added centrally
 * without changing the `<head>` rendering logic below.
 */
const preloadedResources: Array<{
  href: string;
  as: "style" | "script" | "font" | "image";
  crossorigin?: "anonymous" | "use-credentials";
}> = [];
const fontPreloads: Array<{
  href: string;
  as: "style" | "script" | "font" | "image";
  type?: string;
  crossorigin?: "anonymous" | "use-credentials";
}> = [];
const dnsPrefetch = [{ href: "https://cdn.usefathom.com" }];

// Shared primary navigation for the Knowledge app shell.
const navItems: NavItem[] = [
  {
    href: "https://podcasts.melody-mind.de",
    label: "Podcast",
    icon: "headphones",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    href: "https://quiz.melody-mind.de",
    label: "Quiz",
    icon: "help-circle",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    href: "/search",
    label: "Search",
    icon: "search",
  },
];
---

<MasterLayout lang={lang} appTitle="MelodyMind">
  <Fragment slot="head">
    {dnsPrefetch.map((resource) => <link rel="dns-prefetch" href={resource.href} />)}
    {
      preloadedResources.map((resource) => (
        <link
          rel="preload"
          href={resource.href}
          as={resource.as}
          crossorigin={resource.crossorigin}
        />
      ))
    }
    {
      fontPreloads.map((font) => (
        <link
          rel="preload"
          href={font.href}
          as={font.as}
          type={font.type}
          crossorigin={font.crossorigin}
        />
      ))
    }
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="MelodyMind Knowledge RSS Feed"
      href="/rss.xml"
    />
    {/* Shared SEO renders canonical, robots, JSON-LD, and article-specific meta tags. */}
    <SEO
      title={mergedTitle}
      description={mergedDescription}
      keywords={mergedKeywords.split(",").map((keyword) => keyword.trim())}
      image={mergedImage}
      {imageWidth}
      {imageHeight}
      type={mergedType}
      publishDate={mergedPublishDate}
      modifiedDate={mergedModifiedDate}
      {ogMusic}
      {audioSrc}
      {episodeNumber}
      {seriesName}
      {seriesUrl}
      canonical={mergedCanonical}
      noIndex={robotsTag.includes("noindex")}
      noFollow={robotsTag.includes("nofollow")}
      {prevUrl}
      {nextUrl}
      {disableAlternateLanguages}
      structuredDataExtra={finalStructuredData}
      authorName={authorName || constructedPageSeo.authorName}
      imageAlt={constructedPageSeo.imageAlt}
    />
    {robotsTag !== "index,follow" && <meta name="robots" content={robotsTag} />}
    <meta property="og:title" content={constructedPageSeo.openGraph.title} />
    <meta property="og:description" content={constructedPageSeo.openGraph.description} />
    <meta property="og:type" content={constructedPageSeo.openGraph.type} />
    <meta property="og:url" content={constructedPageSeo.openGraph.url} />
    <meta
      property="og:locale"
      content={constructedPageSeo.openGraph.locale ||
        constructedPageSeo.ogLocale ||
        autoOgLocale}
    />
    {
      Array.isArray(constructedPageSeo.alternateLocales) &&
        constructedPageSeo.alternateLocales.map((locale) => (
          <meta property="og:locale:alternate" content={locale} />
        ))
    }
    {
      constructedPageSeo.openGraph.image && (
        <meta property="og:image" content={constructedPageSeo.openGraph.image} />
      )
    }
    {
      constructedPageSeo.imageAlt && (
        <meta property="og:image:alt" content={constructedPageSeo.imageAlt} />
      )
    }
    <meta name="twitter:card" content={constructedPageSeo.twitter.card} />
    <meta name="twitter:title" content={constructedPageSeo.twitter.title} />
    <meta name="twitter:description" content={constructedPageSeo.twitter.description} />
    {
      constructedPageSeo.twitter.image && (
        <meta name="twitter:image" content={constructedPageSeo.twitter.image} />
      )
    }
    {
      constructedPageSeo.twitter.creator && (
        <meta name="twitter:creator" content={constructedPageSeo.twitter.creator} />
      )
    }
  </Fragment>

  <SiteHeader
    {navItems}
    brandHref="/"
    brandText={siteName}
    brandMark="MM"
    brandLogoSrc="/melody-mind.png"
    brandLogoAlt={siteName}
    brandLogoWidth={1536}
    brandLogoHeight={1024}
    brandAriaLabel={`Go to the ${siteName} homepage`}
    menuOpenLabel="Open main menu"
    menuCloseLabel="Close main menu"
    menuText="Menu"
    navAriaLabel="Primary navigation"
  />

  <slot />

  <SharedFooter
    brandTitle={siteName}
    brandText="Curated guides and playlists to help you listen more closely and discover new sounds."
    exploreLinks={[
      {
        href: "https://podcasts.melody-mind.de",
        label: "Podcasts",
        target: "_blank",
        rel: "noopener noreferrer",
      },
    ]}
    supportLinks={[
      {
        href: "https://www.paypal.me/dcschmid",
        label: "PayPal",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "https://www.buymeacoffee.com/dcschmid",
        label: "Buy Me a Coffee",
        target: "_blank",
        rel: "noopener noreferrer",
      },
    ]}
    legalLinks={[
      { href: "/imprint", label: "Legal Notice" },
      { href: "/privacy", label: "Privacy Policy" },
      { href: "/ai-content", label: "AI Content" },
    ]}
    cookieSettingsLabel="Cookie settings"
    themeStatusPrefix="Theme"
    cookiesWaitingLabel="Cookies: waiting"
    cookiesAllowedLabel="Cookies: analytics allowed"
    cookiesEssentialLabel="Cookies: essential only"
    copyrightText={`© ${new Date().getFullYear()} MelodyMind. All rights reserved.`}
  />

  <AutoInitScript slot="body-end" />
</MasterLayout>
