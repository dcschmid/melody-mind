---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import AppHeadResources from "@shared-ui/components/meta/AppHeadResources.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import SiteHeader from "@shared-ui/components/navigation/SiteHeader.astro";
import SkipLink from "@shared-ui/components/navigation/SkipLink.astro";
import SharedFooter from "@shared-ui/components/layout/Footer.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import {
  buildDefaultCopyrightText,
  PODCASTS_SITE_URL,
} from "@shared-utils/utils/appShell";
import {
  ensureTrailingSlash,
  resolveAbsoluteUrl,
  resolveBaseUrl,
} from "@shared-utils/utils/siteUrls";
import {
  buildOrganizationSchema,
  buildPodcastEpisodeSchema,
  buildPodcastSeriesSchema,
  buildWebSiteSchema,
  buildSpeakableSpecificationSchema,
} from "@shared-utils/utils/seo/seoSchema";
import {
  PODCAST_FEED_PATH,
  PODCAST_FEED_URL,
  PODCAST_PLATFORM_URLS,
  PODCAST_PRECONNECT_ORIGINS,
} from "../constants/podcastLinks";
import { podcastBrandLogo, podcastHeroImageUrl } from "../utils/podcastImages";
import { normalizeWhitespace } from "@shared-utils/utils/format";
import { toIsoDuration } from "../utils/podcastPresentation";
import { podcastAppShellConfig } from "../utils/appShellConfig";

import type { PageSeoResult } from "@shared-utils/utils/seo/buildPageSeo";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string[];
  canonical?: string;
  language?: string;
  locale?: string;
  episodeNumber?: number;
  durationSeconds?: number | undefined;
  audioUrl?: string;
  episodeImage?: string;
  seriesDescription?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  structuredData?: Array<Record<string, unknown>>;
  index?: boolean;
  follow?: boolean;
  pageSeo?: PageSeoResult;
}

const {
  title,
  description,
  image = podcastHeroImageUrl,
  type = "website",
  publishedTime,
  modifiedTime,
  author = "MelodyMind Podcasts",
  keywords = [],
  canonical,
  language = "en",
  locale = "en-US",
  episodeNumber,
  durationSeconds,
  audioUrl,
  episodeImage,
  seriesDescription,
  breadcrumbs = [],
  structuredData = [],
  index = true,
  follow = true,
  pageSeo,
} = Astro.props as Props;

const siteTitle = "MelodyMind Podcasts";
const normalizedTitle = normalizeWhitespace(title || siteTitle);
const fullTitle = normalizedTitle.toLowerCase().includes(siteTitle.toLowerCase())
  ? normalizedTitle
  : `${normalizedTitle} | ${siteTitle}`;
const siteUrl = resolveBaseUrl(PODCASTS_SITE_URL);
const canonicalPath = canonical
  ? new URL(canonical, `${siteUrl}/`).pathname
  : Astro.url.pathname;
const currentUrl = resolveAbsoluteUrl(siteUrl, ensureTrailingSlash(canonicalPath));
const imageUrl = resolveAbsoluteUrl(siteUrl, image);
const episodeImageUrl = episodeImage
  ? resolveAbsoluteUrl(siteUrl, episodeImage)
  : imageUrl;
const podcastFeedUrl = PODCAST_FEED_URL;
const podcastImage = podcastHeroImageUrl;
const seriesCopy =
  seriesDescription ||
  "Melody Mind explores the stories behind the music that shaped generations, with Daniel and Annabelle.";
const defaultKeywords = [
  "podcast",
  "music history",
  "audio",
  "streaming",
  "entertainment",
];
const normalizedDescription = normalizeWhitespace(description || "");
const shellConfig = podcastAppShellConfig;
const imageAlt =
  type === "article"
    ? `Cover artwork for ${normalizedTitle}`
    : `Cover artwork for ${siteTitle}`;
const publishDate = publishedTime ? new Date(publishedTime) : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime) : undefined;

const publisher = {
  "@type": "Organization",
  name: "MelodyMind Podcasts",
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: podcastImage,
  },
};

const episodeDurationIso =
  typeof durationSeconds === "number" && durationSeconds > 0
    ? toIsoDuration(durationSeconds)
    : undefined;
const authorNames = ["Daniel Schmid", "Annabelle"];

const organizationSchema = buildOrganizationSchema({
  siteUrl,
  siteName: siteTitle,
  description: seriesCopy,
  logoUrl: podcastImage,
});

const webSiteSchema = buildWebSiteSchema({
  siteUrl,
  siteName: siteTitle,
  description: seriesCopy,
  searchPathTemplate: "/search?q={search_term_string}",
});

const podcastSeriesJson = buildPodcastSeriesSchema({
  siteUrl,
  title: siteTitle,
  description: seriesCopy,
  locale,
  imageUrl: podcastImage,
  feedUrl: podcastFeedUrl,
  sameAs: PODCAST_PLATFORM_URLS,
  authorNames,
  publisherName: publisher.name,
  publisherLogoUrl: podcastImage,
});

const podcastEpisodeJson =
  type === "article"
    ? buildPodcastEpisodeSchema({
        title: normalizedTitle,
        description: normalizedDescription,
        url: currentUrl,
        seriesTitle: siteTitle,
        seriesUrl: siteUrl,
        locale,
        imageUrl: episodeImageUrl,
        ...(publishedTime ? { publishedAt: publishedTime } : {}),
        ...(modifiedTime || publishedTime
          ? { modifiedAt: modifiedTime || publishedTime }
          : {}),
        ...(typeof episodeNumber === "number" ? { episodeNumber } : {}),
        ...(episodeDurationIso ? { durationIso: episodeDurationIso } : {}),
        ...(audioUrl ? { audioUrl } : {}),
        authorNames,
        publisherName: publisher.name,
        publisherLogoUrl: podcastImage,
      })
    : undefined;

const speakableSchema =
  type === "article"
    ? buildSpeakableSpecificationSchema({
        cssSelectors: [
          "article h1",
          "article .hero__description p:first-of-type",
          "article .prose p:nth-of-type(-n+3)",
        ],
      })
    : undefined;

const seoStructuredData = [
  organizationSchema,
  webSiteSchema,
  podcastSeriesJson,
  podcastEpisodeJson,
  ...(speakableSchema ? [speakableSchema] : []),
  ...structuredData,
].filter((item): item is StructuredData => Boolean(item));

const computedSeo = buildPageSeo({
  title: fullTitle,
  description: normalizedDescription,
  url: currentUrl,
  image: imageUrl,
  imageAlt,
  type: type === "article" ? "article" : "website",
  structuredData: seoStructuredData,
  fallbackKeywords: [...defaultKeywords, ...keywords],
  breadcrumbs,
  index,
  follow,
  maxImagePreview: "large",
  maxSnippet: -1,
  maxVideoPreview: -1,
  ogLocale: locale.replace("-", "_"),
  twitterCreator: "@melodymind",
  authorName: author,
  brandSuffix: false,
  autoSocialImage: true,
  generateSocialImage: ({ title: genTitle }) => {
    void genTitle;
    return undefined;
  },
  ...(publishDate ? { publishDate } : {}),
  ...(modifiedDate ? { modifiedDate } : {}),
});

const pageSeoResolved = pageSeo ?? computedSeo;

const seoProps = {
  title: pageSeoResolved.title || fullTitle,
  description: pageSeoResolved.description || normalizedDescription,
  keywords: pageSeoResolved.keywordArray || [],
  canonical: pageSeoResolved.canonical,
  structuredDataExtra: pageSeoResolved.structuredData,
  ...(pageSeoResolved.image ? { image: pageSeoResolved.image } : {}),
  ...(pageSeoResolved.imageAlt ? { imageAlt: pageSeoResolved.imageAlt } : {}),
  ...(pageSeoResolved.publishDate ? { publishDate: pageSeoResolved.publishDate } : {}),
  ...(pageSeoResolved.modifiedDate ? { modifiedDate: pageSeoResolved.modifiedDate } : {}),
  ...(pageSeoResolved.authorName ? { authorName: pageSeoResolved.authorName } : {}),
};
---

<MasterLayout
  lang={language}
  bodyClass="podcast-layout"
  mainClass="podcast-layout__main"
  contentShellClass="podcast-layout__container"
  showSkipLink={false}
  enableThemeInit={true}
  appTitle="Melody Mind Podcasts"
>
  <Fragment slot="head">
    <AppHeadResources
      fontPreloads={[
        {
          href: "/fonts/atkinson-hyperlegible-regular.woff2",
          as: "font",
          type: "font/woff2",
          crossorigin: true,
        },
      ]}
      rssTitle={shellConfig.rssTitle}
      rssHref={PODCAST_FEED_PATH}
      rssHrefLang={locale}
    />
    {
      PODCAST_PRECONNECT_ORIGINS.map((origin) => (
        <link rel="preconnect" href={origin} crossorigin />
      ))
    }
    <SEO
      {...seoProps}
      {...pageSeoResolved.openGraph && {
        openGraph: {
          ...pageSeoResolved.openGraph,
          locale: pageSeoResolved.openGraph.locale || locale.replace("-", "_"),
        },
      }}
      ogSiteName={siteTitle}
      {...pageSeoResolved.twitter && { twitter: pageSeoResolved.twitter }}
      {...pageSeoResolved.canonical && { twitterUrl: pageSeoResolved.canonical }}
      twitterSite="@melodymind"
      {...type === "article" && author ? { articleAuthor: author } : {}}
    />
    <meta name="robots" content={pageSeoResolved.robots} />
    <meta name="language" content={language} />
    <meta name="revisit-after" content="7 days" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  </Fragment>

  <SkipLink slot="body-start" />
  <SiteHeader
    slot="before-main"
    headerConfig={{
      ...shellConfig.header,
      showBrand: true,
      brandText: "",
      brandLogoSrc: podcastBrandLogo,
      brandLogoAlt: "",
    }}
  />

  <SharedFooter
    slot="after-main"
    footerConfig={{
      ...shellConfig.footer,
      showSettings: true,
      copyrightText: buildDefaultCopyrightText(new Date().getFullYear()),
    }}
  />

  <AutoInitScript slot="body-end" />

  <slot />
</MasterLayout>

<style>
  :global(.podcast-layout) {
    background: var(--page-background);
  }

  :global(.podcast-layout__main) {
    position: relative;
  }

  :global(.podcast-layout__main)::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(
        circle at top center,
        color-mix(in srgb, var(--accent-primary) 10%, transparent),
        transparent 48%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 18%, transparent),
        transparent 28%
      );
  }

  .podcast-layout__container {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--spacing-xl);
    max-inline-size: var(--max-width);
    padding-block: var(--spacing-base);
    padding-inline: var(--spacing-sm);
    margin: 0 auto;
  }

  @media (width >= 480px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-base);
    }
  }

  @media (width >= 768px) {
    .podcast-layout__container {
      padding-block: var(--spacing-xl);
      padding-inline: var(--spacing-xl);
    }
  }

  @media (width >= 1024px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-2xl);
    }
  }

  @media (width >= 1280px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-3xl);
    }
  }
</style>
