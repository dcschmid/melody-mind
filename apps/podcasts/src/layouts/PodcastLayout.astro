---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import Footer from "../components/Footer.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import {
  buildOrganizationSchema,
  buildPodcastEpisodeSchema,
  buildPodcastSeriesSchema,
  buildWebSiteSchema,
} from "@shared-utils/utils/seo/seoSchema";

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string[];
  canonical?: string;
  language?: string;
  locale?: string;
  episodeNumber?: number;
  durationSeconds?: number | undefined;
  audioUrl?: string;
  episodeImage?: string;
  seriesDescription?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  structuredData?: Array<Record<string, unknown>>;
  index?: boolean;
  follow?: boolean;
}

const {
  title,
  description,
  image = "/images/default-og.jpg",
  type = "website",
  publishedTime,
  modifiedTime,
  author = "MelodyMind Podcasts",
  keywords = [],
  canonical,
  language = "en",
  locale = "en-US",
  episodeNumber,
  durationSeconds,
  audioUrl,
  episodeImage,
  seriesDescription,
  breadcrumbs = [],
  structuredData = [],
  index = true,
  follow = true,
} = Astro.props;

const siteTitle = "MelodyMind Podcasts";
const normalizedTitle = normalizeMetaText(title);
const fullTitle = normalizedTitle.toLowerCase().includes(siteTitle.toLowerCase())
  ? normalizedTitle
  : `${normalizedTitle} | ${siteTitle}`;
const siteUrl = "https://podcasts.melody-mind.de";
const currentPath = canonical ? canonical.replace(siteUrl, "") : Astro.url.pathname;
const currentUrl = `${siteUrl}${ensureTrailingSlash(currentPath)}`;
const imageUrl = image.startsWith("http") ? image : `${siteUrl}${image}`;
const episodeImageUrl = episodeImage
  ? episodeImage.startsWith("http")
    ? episodeImage
    : `${siteUrl}${episodeImage}`
  : imageUrl;
const podcastFeedUrl = `${siteUrl}/podcast.xml`;
const podcastImage = `${siteUrl}/the-melody-mind-podcast.jpg`;
const seriesCopy =
  seriesDescription ||
  "Melody Mind explores the stories behind the music that shaped generations, with Daniel and Annabelle.";
const defaultKeywords = [
  "podcast",
  "music history",
  "audio",
  "streaming",
  "entertainment",
];
const skipLinkText = "Skip to main content";
const normalizedDescription = normalizeMetaText(description);
const imageAlt =
  type === "article"
    ? `Cover artwork for ${normalizedTitle}`
    : `Cover artwork for ${siteTitle}`;
const publishDate = publishedTime ? new Date(publishedTime) : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime) : undefined;

const publisher = {
  "@type": "Organization",
  name: "MelodyMind Podcasts",
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: podcastImage,
  },
};

const episodeDurationIso =
  typeof durationSeconds === "number" && durationSeconds > 0
    ? toIsoDuration(durationSeconds)
    : undefined;
const authorNames = ["Daniel Schmid", "Annabelle"];

const organizationSchema = buildOrganizationSchema({
  siteUrl,
  siteName: siteTitle,
  description: seriesCopy,
  logoUrl: podcastImage,
});

const webSiteSchema = buildWebSiteSchema({
  siteUrl,
  siteName: siteTitle,
  description: seriesCopy,
  searchPathTemplate: "/search?q={search_term_string}",
});

const podcastSeriesJson = buildPodcastSeriesSchema({
  siteUrl,
  title: siteTitle,
  description: seriesCopy,
  locale,
  imageUrl: podcastImage,
  feedUrl: podcastFeedUrl,
  sameAs: [
    "https://open.spotify.com/show/6iLbxIzJ4x5nMuuK5qySOQ",
    "https://www.deezer.com/en/show/1002446242",
    "https://podcasts.apple.com/us/podcast/melody-mind-–-english/id1847445333",
  ],
  authorNames,
  publisherName: publisher.name,
  publisherLogoUrl: podcastImage,
});

const podcastEpisodeJson =
  type === "article"
    ? buildPodcastEpisodeSchema({
        title: normalizedTitle,
        description: normalizedDescription,
        url: currentUrl,
        seriesTitle: siteTitle,
        seriesUrl: siteUrl,
        locale,
        imageUrl: episodeImageUrl,
        publishedAt: publishedTime,
        modifiedAt: modifiedTime || publishedTime,
        episodeNumber,
        durationIso: episodeDurationIso,
        audioUrl,
        authorNames,
        publisherName: publisher.name,
        publisherLogoUrl: podcastImage,
      })
    : undefined;

const seoStructuredData = [
  organizationSchema,
  webSiteSchema,
  podcastSeriesJson,
  podcastEpisodeJson,
  ...structuredData,
].filter(Boolean);

const pageSeo = buildPageSeo({
  title: fullTitle,
  description: normalizedDescription,
  url: currentUrl,
  image: imageUrl,
  imageAlt,
  type: type === "article" ? "article" : "website",
  structuredData: seoStructuredData,
  fallbackKeywords: [...defaultKeywords, ...keywords],
  breadcrumbs,
  index,
  follow,
  maxImagePreview: "large",
  maxSnippet: -1,
  maxVideoPreview: -1,
  ogLocale: locale.replace("-", "_"),
  twitterCreator: "@melodymind",
  authorName: author,
  brandSuffix: false,
  ...(publishDate ? { publishDate } : {}),
  ...(modifiedDate ? { modifiedDate } : {}),
});

function ensureTrailingSlash(pathname: string) {
  if (!pathname.startsWith("/")) {
    return `/${pathname}/`;
  }

  return pathname.endsWith("/") ? pathname : `${pathname}/`;
}

function normalizeMetaText(value: string) {
  return value.replace(/\s+/g, " ").trim();
}

function toIsoDuration(totalSeconds: number) {
  const hours = Math.floor(totalSeconds / 3600);
  const minutes = Math.floor((totalSeconds % 3600) / 60);
  const seconds = Math.floor(totalSeconds % 60);
  return `PT${hours > 0 ? `${hours}H` : ""}${minutes > 0 ? `${minutes}M` : ""}${seconds || (!hours && !minutes) ? `${seconds}S` : ""}`;
}
---

<MasterLayout
  lang={language}
  bodyClass="podcast-layout"
  mainClass="podcast-layout__main"
  contentShellClass="podcast-layout__container"
  showSkipLink={false}
  enableThemeInit={true}
  appTitle="Melody Mind Podcasts"
>
  <Fragment slot="head">
    <link
      rel="preload"
      href="/fonts/atkinson-hyperlegible-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preconnect" href="https://open.spotify.com" crossorigin />
    <link rel="preconnect" href="https://www.deezer.com" crossorigin />
    <link rel="preconnect" href="https://www.youtube.com" crossorigin />
    <link rel="preconnect" href="https://cdn.usefathom.com" crossorigin />
    <SEO
      title={pageSeo.title}
      description={pageSeo.description}
      keywords={pageSeo.keywordArray}
      image={pageSeo.image}
      imageAlt={pageSeo.imageAlt}
      canonical={pageSeo.canonical}
      publishDate={pageSeo.publishDate}
      modifiedDate={pageSeo.modifiedDate}
      structuredDataExtra={pageSeo.structuredData}
      authorName={pageSeo.authorName}
    />
    <meta name="robots" content={pageSeo.robots} />
    <meta name="language" content={language} />
    <meta name="revisit-after" content="7 days" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <meta property="og:type" content={pageSeo.openGraph.type} />
    <meta property="og:url" content={pageSeo.openGraph.url} />
    <meta property="og:title" content={pageSeo.openGraph.title} />
    <meta property="og:description" content={pageSeo.openGraph.description} />
    {
      pageSeo.openGraph.image && (
        <meta property="og:image" content={pageSeo.openGraph.image} />
      )
    }
    <meta property="og:site_name" content={siteTitle} />
    <meta
      property="og:locale"
      content={pageSeo.openGraph.locale || locale.replace("-", "_")}
    />
    {type === "article" && <meta property="article:author" content={author} />}
    <meta property="twitter:card" content={pageSeo.twitter.card} />
    <meta property="twitter:url" content={pageSeo.canonical} />
    <meta property="twitter:title" content={pageSeo.twitter.title} />
    <meta property="twitter:description" content={pageSeo.twitter.description} />
    {
      pageSeo.twitter.image && (
        <meta property="twitter:image" content={pageSeo.twitter.image} />
      )
    }
    <meta name="twitter:image:alt" content={imageAlt} />
    {
      pageSeo.twitter.creator && (
        <meta property="twitter:creator" content={pageSeo.twitter.creator} />
      )
    }
    <meta property="twitter:site" content="@melodymind" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed - English"
      href="/podcast.xml"
      hreflang={locale}
    />
    <link rel="dns-prefetch" href="//cdn.usefathom.com" />
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="IGOFKHTB" defer
    ></script>
  </Fragment>

  <a slot="body-start" href="#main-content" class="podcast-layout__skip-link">
    {skipLinkText}
  </a>
  <Footer slot="after-main" />
  <AutoInitScript slot="body-end" />

  <slot />
</MasterLayout>

<style>
  .podcast-layout {
    --podcast-surface-soft: color-mix(in srgb, var(--surface-2) 84%, transparent);
    --podcast-surface-strong: color-mix(in srgb, var(--surface-3) 88%, transparent);
    --podcast-surface-accent: color-mix(
      in srgb,
      var(--surface-3) 96%,
      var(--accent-primary) 4%
    );
    --podcast-surface-raised: color-mix(
      in srgb,
      var(--surface-1) 92%,
      var(--bg-primary) 8%
    );
    --podcast-border-soft: color-mix(
      in srgb,
      var(--accent-primary) 38%,
      var(--border-default) 62%
    );
    --podcast-border-default: color-mix(
      in srgb,
      var(--accent-primary) 52%,
      var(--border-default) 48%
    );
    --podcast-border-strong: color-mix(
      in srgb,
      var(--accent-primary) 68%,
      var(--border-default) 32%
    );
    --podcast-accent-soft-bg: color-mix(
      in srgb,
      var(--accent-primary) 24%,
      var(--podcast-surface-strong) 76%
    );
    --podcast-text-muted: color-mix(in srgb, var(--text-primary) 82%, transparent);
    --podcast-text-subtle: color-mix(in srgb, var(--text-primary) 72%, transparent);
    --podcast-error-soft: color-mix(in srgb, var(--color-error) 24%, transparent);
    --podcast-title-shadow: 0 1px 0 color-mix(in srgb, var(--surface-1) 36%, transparent);
    --podcast-hero-surface: linear-gradient(
      160deg,
      color-mix(in srgb, var(--surface-2) 90%, transparent),
      color-mix(in srgb, var(--surface-1) 94%, transparent)
    );
    --podcast-hero-orb-1: radial-gradient(
      ellipse at 12% 18%,
      color-mix(in srgb, var(--accent-primary) 16%, transparent),
      transparent 48%
    );
    --podcast-hero-orb-2: radial-gradient(
      ellipse at 88% 16%,
      color-mix(in srgb, var(--accent-strong) 14%, transparent),
      transparent 44%
    );
    --podcast-hero-orb-3: radial-gradient(
      ellipse at 52% 86%,
      color-mix(in srgb, var(--accent-muted) 12%, transparent),
      transparent 52%
    );
    --podcast-brand-gradient: linear-gradient(
      135deg,
      color-mix(in srgb, var(--surface-1) 72%, var(--accent-primary) 28%) 0%,
      color-mix(in srgb, var(--surface-2) 58%, var(--accent-primary) 42%) 50%,
      color-mix(in srgb, var(--surface-3) 56%, var(--accent-strong) 44%) 100%
    );
    --podcast-brand-gradient-subtle: linear-gradient(
      135deg,
      color-mix(in srgb, var(--surface-2) 88%, transparent) 0%,
      color-mix(in srgb, var(--surface-1) 92%, var(--accent-primary) 8%) 100%
    );
    --podcast-glass-bg: color-mix(in srgb, var(--surface-2) 72%, transparent);
    --podcast-glass-border: var(--podcast-border-soft);
    --podcast-shadow-glow: 0 0 32px
      color-mix(in srgb, var(--accent-primary) 30%, transparent);
    --max-width: 80rem;

    min-block-size: 100vb;
    margin: 0;
    font-family: "Atkinson Hyperlegible", system-ui, sans-serif;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--text-primary);
    letter-spacing: 0.005em;
    text-wrap: pretty;
    background-color: var(--bg-primary);
    background-image:
      radial-gradient(
        ellipse at 10% 10%,
        color-mix(in srgb, var(--accent-primary) 12%, transparent),
        transparent 40%
      ),
      radial-gradient(
        ellipse at 90% 20%,
        color-mix(in srgb, var(--accent-strong) 10%, transparent),
        transparent 35%
      ),
      radial-gradient(
        ellipse at 50% 80%,
        color-mix(in srgb, var(--accent-muted) 8%, transparent),
        transparent 45%
      );
    text-rendering: optimizelegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  .podcast-layout__container {
    display: grid;
    gap: var(--spacing-xl);
    max-inline-size: var(--max-width);
    padding-block: var(--spacing-base);
    padding-inline: var(--spacing-sm);
    margin: 0 auto;
  }

  .podcast-layout__main {
    outline: none;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .podcast-layout__skip-link {
      transition: none;
    }
  }

  .podcast-layout__skip-link {
    position: fixed;
    inset-block-start: var(--spacing-sm);
    inset-inline-start: 50%;
    z-index: 1000;
    inline-size: auto;
    block-size: auto;
    padding: var(--spacing-sm) var(--spacing-lg);
    font-weight: 600;
    color: var(--bg-primary);
    text-decoration: none;
    background: var(--accent-primary);
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-lg), var(--podcast-shadow-glow);
    transform: translateX(-50%) translateY(-200%);
    transition: transform var(--transition-fast);
  }

  .podcast-layout__skip-link:focus,
  .podcast-layout__skip-link:focus-visible {
    outline: 3px solid var(--text-primary);
    outline-offset: 3px;
    transform: translateX(-50%) translateY(0);
  }

  @media (width >= 480px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-base);
    }
  }

  @media (width >= 768px) {
    .podcast-layout__container {
      padding-block: var(--spacing-xl);
      padding-inline: var(--spacing-xl);
    }
  }

  @media (width >= 1024px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-2xl);
    }
  }

  @media (width >= 1280px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-3xl);
    }
  }
</style>
