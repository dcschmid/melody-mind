---
import MasterLayout from "@shared-ui/components/layout/MasterLayout.astro";
import SEO from "@shared-ui/components/meta/SEO.astro";
import SiteHeader from "@shared-ui/components/navigation/SiteHeader.astro";
import SkipLink from "@shared-ui/components/navigation/SkipLink.astro";
import SharedFooter from "@shared-ui/components/layout/Footer.astro";
import AutoInitScript from "@shared-ui/components/init/AutoInitScript.astro";
import { buildPageSeo } from "@shared-utils/utils/seo/buildPageSeo";
import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import type { NavItem } from "@shared-ui/components/navigation/types";
import {
  buildOrganizationSchema,
  buildPodcastEpisodeSchema,
  buildPodcastSeriesSchema,
  buildWebSiteSchema,
} from "@shared-utils/utils/seo/seoSchema";
import {
  PODCAST_FEED_PATH,
  PODCAST_FEED_URL,
  PODCAST_IMAGE_URL,
  PODCAST_PLATFORM_URLS,
  PODCAST_PRECONNECT_ORIGINS,
  PODCAST_SITE_URL,
} from "../constants/podcastLinks";
import { normalizeWhitespace, toIsoDuration } from "../utils/podcastPresentation";

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  keywords?: string[];
  canonical?: string;
  language?: string;
  locale?: string;
  episodeNumber?: number;
  durationSeconds?: number | undefined;
  audioUrl?: string;
  episodeImage?: string;
  seriesDescription?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  structuredData?: Array<Record<string, unknown>>;
  index?: boolean;
  follow?: boolean;
}

const {
  title,
  description,
  image = "/images/default-og.jpg",
  type = "website",
  publishedTime,
  modifiedTime,
  author = "MelodyMind Podcasts",
  keywords = [],
  canonical,
  language = "en",
  locale = "en-US",
  episodeNumber,
  durationSeconds,
  audioUrl,
  episodeImage,
  seriesDescription,
  breadcrumbs = [],
  structuredData = [],
  index = true,
  follow = true,
} = Astro.props;

const siteTitle = "MelodyMind Podcasts";
const normalizedTitle = normalizeWhitespace(title);
const fullTitle = normalizedTitle.toLowerCase().includes(siteTitle.toLowerCase())
  ? normalizedTitle
  : `${normalizedTitle} | ${siteTitle}`;
const siteUrl = PODCAST_SITE_URL;
const currentPath = canonical ? canonical.replace(siteUrl, "") : Astro.url.pathname;
const currentUrl = `${siteUrl}${ensureTrailingSlash(currentPath)}`;
const imageUrl = image.startsWith("http") ? image : `${siteUrl}${image}`;
const episodeImageUrl = episodeImage
  ? episodeImage.startsWith("http")
    ? episodeImage
    : `${siteUrl}${episodeImage}`
  : imageUrl;
const podcastFeedUrl = PODCAST_FEED_URL;
const podcastImage = PODCAST_IMAGE_URL;
const seriesCopy =
  seriesDescription ||
  "Melody Mind explores the stories behind the music that shaped generations, with Daniel and Annabelle.";
const defaultKeywords = [
  "podcast",
  "music history",
  "audio",
  "streaming",
  "entertainment",
];
const normalizedDescription = normalizeWhitespace(description);
const imageAlt =
  type === "article"
    ? `Cover artwork for ${normalizedTitle}`
    : `Cover artwork for ${siteTitle}`;
const publishDate = publishedTime ? new Date(publishedTime) : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime) : undefined;
const navItems: NavItem[] = [
  {
    href: "https://www.melody-mind.de",
    label: "Knowledge",
    icon: "book-open",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    href: "https://www.quiz.melody-mind.de",
    label: "Quiz",
    icon: "book-open",
    target: "_blank",
    rel: "noopener noreferrer",
  },
  {
    href: "/search",
    label: "Search",
    icon: "search",
  },
];

const publisher = {
  "@type": "Organization",
  name: "MelodyMind Podcasts",
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: podcastImage,
  },
};

const episodeDurationIso =
  typeof durationSeconds === "number" && durationSeconds > 0
    ? toIsoDuration(durationSeconds)
    : undefined;
const authorNames = ["Daniel Schmid", "Annabelle"];

const organizationSchema = buildOrganizationSchema({
  siteUrl,
  siteName: siteTitle,
  description: seriesCopy,
  logoUrl: podcastImage,
});

const webSiteSchema = buildWebSiteSchema({
  siteUrl,
  siteName: siteTitle,
  description: seriesCopy,
  searchPathTemplate: "/search?q={search_term_string}",
});

const podcastSeriesJson = buildPodcastSeriesSchema({
  siteUrl,
  title: siteTitle,
  description: seriesCopy,
  locale,
  imageUrl: podcastImage,
  feedUrl: podcastFeedUrl,
  sameAs: PODCAST_PLATFORM_URLS,
  authorNames,
  publisherName: publisher.name,
  publisherLogoUrl: podcastImage,
});

const podcastEpisodeJson =
  type === "article"
    ? buildPodcastEpisodeSchema({
        title: normalizedTitle,
        description: normalizedDescription,
        url: currentUrl,
        seriesTitle: siteTitle,
        seriesUrl: siteUrl,
        locale,
        imageUrl: episodeImageUrl,
        ...(publishedTime ? { publishedAt: publishedTime } : {}),
        ...(modifiedTime || publishedTime
          ? { modifiedAt: modifiedTime || publishedTime }
          : {}),
        ...(typeof episodeNumber === "number" ? { episodeNumber } : {}),
        ...(episodeDurationIso ? { durationIso: episodeDurationIso } : {}),
        ...(audioUrl ? { audioUrl } : {}),
        authorNames,
        publisherName: publisher.name,
        publisherLogoUrl: podcastImage,
      })
    : undefined;

const seoStructuredData = [
  organizationSchema,
  webSiteSchema,
  podcastSeriesJson,
  podcastEpisodeJson,
  ...structuredData,
].filter((item): item is StructuredData => Boolean(item));

const pageSeo = buildPageSeo({
  title: fullTitle,
  description: normalizedDescription,
  url: currentUrl,
  image: imageUrl,
  imageAlt,
  type: type === "article" ? "article" : "website",
  structuredData: seoStructuredData,
  fallbackKeywords: [...defaultKeywords, ...keywords],
  breadcrumbs,
  index,
  follow,
  maxImagePreview: "large",
  maxSnippet: -1,
  maxVideoPreview: -1,
  ogLocale: locale.replace("-", "_"),
  twitterCreator: "@melodymind",
  authorName: author,
  brandSuffix: false,
  ...(publishDate ? { publishDate } : {}),
  ...(modifiedDate ? { modifiedDate } : {}),
});

const seoProps = {
  title: pageSeo.title,
  description: pageSeo.description,
  keywords: pageSeo.keywordArray,
  canonical: pageSeo.canonical,
  structuredDataExtra: pageSeo.structuredData,
  ...(pageSeo.image ? { image: pageSeo.image } : {}),
  ...(pageSeo.imageAlt ? { imageAlt: pageSeo.imageAlt } : {}),
  ...(pageSeo.publishDate ? { publishDate: pageSeo.publishDate } : {}),
  ...(pageSeo.modifiedDate ? { modifiedDate: pageSeo.modifiedDate } : {}),
  ...(pageSeo.authorName ? { authorName: pageSeo.authorName } : {}),
};

function ensureTrailingSlash(pathname: string) {
  if (!pathname.startsWith("/")) {
    return `/${pathname}/`;
  }

  return pathname.endsWith("/") ? pathname : `${pathname}/`;
}
---

<MasterLayout
  lang={language}
  bodyClass="podcast-layout"
  mainClass="podcast-layout__main"
  contentShellClass="podcast-layout__container"
  showSkipLink={false}
  enableThemeInit={true}
  appTitle="Melody Mind Podcasts"
>
  <Fragment slot="head">
    <link
      rel="preload"
      href="/fonts/atkinson-hyperlegible-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      PODCAST_PRECONNECT_ORIGINS.map((origin) => (
        <link rel="preconnect" href={origin} crossorigin />
      ))
    }
    <link rel="preconnect" href="https://cdn.usefathom.com" crossorigin />
    <SEO {...seoProps} />
    <meta name="robots" content={pageSeo.robots} />
    <meta name="language" content={language} />
    <meta name="revisit-after" content="7 days" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <meta property="og:type" content={pageSeo.openGraph.type} />
    <meta property="og:url" content={pageSeo.openGraph.url} />
    <meta property="og:title" content={pageSeo.openGraph.title} />
    <meta property="og:description" content={pageSeo.openGraph.description} />
    {
      pageSeo.openGraph.image && (
        <meta property="og:image" content={pageSeo.openGraph.image} />
      )
    }
    <meta property="og:site_name" content={siteTitle} />
    <meta
      property="og:locale"
      content={pageSeo.openGraph.locale || locale.replace("-", "_")}
    />
    {type === "article" && <meta property="article:author" content={author} />}
    <meta property="twitter:card" content={pageSeo.twitter.card} />
    <meta property="twitter:url" content={pageSeo.canonical} />
    <meta property="twitter:title" content={pageSeo.twitter.title} />
    <meta property="twitter:description" content={pageSeo.twitter.description} />
    {
      pageSeo.twitter.image && (
        <meta property="twitter:image" content={pageSeo.twitter.image} />
      )
    }
    <meta name="twitter:image:alt" content={imageAlt} />
    {
      pageSeo.twitter.creator && (
        <meta property="twitter:creator" content={pageSeo.twitter.creator} />
      )
    }
    <meta property="twitter:site" content="@melodymind" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed - English"
      href={PODCAST_FEED_PATH}
      hreflang={locale}
    />
    <link rel="dns-prefetch" href="//cdn.usefathom.com" />
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="IGOFKHTB" defer
    ></script>
  </Fragment>

  <SkipLink slot="body-start" />
  <SiteHeader
    slot="before-main"
    {navItems}
    brandHref="/"
    brandText={siteTitle}
    brandLogoSrc="/melody-mind-podcast.png"
    brandLogoAlt={siteTitle}
    brandLogoWidth={1024}
    brandLogoHeight={1024}
    brandAriaLabel={`Go to the ${siteTitle} homepage`}
    menuOpenLabel="Open main menu"
    menuCloseLabel="Close main menu"
    menuText="Menu"
    navAriaLabel="Podcast navigation"
  />

  <SharedFooter
    slot="after-main"
    brandTitle="Melody Mind"
    brandText="Curated stories, timelines, and playlists to help you listen more closely and discover new sounds."
    exploreLinks={[
      {
        href: "https://quiz.melody-mind.de",
        label: "Quiz",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "https://melody-mind.de",
        label: "Knowledge",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      { href: PODCAST_FEED_PATH, label: "RSS" },
    ]}
    supportLinks={[
      {
        href: "https://www.paypal.me/dcschmid",
        label: "PayPal",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "https://www.buymeacoffee.com/dcschmid",
        label: "Buy Me a Coffee",
        target: "_blank",
        rel: "noopener noreferrer",
      },
    ]}
    legalLinks={[
      {
        href: "https://melody-mind.de/imprint",
        label: "Legal Notice",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "https://melody-mind.de/privacy",
        label: "Privacy Policy",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "https://melody-mind.de/cookies",
        label: "Cookie Policy",
        target: "_blank",
        rel: "noopener noreferrer",
      },
      {
        href: "https://melody-mind.de/ai-content",
        label: "AI Content",
        target: "_blank",
        rel: "noopener noreferrer",
      },
    ]}
    showSettings={true}
    copyrightText={`© ${new Date().getFullYear()} MelodyMind. All rights reserved.`}
  />

  <AutoInitScript slot="body-end" />

  <slot />
</MasterLayout>

<style>
  :global(.podcast-layout) {
    background: var(--page-background);
  }

  :global(.podcast-layout__main) {
    position: relative;
  }

  :global(.podcast-layout__main)::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(
        circle at top center,
        color-mix(in srgb, var(--accent-primary) 10%, transparent),
        transparent 48%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--surface-1) 18%, transparent),
        transparent 28%
      );
  }

  .podcast-layout__container {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--spacing-xl);
    max-inline-size: var(--max-width);
    padding-block: var(--spacing-base);
    padding-inline: var(--spacing-sm);
    margin: 0 auto;
  }

  @media (width >= 480px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-base);
    }
  }

  @media (width >= 768px) {
    .podcast-layout__container {
      padding-block: var(--spacing-xl);
      padding-inline: var(--spacing-xl);
    }
  }

  @media (width >= 1024px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-2xl);
    }
  }

  @media (width >= 1280px) {
    .podcast-layout__container {
      padding-inline: var(--spacing-3xl);
    }
  }
</style>
