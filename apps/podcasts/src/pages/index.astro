---
import PodcastLayout from "../layouts/PodcastLayout.astro";
import PodcastPlatformLinks from "../components/PodcastPlatformLinks.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import SectionSurface from "@shared-ui/components/layout/SectionSurface.astro";
import {
  buildCollectionPageSchema,
  buildPodcastEpisodesItemListSchema,
  type PodcastEpisodeListItem,
} from "@shared-utils/utils/seo/seoSchema";
import type { StructuredData } from "@shared-utils/utils/seo/buildPageSeo";
import { formatDate } from "@shared-utils/utils/format";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";
import type { PodcastData } from "../types/podcast";

import { getAvailablePodcasts } from "../utils/podcasts";
import {
  getPodcastCoverImage,
  getPodcastCoverImageUrl,
  podcastHeroImage,
  podcastHeroImageUrl,
} from "../utils/podcastImages";
import {
  buildEpisodeMetaItems,
  normalizeSearchText,
  toIsoDuration,
} from "../utils/podcastPresentation";

const podcasts: PodcastData[] = await getAvailablePodcasts();
const sortedPodcasts = [...podcasts].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);

const buildEpisodeListItem = (podcast: PodcastData): PodcastEpisodeListItem => {
  const durationIso = toIsoDuration(podcast.durationSeconds);

  return {
    title: podcast.title,
    description: podcast.description,
    url: resolvePageUrl(Astro.site, `/${podcast.id}`),
    image: getPodcastCoverImageUrl(podcast.imageUrl) ?? podcastHeroImageUrl,
    publishedAt: podcast.publishedAt,
    ...(durationIso ? { durationIso } : {}),
  };
};

const episodeEntries = sortedPodcasts.map((podcast, index) => ({
  id: podcast.id,
  title: podcast.title,
  description: podcast.description,
  imageSrc: getPodcastCoverImage(podcast.imageUrl) ?? podcastHeroImage,
  durationSeconds: podcast.durationSeconds,
  publishedAt: podcast.publishedAt,
  publishedLabel: formatDate(podcast.publishedAt),
  isLatest: index === 0,
  searchText: normalizeSearchText(`${podcast.title} ${podcast.description}`),
  metaItems: buildEpisodeMetaItems(podcast.publishedAt, podcast.durationSeconds),
}));
const canonical = resolvePageUrl(Astro.site, "/");
const breadcrumbs = [{ name: "Home", url: canonical }];
const episodeListId = `${canonical}#podcast-itemlist`;

const t = {
  title: "MelodyMind Podcasts",
  seoTitle: "MelodyMind Podcasts | Music History with Daniel and Annabelle",
  subtitle: "A music history podcast with Daniel & Annabelle",
  description:
    "Welcome to MelodyMind Podcasts, a music history podcast about the stories, scenes, and artists that shaped each era. Daniel and Annabelle guide you from 1950s rock 'n' roll to the streaming era with thoughtful listening and cultural context.",
  seoDescription:
    "Official site of MelodyMind Podcasts, a music history podcast with Daniel and Annabelle. Explore episodes that move from 1950s rock 'n' roll to the present day.",
  episodes: "Episodes",
  availableOn: "Listen on:",
  keywords: [
    "melodymind podcasts",
    "music history podcast",
    "daniel and annabelle",
    "music decades",
    "rock and roll",
    "music culture",
    "vintage music",
    "music documentary",
    "audio stories",
  ],
  rssFeed: "RSS Feed",
  heroImageAlt: "MelodyMind Podcasts cover image",
};

const collectionPageSchema = buildCollectionPageSchema({
  url: canonical,
  name: t.title,
  description: t.seoDescription,
  lang: "en",
  image: podcastHeroImageUrl,
  mainEntityId: episodeListId,
});

const episodeListSchema = buildPodcastEpisodesItemListSchema({
  episodes: sortedPodcasts.map(buildEpisodeListItem),
  listName: "MelodyMind Podcast Episodes",
  itemListId: episodeListId,
});

const structuredData = [collectionPageSchema, episodeListSchema].filter(
  (item): item is StructuredData => Boolean(item)
);
---

<PodcastLayout
  title={t.seoTitle}
  description={t.seoDescription}
  keywords={t.keywords}
  type="website"
  image={podcastHeroImageUrl}
  language="en"
  locale="en-US"
  seriesDescription={t.seoDescription}
  canonical={canonical}
  {breadcrumbs}
  {structuredData}
>
  <PageShell className="page-shell--aurora">
    <div class="home">
      <section
        id="podcast-home-hero"
        class="home__hero"
        aria-labelledby="podcast-home-hero-title"
        aria-describedby="podcast-home-hero-description"
      >
        <div class="home__hero-media">
          <img
            src={podcastHeroImage.src}
            alt={t.heroImageAlt}
            class="home__hero-image"
            width="1200"
            height="800"
            loading="eager"
            decoding="sync"
          />
        </div>

        <div class="home__hero-copy">
          <p class="home__hero-eyebrow">{t.subtitle}</p>
          <Headline
            id="podcast-home-hero-title"
            level="h1"
            textSize="xl"
            className="home__hero-title"
          >
            MelodyMind Podcasts
          </Headline>
          <p id="podcast-home-hero-description" class="home__hero-description">
            {t.description}
          </p>
          <div class="home__hero-actions">
            <PodcastPlatformLinks ariaLabel={t.availableOn} rssLabel={t.rssFeed} />
          </div>
        </div>
      </section>

      <SectionSurface
        as="section"
        className="home__episodes"
        variant="accent"
        aria-labelledby="episodes-heading"
      >
        <Headline level="h2" textSize="xl" className="home__section-title">
          <span id="episodes-heading">{t.episodes}</span>
        </Headline>

        <div class="home__episodes-grid" role="list" id="episodes-list">
          {
            episodeEntries.map((podcast) => (
              <ContentCard
                id={`episode-card-${podcast.id}`}
                data-episode
                data-search={podcast.searchText}
                role="listitem"
                href={`/${podcast.id}`}
                variant="feature"
                size="spacious"
                mediaObjectFit="contain"
                imageSrc={podcast.imageSrc}
                imageAlt={`Cover art for the podcast episode ${podcast.title}`}
                imageWidth={1536}
                imageHeight={1024}
                title={podcast.title}
                description={podcast.description}
                metaItems={podcast.metaItems}
                descriptionLineClamp={3}
                ctaLabel="View Episode"
              >
                <Fragment slot="badge">
                  {podcast.isLatest && <span class="episode-card__badge">Latest</span>}
                </Fragment>
              </ContentCard>
            ))
          }
        </div>
        {
          podcasts.length === 0 && (
            <EmptyState
              className="home__empty"
              description="No episodes available yet. Check back soon for new content!"
            />
          )
        }
      </SectionSurface>
    </div>
  </PageShell>
</PodcastLayout>

<style>
  .episode-card__badge {
    padding: var(--spacing-2xs) var(--spacing-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: color-mix(in srgb, var(--accent-primary) 10%, var(--surface-1));
    border: 1px solid var(--surface-border-accent);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xs);
  }

  .home {
    display: grid;
    gap: var(--spacing-xl);
  }

  .home__hero {
    position: relative;
    display: grid;
    gap: clamp(var(--spacing-lg), 3vw, var(--spacing-2xl));
    align-items: center;
    padding-block-end: clamp(var(--spacing-xl), 4vw, var(--spacing-2xl));
  }

  .home__hero-media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-2) 82%, transparent),
      color-mix(in srgb, var(--surface-1) 88%, transparent)
    );
    border: 1px solid color-mix(in srgb, var(--surface-border-soft) 90%, transparent);
    border-radius: calc(var(--radius-xl) + var(--spacing-2xs));
    box-shadow: var(--shadow-lg);
  }

  .home__hero-media::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(
        180deg,
        transparent 55%,
        color-mix(in srgb, var(--surface-1) 18%, transparent)
      ),
      linear-gradient(
        90deg,
        transparent 60%,
        color-mix(in srgb, var(--surface-1) 14%, transparent)
      );
  }

  .home__hero-image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
  }

  .home__hero-copy {
    display: grid;
    gap: clamp(var(--spacing-base), 2vw, var(--spacing-lg));
    align-content: center;
    min-inline-size: 0;
  }

  .home__hero-eyebrow {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .home__hero-title {
    margin: 0;
    font-size: clamp(2.8rem, 5.8vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .home__hero-title-line {
    display: block;
  }

  .home__hero-description {
    max-inline-size: 38rem;
    margin: 0;
    font-size: clamp(1rem, 1.4vw, 1.18rem);
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .home__hero-actions {
    display: grid;
    margin-block-start: var(--spacing-xs);
  }

  .home__hero-actions :global(.podcast-platform-links) {
    grid-template-columns: repeat(auto-fit, minmax(7.5rem, max-content));
    gap: var(--spacing-sm);
  }

  .home__hero-actions :global(.podcast-platform-links__link) {
    min-block-size: 3rem;
    padding: 0.8rem 1rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    background: color-mix(in srgb, var(--surface-1) 86%, transparent);
    border-color: color-mix(in srgb, var(--surface-border-soft) 94%, transparent);
    box-shadow: none;
  }

  .home__hero-actions :global(.podcast-platform-links__link:hover),
  .home__hero-actions :global(.podcast-platform-links__link:focus-visible) {
    background: color-mix(in srgb, var(--surface-card-hover) 92%, transparent);
    transform: translateY(-2px);
  }

  .home__hero-actions :global(.podcast-platform-links__link--secondary) {
    color: #05292b;
    background: linear-gradient(135deg, #35dfd0, #2dc7d7);
    border-color: color-mix(in srgb, #62efe3 40%, transparent);
    box-shadow: 0 1rem 2rem color-mix(in srgb, #35dfd0 20%, transparent);
  }

  .home__hero-actions :global(.podcast-platform-links__link--secondary:hover),
  .home__hero-actions :global(.podcast-platform-links__link--secondary:focus-visible) {
    background: linear-gradient(135deg, #45ead9, #39d4e3);
    border-color: color-mix(in srgb, #8ef4ec 48%, transparent);
  }

  .home__episodes {
    display: grid;
    gap: var(--spacing-lg);
  }

  .home :global(.home__episodes) {
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .home :global(.content-card) {
    border-color: transparent;
  }

  .home :global(.content-card__media) {
    border-block-end: 0;
  }

  .home__section-title {
    margin: 0;
    color: var(--text-primary);
  }

  .home__episodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: var(--spacing-lg);
  }

  @media (width >= 960px) {
    .home__hero {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr);
      gap: clamp(var(--spacing-xl), 4vw, var(--spacing-3xl));
    }

    .home__episodes-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (width < 40rem) {
    .home__hero {
      gap: var(--spacing-lg);
      padding-block-end: var(--spacing-xl);
    }

    .home__episodes {
      gap: var(--spacing-base);
    }
  }
</style>
