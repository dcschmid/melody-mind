---
import PodcastLayout from "../layouts/PodcastLayout.astro";
import HomeHero from "../components/HomeHero.astro";
import ContentCard from "@shared-ui/components/cards/ContentCard.astro";
import EmptyState from "@shared-ui/components/layout/EmptyState.astro";
import PageShell from "@shared-ui/components/layout/PageShell.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";
import SearchForm from "@shared-ui/components/search/SearchForm.astro";
import type { ContentCardMetaItem } from "@shared-ui/components/cards/contentCard";
import {
  buildCollectionPageSchema,
  buildPodcastEpisodesItemListSchema,
} from "@shared-utils/utils/seo/seoSchema";
import type { PodcastData } from "../types/podcast";
import { formatDate } from "../utils/helpers";
import { resolvePageUrl } from "@shared-utils/utils/siteUrls";

import { getAvailablePodcasts } from "../utils/podcasts";
import { PAGINATION_CONFIG } from "../constants";

const podcasts: PodcastData[] = await getAvailablePodcasts();
const sortedPodcasts = [...podcasts].sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);
const normalizeSearchText = (value: string) =>
  value.toLowerCase().replace(/\s+/g, " ").trim();
const buildEpisodeMetaItems = (
  publishedAt: string,
  durationSeconds?: number
): ContentCardMetaItem[] => {
  const items: ContentCardMetaItem[] = [
    {
      iconName: "calendar",
      label: formatDate(publishedAt),
      datetime: publishedAt,
    },
  ];

  if (durationSeconds) {
    items.push({
      iconName: "headphones",
      label: `${Math.floor(durationSeconds / 60)} min`,
    });
  }

  return items;
};

const toIsoDuration = (durationSeconds?: number): string | undefined => {
  if (!durationSeconds || durationSeconds <= 0) {
    return undefined;
  }

  const hours = Math.floor(durationSeconds / 3600);
  const minutes = Math.floor((durationSeconds % 3600) / 60);
  const seconds = Math.floor(durationSeconds % 60);

  return `PT${hours > 0 ? `${hours}H` : ""}${minutes > 0 ? `${minutes}M` : ""}${seconds || (!hours && !minutes) ? `${seconds}S` : ""}`;
};

const episodeEntries = sortedPodcasts.map((podcast, index) => ({
  id: podcast.id,
  title: podcast.title,
  description: podcast.description,
  imageUrl: podcast.imageUrl,
  durationSeconds: podcast.durationSeconds,
  publishedAt: podcast.publishedAt,
  publishedLabel: formatDate(podcast.publishedAt),
  isLatest: index === 0,
  searchText: normalizeSearchText(`${podcast.title} ${podcast.description}`),
  metaItems: buildEpisodeMetaItems(podcast.publishedAt, podcast.durationSeconds),
}));
const initialEpisodes = episodeEntries.slice(0, PAGINATION_CONFIG.EPISODES_PER_PAGE);
const templateEpisode = episodeEntries[0];
const serializedEpisodes = JSON.stringify(episodeEntries).replace(/</g, "\\u003c");
const encodedEpisodes = Buffer.from(serializedEpisodes, "utf8").toString("base64");
const canonical = resolvePageUrl(Astro.site, "/");
const breadcrumbs = [{ name: "Home", url: canonical }];
const episodeListId = `${canonical}#podcast-itemlist`;

const t = {
  title: "MelodyMind Podcasts",
  seoTitle: "MelodyMind Podcasts | Music History with Daniel and Annabelle",
  subtitle: "A music history podcast with Daniel & Annabelle",
  description:
    "Welcome to MelodyMind Podcasts, a music history podcast about the stories, scenes, and artists that shaped each era. Daniel and Annabelle guide you from 1950s rock 'n' roll to the streaming era with thoughtful listening and cultural context.",
  seoDescription:
    "Official site of MelodyMind Podcasts, a music history podcast with Daniel and Annabelle. Explore episodes that move from 1950s rock 'n' roll to the present day.",
  episodes: "Episodes",
  featuredContent:
    "Discover the voices, rhythms, and turning points that shaped each musical era",
  totalEpisodes: " episodes available",
  availableOn: "Listen on:",
  spotifyUrl: "https://open.spotify.com/show/1qCTySbRctOad9Oi3FGpoF",
  deezerUrl: "https://www.deezer.com/en/show/1002678961",
  youtubeUrl: "https://www.youtube.com/channel/UCD7MQkWw4P5Pd5xA_o6McLg",
  keywords: [
    "melodymind podcasts",
    "music history podcast",
    "daniel and annabelle",
    "music decades",
    "rock and roll",
    "music culture",
    "vintage music",
    "music documentary",
    "audio stories",
  ],
};

const collectionPageSchema = buildCollectionPageSchema({
  url: canonical,
  name: t.title,
  description: t.seoDescription,
  lang: "en",
  image: "https://podcasts.melody-mind.de/the-melody-mind-podcast.jpg",
  mainEntityId: episodeListId,
});

const episodeListSchema = buildPodcastEpisodesItemListSchema({
  episodes: sortedPodcasts.map((podcast) => ({
    title: podcast.title,
    description: podcast.description,
    url: resolvePageUrl(Astro.site, `/${podcast.id}`),
    image: `https://podcasts.melody-mind.de/images/${podcast.imageUrl}.jpg`,
    publishedAt: podcast.publishedAt,
    durationIso: toIsoDuration(podcast.durationSeconds),
  })),
  listName: "MelodyMind Podcast Episodes",
  itemListId: episodeListId,
});
---

<PodcastLayout
  title={t.seoTitle}
  description={t.seoDescription}
  keywords={t.keywords}
  type="website"
  language="en"
  locale="en-US"
  seriesDescription={t.seoDescription}
  canonical={canonical}
  {breadcrumbs}
  structuredData={[collectionPageSchema, episodeListSchema].filter(Boolean)}
>
  <PageShell className="page-shell--aurora">
    <div class="home">
      <HomeHero
        title={t.title}
        subtitle={t.subtitle}
        description={t.description}
        totalEpisodes={podcasts.length}
        featuredContent={t.featuredContent}
        availableOn={t.availableOn}
        spotifyUrl={t.spotifyUrl}
        deezerUrl={t.deezerUrl}
        youtubeUrl={t.youtubeUrl}
      />

      <SearchForm
        label="Search episodes"
        placeholder="Search by title or description"
        clearLabel="Clear search"
        hintText="Submit to open the dedicated search page with a shareable query URL."
        inputId="episode-search"
        hintId="search-hint"
        action="/search"
        method="get"
      />

      <section class="home__episodes" aria-labelledby="episodes-heading">
        <Headline level="h2" textSize="xl" className="home__section-title">
          <span id="episodes-heading">{t.episodes}</span>
        </Headline>

        <div class="home__episodes-grid" role="list" id="episodes-list">
          {
            initialEpisodes.map((podcast) => (
              <ContentCard
                id={`episode-card-${podcast.id}`}
                data-episode
                data-search={podcast.searchText}
                role="listitem"
                href={`/${podcast.id}`}
                variant="feature"
                size="spacious"
                imageSrc={`/images/${podcast.imageUrl}.jpg`}
                imageAlt={`Cover art for the podcast episode ${podcast.title}`}
                imageWidth={1536}
                imageHeight={1024}
                title={podcast.title}
                description={podcast.description}
                metaItems={podcast.metaItems}
                descriptionLineClamp={3}
                ctaLabel="View Episode"
              >
                <Fragment slot="badge">
                  {podcast.isLatest && <span class="episode-card__badge">Latest</span>}
                </Fragment>
              </ContentCard>
            ))
          }
        </div>
        {
          podcasts.length === 0 && (
            <EmptyState
              className="home__empty"
              description="No episodes available yet. Check back soon for new content!"
            />
          )
        }
        <div id="episodes-data" data-episodes={encodedEpisodes} hidden></div>
        {
          templateEpisode && (
            <div id="episode-template" hidden>
              <ContentCard
                id={`episode-card-${templateEpisode.id}`}
                data-episode
                data-search={templateEpisode.searchText}
                role="listitem"
                href={`/${templateEpisode.id}`}
                variant="feature"
                size="spacious"
                imageSrc={`/images/${templateEpisode.imageUrl}.jpg`}
                imageAlt={`Cover art for the podcast episode ${templateEpisode.title}`}
                imageWidth={1536}
                imageHeight={1024}
                title={templateEpisode.title}
                description={templateEpisode.description}
                metaItems={templateEpisode.metaItems}
                descriptionLineClamp={3}
                ctaLabel="View Episode"
              >
                <Fragment slot="badge">
                  {templateEpisode.isLatest && (
                    <span class="episode-card__badge">Latest</span>
                  )}
                </Fragment>
              </ContentCard>
            </div>
          )
        }
        <div class="home__load-more" id="episodes-load-more" hidden>
          <div class="home__load-more-panel" role="group" aria-label="More episodes">
            <Paragraph
              textSize="sm"
              className="home__load-more-status"
              id="episodes-load-more-status"
              role="status"
              aria-live="polite"
              aria-atomic="true"
            >
              Showing {Math.min(PAGINATION_CONFIG.EPISODES_PER_PAGE, podcasts.length)} of {
                podcasts.length
              } episodes.
            </Paragraph>
            <button
              class="home__load-more-button"
              id="episodes-load-more-button"
              type="button"
              aria-controls="episodes-list"
            >
              Show more episodes
            </button>
          </div>
        </div>
      </section>
    </div>
  </PageShell>

  <script>
    import "../scripts/episodes";
  </script>
</PodcastLayout>

<style>
  .episode-card__image {
    object-fit: cover;
    border-block-end: 1px solid color-mix(in srgb, var(--border-default) 85%, transparent);
  }

  .episode-card__badge {
    padding: 0.2em 0.6em;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--accent-primary) 14%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--accent-primary) 26%, var(--border-default));
    border-radius: var(--radius-full);
  }

  .home {
    display: grid;
    gap: 2rem;
  }

  .home__episodes {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--surface-1) 94%, transparent),
      var(--surface-2)
    );
    border: 1px solid var(--border-default);
    border-radius: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  .home__section-title {
    margin: 0;
    color: var(--text-primary);
  }

  .home__episodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 1.25rem;
  }

  .home__load-more {
    display: grid;
    justify-items: center;
    margin-block-start: 1.5rem;
  }

  .home__load-more-panel {
    display: grid;
    gap: 0.85rem;
    justify-items: center;
    inline-size: min(28rem, 100%);
    padding: 1.1rem 1.5rem;
    background: linear-gradient(
      150deg,
      color-mix(in srgb, var(--surface-3) 92%, transparent),
      color-mix(in srgb, var(--surface-2) 95%, transparent)
    );
    border: 1px solid var(--podcast-border-soft);
    border-radius: 1.25rem;
    box-shadow: var(--shadow-lg);
  }

  .home__load-more-status {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--podcast-text-muted);
    text-align: center;
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .home__load-more-button {
      padding: 0.65rem 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
      cursor: pointer;
      background: linear-gradient(
        135deg,
        color-mix(in srgb, var(--accent-primary) 35%, var(--surface-2)),
        color-mix(in srgb, var(--accent-primary) 22%, var(--surface-3))
      );
      border: 1px solid var(--podcast-border-default);
      border-radius: 999px;
      transition: none;
    }
  }

  .home__load-more-button {
    padding: 0.65rem 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--accent-primary) 35%, var(--surface-2)),
      color-mix(in srgb, var(--accent-primary) 22%, var(--surface-3))
    );
    border: 1px solid var(--podcast-border-default);
    border-radius: 999px;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .home__load-more-button:focus-visible {
    outline: none;
    box-shadow: var(--interactive-shadow-focus);
  }

  .home__load-more-button:hover,
  .home__load-more-button:focus-visible {
    border-color: var(--podcast-border-strong);
    box-shadow: var(--shadow-lg);
    transform: translateY(-1px);
  }

  .home__load-more-button[disabled] {
    cursor: not-allowed;
    box-shadow: none;
    opacity: 0.55;
    transform: none;
  }

  .home__empty {
    padding: var(--spacing-2xl) var(--spacing-lg);
    background: var(--surface-1);
    border: 1px solid var(--border-muted);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-base);
  }

  :global(.home__empty .empty-state__description) {
    font-size: var(--font-size-base);
    line-height: var(--line-height-loose);
    color: var(--text-secondary);
  }

  @media (width >= 960px) {
    .home__episodes-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (width < 40rem) {
    .home__episodes {
      padding: 1.25rem;
    }
  }
</style>
