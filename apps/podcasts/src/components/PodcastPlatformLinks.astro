---
import AccessibleExternalLink from "@shared-ui/components/links/AccessibleExternalLink.astro";
import AutoGrid from "@shared-ui/components/layout/AutoGrid.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import { PODCAST_FEED_PATH, PODCAST_PLATFORM_LINKS } from "../constants/podcastLinks";

interface Props {
  ariaLabel?: string;
  rssLabel?: string;
  appearance?: "default" | "hero";
  size?: "default" | "compact";
}

const {
  ariaLabel = "Listen on",
  rssLabel = "RSS Feed",
  appearance = "default",
  size = "default",
} = Astro.props as Props;
---

<AutoGrid
  className={`podcast-platform-links podcast-platform-links--${appearance} podcast-platform-links--size-${size}`}
  aria-label={ariaLabel}
  preset="auto-fit"
  min="sm"
  gap="sm"
>
  {
    PODCAST_PLATFORM_LINKS.map((link) => (
      <AccessibleExternalLink
        href={link.href}
        className="podcast-platform-links__link"
        aria-label={link.ariaLabel}
        target={link.target}
        rel={link.rel}
      >
        <Icon name={link.iconName} aria-hidden="true" />
        <span>{link.label}</span>
      </AccessibleExternalLink>
    ))
  }
  <a
    href={PODCAST_FEED_PATH}
    class="podcast-platform-links__link podcast-platform-links__link--secondary"
    aria-label="Subscribe via RSS"
  >
    <Icon name="wave" aria-hidden="true" />
    {rssLabel}
  </a>
</AutoGrid>

<style>
  .podcast-platform-links {
    align-items: center;
  }

  .podcast-platform-links__link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: center;
    min-block-size: calc(var(--spacing-2xl) + var(--spacing-xs));
    padding: var(--spacing-md) var(--spacing-lg);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    text-decoration: none;
    background: color-mix(in srgb, var(--surface-1) 74%, transparent);
    border: 1px solid var(--surface-border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .podcast-platform-links--size-compact .podcast-platform-links__link {
    min-block-size: 3rem;
    padding: 0.8rem 1rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
  }

  .podcast-platform-links__link:hover,
  .podcast-platform-links__link:focus-visible {
    background: var(--surface-card-hover);
    border-color: var(--surface-border-accent);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  .podcast-platform-links__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .podcast-platform-links__link--secondary {
    color: var(--button-text-accent);
    background: linear-gradient(
      135deg,
      var(--accent-primary),
      color-mix(in srgb, var(--accent-primary) 76%, var(--accent-strong))
    );
    border-color: var(--surface-border-accent);
  }

  .podcast-platform-links__link--secondary:hover,
  .podcast-platform-links__link--secondary:focus-visible {
    background: var(--accent-primary-hover);
    border-color: var(--surface-border-accent-strong);
  }

  .podcast-platform-links--hero .podcast-platform-links__link {
    background: color-mix(in srgb, var(--surface-1) 86%, transparent);
    border-color: color-mix(in srgb, var(--surface-border-soft) 94%, transparent);
    box-shadow: none;
  }

  .podcast-platform-links--hero .podcast-platform-links__link:hover,
  .podcast-platform-links--hero .podcast-platform-links__link:focus-visible {
    background: color-mix(in srgb, var(--surface-card-hover) 92%, transparent);
    transform: translateY(-2px);
  }

  .podcast-platform-links--hero .podcast-platform-links__link--secondary {
    color: #05292b;
    background: linear-gradient(135deg, #35dfd0, #2dc7d7);
    border-color: color-mix(in srgb, #62efe3 40%, transparent);
    box-shadow: 0 1rem 2rem color-mix(in srgb, #35dfd0 20%, transparent);
  }

  .podcast-platform-links--hero .podcast-platform-links__link--secondary:hover,
  .podcast-platform-links--hero .podcast-platform-links__link--secondary:focus-visible {
    background: linear-gradient(135deg, #45ead9, #39d4e3);
    border-color: color-mix(in srgb, #8ef4ec 48%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .podcast-platform-links__link {
      transition: none;
    }
  }
</style>
