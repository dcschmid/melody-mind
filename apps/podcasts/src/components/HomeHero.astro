---
import Headline from "@shared-ui/components/typography/Headline.astro";
import Icon from "@shared-ui/components/visual/Icon.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  title: string;
  subtitle: string;
  description: string;
  totalEpisodes: number;
  featuredContent: string;
  availableOn: string;
  spotifyUrl: string;
  deezerUrl: string;
  youtubeUrl: string;
}

const {
  title,
  subtitle,
  description,
  totalEpisodes,
  featuredContent,
  availableOn,
  spotifyUrl,
  deezerUrl,
  youtubeUrl,
} = Astro.props as Props;
---

<section class="home-hero">
  <div class="home-hero__inner">
    <div class="home-hero__grid">
      <div class="home-hero__copy">
        <div class="home-hero__intro">
          <Headline level="h1" textSize="4xl" className="home-hero__title">
            {title}
          </Headline>
          <Paragraph textSize="base" className="home-hero__subtitle">
            {subtitle}
          </Paragraph>
          <Paragraph textSize="base" className="home-hero__description">
            {description}
          </Paragraph>
        </div>

        <div class="home-hero__cta-row">
          <a href="#episodes-heading" class="home-hero__cta home-hero__cta--primary">
            Explore episodes
          </a>
          <a
            href="/podcast.xml"
            class="home-hero__cta home-hero__cta--secondary"
            aria-label="Subscribe via RSS"
          >
            RSS Feed
          </a>
        </div>
      </div>

      <div class="home-hero__visual">
        <img
          src="/the-melody-mind-podcast.jpg"
          alt="Illustrated podcast cover art"
          class="home-hero__image"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <div class="home-hero__info">
      <div class="home-hero__highlights">
        <div class="home-hero__highlight">
          <span class="home-hero__highlight-icon" aria-hidden="true">
            <Icon name="headphones" aria-hidden="true" />
          </span>
          <span> New episodes for walks, commutes, or quiet evenings. </span>
        </div>
        <div class="home-hero__highlight">
          <span class="home-hero__highlight-icon" aria-hidden="true">
            <Icon name="sparkles" aria-hidden="true" />
          </span>
          <span>
            Stories first, facts second - always warm, curious, and welcoming.
          </span>
        </div>
        <div class="home-hero__highlight">
          <span class="home-hero__highlight-icon" aria-hidden="true">
            <Icon name="music" aria-hidden="true" />
          </span>
          <span>
            From early rock 'n' roll sparks to modern electronic worlds, hear how music
            became part of everyday life.
          </span>
        </div>
      </div>

      <div class="home-hero__platforms">
        <span class="home-hero__platforms-label">{availableOn}</span>
        <div class="home-hero__platforms-row">
          <a
            href={spotifyUrl}
            class="home-hero__platform-link home-hero__platform-link--spotify"
            aria-label="Listen on Spotify"
            target="_blank"
            rel="noopener"
          >
            <span class="home-hero__platform-icon" aria-hidden="true">
              <Icon name="spotify" aria-hidden="true" />
            </span>
            Spotify
          </a>
          <a
            href={deezerUrl}
            class="home-hero__platform-link home-hero__platform-link--deezer"
            aria-label="Listen on Deezer"
            target="_blank"
            rel="noopener"
          >
            <span class="home-hero__platform-icon" aria-hidden="true">
              <Icon name="deezer" aria-hidden="true" />
            </span>
            Deezer
          </a>
          <a
            href={youtubeUrl}
            class="home-hero__platform-link home-hero__platform-link--youtube"
            aria-label="Listen on YouTube"
            target="_blank"
            rel="noopener"
          >
            <span class="home-hero__platform-icon" aria-hidden="true">
              <Icon name="simple-icons:youtube" aria-hidden="true" />
            </span>
            YouTube
          </a>
        </div>
      </div>

      <div class="home-hero__meta">
        <span class="home-hero__meta-item">
          {totalEpisodes} episodes available
        </span>
        <span class="home-hero__meta-item">
          {featuredContent}
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero {
    position: relative;
    padding: 3rem 2rem;
    overflow: hidden;
    background: var(--podcast-hero-surface);
    border: 1px solid var(--podcast-border-soft);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-md);
  }

  .home-hero::before {
    position: absolute;
    inset: 0;
    content: "";
    background:
      var(--podcast-hero-orb-1), var(--podcast-hero-orb-2), var(--podcast-hero-orb-3);
    opacity: 0.85;
  }

  .home-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: stretch;
    max-inline-size: 68rem;
    margin: 0 auto;
  }

  .home-hero__grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .home-hero__copy {
    display: grid;
    gap: 1.5rem;
  }

  .home-hero__intro {
    display: grid;
    gap: 0.75rem;
  }

  .home-hero__title {
    margin: 0;
    font-size: var(--font-size-hero);
    font-weight: 800;
    color: transparent;
    text-shadow: var(--podcast-title-shadow);
    background: var(--podcast-brand-gradient);
    background-clip: text;
  }

  .home-hero__subtitle {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
  }

  .home-hero__description {
    margin: 0;
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  .home-hero__visual {
    display: grid;
    gap: 0.75rem;
  }

  .home-hero__image {
    display: block;
    inline-size: 100%;
    block-size: auto;
    border: 1px solid var(--podcast-border-soft);
    border-radius: 1.6rem;
    box-shadow: var(--shadow-lg);
  }

  .home-hero__info {
    display: grid;
    gap: 2rem;
  }

  .home-hero__highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1rem;
  }

  .home-hero__highlight {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    min-inline-size: 0;
    padding: 1rem 1.2rem;
    color: var(--text-primary);
    background: var(--podcast-surface-soft);
    border: 1px solid var(--podcast-border-soft);
    border-radius: 1.1rem;
  }

  .home-hero__highlight-icon {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    inline-size: 2rem;
    block-size: 2rem;
    color: var(--accent-primary);
    background: color-mix(
      in srgb,
      var(--accent-primary) 14%,
      var(--podcast-surface-soft)
    );
    border: 1px solid var(--podcast-border-soft);
    border-radius: 999px;
  }

  .home-hero__highlight span:last-child {
    min-inline-size: 0;
    overflow-wrap: anywhere;
  }

  .home-hero__cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-start;
  }

  .home-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.4rem;
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.9rem;
  }

  .home-hero__cta--primary {
    color: var(--bg-primary);
    background: var(--accent-primary);
    box-shadow: var(--shadow-lg);
  }

  .home-hero__cta--secondary {
    color: var(--text-primary);
    background: var(--podcast-surface-soft);
    border: 1px solid var(--podcast-border-default);
  }

  .home-hero__cta:focus-visible {
    outline: none;
    box-shadow: var(--interactive-shadow-focus);
  }

  .home-hero__platforms {
    display: grid;
    gap: 0.75rem;
    justify-items: start;
  }

  .home-hero__platforms-label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--podcast-text-muted);
  }

  .home-hero__platforms-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-start;
  }

  .home-hero__platform-link {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    min-inline-size: 0;
    padding: 0.5rem 0.95rem;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-primary);
    white-space: normal;
    text-decoration: none;
    background: var(--podcast-surface-strong);
    border: 1px solid var(--podcast-border-default);
    border-radius: 0.9rem;
  }

  .home-hero__platform-icon {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    inline-size: 1.35rem;
    block-size: 1.35rem;
    color: var(--platform-color, var(--accent-primary));
  }

  .home-hero__platform-icon :global(svg) {
    inline-size: 100%;
    block-size: 100%;
  }

  .home-hero__platform-link--spotify {
    --platform-color: #1db954;
  }

  .home-hero__platform-link--deezer {
    --platform-color: #ef5466;
  }

  .home-hero__platform-link--youtube {
    --platform-color: #f00;
  }

  .home-hero__platform-link:focus-visible {
    outline: none;
    box-shadow: var(--interactive-shadow-focus);
  }

  .home-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-start;
    font-size: var(--font-size-sm);
    color: var(--podcast-text-muted);
  }

  .home-hero__meta-item {
    min-inline-size: 0;
    padding: 0.4rem 0.85rem;
    overflow-wrap: anywhere;
    background: var(--podcast-surface-strong);
    border: 1px solid var(--podcast-border-soft);
    border-radius: 0.75rem;
  }

  @media (width <= 380px) {
    .home-hero {
      padding: 2rem 1.1rem;
    }

    .home-hero__title {
      font-size: 2.2rem;
    }

    .home-hero__cta {
      justify-content: center;
      inline-size: 100%;
    }

    .home-hero__platform-link {
      justify-content: center;
      inline-size: 100%;
    }

    .home-hero__meta {
      inline-size: 100%;
    }

    .home-hero__meta-item {
      inline-size: 100%;
      text-align: center;
    }
  }

  @media (width >= 900px) {
    .home-hero__grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 3rem;
    }

    .home-hero__title {
      font-size: clamp(2.85rem, 4.8vi, 3.4rem);
    }

    .home-hero__subtitle {
      font-size: var(--font-size-xl);
    }
  }
</style>
