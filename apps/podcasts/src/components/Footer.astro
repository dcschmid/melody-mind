---
import SharedFooter from "@shared-ui/components/layout/Footer.astro";

const year = new Date().getFullYear();
---

<SharedFooter
  brandTitle="Melody Mind"
  brandText="Curated stories, timelines, and playlists to help you listen more closely and discover new sounds."
  exploreLinks={[
    {
      href: "https://melody-mind.de/",
      label: "Melody Mind",
      target: "_blank",
      rel: "noopener noreferrer",
    },
    { href: "/podcast.xml", label: "RSS" },
  ]}
  supportLinks={[
    {
      href: "https://www.paypal.me/dcschmid",
      label: "PayPal",
      target: "_blank",
      rel: "noopener noreferrer",
    },
    {
      href: "https://www.buymeacoffee.com/dcschmid",
      label: "Buy Me a Coffee",
      target: "_blank",
      rel: "noopener noreferrer",
    },
  ]}
  legalLinks={[
    {
      href: "https://melody-mind.de/imprint",
      label: "Legal Notice",
      target: "_blank",
      rel: "noopener noreferrer",
    },
    {
      href: "https://melody-mind.de/privacy",
      label: "Privacy Policy",
      target: "_blank",
      rel: "noopener noreferrer",
    },
  ]}
  showSettings={true}
  copyrightText={`© ${year} MelodyMind. All rights reserved.`}
/>
