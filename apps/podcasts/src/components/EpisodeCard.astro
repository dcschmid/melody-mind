---
import Card from "@shared-ui/components/cards/Card.astro";
import Headline from "@shared-ui/components/typography/Headline.astro";
import Paragraph from "@shared-ui/components/typography/Paragraph.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  imageUrl: string;
  durationSeconds?: number | undefined;
  searchText: string;
  publishedAt: string;
  publishedLabel: string;
  isLatest: boolean;
}

const {
  id,
  title,
  description,
  imageUrl,
  durationSeconds,
  searchText,
  publishedAt,
  publishedLabel,
  isLatest,
} = Astro.props as Props;

const cardId = `episode-card-${id}`;
const descriptionId = `${cardId}-description`;
const metaId = `${cardId}-meta`;
---

<Card
  class="episode-card"
  data-episode
  data-search={searchText}
  role="listitem"
  href={`/${id}`}
  linkClassName="episode-card__link"
  labelledBy={cardId}
  describedBy={`${metaId} ${descriptionId}`}
  variant="default"
>
  <Fragment slot="media">
    <picture>
      <source srcset={`/images/${imageUrl}.avif`} type="image/avif" />
      <source srcset={`/images/${imageUrl}.webp`} type="image/webp" />
      <img
        src={`/images/${imageUrl}.jpg`}
        alt={`Cover art for the podcast episode ${title}`}
        class="episode-card__image"
        loading="lazy"
        decoding="async"
        width={600}
        height={400}
        sizes="(max-width: 640px) 100vw, (max-width: 980px) 50vw, 33vw"
      />
    </picture>
  </Fragment>

  <div class="episode-card__body">
    <div class="episode-card__meta" id={metaId}>
      <time class="episode-card__date" datetime={publishedAt}>
        {publishedLabel}
      </time>
      {isLatest && <span class="episode-card__badge">Latest</span>}
      {
        durationSeconds && (
          <span class="episode-card__duration">
            {Math.floor(durationSeconds / 60)} min
          </span>
        )
      }
    </div>
    <Headline level="h3" textSize="lg" className="episode-card__title">
      <span id={cardId}>{title}</span>
    </Headline>
    <Paragraph id={descriptionId} textSize="sm" className="episode-card__description">
      {description}
    </Paragraph>
  </div>

  <Fragment slot="footer">
    <span class="episode-card__cta">View Episode</span>
  </Fragment>
</Card>

<style>
  .episode-card {
    --card-text: var(--color-text);
    --card-bg: linear-gradient(
      160deg,
      color-mix(in srgb, var(--color-layer-2) 92%, transparent),
      color-mix(in srgb, var(--color-layer-1) 96%, transparent)
    );
    --card-border-width: 1px;
    --card-border-color: var(--color-border-soft);
    --card-focus-color: var(--color-primary);
    --card-media-bg: var(--color-layer-3);

    box-shadow: var(--effect-elevated-md);
  }

  .episode-card[hidden] {
    display: none;
  }

  :global(.episode-card.card--default:has(.card__link:focus-visible)) {
    box-shadow:
      inset 0 0 0 3px var(--color-border-default),
      var(--effect-elevated-soft);
  }

  .episode-card__image {
    object-fit: cover;
    border-block-end: 1px solid var(--color-border-soft);
  }

  .episode-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.1rem 1.15rem 1rem;
  }

  .episode-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: var(--font-size-ui);
    color: var(--color-text-muted);
  }

  .episode-card__date {
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .episode-card__badge,
  .episode-card__duration {
    padding: 0.2em 0.6em;
    font-size: var(--font-size-caption);
    font-weight: 600;
    color: var(--color-text);
    background: var(--color-layer-2);
    border: 1px solid var(--color-border-soft);
    border-radius: 999px;
  }

  .episode-card__badge {
    color: var(--color-text);
    background: var(--color-accent-soft-bg);
  }

  .episode-card__title {
    margin: 0;
    font-size: clamp(1.3rem, 1.2rem + 0.5vw, 1.7rem);
    color: var(--color-text);
    text-wrap: balance;
  }

  .episode-card__description {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 3;
    line-height: var(--leading-relaxed, 1.75);
    color: var(--color-text-muted);
    /* stylelint-disable-next-line property-no-deprecated */
    -webkit-box-orient: block-axis;
  }

  .episode-card__link {
    block-size: 100%;
  }

  .episode-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: fit-content;
    min-inline-size: 10rem;
    min-block-size: 2.75rem;
    padding: 0.65rem 1.1rem;
    font-weight: 700;
    color: var(--color-background);
    background: var(--color-primary);
    border-radius: 0.75rem;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  :global(.episode-card.card--default:hover) .episode-card__cta,
  :global(.episode-card.card--default:focus-visible) .episode-card__cta {
    background: var(--color-primary-hover);
    box-shadow: var(--effect-elevated-soft);
    transform: translateY(-1px);
  }

  @media screen and (prefers-reduced-motion: reduce) {
    .episode-card__cta {
      transition: none;
    }
  }

  @container (max-width: 480px) {
    .episode-card__body {
      padding: 1rem;
    }

    .episode-card__title {
      font-size: 1.2rem;
    }
  }
</style>
