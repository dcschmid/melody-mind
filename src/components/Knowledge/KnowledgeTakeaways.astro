---
const { title = "Key takeaways", items = [] } = Astro.props as {
  title?: string;
  items?: string[];
};
---

{
  items.length ? (
    <aside class="knowledge-takeaways" aria-labelledby="knowledge-takeaways-title">
      <div class="knowledge-takeaways__header">
        <div class="knowledge-takeaways__badge">What you'll take away</div>
        <h2 class="knowledge-takeaways__title" id="knowledge-takeaways-title">
          {title}
        </h2>
        <p class="knowledge-takeaways__subtitle">
          Short points to remember after reading.
        </p>
      </div>
      <ol class="knowledge-takeaways__list">
        {items.map((item) => (
          <li class="knowledge-takeaways__item">
            <span class="knowledge-takeaways__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
                <path
                  d="M12 3.5l1.9 4.3 4.6.4-3.5 3.1 1 4.6-4-2.4-4 2.4 1-4.6-3.5-3.1 4.6-.4L12 3.5z"
                  fill="currentColor"
                />
              </svg>
            </span>
            <span class="knowledge-takeaways__text">{item}</span>
          </li>
        ))}
      </ol>
    </aside>
  ) : null
}

<style>
  .knowledge-takeaways {
    display: grid;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: 1rem;
    border: 2px solid var(--gn-panel-border);
    background: var(--gn-bg-muted);
  }

  .knowledge-takeaways__header {
    display: grid;
    gap: 0.45rem;
  }

  .knowledge-takeaways__badge {
    width: fit-content;
    padding: 0.25rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--gn-accent);
    background: var(--gn-bg);
    color: var(--gn-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .knowledge-takeaways__title {
    margin: 0;
    font-size: clamp(1.35rem, 1.15rem + 1vw, 1.75rem);
    color: var(--gn-ink);
    font-weight: 700;
  }

  .knowledge-takeaways__subtitle {
    margin: 0;
    color: var(--gn-ink-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  .knowledge-takeaways__list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.85rem;
  }

  .knowledge-takeaways__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--gn-panel-border);
    background: var(--gn-bg);
  }

  .knowledge-takeaways__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: var(--gn-bg-muted);
    color: var(--gn-accent);
    flex-shrink: 0;
  }

  .knowledge-takeaways__icon :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  .knowledge-takeaways__text {
    color: var(--gn-ink);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  @media (min-width: 768px) {
    .knowledge-takeaways__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
