---
/**
 * @component BackToTop
 * @description Simple back-to-top button with accessibility support.
 */
import { Icon } from "astro-icon/components";
import { useTranslations } from "@utils/i18n";

interface Props {
  lang: string;
  className?: string;
  ariaLabel?: string;
  scrollThreshold?: number;
}

const { lang = "en", className = "", ariaLabel, scrollThreshold } = Astro.props;
const t = useTranslations(lang);
const buttonAriaLabel = ariaLabel || t("common.back.to.top");
const screenReaderText = t("common.back.to.top");
---

<button
  id="back-to-top"
  class={`back-to-top ${className}`.trim()}
  aria-label={buttonAriaLabel}
  type="button"
  style="display: none;"
  data-scroll-threshold={scrollThreshold}
>
  <Icon name="arrow-up" class="back-to-top__icon" aria-hidden="true" />
  <span class="back-to-top__sr">{screenReaderText}</span>
</button>
<style>
  .back-to-top {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 30;
    min-width: 52px;
    min-height: 52px;
    padding: 1rem;
    border-radius: 999px;
    border: 2px solid var(--gn-panel-border);
    background: var(--gn-bg-muted);
    color: var(--gn-ink);
    cursor: pointer;
  }

  .back-to-top:hover {
    background: var(--gn-bg);
  }

  .back-to-top:focus-visible {
    outline: 3px solid var(--gn-accent);
    outline-offset: 2px;
  }

  .back-to-top__icon {
    display: block;
    width: 1.5rem;
    height: 1.5rem;
  }

  @media (min-width: 768px) {
    .back-to-top__icon {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  .back-to-top__sr {
    position: absolute;
    width: var(--sr-only-width);
    height: var(--sr-only-height);
    margin: var(--sr-only-margin);
    overflow: hidden;
    clip-path: var(--sr-only-clip-path);
    white-space: nowrap;
    border: 0;
  }
</style>
