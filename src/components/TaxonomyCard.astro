---
/**
 * TaxonomyCard Component - Display a taxonomy section
 *
 * Used on the homepage to display the 21 main taxonomy sections.
 */
import { Image } from "astro:assets";

interface Props {
  /** Section ID, e.g. "time-change-evolution" */
  id: string;
  /** Section title */
  title: string;
  /** Optional description */
  description?: string;
  /** Image path */
  image?: string;
  /** Number of subsections */
  subsectionCount: number;
  /** Number of articles in this section */
  articleCount: number;
  /** Link URL */
  href: string;
  /** Index for animation delay */
  index?: number;
}

const {
  id,
  title,
  description,
  image = "/taxonomy/default.jpg",
  subsectionCount,
  articleCount,
  href,
  index: _index = 0,
} = Astro.props;

const cardId = `taxonomy-card-${id}`;
---

<article
  class="taxonomy-card"
  data-testid="taxonomy-card"
  data-title={title}
  aria-labelledby={cardId}
>
  <a href={href} class="taxonomy-card__link" aria-labelledby={cardId}>
    <div class="taxonomy-card__media">
      <Image
        src={image}
        alt={`${title} cover`}
        loading="lazy"
        decoding="async"
        class="taxonomy-card__image"
        width="640"
        height="360"
      />
      <div class="taxonomy-card__overlay" aria-hidden="true"></div>
      <div class="taxonomy-card__badge">
        <span class="taxonomy-card__badge-dot"></span>
        {articleCount > 0 ? `${articleCount} articles` : `${subsectionCount} topics`}
      </div>
    </div>
    <div class="taxonomy-card__body">
      <h3 id={cardId} class="taxonomy-card__title">{title}</h3>
      {description && <p class="taxonomy-card__description">{description}</p>}
    </div>
  </a>
</article>

<style>
  /* Card Container with CSS Container Query support */
  .taxonomy-card {
    container-type: inline-size;
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    /* Modern, rounded corners */
    border-radius: 1.5rem;
    /* Glassmorphism: Semi-transparent with blur */
    background: color-mix(in srgb, var(--gn-bg-muted) 75%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid color-mix(in srgb, var(--gn-panel-border) 85%, transparent);
    /* Modern shadow system */
    box-shadow: var(--shadow-xl);
    overflow: hidden;
    /* Performance: Skip rendering off-screen content */
    content-visibility: auto;
    contain-intrinsic-size: 320px;
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base),
      border-color var(--transition-base);
  }

  /* Modern inner border effect */
  .taxonomy-card::after {
    content: "";
    position: absolute;
    inset: 6px;
    border: 1px solid color-mix(in srgb, var(--gn-panel-inner) 50%, transparent);
    border-radius: 1.25rem;
    pointer-events: none;
  }

  /* WCAG AAA: Enhanced hover with reduced motion */
  .taxonomy-card:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: var(--shadow-2xl);
    border-color: color-mix(in srgb, var(--gn-accent) 35%, var(--gn-panel-border));
  }

  /* Active state for touch feedback */
  .taxonomy-card:active {
    transform: translateY(-2px) scale(0.99);
    transition-duration: 50ms;
  }

  @media (prefers-reduced-motion: no-preference) {
    .taxonomy-card:hover {
      transform: none;
    }
  }

  .taxonomy-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* WCAG AAA: Enhanced focus state */
  .taxonomy-card__link:focus-visible {
    outline: var(--focus-ring-width) var(--focus-ring-style) var(--gn-accent);
    outline-offset: var(--focus-ring-offset);
    box-shadow: var(--shadow-glow);
  }

  .taxonomy-card__media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--gn-bg);
  }

  .taxonomy-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  /* Hover zoom with reduced motion support */
  @media (prefers-reduced-motion: no-preference) {
    .taxonomy-card:hover .taxonomy-card__image,
    .taxonomy-card__link:focus-visible .taxonomy-card__image {
      transform: scale(1.03);
    }
  }

  .taxonomy-card__overlay {
    position: absolute;
    inset: 0;
  }

  /* WCAG AAA: Better badge contrast */
  .taxonomy-card__badge {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 2px solid var(--gn-panel-border);
    background: color-mix(in srgb, var(--gn-bg) 92%, transparent);
    backdrop-filter: blur(8px);
    font-size: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--gn-ink);
    box-shadow: var(--shadow-md);
  }

  .taxonomy-card__badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-gn-amber-400);
  }

  /* WCAG AAA: Better text contrast */
  .taxonomy-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    flex: 1;
  }

  /* Fluid title sizing */
  .taxonomy-card__title {
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
    font-weight: 600;
    margin: 0;
    color: var(--gn-ink);
    line-height: 1.4;
  }

  /* WCAG AAA: Improved description contrast */
  .taxonomy-card__description {
    margin: 0;
    font-size: clamp(0.9rem, 0.85rem + 0.25vw, 1.05rem);
    line-height: 1.65;
    color: var(--gn-ink-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Mobile optimization - better spacing on small screens */
  @container (max-width: 480px) {
    .taxonomy-card__body {
      padding: 1rem;
      gap: 0.5rem;
    }

    .taxonomy-card__badge {
      bottom: 0.75rem;
      right: 0.75rem;
      padding: 0.3rem 0.6rem;
      font-size: 0.7rem;
    }

    .taxonomy-card__title {
      font-size: clamp(1rem, 0.9rem + 0.2vw, 1.125rem);
    }

    .taxonomy-card__description {
      font-size: clamp(0.85rem, 0.8rem + 0.15vw, 0.9rem);
    }
  }
</style>
