---
/**
 * KnowledgeCard Component - Minimal & Accessible
 *
 * A simple card for displaying music knowledge articles.
 * WCAG AAA compliant with essential hover feedback for links only.
 */
import { useTranslations } from "@utils/i18n";
import { format } from "date-fns";
import { enUS as en } from "date-fns/locale";
import { Icon } from "astro-icon/components";
import Headline from "@components/Headline.astro";
import Paragraph from "@components/Paragraph.astro";
import { Image } from "astro:assets";

export const prerender = true;

interface Props {
  title: string;
  description: string;
  image?: string;
  createdAt: Date;
  slug: string;
  lang: string;
  readingTime?: number;
  articleUrl?: string;
  keywords?: string;
  index?: number;
}

const {
  title,
  description,
  image = "/default-cover.jpg",
  createdAt,
  slug,
  lang,
  readingTime = 0,
  articleUrl,
  keywords,
  index = 0,
} = Astro.props;

const locale = en;
const lang_t = useTranslations(lang);
const formattedDate = format(createdAt, "MMMM d, yyyy", { locale });
const hasOwnLink = Boolean(articleUrl);
const cardId = `card-title-${slug}-${index}`;
const metaId = `${cardId}-meta`;
const descId = `${cardId}-desc`;
const imageAltText = title ? `Cover image for ${title}` : "";
---

<article
  class="knowledge-card"
  data-testid="knowledge-card"
  data-title={title}
  data-description={description}
  data-keywords={keywords}
  aria-labelledby={cardId}
  aria-describedby={`${descId} ${metaId}`}
>
  {
    hasOwnLink ? (
      <a
        href={articleUrl}
        class="knowledge-card__link"
        aria-labelledby={cardId}
        aria-describedby={`${descId} ${metaId}`}
      >
        <div class="knowledge-card__content">
          <div class="knowledge-card__media">
            <Image
              src={image}
              alt={imageAltText}
              loading="lazy"
              decoding="async"
              width="640"
              height="360"
              class="knowledge-card__image"
            />
          </div>

          <div class="knowledge-card__body">
            <Headline
              level="h3"
              textSize="base"
              textAlign="left"
              className="knowledge-card__title"
            >
              {title}
            </Headline>

            <div id={descId}>
              <Paragraph
                textSize="base"
                textAlign="left"
                className="knowledge-card__description"
              >
                {description}
              </Paragraph>
            </div>

            <div class="knowledge-card__meta" id={metaId}>
              <div class="knowledge-card__meta-item">
                <Icon name="clock" class="knowledge-card__meta-icon" aria-hidden="true" />
                <span>
                  {readingTime} {lang_t("knowledge.reading.time")}
                </span>
              </div>
              <time
                datetime={createdAt.toISOString()}
                class="knowledge-card__meta-item"
                aria-label={`${lang_t("knowledge.published")}: ${formattedDate}`}
              >
                <Icon
                  name="calendar"
                  class="knowledge-card__meta-icon"
                  aria-hidden="true"
                />
                {formattedDate}
              </time>
            </div>
          </div>
        </div>
        <span class="knowledge-card__sr">{lang_t("navigation.article.opens")}</span>
      </a>
    ) : (
      <div class="knowledge-card__content">
        <div class="knowledge-card__media">
          <Image
            src={image}
            alt={imageAltText}
            loading="lazy"
            decoding="async"
            width="640"
            height="360"
            class="knowledge-card__image"
          />
        </div>

        <div class="knowledge-card__body">
          <Headline
            level="h3"
            textSize="xl"
            textAlign="center"
            className="knowledge-card__title"
          >
            {title}
          </Headline>

          <div id={descId}>
            <Paragraph
              textSize="base"
              textAlign="center"
              className="knowledge-card__description"
            >
              {description}
            </Paragraph>
          </div>

          <div class="knowledge-card__meta" id={metaId}>
            <div class="knowledge-card__meta-item">
              <Icon name="clock" class="knowledge-card__meta-icon" aria-hidden="true" />
              <span>
                {readingTime} {lang_t("knowledge.reading.time")}
              </span>
            </div>
            <time
              datetime={createdAt.toISOString()}
              class="knowledge-card__meta-item"
              aria-label={`${lang_t("knowledge.published")}: ${formattedDate}`}
            >
              <Icon
                name="calendar"
                class="knowledge-card__meta-icon"
                aria-hidden="true"
              />
              {formattedDate}
            </time>
          </div>
        </div>
      </div>
    )
  }
  <style>
    .knowledge-card {
      container-type: inline-size;
      position: relative;
      display: flex;
      flex-direction: column;
      height: 100%;
      color: var(--gn-ink);
      border-radius: 1rem;
      background: var(--gn-bg-muted);
      border: 2px solid var(--gn-panel-border);
      overflow: hidden;
      content-visibility: auto;
      contain-intrinsic-size: 380px;
    }

    /* WCAG AAA: Focus ring directly on card border */
    .knowledge-card__link:focus-visible {
      outline: none;
    }

    .knowledge-card:has(.knowledge-card__link:focus-visible) {
      border-color: var(--gn-accent);
      box-shadow: inset 0 0 0 3px var(--gn-accent);
    }

    .knowledge-card__link,
    .knowledge-card__content {
      display: flex;
      flex-direction: column;
      height: 100%;
      text-decoration: none;
      color: inherit;
    }

    .knowledge-card__media {
      position: relative;
      aspect-ratio: 3 / 2;
      overflow: hidden;
      background: var(--gn-bg);
    }

    .knowledge-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .knowledge-card__body {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem;
      flex: 1;
    }

    .knowledge-card__title {
      margin: 0;
      color: var(--gn-ink);
      font-size: var(--font-size-lg);
    }

    .knowledge-card__description {
      margin: 0;
      color: var(--gn-ink-muted);
      line-height: 1.65;
    }

    .knowledge-card__meta {
      margin-top: auto;
      padding-top: 1.25rem;
      border-top: 1px solid var(--gn-panel-border);
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1.5rem;
      font-size: var(--font-size-sm);
      color: var(--gn-ink-muted);
    }

    .knowledge-card__meta-item {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
      white-space: nowrap;
    }

    .knowledge-card__meta-icon {
      display: block;
      width: 1.125rem;
      height: 1.125rem;
      flex-shrink: 0;
      color: var(--color-gn-amber-300);
    }

    .knowledge-card__sr {
      position: absolute;
      width: var(--sr-only-width);
      height: var(--sr-only-height);
      margin: var(--sr-only-margin);
      overflow: hidden;
      clip-path: var(--sr-only-clip-path);
      white-space: nowrap;
      border: 0;
    }

    @container (max-width: 480px) {
      .knowledge-card__body {
        padding: 1.25rem;
        gap: 0.875rem;
      }

      .knowledge-card__meta {
        padding-top: 1rem;
        gap: 0.5rem;
      }

      .knowledge-card__title {
        font-size: var(--font-size-base);
      }
    }
  </style>
</article>
