---
/**
 * Quiz Overview Page
 *
 * Displays all available quizzes organized by category.
 */
import Layout from "@layouts/Layout.astro";
import QuizCard from "@components/Quiz/QuizCard.astro";
import PageShell from "@components/Shared/PageShell.astro";
import BackToTop from "@components/Shared/BackToTop.astro";
import { buildPageSeo, type StructuredData } from "@utils/seo/buildPageSeo";
import { resolveBaseUrl, resolvePageUrl } from "@utils/siteUrls";
import { getCollection } from "astro:content";
import type { KnowledgeData, QuizData } from "../../content/config";

export const prerender = true;

interface QuizEntry {
  id: string;
  data: QuizData;
  image?: string;
  imageAlt?: string;
}

const allQuizzes = await getCollection("quizzes");
const knowledgeArticles = await getCollection("knowledge-en");
const knowledgeBySlug = new Map<string, KnowledgeData>(
  knowledgeArticles.map((article) => [article.id, article.data])
);
const quizzes: QuizEntry[] = allQuizzes.map((q) => {
  const leadArticleSlug = q.data.relatedArticles[0];
  const leadArticle = knowledgeBySlug.get(leadArticleSlug);

  return {
    id: q.id,
    data: q.data,
    image: leadArticle?.image,
    imageAlt: leadArticle ? `${leadArticle.title} article image` : undefined,
  };
});

const quizzesByCategory = {
  decade: quizzes.filter((q) => q.data.category === "decade"),
  "genre-evolution": quizzes.filter((q) => q.data.category === "genre-evolution"),
  mixed: quizzes.filter((q) => q.data.category === "mixed"),
};

const categoryLabels = {
  decade: "Decade Quizzes",
  "genre-evolution": "Genre Evolution",
  mixed: "Mixed Topics",
};

const baseUrl = resolveBaseUrl(Astro.site);
const currentUrl = resolvePageUrl(Astro.site, "/quiz");

const seoBreadcrumbs = [
  { name: "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: "Quizzes", url: currentUrl },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: seoBreadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.name,
    item: crumb.url,
  })),
};

const itemListSchema = quizzes.length
  ? {
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: "Music Knowledge Quizzes",
      numberOfItems: quizzes.length,
      itemListElement: quizzes.map((quiz, index) => ({
        "@type": "ListItem",
        position: index + 1,
        item: {
          "@type": "Quiz",
          name: quiz.data.title,
          description: quiz.data.description,
          url: `${baseUrl}/quiz/${quiz.id}`,
        },
      })),
    }
  : undefined;

const pageSeo = buildPageSeo({
  title: "Music History Quizzes And Trivia",
  description:
    "Play music history quizzes on decades, genres, artists, and cultural shifts from rock and roll to global pop.",
  url: currentUrl,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: [breadcrumbSchema, itemListSchema].filter(Boolean) as StructuredData[],
  fallbackKeywords: [
    "music quiz",
    "music trivia",
    "rock history quiz",
    "jazz quiz",
    "music knowledge",
  ],
  index: true,
  follow: true,
});
---

<Layout {pageSeo}>
  <PageShell className="page-shell--aurora page-shell--grid">
    <div class="quiz-page">
      <header class="quiz-hero">
        <div class="quiz-hero__panel">
          <div class="quiz-hero__copy">
            <h1 class="quiz-hero__title">Music Quizzes</h1>
            <p class="quiz-hero__description">
              Challenge yourself with quizzes covering music history, genres, and artists.
              Each question is grounded in the same research-driven content as the rest of
              MelodyMind.
            </p>
          </div>
        </div>
      </header>

      {
        quizzesByCategory.decade.length > 0 && (
          <section class="quiz-section" aria-labelledby="decade-heading">
            <h2 id="decade-heading" class="quiz-section__title">
              {categoryLabels.decade}
            </h2>
            <p class="quiz-section__description">
              Test your knowledge of music from different decades, from the birth of rock
              and roll to modern streaming pop.
            </p>
            <ul class="quiz-section__grid" aria-label={categoryLabels.decade}>
              {quizzesByCategory.decade.map((quiz) => (
                <li>
                  <QuizCard
                    title={quiz.data.title}
                    description={quiz.data.description}
                    slug={quiz.id}
                    image={quiz.image}
                    imageAlt={quiz.imageAlt}
                  />
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        quizzesByCategory["genre-evolution"].length > 0 && (
          <section class="quiz-section" aria-labelledby="genre-heading">
            <h2 id="genre-heading" class="quiz-section__title">
              {categoryLabels["genre-evolution"]}
            </h2>
            <p class="quiz-section__description">
              Explore how genres transformed over time, from blues to rock, jazz to neo
              soul.
            </p>
            <ul class="quiz-section__grid" aria-label={categoryLabels["genre-evolution"]}>
              {quizzesByCategory["genre-evolution"].map((quiz) => (
                <li>
                  <QuizCard
                    title={quiz.data.title}
                    description={quiz.data.description}
                    slug={quiz.id}
                    image={quiz.image}
                    imageAlt={quiz.imageAlt}
                  />
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        quizzesByCategory.mixed.length > 0 && (
          <section class="quiz-section" aria-labelledby="mixed-heading">
            <h2 id="mixed-heading" class="quiz-section__title">
              {categoryLabels.mixed}
            </h2>
            <p class="quiz-section__description">
              Comprehensive quizzes covering multiple topics and time periods.
            </p>
            <ul class="quiz-section__grid" aria-label={categoryLabels.mixed}>
              {quizzesByCategory.mixed.map((quiz) => (
                <li>
                  <QuizCard
                    title={quiz.data.title}
                    description={quiz.data.description}
                    slug={quiz.id}
                    image={quiz.image}
                    imageAlt={quiz.imageAlt}
                  />
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        quizzes.length === 0 && (
          <div class="quiz-empty" role="status">
            <p class="quiz-empty__title">No quizzes available yet</p>
            <p class="quiz-empty__text">Check back soon for new music quizzes!</p>
          </div>
        )
      }
    </div>
  </PageShell>

  <BackToTop lang="en" />
</Layout>

<style>
  .quiz-page {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .quiz-hero {
    position: relative;
  }

  .quiz-hero__panel {
    position: relative;
    display: flex;
    padding: 1.5rem;
    border-radius: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--gn-accent) 24%, var(--gn-panel-border));
    background:
      radial-gradient(
        circle at top right,
        color-mix(in srgb, var(--gn-accent) 20%, transparent),
        transparent 30%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--gn-bg) 92%, transparent),
        var(--gn-bg-muted)
      );
    box-shadow:
      0 24px 48px color-mix(in srgb, var(--gn-accent) 10%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 28%, transparent);
  }

  @media (min-width: 960px) {
    .quiz-hero__panel {
      padding: 2rem;
    }
  }

  .quiz-hero__copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 62ch;
  }

  .quiz-hero__title {
    margin: 0;
    font-size: 2.6rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--gn-ink);
    letter-spacing: -0.035em;
  }

  @media (min-width: 640px) {
    .quiz-hero__title {
      font-size: 3.4rem;
    }
  }

  @media (min-width: 1024px) {
    .quiz-hero__title {
      font-size: 4.4rem;
    }
  }

  .quiz-hero__description {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--gn-ink-muted);
  }

  @media (min-width: 640px) {
    .quiz-hero__description {
      font-size: 1.125rem;
    }
  }

  .quiz-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    border-radius: 1.35rem;
    border: 1px solid var(--gn-panel-border);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--gn-bg) 94%, transparent),
      var(--gn-bg-muted)
    );
    box-shadow: 0 16px 34px color-mix(in srgb, var(--gn-ink) 4%, transparent);
  }

  @media (min-width: 768px) {
    .quiz-section {
      padding: 1.75rem;
    }
  }

  .quiz-section__title {
    margin: 0;
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--gn-ink);
    letter-spacing: -0.02em;
  }

  @media (min-width: 640px) {
    .quiz-section__title {
      font-size: 1.75rem;
    }
  }

  .quiz-section__description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--gn-ink-muted);
    max-width: 65ch;
  }

  .quiz-section__grid {
    display: grid;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .quiz-section__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .quiz-section__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .quiz-empty {
    padding: 3rem 2rem;
    border-radius: 1.25rem;
    border: 1px solid var(--gn-panel-border);
    background:
      radial-gradient(
        circle at top center,
        color-mix(in srgb, var(--gn-accent) 10%, transparent),
        transparent 42%
      ),
      var(--gn-bg-muted);
    text-align: center;
  }

  .quiz-empty__title {
    margin: 0;
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--gn-ink);
  }

  .quiz-empty__text {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--gn-ink-muted);
  }
</style>
