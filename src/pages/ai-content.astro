---
import Layout from "@layouts/Layout.astro";
import PageShell from "@components/Shared/PageShell.astro";
import { useTranslations } from "@utils/i18n";
import Headline from "@components/Headline.astro";
import Paragraph from "@components/Paragraph.astro";
import Prose from "@components/Prose.astro";
import { Icon } from "astro-icon/components";
import { buildPageSeo } from "@utils/seo/buildPageSeo";
import { resolvePageUrl } from "@utils/siteUrls";

export const prerender = true;

const lang = "en";
const t = useTranslations(lang);

const canonical = resolvePageUrl(Astro.site, "/ai-content");

const seoBreadcrumbs = [
  { name: t("nav.home") || "Home", url: resolvePageUrl(Astro.site, "/") },
  { name: "AI Content Policy", url: canonical },
];

const structuredDataExtra = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "AI Content Policy",
    name: "AI Content Policy",
    description:
      "How we use AI tools at Melody Mind and ensure content quality, transparency, and compliance with copyright law.",
    url: canonical,
    author: { "@type": "Organization", name: "Melody Mind" },
    publisher: {
      "@type": "Organization",
      name: "Melody Mind",
      logo: {
        "@type": "ImageObject",
        url: "https://melody-mind.de/melody-mind.png",
      },
    },
    datePublished: new Date().toISOString(),
    dateModified: new Date().toISOString(),
    mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
    inLanguage: lang,
    articleSection: "About",
  },
];

const pageSeo = buildPageSeo({
  title: "AI Content Policy | Melody Mind",
  description:
    "How we use AI tools at Melody Mind and ensure content quality, transparency, and compliance with copyright law.",
  url: canonical,
  contentKind: "generic",
  breadcrumbs: seoBreadcrumbs,
  structuredData: structuredDataExtra,
  enrichedParts: [
    "AI Content Policy",
    "How we use AI tools",
    "Content quality",
    "Transparency",
  ],
  fallbackKeywords: [
    "AI",
    "artificial intelligence",
    "content policy",
    "transparency",
    "copyright",
    "UrhG",
    "ChatGPT",
    "Claude",
  ],
  keywordLimit: 24,
  maxDescription: 155,
  image: "/knowledge.png",
  imageAlt: "AI Content Policy",
  publishDate: new Date(),
  modifiedDate: new Date(),
  index: true,
  follow: true,
  autoSocialImage: false,
  authorName: "Melody Mind",
});
---

<Layout {pageSeo}>
  <PageShell containerClass="page-shell__container--spacious">
    <div class="ai-policy">
      <div class="ai-policy__container">
        <header class="ai-policy__header static-page-header">
          <div class="ai-policy__badge">AI Content Policy</div>
          <Headline
            level="h1"
            textSize="xl"
            textAlign="left"
            className="ai-policy__title static-page-title"
          >
            Transparency About AI-Generated Content
          </Headline>
          <Paragraph
            textSize="lg"
            textAlign="left"
            className="ai-policy__summary static-page-lead"
          >
            We use AI tools to enhance our content creation process while maintaining
            quality, accuracy, and legal compliance.
          </Paragraph>
        </header>

        <section class="legal-panel ai-policy__section">
          <div class="ai-policy__section-header">
            <Icon name="sparkles" class="ai-policy__icon" aria-hidden="true" />
            <Headline level="h2" textSize="lg" textAlign="left">
              What AI Tools We Use
            </Headline>
          </div>
          <Prose>
            <p>
              At Melody Mind, we use AI tools to support content creation, research, and
              optimization. The main tools we use include:
            </p>
            <ul>
              <li>
                <strong>ChatGPT (OpenAI)</strong> - Content drafting, research support, and
                idea development
              </li>
              <li>
                <strong>Claude (Anthropic)</strong> - Technical writing, code explanation, and
                content refinement
              </li>
              <li>
                <strong>Other AI tools</strong> - Image generation, translation, and SEO support
              </li>
            </ul>
          </Prose>
        </section>

        <section class="legal-panel ai-policy__section">
          <div class="ai-policy__section-header">
            <Icon name="shield" class="ai-policy__icon" aria-hidden="true" />
            <Headline level="h2" textSize="lg" textAlign="left">
              Human Oversight & Quality Assurance
            </Headline>
          </div>
          <Prose>
            <p>
              AI-generated content is never published without human review. Our editorial
              process includes:
            </p>
            <ul>
              <li>Fact-checking all information against reliable sources</li>
              <li>Ensuring historical and musical accuracy</li>
              <li>Reviewing for clarity, tone, and style consistency</li>
              <li>Verifying compliance with copyright laws</li>
              <li>Adding human insights and expertise</li>
            </ul>
            <p>
              The AI-Generated badge shown on some articles indicates that AI tools
              contributed to the creation process. It is there to make that use clear and
              transparent.
            </p>
          </Prose>
        </section>

        <section class="legal-panel ai-policy__section">
          <div class="ai-policy__section-header">
            <Icon name="file-text" class="ai-policy__icon" aria-hidden="true" />
            <Headline level="h2" textSize="lg" textAlign="left">
              Copyright & Legal Compliance
            </Headline>
          </div>
          <Prose>
            <p>We take copyright law seriously. Our AI content practices align with:</p>
            <ul>
              <li>
                <strong>German Copyright Act (UrhG)</strong> - We respect intellectual property
                rights and do not intentionally create content that infringes existing copyrights
              </li>
              <li>
                <strong>EU AI Act transparency requirements</strong> - AI-generated content
                is clearly labeled in line with EU rules
              </li>
              <li>
                <strong>Transparency principle</strong> - Users can identify AI-generated content
                and understand how we use AI tools
              </li>
            </ul>
            <p>
              AI does not replace human judgment or creativity. It is a tool that helps us
              work more efficiently, while our editorial review maintains quality,
              accuracy, and originality.
            </p>
          </Prose>
        </section>

        <section class="legal-panel ai-policy__section">
          <div class="ai-policy__section-header">
            <Icon name="help-circle" class="ai-policy__icon" aria-hidden="true" />
            <Headline level="h2" textSize="lg" textAlign="left">
              Frequently Asked Questions
            </Headline>
          </div>
          <Prose>
            <p><strong>Does AI write all your content?</strong></p>
            <p>
              No. AI assists with drafting, research, and optimization, but human editors
              review, refine, and verify all content before publication.
            </p>

            <p><strong>Is AI-generated content reliable?</strong></p>
            <p>
              Yes. Human oversight helps ensure that AI-generated content meets our
              standards for accuracy, clarity, and musical expertise. We fact-check
              information and verify sources.
            </p>

            <p><strong>Can I trust AI-generated articles?</strong></p>
            <p>
              Yes. Our editorial process ensures that all content, whether AI-assisted or
              not, goes through review for accuracy and quality.
            </p>

            <p><strong>What about images and media?</strong></p>
            <p>
              We use AI tools for image generation when appropriate, while following
              copyright and licensing requirements. AI-generated images are also clearly
              labeled.
            </p>
          </Prose>
        </section>

        <section class="legal-panel ai-policy__section ai-policy__section--contact">
          <div class="ai-policy__section-header">
            <Icon name="mail" class="ai-policy__icon" aria-hidden="true" />
            <Headline level="h2" textSize="lg" textAlign="left">
              Questions or Feedback?
            </Headline>
          </div>
          <Prose>
            <p>
              If you have questions about our AI content policy or would like to share
              feedback, please contact us. We are committed to transparency and ongoing
              improvement.
            </p>
          </Prose>
        </section>
      </div>
    </div>
  </PageShell>
</Layout>

<style>
  .ai-policy {
    background: var(--gn-bg-muted);
    border-radius: 1rem;
    border: 1px solid var(--gn-panel-border);
    padding: 1.25rem;
  }

  .ai-policy__container {
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: var(--static-page-gap);
  }

  .ai-policy__header {
    gap: 1rem;
  }

  .ai-policy__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: var(--gn-bg);
    border: 2px solid var(--gn-accent);
    color: var(--gn-accent);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    justify-self: start;
  }

  .ai-policy__section {
    padding: 2rem;
    display: grid;
    gap: var(--static-page-section-gap-wide);
  }

  .ai-policy__section--contact {
    background: var(--gn-bg);
    border-color: var(--gn-accent);
  }

  .ai-policy__section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--gn-panel-border);
  }

  .ai-policy__icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--gn-accent);
    flex-shrink: 0;
  }

  @media (min-width: 720px) {
    .ai-policy {
      padding: 1.75rem;
    }

    .ai-policy__section {
      padding: 2.5rem;
    }
  }
</style>
