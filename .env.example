# MelodyMind Environment Variables
# Copy this file to .env and fill in your values

# Fathom Analytics Site ID
# Get your site ID from https://usefathom.com/
# Required for analytics tracking. Leave empty to disable.
FATHOM_SITE_ID=your-site-id-here

# Collection cache TTL in milliseconds
# Controls how long content collection results are cached in memory.
# Set to 0 to disable caching (useful during development).
# Default: 60000 (1 minute)
COLLECTION_CACHE_TTL_MS=60000

# Google Site Verification token
# Used for Google Search Console verification.
# Leave empty to disable.
GOOGLE_SITE_VERIFICATION=

# Podcast RSS feed contact email
# Used as webMaster, managingEditor, and itunes:email in the RSS feed.
PODCAST_CONTACT_EMAIL=

# IndexNow overrides for local/manual URL submission.
# The default public key is checked in at apps/music/public/<key>.txt.
INDEXNOW_SITE_URL=https://melody-mind.de
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
INDEXNOW_KEY=
